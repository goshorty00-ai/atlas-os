		{
			"label": "kill-atlas",
			"command": "powershell",
			"type": "process",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"$p = Get-Process Atlas,Atlas_v2 -ErrorAction SilentlyContinue; if ($p) { $p | Stop-Process -Force -ErrorAction SilentlyContinue }; exit 0"
			],
			"problemMatcher": [],
			"presentation": {
				"reveal": "never",
				"panel": "dedicated",
				"clear": true,
				"showReuseMessage": false
			}
		},
		{
