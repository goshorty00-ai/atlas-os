                                        <ColorAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Color)" To="#A855F7" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)" To="0.18" Duration="0:0:0"/>
