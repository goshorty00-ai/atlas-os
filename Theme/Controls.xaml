<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:core="clr-namespace:AtlasAI.Core"
                    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework">
    
    <!-- ═══════════════════════════════════════════════════════════════════════════
         ATLAS AI - CONTROL STYLES
         Modern, premium control styles with subtle animations
    ═══════════════════════════════════════════════════════════════════════════ -->

    <DropShadowEffect x:Key="NeonGlowEffect"
                      Color="{StaticResource AtlasCyan}"
                      Direction="270"
                      BlurRadius="8"
                      ShadowDepth="0"
                      Opacity="0.4"/>

    <DropShadowEffect x:Key="AtlasNeonLineGlowEffect"
                      Color="{StaticResource AtlasCyan}"
                      Direction="270"
                      BlurRadius="8"
                      ShadowDepth="0"
                      Opacity="0.22"/>

    <LinearGradientBrush x:Key="HeaderDividerBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#0022D3EE" Offset="0"/>
        <GradientStop Color="#0022D3EE" Offset="0.18"/>
        <GradientStop Color="#6622D3EE" Offset="0.5"/>
        <GradientStop Color="#0022D3EE" Offset="0.82"/>
        <GradientStop Color="#0022D3EE" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HeaderDividerHairlineBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#0022D3EE" Offset="0"/>
        <GradientStop Color="#0022D3EE" Offset="0.18"/>
        <GradientStop Color="#1A22D3EE" Offset="0.5"/>
        <GradientStop Color="#0022D3EE" Offset="0.82"/>
        <GradientStop Color="#0022D3EE" Offset="1"/>
    </LinearGradientBrush>

    <Style x:Key="NeonWindowFrameStyle" TargetType="ContentControl">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Border x:Name="Frame"
                            Background="{TemplateBinding Background}"
                            BorderThickness="1.5"
                            CornerRadius="18">
                        <Border.BorderBrush>
                            <LinearGradientBrush x:Name="FrameBrush" StartPoint="0,0" EndPoint="1,0">
                                <GradientStop x:Name="FS0" Color="#22D3EE" Offset="0"/>
                                <GradientStop x:Name="FS1" Color="#22D3EE" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.Effect>
                            <DropShadowEffect x:Name="Glow" Color="#22D3EE" BlurRadius="25" ShadowDepth="0" Opacity="0.45"/>
                        </Border.Effect>
                        <ContentPresenter Content="{TemplateBinding Content}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                    <DoubleAnimation Storyboard.TargetName="Glow"
                                                     Storyboard.TargetProperty="Opacity"
                                                     From="0.35"
                                                     To="0.65"
                                                     Duration="0:0:2.5">
                                        <DoubleAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NeonWindowFrameStyle.Sweep" TargetType="ContentControl" BasedOn="{StaticResource NeonWindowFrameStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Border x:Name="Frame"
                            Background="{TemplateBinding Background}"
                            BorderThickness="1.5"
                            CornerRadius="18">
                        <Border.BorderBrush>
                            <LinearGradientBrush x:Name="FrameBrush" StartPoint="0,0" EndPoint="1,0">
                                <GradientStop x:Name="FS0" Color="#00000000" Offset="0.0"/>
                                <GradientStop x:Name="FS1" Color="#22D3EE" Offset="0.45"/>
                                <GradientStop x:Name="FS2" Color="#22D3EE" Offset="0.55"/>
                                <GradientStop x:Name="FS3" Color="#00000000" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.Effect>
                            <DropShadowEffect x:Name="Glow" Color="#22D3EE" BlurRadius="25" ShadowDepth="0" Opacity="0.45"/>
                        </Border.Effect>
                        <ContentPresenter Content="{TemplateBinding Content}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="Glow"
                                                     Storyboard.TargetProperty="Opacity"
                                                     From="0.35"
                                                     To="0.65"
                                                     Duration="0:0:2.5"
                                                     AutoReverse="True">
                                        <DoubleAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="FS1"
                                                     Storyboard.TargetProperty="Offset"
                                                     From="0"
                                                     To="1"
                                                     Duration="0:0:4"/>
                                    <DoubleAnimation Storyboard.TargetName="FS2"
                                                     Storyboard.TargetProperty="Offset"
                                                     From="0.1"
                                                     To="1.1"
                                                     Duration="0:0:4"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NeonFrameBorderStyle" TargetType="ContentControl">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Border x:Name="Frame"
                            Background="{TemplateBinding Background}"
                            BorderThickness="1.5"
                            CornerRadius="18">
                        <Border.BorderBrush>
                            <LinearGradientBrush x:Name="FrameBrush" StartPoint="0,0" EndPoint="1,0">
                                <GradientStop x:Name="E0" Color="#22D3EE" Offset="0.0"/>
                                <GradientStop x:Name="E1" Color="#22D3EE" Offset="0.33"/>
                                <GradientStop x:Name="E2" Color="#22D3EE" Offset="0.66"/>
                                <GradientStop x:Name="E3" Color="#22D3EE" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.Effect>
                            <DropShadowEffect x:Name="Glow" Color="#22D3EE" BlurRadius="25" ShadowDepth="0" Opacity="0.28"/>
                        </Border.Effect>
                        <ContentPresenter Content="{TemplateBinding Content}"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding CurrentMode}" Value="{x:Static core:PresenceMode.Idle}">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard x:Name="IdlePulse">
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[0].Color" To="#22D3EE" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[1].Color" To="#22D3EE" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[2].Color" To="#22D3EE" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[3].Color" To="#22D3EE" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[0].Offset" To="0.0" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[1].Offset" To="0.33" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[2].Offset" To="0.66" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[3].Offset" To="1.0" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Color)" To="#22D3EE" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)" To="22" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame"
                                                         Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                         From="0.18"
                                                         To="0.32"
                                                         Duration="0:0:2.8">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="IdlePulse"/>
                            </DataTrigger.ExitActions>
                        </DataTrigger>

                        <DataTrigger Binding="{Binding CurrentMode}" Value="{x:Static core:PresenceMode.Listening}">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard x:Name="ListeningPulse">
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[0].Color" To="#22D3EE" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[1].Color" To="#22D3EE" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[2].Color" To="#22D3EE" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[3].Color" To="#22D3EE" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[0].Offset" To="0.0" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[1].Offset" To="0.33" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[2].Offset" To="0.66" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[3].Offset" To="1.0" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Color)" To="#22D3EE" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)" To="26" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame"
                                                         Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                         From="0.28"
                                                         To="0.55"
                                                         Duration="0:0:1.6">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="ListeningPulse"/>
                            </DataTrigger.ExitActions>
                        </DataTrigger>

                        <DataTrigger Binding="{Binding CurrentMode}" Value="{x:Static core:PresenceMode.Thinking}">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard x:Name="ThinkingWave">
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[0].Color" To="#A855F7" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[1].Color" To="#A855F7" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[2].Color" To="#A855F7" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[3].Color" To="#A855F7" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[0].Offset" To="0.0" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[1].Offset" To="0.33" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[2].Offset" To="0.66" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[3].Offset" To="1.0" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Color)" To="#A855F7" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame"
                                                         Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                         From="20"
                                                         To="30"
                                                         Duration="0:0:2.2">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Frame"
                                                         Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                         From="0.22"
                                                         To="0.42"
                                                         Duration="0:0:2.2">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="ThinkingWave"/>
                            </DataTrigger.ExitActions>
                        </DataTrigger>

                        <DataTrigger Binding="{Binding CurrentMode}" Value="{x:Static core:PresenceMode.Typing}">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard x:Name="TypingFlickerSoft">
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[0].Color" To="#A855F7" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[1].Color" To="#A855F7" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[2].Color" To="#A855F7" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[3].Color" To="#A855F7" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[0].Offset" To="0.0" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[1].Offset" To="0.33" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[2].Offset" To="0.66" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[3].Offset" To="1.0" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Color)" To="#A855F7" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame"
                                                         Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                         From="0.22"
                                                         To="0.34"
                                                         Duration="0:0:0.9">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="TypingFlickerSoft"/>
                            </DataTrigger.ExitActions>
                        </DataTrigger>

                        <DataTrigger Binding="{Binding CurrentMode}" Value="{x:Static core:PresenceMode.Talking}">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard x:Name="TalkingBreath">
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[0].Color" To="#22D3EE" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[1].Color" To="#22D3EE" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[2].Color" To="#22D3EE" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[3].Color" To="#22D3EE" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[0].Offset" To="0.0" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[1].Offset" To="0.33" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[2].Offset" To="0.66" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[3].Offset" To="1.0" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Color)" To="#22D3EE" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame"
                                                         Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                         From="0.34"
                                                         To="0.52"
                                                         Duration="0:0:2.0">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Frame"
                                                         Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                         From="22"
                                                         To="28"
                                                         Duration="0:0:2.0">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="TalkingBreath"/>
                            </DataTrigger.ExitActions>
                        </DataTrigger>

                        <DataTrigger Binding="{Binding CurrentMode}" Value="{x:Static core:PresenceMode.Working}">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard x:Name="WorkingSweep">
                                    <Storyboard RepeatBehavior="Forever">
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[0].Color" To="#00000000" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[1].Color" To="#F97316" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[2].Color" To="#F97316" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[3].Color" To="#00000000" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[0].Offset" To="0.0" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[3].Offset" To="1.0" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Color)" To="#F97316" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame"
                                                         Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                         From="0.22"
                                                         To="0.38"
                                                         Duration="0:0:2.2"
                                                         AutoReverse="True">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Frame"
                                                         Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[1].Offset"
                                                         From="0"
                                                         To="1"
                                                         Duration="0:0:4">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Frame"
                                                         Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[2].Offset"
                                                         From="0.12"
                                                         To="1.12"
                                                         Duration="0:0:4">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="WorkingSweep"/>
                            </DataTrigger.ExitActions>
                        </DataTrigger>

                        <DataTrigger Binding="{Binding CurrentMode}" Value="{x:Static core:PresenceMode.Error}">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard x:Name="ErrorBlink">
                                    <Storyboard FillBehavior="HoldEnd">
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[0].Color" To="#EF4444" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[1].Color" To="#EF4444" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[2].Color" To="#EF4444" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[3].Color" To="#EF4444" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[0].Offset" To="0.0" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[1].Offset" To="0.33" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[2].Offset" To="0.66" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(Border.BorderBrush).(LinearGradientBrush.GradientStops)[3].Offset" To="1.0" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Color)" To="#EF4444" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="Frame" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)" To="24" Duration="0:0:0"/>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Frame" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)">
                                            <EasingDoubleKeyFrame Value="0.22" KeyTime="0:0:0"/>
                                            <EasingDoubleKeyFrame Value="0.60" KeyTime="0:0:0.18">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                            <EasingDoubleKeyFrame Value="0.22" KeyTime="0:0:0.36">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                            <EasingDoubleKeyFrame Value="0.55" KeyTime="0:0:0.54">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                            <EasingDoubleKeyFrame Value="0.26" KeyTime="0:0:0.9">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="ErrorBlink"/>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ToolTip">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Background" Value="#CC0B0F14"/>
        <Setter Property="Foreground" Value="{StaticResource AtlasTextSecondaryBrush}"/>
        <Setter Property="BorderBrush" Value="#3322D3EE"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Placement" Value="Mouse"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10"
                            Padding="{TemplateBinding Padding}">
                        <Border.Effect>
                            <DropShadowEffect Color="#22D3EE" BlurRadius="16" ShadowDepth="0" Opacity="0.18"/>
                        </Border.Effect>
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Global Neon Accent Pulse (subtle) -->
    <Style x:Key="NeonBorderStyle" TargetType="Border">
        <Setter Property="Effect" Value="{StaticResource AtlasNeonLineGlowEffect}"/>
        <Style.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                        <DoubleAnimation Storyboard.TargetProperty="(Border.BorderBrush).(Brush.Opacity)"
                                         From="0.7"
                                         To="1"
                                         Duration="0:0:2.5"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <!-- Staggered variants so separators don't all pulse in sync -->
    <Style x:Key="NeonBorderStyle.Delay0_8" TargetType="Border">
        <Setter Property="Effect" Value="{StaticResource AtlasNeonLineGlowEffect}"/>
        <Style.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                        <DoubleAnimation Storyboard.TargetProperty="(Border.BorderBrush).(Brush.Opacity)"
                                         BeginTime="0:0:0.8"
                                         From="0.7"
                                         To="1"
                                         Duration="0:0:2.5"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="NeonBorderStyle.Delay1_6" TargetType="Border">
        <Setter Property="Effect" Value="{StaticResource AtlasNeonLineGlowEffect}"/>
        <Style.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                        <DoubleAnimation Storyboard.TargetProperty="(Border.BorderBrush).(Brush.Opacity)"
                                         BeginTime="0:0:1.6"
                                         From="0.7"
                                         To="1"
                                         Duration="0:0:2.5"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>
    
    <Style x:Key="AtlasNeonBorder" TargetType="Border">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Effect" Value="{StaticResource AtlasNeonLineGlowEffect}"/>
    </Style>

    <Style TargetType="Border">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    
    <!-- ─────────────────────────────────────────────────────────────────────────
         PRIMARY BUTTON - Main action buttons
    ───────────────────────────────────────────────────────────────────────── -->
    <Style x:Key="AtlasPrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AtlasSurfaceAlt}"/>
        <Setter Property="Foreground" Value="{StaticResource AtlasAccent}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AtlasAccent}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="{DynamicResource AtlasFontPrimary}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            CornerRadius="8" Padding="{TemplateBinding Padding}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource AtlasSurfaceHoverBrush}"/>
                            <Setter TargetName="bd" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="{StaticResource AtlasCyan}" BlurRadius="8" ShadowDepth="0" Opacity="0.2"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource AtlasSurfaceActiveBrush}"/>
                            <Setter TargetName="bd" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource AtlasSurfaceBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource AtlasTextDisabledBrush}"/>
                            <Setter TargetName="bd" Property="BorderBrush" Value="Transparent"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- ─────────────────────────────────────────────────────────────────────────
         SECONDARY BUTTON - Standard actions
    ───────────────────────────────────────────────────────────────────────── -->
    <Style x:Key="AtlasSecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource AtlasTextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AtlasBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontFamily" Value="{DynamicResource AtlasFontPrimary}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" 
                            CornerRadius="6" Padding="{TemplateBinding Padding}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource AtlasSurfaceActiveBrush}"/>
                            <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AtlasAccent}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource AtlasSurfaceBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- ─────────────────────────────────────────────────────────────────────────
         ICON BUTTON - Toolbar/header icons
    ───────────────────────────────────────────────────────────────────────── -->
    <Style x:Key="AtlasIconButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource AtlasCyanBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="{DynamicResource AtlasCyan}"
                                  BlurRadius="14"
                                  ShadowDepth="0"
                                  Opacity="1"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" 
                            CornerRadius="6" Width="{TemplateBinding Width}" 
                            Height="{TemplateBinding Height}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource AtlasSurfaceHoverBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource AtlasCyanBrush}"/>
                        </Trigger>
                        <Trigger Property="Tag" Value="Active">
                            <Setter TargetName="bd" Property="Background" Value="#30AA0000"/>
                            <Setter Property="Foreground" Value="{DynamicResource AtlasCyanBrush}"/>
                            <Setter TargetName="bd" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="{DynamicResource AtlasCyan}" BlurRadius="18" ShadowDepth="0" Opacity="1"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource AtlasSurfaceActiveBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GhostBtn" TargetType="Button" BasedOn="{StaticResource AtlasIconButton}"/>
    
    <!-- ─────────────────────────────────────────────────────────────────────────
         PILL BUTTON - Quick action chips
    ───────────────────────────────────────────────────────────────────────── -->
    <Style x:Key="AtlasPillButton" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource AtlasSurfaceAlt}"/>
        <Setter Property="Foreground" Value="{StaticResource AtlasAccent}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AtlasBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="FontFamily" Value="{DynamicResource AtlasFontPrimary}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" CornerRadius="16" Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource AtlasSurfaceHoverBrush}"/>
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AtlasAccent}"/>
