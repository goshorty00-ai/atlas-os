<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System.Windows;assembly=PresentationFramework">

    <!-- Canonical theme aliases (used by overrides below) -->
    <SolidColorBrush x:Key="Atlas.Surface"      Color="#111c2e"/>
    <SolidColorBrush x:Key="Atlas.Surface2"     Color="#0f172a"/>
    <SolidColorBrush x:Key="Atlas.Border"       Color="#1e293b"/>
    <SolidColorBrush x:Key="Atlas.Accent"       Color="#22d3ee"/>
    <SolidColorBrush x:Key="Atlas.Text"         Color="#e2e8f0"/>
    <SolidColorBrush x:Key="Atlas.TextMuted"    Color="#94a3b8"/>

    <!-- System brush overrides to avoid default bright highlight / washed-out menus -->
    <SolidColorBrush x:Key="{x:Static sys:SystemColors.HighlightBrushKey}"        Color="#1A22D3EE"/>
    <SolidColorBrush x:Key="{x:Static sys:SystemColors.HighlightTextBrushKey}"    Color="#E2E8F0"/>
    <SolidColorBrush x:Key="{x:Static sys:SystemColors.ControlBrushKey}"          Color="#111c2e"/>
    <SolidColorBrush x:Key="{x:Static sys:SystemColors.ControlTextBrushKey}"      Color="#E2E8F0"/>

    <SolidColorBrush x:Key="{x:Static sys:SystemColors.MenuBrushKey}"             Color="#111c2e"/>
    <SolidColorBrush x:Key="{x:Static sys:SystemColors.MenuTextBrushKey}"         Color="#E2E8F0"/>

    <SolidColorBrush x:Key="{x:Static sys:SystemColors.GrayTextBrushKey}"         Color="#94A3B8"/>

    <!-- Readable item styles (ComboBox / ListBox / Menu) -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource Atlas.Text}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd"
                            Style="{x:Null}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="8"
                            Margin="4,2"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Atlas.Surface2}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#3322D3EE"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Atlas.Surface2}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Atlas.Accent}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource Atlas.TextMuted}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{StaticResource Atlas.Text}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd"
                            Style="{x:Null}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="8"
                            Margin="4,2"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Atlas.Surface2}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#3322D3EE"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Atlas.Surface2}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Atlas.Accent}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource Atlas.TextMuted}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ContextMenu container -->
    <Style TargetType="ContextMenu">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Background" Value="{StaticResource Atlas.Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Atlas.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Style="{x:Null}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10"
                            Padding="{TemplateBinding Padding}">
                        <ScrollViewer CanContentScroll="True">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="{StaticResource Atlas.Text}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="{StaticResource Atlas.Surface2}"/>
                <Setter Property="BorderBrush" Value="#3322D3EE"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="{StaticResource Atlas.Surface2}"/>
                <Setter Property="BorderBrush" Value="{StaticResource Atlas.Accent}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="Separator">
        <Setter Property="Margin" Value="6,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                        <Border Height="1"
                            Background="Transparent"
                            BorderThickness="0,0,0,1"
                            Style="{StaticResource NeonBorderStyle}">
                        <!-- Use a non-shared brush so it can be animated -->
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#3322D3EE" Opacity="0.7"/>
                        </Border.BorderBrush>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
