<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="BuilderAccentBrush" Color="{StaticResource AtlasCyan}"/>
    <SolidColorBrush x:Key="BuilderWarningBrush" Color="{StaticResource AtlasWarning}"/>
    <SolidColorBrush x:Key="BuilderSuccessBrush" Color="{StaticResource AtlasSuccess}"/>
    <SolidColorBrush x:Key="BuilderApiBrush" Color="{StaticResource AtlasPurple}"/>

    <SolidColorBrush x:Key="BuilderTextPrimaryBrush" Color="{StaticResource AtlasTextPrimary}"/>
    <SolidColorBrush x:Key="BuilderTextSecondaryBrush" Color="{StaticResource AtlasTextSecondary}"/>
    <SolidColorBrush x:Key="BuilderTextMutedBrush" Color="{StaticResource AtlasTextMuted}"/>
    <SolidColorBrush x:Key="BuilderTextDisabledBrush" Color="{StaticResource AtlasTextDisabled}"/>

    <SolidColorBrush x:Key="BuilderBackgroundBrush" Color="{StaticResource AtlasBgDeep}"/>
    <SolidColorBrush x:Key="BuilderPanelBrush" Color="{StaticResource AtlasGlassSolid}"/>
    <SolidColorBrush x:Key="BuilderPanelBorderBrush" Color="{StaticResource AtlasGlassBorder}"/>
    <SolidColorBrush x:Key="BuilderPanelHighlightBrush" Color="{StaticResource AtlasGlassMedium}"/>

</ResourceDictionary>

