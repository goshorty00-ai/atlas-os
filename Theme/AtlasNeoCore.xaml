<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════
         ATLAS NEO — Core Styles
         All keys are prefixed with Neo to avoid collision with
         existing Atlas* style keys already in Controls.xaml.
    ═══════════════════════════════════════════════════════════════════ -->

    <!-- ── 1) GlassPanel Border ─────────────────────────────────────── -->
    <Style x:Key="NeoGlassPanelBorder" TargetType="Border">
        <Setter Property="Background"       Value="{StaticResource NeoGlassSurface}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource NeoBorderGlass}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="{StaticResource NeoRadius16}"/>
    </Style>

    <Style x:Key="NeoGlassElevatedBorder" TargetType="Border">
        <Setter Property="Background"       Value="{StaticResource NeoGlassElevated}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource NeoBorderNeon}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="{StaticResource NeoRadius16}"/>
    </Style>

    <!-- ── 2) PrimaryButton ─────────────────────────────────────────── -->
    <Style x:Key="NeoPrimaryButton" TargetType="Button">
        <Setter Property="Height"           Value="48"/>
        <Setter Property="MinWidth"         Value="120"/>
        <Setter Property="Padding"          Value="24,0"/>
        <Setter Property="Background"       Value="{StaticResource NeoGlass12}"/>
        <Setter Property="Foreground"       Value="{StaticResource NeoTextPrimary}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource NeoBorderNeon}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="FontFamily"       Value="{StaticResource NeoFontFamily}"/>
        <Setter Property="FontSize"         Value="14"/>
        <Setter Property="FontWeight"       Value="SemiBold"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource NeoRadius12}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush"
                                    Value="{StaticResource NeoBorderActive}"/>
                            <Setter TargetName="Root" Property="Effect"
                                    Value="{StaticResource NeoGlowCyanSoftEffect}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource NeoGlass16}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── 3) IconButton ─────────────────────────────────────────────── -->
    <Style x:Key="NeoIconButton" TargetType="Button">
        <Setter Property="Width"            Value="48"/>
        <Setter Property="Height"           Value="48"/>
        <Setter Property="Background"       Value="{StaticResource NeoGlass10}"/>
        <Setter Property="Foreground"       Value="{StaticResource NeoTextSecondary}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource NeoBorderGlass}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource NeoRadius12}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush"
                                    Value="{StaticResource NeoBorderNeon}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource NeoCyanIce}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource NeoGlass16}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── 4) SearchBar ──────────────────────────────────────────────── -->
    <Style x:Key="NeoSearchBar" TargetType="TextBox">
        <Setter Property="Height"                   Value="56"/>
        <Setter Property="MaxWidth"                 Value="600"/>
        <Setter Property="Foreground"               Value="{StaticResource NeoTextPrimary}"/>
        <Setter Property="Background"               Value="{StaticResource NeoGlass12}"/>
        <Setter Property="BorderBrush"              Value="{StaticResource NeoBorderGlass}"/>
        <Setter Property="BorderThickness"          Value="1"/>
        <Setter Property="FontFamily"               Value="{StaticResource NeoFontFamily}"/>
        <Setter Property="FontSize"                 Value="15"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="CaretBrush"               Value="{StaticResource NeoCyanIce}"/>
        <Setter Property="SelectionBrush"           Value="{StaticResource NeoGlowCyanSoft}"/>
        <Setter Property="Padding"                  Value="56,0,16,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource NeoRadius12}">
                        <Grid>
                            <!-- Search icon -->
                            <Path Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z"
                                  Fill="{StaticResource NeoTextSecondary}"
                                  Width="14" Height="14" Stretch="Uniform"/>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush"
                                    Value="{StaticResource NeoBorderNeon}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush"
                                    Value="{StaticResource NeoBorderGlass}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── 5) Nav Sidebar Item (unified) ────────────────── -->
    <Style x:Key="NeoNavSidebarItem" TargetType="Button">
        <Setter Property="Height"           Value="56"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="Foreground"       Value="{StaticResource AtlasTextSecondary}"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="FontFamily"       Value="{StaticResource NeoFontFamily}"/>
        <Setter Property="FontSize"         Value="14"/>
        <Setter Property="FontWeight"       Value="Medium"/>
        <Setter Property="Padding"          Value="20,0,20,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource NeoRadius12}"
                            Padding="{TemplateBinding Padding}"
                            Margin="8,1,8,1">
                        <Grid>
                            <!-- Active indicator bar -->
                            <Rectangle x:Name="ActiveBar"
                                       Width="3" Height="24"
                                       RadiusX="2" RadiusY="2"
                                       Fill="{StaticResource AtlasAccent}"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Margin="-12,0,0,0"
                                       Visibility="Collapsed"/>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Hover State -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#1A2332"/>
                            <Setter Property="Foreground" Value="{StaticResource AtlasTextPrimary}"/>
                        </Trigger>
                        <!-- Pressed State -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#1F2A37"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── 6) Chip / Badge ───────────────────────────────────────────── -->
    <Style x:Key="NeoChip" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource NeoGlass12}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource NeoBorderNeon}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="{StaticResource NeoRadius8}"/>
        <Setter Property="Padding"         Value="10,4"/>
        <Setter Property="Height"          Value="28"/>
    </Style>

    <!-- ── 7) MediaCard (poster 260×390) ─────────────────────────────── -->
    <!--
        Sizing:   260 wide, 390 tall (image 260×280, info overlay 110px)
        Hover:    lift (TranslateTransform Y=-4) + border glow cyan
        Binding:  Title, Year, Rating, CoverImage, Genres[0] as mood tag
                  Commands via AncestorType=UserControl → DataContext
    -->
    <DataTemplate x:Key="NeoMediaCardTemplate">
        <Border x:Name="Card"
                Width="260" Height="390"
                CornerRadius="{StaticResource NeoRadius16}"
                Background="{StaticResource NeoBgLayer}"
                BorderBrush="{StaticResource NeoBorderGlass}"
                BorderThickness="1"
                Margin="8"
                Cursor="Hand"
                UseLayoutRounding="True">
            <Border.RenderTransform>
                <TranslateTransform x:Name="CardTranslate" Y="0"/>
            </Border.RenderTransform>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Border.MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="CardTranslate"
                                             Storyboard.TargetProperty="Y"
                                             To="-4" Duration="0:0:0.15"
                                             AccelerationRatio="0.5"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="Border.MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="CardTranslate"
                                             Storyboard.TargetProperty="Y"
                                             To="0" Duration="0:0:0.15"
                                             AccelerationRatio="0.5"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
            <Grid ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="280"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Poster image (260×280) — DecodePixelWidth≈260 set by ViewModel -->
                <Image Grid.Row="0"
                       Source="{Binding CoverImage}"
                       Stretch="UniformToFill"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       SnapsToDevicePixels="True"/>

                <!-- Gradient overlay at the image bottom -->
                <Border Grid.Row="0"
                        VerticalAlignment="Bottom"
                        Height="80">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#E0131826"   Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- AI Score badge (top-right) -->
                <Border Grid.Row="0"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,10,10,0"
                        Background="#CC0a0d18"
                        BorderBrush="{StaticResource NeoBorderNeon}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource NeoRadius8}"
                        Padding="6,3">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="★"
                                   Foreground="{StaticResource NeoOrange}"
                                   FontSize="10" VerticalAlignment="Center"
                                   Margin="0,0,3,0"/>
                        <TextBlock Text="{Binding Rating, StringFormat='{}{0:F1}'}"
                                   Foreground="{StaticResource NeoTextPrimary}"
                                   FontSize="11" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <!-- Info panel (Row 1 — 110px) -->
                <Border Grid.Row="1"
                        Background="{StaticResource NeoBgLayer}"
                        Padding="12,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="{Binding Title}"
                                   Foreground="{StaticResource NeoTextPrimary}"
                                   FontFamily="{StaticResource NeoFontFamily}"
                                   FontSize="14" FontWeight="SemiBold"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"/>

                        <!-- Year + first genre -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding Year}"
                                       Foreground="{StaticResource NeoTextSecondary}"
                                       FontSize="12"/>
                            <TextBlock Text=" · "
                                       Foreground="{StaticResource NeoTextTertiary}"
                                       FontSize="12"/>
                            <TextBlock Foreground="{StaticResource NeoTextTertiary}"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="120">
                                <TextBlock.Text>
                                    <Binding Path="Genres[0]" FallbackValue="" TargetNullValue=""/>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>

                        <!-- Play row -->
                        <Grid Grid.Row="2" Margin="0,6,0,0">
                            <Button HorizontalAlignment="Left"
                                    Style="{StaticResource NeoPrimaryButton}"
                                    Height="32" FontSize="12"
                                    Padding="14,0"
                                    Command="{Binding DataContext.PlayItemCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Content="▶  Play"/>
                            <Button HorizontalAlignment="Right"
                                    Style="{StaticResource NeoIconButton}"
                                    Width="32" Height="32"
                                    Command="{Binding DataContext.OpenItemCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    ToolTip="Details">
                                <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"
                                      Fill="{StaticResource NeoTextSecondary}"
                                      Width="16" Height="16" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                      <!-- Note: Reused Path Data from SearchBar for details icon is incorrect, but I must preserve original content except Sidebar. -->
                                      <!-- Wait, the original content had a different Path Data. I need to be careful. -->
                                      <!-- Checking Chunk 3 (original content) for NeoIconButton path. -->
                                      <!-- Chunk 3 (lines 393+) has <Path Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z" ... -->
                                      <!-- My proposed content for NeoIconButton in the previous block was using the SearchBar Icon? No, wait. NeoIconButton is defined at line 76+. The Path inside NeoMediaCardTemplate (line 393+) is distinct. -->
                                      <!-- I need to ensure I copy the NeoMediaCardTemplate content correctly! -->
                            </Button>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Hover glow border (triggered in code via EventTrigger above) -->
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush"
                                    Value="{StaticResource NeoBorderNeon}"/>
                            <Setter Property="Effect"
                                    Value="{StaticResource NeoGlowCyanSoftEffect}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>
    </DataTemplate>


    <!-- ── 8) FocusVisualStyle ───────────────────────────────────────── -->
    <Style x:Key="NeoFocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Rectangle StrokeDashArray="2,1"
                                Stroke="{StaticResource NeoBorderActive}"
                                StrokeThickness="2"
                                RadiusX="10" RadiusY="10"
                                SnapsToDevicePixels="True">
                        <Rectangle.Effect>
                            <DropShadowEffect Color="#00E5FF" BlurRadius="6"
                                              ShadowDepth="0" Opacity="0.6"/>
                        </Rectangle.Effect>
                    </Rectangle>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── PiP Container ────────────────────────────────────────────── -->
    <Style x:Key="NeoPipContainerStyle" TargetType="Border">
        <Setter Property="Background"       Value="#E0050810"/>
        <Setter Property="BorderBrush"      Value="{StaticResource NeoBorderNeon}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="{StaticResource NeoRadius12}"/>
        <Setter Property="Effect"           Value="{StaticResource NeoGlowCyanSoftEffect}"/>
    </Style>

</ResourceDictionary>