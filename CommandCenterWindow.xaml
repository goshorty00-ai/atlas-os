<!-- Figma Component: Command Center Main Window -->
<!-- Design URL: https://www.figma.com/design/hDqUZDE0S3Y4d2Z7hgWbGG/Futuristic-AI-Command-Center -->
<Window x:Class="AtlasAI.CommandCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AtlasAI.Controls"
        xmlns:controls="clr-namespace:AtlasAI.Controls"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Atlas AI Command Center"
        Icon="atlas.ico"
        WindowState="Maximized"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#0A0E14"
        ResizeMode="CanResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="18"/>
    </WindowChrome.WindowChrome>
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Theme/Colors.xaml"/>
                <ResourceDictionary Source="Theme/Typography.xaml"/>
                <ResourceDictionary Source="Theme/Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Section voice icon button: no white bleed on hover/focus/press/disabled -->
            <Style x:Key="SectionVoiceIconBtnStyle" TargetType="Button">
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="OverridesDefaultStyle" Value="True"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="False"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#44FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#18FFFFFF"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#33FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Background" Value="Transparent"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#22FFFFFF"/>
                                    <Setter Property="Opacity" Value="0.38"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    
    <Border CornerRadius="18" ClipToBounds="True" Background="#0A0E14">
        <Grid x:Name="ShellGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>      <!-- Top Navigation -->
                <RowDefinition Height="*"/>       <!-- Content Area -->
                <RowDefinition Height="Auto"/>    <!-- Status Bar (optional) -->
            </Grid.RowDefinitions>

        <Grid Grid.Row="0" Grid.RowSpan="3" Panel.ZIndex="0" IsHitTestVisible="False">
            <Image x:Name="WallpaperImage" Stretch="UniformToFill" Opacity="1" Visibility="Collapsed"/>
            <Image x:Name="WallpaperVideoImage" Stretch="UniformToFill" Opacity="1" Visibility="Collapsed"/>
            <Grid x:Name="WallpaperHost" ClipToBounds="True"/>
            <Rectangle Fill="#0A0E14" Opacity="0.12"/>
        </Grid>

        <Border Grid.Row="0"
                Panel.ZIndex="10"
                Background="#0A0E14"
                BorderBrush="{StaticResource HeaderDividerBrush}"
                BorderThickness="1.5"
            CornerRadius="16"
            shell:WindowChrome.IsHitTestVisibleInChrome="False">
            <Border.Effect>
                <DropShadowEffect Color="#22D3EE" BlurRadius="18" ShadowDepth="0" Opacity="0.32"/>
            </Border.Effect>
            <Border.CacheMode>
                <BitmapCache/>
            </Border.CacheMode>
            <controls:TopNavBarControl x:Name="TopNavBar" UnloadRequested="TopNavBar_UnloadRequested" shell:WindowChrome.IsHitTestVisibleInChrome="False" />
        </Border>

        <StackPanel Grid.Row="0" Visibility="Collapsed">
            <Button Name="ChatTab" Content="AI CHAT" Tag="Active" Click="Tab_Click"/>
            <Button Name="MediaTab" Content="AI MEDIA CENTRE" Click="Tab_Click"/>
            <Button Name="DJTab" Content="AI DJ BOOTH" Click="Tab_Click"/>
            <Button Name="SecurityTab" Content="AI SECURITY" Click="Tab_Click"/>
            <Button Name="CreateTab" Content="AI CREATE" Click="Tab_Click"/>
            <Button Name="CodeTab" Content="AI CODE" Click="Tab_Click"/>
        </StackPanel>
        
        <!-- Content Area with Left Sidebar -->
        <Grid x:Name="MainArea" Grid.Row="1" Panel.ZIndex="5" Background="Transparent" ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="SubHeaderRow" Height="0"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="80"/>   <!-- Left Sidebar -->
                <ColumnDefinition Width="*"/>    <!-- Main Content -->
            </Grid.ColumnDefinitions>

            <Border x:Name="SubHeaderBar"
                    Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Panel.ZIndex="0"
                    Background="{StaticResource DeepSeaGradient}"
                    BorderBrush="{StaticResource HeaderDividerBrush}"
                    BorderThickness="0,0,0,1.5"
                    Visibility="Collapsed"
                    IsHitTestVisible="False"/>

                <Grid Grid.Row="0"
                  Grid.Column="1"
                  Panel.ZIndex="12"
                  Margin="18,0,18,0"
                                    Visibility="Collapsed"
                  IsHitTestVisible="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="SubHeaderTitle"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       Margin="84,0,0,0"
                       Foreground="#CBE6FF"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Text="AI Chat"
                       TextTrimming="CharacterEllipsis"/>

                <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right">
                    <Button x:Name="SectionSpeechIconBtn"
                        Style="{StaticResource SectionVoiceIconBtnStyle}"
                        Width="30"
                        Height="30"
                        Margin="0,0,8,0"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="#67E8F9"
                        Background="#1A0F172A"
                        BorderBrush="#5538BDF8"
                        BorderThickness="1"
                        Cursor="Hand"
                        FocusVisualStyle="{x:Null}"
                        ToolTip="Toggle section speech"
                        Click="SectionSpeechIconBtn_Click"
                        Content="🔊"/>

                    <Button x:Name="SectionMicIconBtn"
                        Style="{StaticResource SectionVoiceIconBtnStyle}"
                        Width="30"
                        Height="30"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="#34D399"
                        Background="#1A0F172A"
                        BorderBrush="#5555D6BE"
                        BorderThickness="1"
                        Cursor="Hand"
                        FocusVisualStyle="{x:Null}"
                        ToolTip="Start section microphone"
                        Click="SectionMicIconBtn_Click"
                        Content="🎤"/>

                    <TextBlock x:Name="SectionVoiceNote"
                        VerticalAlignment="Center"
                        Margin="6,0,0,0"
                        FontSize="10"
                        Foreground="#FBBF24"
                        Opacity="0.85"
                        Visibility="Collapsed"
                        Text=""/>
                </StackPanel>
                </Grid>

                  <Image x:Name="SubHeaderLogo"
                        Grid.Row="0"
                        Grid.Column="1"
                        Panel.ZIndex="10"
                        Height="62"
                        Margin="20,0,0,0"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        Stretch="Uniform"
                        Visibility="Collapsed"
                        Source="pack://application:,,,/Assets/Logos/AtlasAiChatLogo.png"/>
            
            <!-- Left Sidebar -->
            <controls:LeftSidebarControl Grid.Column="0"
                                         Grid.Row="0"
                                         Grid.RowSpan="2"
                                         Panel.ZIndex="5"
                                         x:Name="LeftSidebar"
                                         SidebarItemClicked="LeftSidebar_ItemClicked"/>

            <Button x:Name="SidebarToggleButton"
                    Grid.Column="0"
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    Panel.ZIndex="6"
                    Width="18"
                    Height="46"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,0,0"
                    Padding="0"
                    Background="Transparent"
                    Foreground="{StaticResource Brush.AccentCyan}"
                    BorderBrush="#331E293B"
                    BorderThickness="1"
                    Click="SidebarToggleButton_Click"
                    Content="⟨">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#141E293B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#241E293B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            
            <Button x:Name="ShowHeaderArrowButton"
                    Grid.Column="1"
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    Width="26"
                    Height="26"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,10,12,0"
                    Padding="0"
                    Background="#1A0F172A"
                    Foreground="{StaticResource Brush.AccentCyan}"
                    BorderBrush="{StaticResource AtlasGlassBorderBrush}"
                    BorderThickness="1"
                    Click="ShowHeaderArrowButton_Click"
                    Content="˄"
                    Visibility="Collapsed"
                    Panel.ZIndex="3001"/>
            
            <!-- Main Content Area -->
            <Grid Name="ContentArea" Grid.Column="1" Grid.Row="1" ClipToBounds="True">
                <!-- Views will be loaded here dynamically -->
            </Grid>
        </Grid>
        
        <!-- Status Bar (Optional) -->
        <Border Grid.Row="2"
                Name="StatusBar"
                Background="{StaticResource AtlasGlassBrush}"
                BorderBrush="{StaticResource AtlasGlassBorderBrush}"
                BorderThickness="0,1,0,0"
                Height="32"
                Visibility="Collapsed">
            <TextBlock Text="Ready"
                       Foreground="{StaticResource AtlasTextSecondaryBrush}"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Margin="24,0"/>
        </Border>

        <StackPanel x:Name="ToastContainer"
                    Grid.Row="0"
                    Grid.RowSpan="3"
                    Panel.ZIndex="6000"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,18,18"
                    IsHitTestVisible="True"/>

        <Button x:Name="WallpaperOnlyExitButton"
            Grid.Row="0"
            Grid.RowSpan="3"
            Panel.ZIndex="7000"
            Width="36"
            Height="36"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,16,16,0"
            Padding="0"
            Background="#220A0E14"
            Foreground="#22D3EE"
            BorderBrush="#6622D3EE"
            BorderThickness="1"
            Visibility="Collapsed"
            Click="WallpaperOnlyExitButton_Click"
            ToolTip="Show Atlas UI"
            Content="✕"/>
        </Grid>
    </Border>
</Window>
