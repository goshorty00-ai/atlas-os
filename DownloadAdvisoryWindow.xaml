<Window x:Class="AtlasAI.DownloadAdvisoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Atlas Neural Download Guard"
        Width="500"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">

    <!-- Outer margin gives drop shadow room to render without clipping -->
    <Border x:Name="MainCard"
            Background="#0A0C14"
            BorderThickness="2"
            BorderBrush="#22D3EE"
            CornerRadius="14"
            Margin="18">
        <Border.Effect>
            <DropShadowEffect Color="#22D3EE" BlurRadius="34" ShadowDepth="0" Opacity="0.4"/>
        </Border.Effect>

        <StackPanel Margin="24,22,24,22">

            <!-- Header: icon + branding + close button -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="HeaderIcon" Grid.Column="0"
                           Text="🛡️" FontSize="26"
                           Margin="0,0,12,0" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="HeaderTitle"
                               Text="NEURAL DOWNLOAD GUARD"
                               Foreground="#22D3EE"
                               FontSize="12" FontWeight="Bold"
                               FontFamily="Cascadia Code, Consolas, Courier New"/>
                    <TextBlock Text="Atlas · Pre-download Security Advisory"
                               Foreground="#4B5563" FontSize="10"/>
                </StackPanel>

                <TextBlock x:Name="CloseX" Grid.Column="2"
                           Text="✕" Foreground="#374151"
                           FontSize="15" VerticalAlignment="Top"
                           Cursor="Hand" Margin="10,0,0,0"/>
            </Grid>

            <!-- Risk badge -->
            <Border x:Name="RiskBadge"
                    CornerRadius="5" Padding="12,5"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,18">
                <TextBlock x:Name="RiskLabel"
                           Text="RISK: UNKNOWN"
                           FontFamily="Cascadia Code, Consolas, Courier New"
                           FontSize="11" FontWeight="SemiBold"/>
            </Border>

            <!-- File metadata grid -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="68"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition MinHeight="28"/>
                    <RowDefinition MinHeight="24"/>
                    <RowDefinition MinHeight="24"/>
                    <RowDefinition MinHeight="24"/>
                </Grid.RowDefinitions>

                <TextBlock Text="FILE" Grid.Row="0" Grid.Column="0"
                           Foreground="#4B5563" FontSize="10"
                           FontFamily="Cascadia Code, Consolas"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="FileNameLabel" Grid.Row="0" Grid.Column="1"
                           Foreground="White" FontSize="13" FontWeight="SemiBold"
                           TextWrapping="Wrap" VerticalAlignment="Center"/>

                <TextBlock Text="TYPE" Grid.Row="1" Grid.Column="0"
                           Foreground="#4B5563" FontSize="10"
                           FontFamily="Cascadia Code, Consolas"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="ExtLabel" Grid.Row="1" Grid.Column="1"
                           Foreground="#9CA3AF" FontSize="11" VerticalAlignment="Center"/>

                <TextBlock Text="SOURCE" Grid.Row="2" Grid.Column="0"
                           Foreground="#4B5563" FontSize="10"
                           FontFamily="Cascadia Code, Consolas"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="SourceLabel" Grid.Row="2" Grid.Column="1"
                           Foreground="#9CA3AF" FontSize="11"
                           TextWrapping="Wrap" VerticalAlignment="Center"/>

                <TextBlock Text="SIZE" Grid.Row="3" Grid.Column="0"
                           Foreground="#4B5563" FontSize="10"
                           FontFamily="Cascadia Code, Consolas"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="SizeLabel" Grid.Row="3" Grid.Column="1"
                           Foreground="#9CA3AF" FontSize="11" VerticalAlignment="Center"/>
            </Grid>

            <!-- Risk explanation box -->
            <Border Background="#0D1117" CornerRadius="7"
                    Padding="14,10" Margin="0,0,0,22">
                <TextBlock x:Name="ExplanationLabel"
                           Foreground="#D1D5DB" FontSize="12"
                           TextWrapping="Wrap" LineHeight="19"/>
            </Border>

            <!-- Action buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelBtn" Content="Cancel"
                        Background="#0D1117" Foreground="#9CA3AF"
                        BorderBrush="#1F2937" BorderThickness="1"
                        Padding="16,8" Margin="0,0,8,0"
                        FontSize="12" FontWeight="SemiBold"
                        Cursor="Hand"/>
                <Button x:Name="ConfirmBtn"
                        Content="⬇  Download with Atlas"
                        Padding="18,8"
                        FontSize="12" FontWeight="SemiBold"
                        Cursor="Hand"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
