<UserControl x:Class="AtlasAI.UI.Pages.SecurityPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:AtlasAI.Controls"
             mc:Ignorable="d"
             d:DesignWidth="1280"
             d:DesignHeight="720"
             Background="Transparent"
             MinWidth="1280"
             MinHeight="720">
    <UserControl.Resources>
        <FontFamily x:Key="MonoFont">Cascadia Code, Consolas</FontFamily>
        <SolidColorBrush x:Key="Cyan" Color="#22D3EE"/>
        <SolidColorBrush x:Key="Orange" Color="#FB923C"/>
        <SolidColorBrush x:Key="Red" Color="#EF4444"/>
        <SolidColorBrush x:Key="Green" Color="#22C55E"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#9CA3AF"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6B7280"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="384"/>
        </Grid.ColumnDefinitions>

        <Button Click="RestoreShellChrome_Click"
                Width="26"
                Height="26"
                Grid.ColumnSpan="2"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,10,12,0"
                Padding="0"
                Background="#1A0F172A"
                Foreground="{StaticResource Cyan}"
                BorderBrush="#331E293B"
                BorderThickness="1"
                ToolTip="Restore Atlas header and sidebar"
                Content="˄"
                Panel.ZIndex="10"/>

        <Border Grid.Column="0" Background="#330B0F14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="24"
                        BorderBrush="#1A22D3EE"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Grid Width="40" Height="40" Margin="0,0,16,0">
                                <Ellipse Stroke="#4D22D3EE" StrokeThickness="2" Opacity="0.5">
                                    <Ellipse.RenderTransform>
                                        <ScaleTransform x:Name="PulseScale" ScaleX="1" ScaleY="1" CenterX="0.5" CenterY="0.5"/>
                                    </Ellipse.RenderTransform>
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetName="PulseScale"
                                                                     Storyboard.TargetProperty="ScaleX"
                                                                     From="1" To="1.5"
                                                                     Duration="0:0:2"/>
                                                    <DoubleAnimation Storyboard.TargetName="PulseScale"
                                                                     Storyboard.TargetProperty="ScaleY"
                                                                     From="1" To="1.5"
                                                                     Duration="0:0:2"/>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="0.5" To="0"
                                                                     Duration="0:0:2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <Path Data="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                                      Width="32"
                                      Height="32"
                                      Stretch="Uniform"
                                      Fill="{StaticResource Cyan}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center">
                                    <Path.RenderTransform>
                                        <RotateTransform x:Name="ShieldRotate" CenterX="16" CenterY="16"/>
                                    </Path.RenderTransform>
                                    <Path.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetName="ShieldRotate"
                                                                     Storyboard.TargetProperty="Angle"
                                                                     From="0" To="360"
                                                                     Duration="0:0:4"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Path.Triggers>
                                </Path>
                            </Grid>
                            <StackPanel>
                                <TextBlock Text="AI SECURITY SCANNER"
                                           Foreground="{StaticResource Cyan}"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="20"
                                           FontWeight="Bold"/>
                                <TextBlock Text="AUTONOMOUS THREAT DETECTION SYSTEM"
                                           Foreground="#6B7280"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="11"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel Margin="0,0,24,0">
                                <TextBlock Text="SCANNED ITEMS" Foreground="#6B7280" FontFamily="{StaticResource MonoFont}" FontSize="11"/>
                                <TextBlock Text="{Binding ScannedItems, StringFormat={}{0:N0}}"
                                           Foreground="{StaticResource Cyan}"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="18"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="THREATS DETECTED" Foreground="#6B7280" FontFamily="{StaticResource MonoFont}" FontSize="11"/>
                                <TextBlock Text="{Binding ThreatsDetected, StringFormat={}{0:N0}}"
                                           Foreground="{Binding ThreatsBrush}"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="18"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Padding="24,0,24,0" Margin="0,16,0,0">
                    <controls:ScanProgressBar Progress="{Binding ScanProgress}"
                                              Maximum="100"
                                              StatusText="{Binding ScanPhaseText}"
                                              ProgressText="{Binding ScanProgressText}"
                                              MonoFontFamily="{StaticResource MonoFont}"/>
                </Border>

                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="32">
                    <StackPanel>
                        <UniformGrid Columns="2" Rows="2" HorizontalAlignment="Center" Margin="0,0,0,32">
                            <controls:SpeedometerGauge Value="{Binding Cpu.Value}"
                                                       ValueText="{Binding Cpu.ValueText}"
                                                       Label="{Binding Cpu.Label}"
                                                       StatusText="{Binding Cpu.StatusText}"
                                                       StatusBrush="{Binding Cpu.StatusBrush}"
                                                       IconGeometry="{Binding Cpu.IconGeometry}"
                                                       MonoFontFamily="{StaticResource MonoFont}"/>
                            <controls:SpeedometerGauge Value="{Binding Gpu.Value}"
                                                       ValueText="{Binding Gpu.ValueText}"
                                                       Label="{Binding Gpu.Label}"
                                                       StatusText="{Binding Gpu.StatusText}"
                                                       StatusBrush="{Binding Gpu.StatusBrush}"
                                                       IconGeometry="{Binding Gpu.IconGeometry}"
                                                       MonoFontFamily="{StaticResource MonoFont}"/>
                            <controls:SpeedometerGauge Value="{Binding Memory.Value}"
                                                       ValueText="{Binding Memory.ValueText}"
                                                       Label="{Binding Memory.Label}"
                                                       StatusText="{Binding Memory.StatusText}"
                                                       StatusBrush="{Binding Memory.StatusBrush}"
                                                       IconGeometry="{Binding Memory.IconGeometry}"
                                                       MonoFontFamily="{StaticResource MonoFont}"/>
                            <controls:SpeedometerGauge Value="{Binding Disk.Value}"
                                                       ValueText="{Binding Disk.ValueText}"
                                                       Label="{Binding Disk.Label}"
                                                       StatusText="{Binding Disk.StatusText}"
                                                       StatusBrush="{Binding Disk.StatusBrush}"
                                                       IconGeometry="{Binding Disk.IconGeometry}"
                                                       MonoFontFamily="{StaticResource MonoFont}"/>
                        </UniformGrid>

                        <Border Padding="16"
                                CornerRadius="8"
                                Background="#0D22C55E"
                                BorderBrush="#4D22C55E"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="12" Height="12" Fill="{StaticResource Green}" VerticalAlignment="Center">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="#22C55E" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
                                    </Ellipse.Effect>
                                    <Ellipse.RenderTransform>
                                        <ScaleTransform x:Name="SecurePulse" ScaleX="1" ScaleY="1" CenterX="0.5" CenterY="0.5"/>
                                    </Ellipse.RenderTransform>
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetName="SecurePulse" Storyboard.TargetProperty="ScaleX"
                                                                     From="1" To="1.2" Duration="0:0:1" AutoReverse="True"/>
                                                    <DoubleAnimation Storyboard.TargetName="SecurePulse" Storyboard.TargetProperty="ScaleY"
                                                                     From="1" To="1.2" Duration="0:0:1" AutoReverse="True"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <TextBlock Text="ALL SYSTEMS SECURE"
                                               Foreground="{StaticResource Green}"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="14"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="AI continuously monitoring for threats"
                                               Foreground="#6B7280"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="11"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                BorderBrush="#1A22D3EE"
                BorderThickness="1,0,0,0">
            <controls:SecurityChatPanel DataContext="{Binding Chat}" MonoFontFamily="{StaticResource MonoFont}"/>
        </Border>
    </Grid>
</UserControl>
