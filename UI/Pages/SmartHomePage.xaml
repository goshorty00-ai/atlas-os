<UserControl x:Class="AtlasAI.UI.Pages.SmartHomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="Transparent">
    <Grid Background="Transparent" ClipToBounds="True">
        <wv2:WebView2 x:Name="SmartHomeWebView" Margin="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

        <Grid x:Name="EmbeddedBrowserOverlay"
              Background="#D8060A12"
              Visibility="Collapsed"
              Panel.ZIndex="40">
            <Border Margin="30"
                    CornerRadius="22"
                    Background="#0A1018"
                    BorderBrush="#2B67E8F9"
                    BorderThickness="1.5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Margin="18,16,18,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Vertical">
                            <TextBlock x:Name="EmbeddedBrowserTitle"
                                       Text="Smart Home Live View"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AtlasTextPrimaryBrush}"/>
                            <TextBlock x:Name="EmbeddedBrowserUrlText"
                                       Margin="0,6,0,0"
                                       FontSize="12"
                                       Foreground="{DynamicResource AtlasTextSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="EmbeddedBrowserRecordingStatusText"
                                       Margin="0,6,0,0"
                                       FontSize="12"
                                       Foreground="#FF7FE8F9"
                                       Text="Recording is available when Atlas has a direct stream URL."
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="16,0,0,0">
                                <Button x:Name="EmbeddedBrowserRecordButton"
                                    Click="ToggleCameraWorkspaceLayout_Click"
                                    Padding="12,6"
                                    Margin="0,0,8,0"
                                    Background="#3A1A24"
                                    BorderBrush="#66FF6B7D"
                                    BorderThickness="1"
                                    Foreground="{DynamicResource AtlasTextPrimaryBrush}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="Single View" FontSize="12" FontWeight="SemiBold"/>
                            </Button>
                            <Button Click="CloseEmbeddedBrowser_Click"
                                    Padding="12,6"
                                    Background="#162330"
                                    BorderBrush="#3367E8F9"
                                    BorderThickness="1"
                                    Foreground="{DynamicResource AtlasTextPrimaryBrush}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="Close" FontSize="12" FontWeight="SemiBold"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="18,0,18,18"
                            CornerRadius="16"
                            BorderBrush="#22384C"
                            BorderThickness="1"
                            Background="#05080D"
                            ClipToBounds="True">
                        <Grid>
                            <wv2:WebView2 x:Name="EmbeddedBrowserWebView" Margin="0" Visibility="Collapsed"/>
                            <ContentControl x:Name="CameraWorkspaceContentHost" Margin="0"/>

                            <Border x:Name="EmbeddedBrowserLoadingOverlay"
                                    Background="#AA05080D"
                                    Visibility="Collapsed">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock x:Name="EmbeddedBrowserLoadingTitle"
                                               Text="Loading provider view..."
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AtlasTextPrimaryBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="EmbeddedBrowserLoadingSubtitle"
                                               Text="Atlas is keeping this inside Smart Home instead of sending you to the browser."
                                               Margin="0,8,0,0"
                                               FontSize="12"
                                               Foreground="{DynamicResource AtlasTextSecondaryBrush}"
                                               TextAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="MissingUiOverlay"
                Background="#CC0A0E14"
                Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="760">
                <TextBlock Text="Smart Home UI not built"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AtlasCyanBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Build the Figma Smart Home app in Figma/AI_Smart_Home and restart Atlas."
                           Margin="0,10,0,0"
                           FontSize="14"
                           Foreground="{DynamicResource AtlasTextSecondaryBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>