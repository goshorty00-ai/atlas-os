<Window x:Class="AtlasAI.UI.SafetySelfTestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Safety Self-Test" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🛡️ Safety Self-Test" FontSize="24" FontWeight="Bold" Foreground="#22d3ee"/>
            <TextBlock Text="Validates that all dangerous operations are properly blocked" 
                       Foreground="#888" FontSize="14" Margin="0,5,0,0"/>
        </StackPanel>
        
        <!-- Status Panel -->
        <Border Grid.Row="1" Background="#252540" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock x:Name="StatusText" Text="Ready to run tests" 
                               Foreground="#fff" FontSize="16" VerticalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0">
                    <TextBlock Text="Passed: " Foreground="#888"/>
                    <TextBlock x:Name="PassedCount" Text="0" Foreground="#4ade80" FontWeight="Bold"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="20,0">
                    <TextBlock Text="Failed: " Foreground="#888"/>
                    <TextBlock x:Name="FailedCount" Text="0" Foreground="#f87171" FontWeight="Bold"/>
                </StackPanel>
                
                <Button x:Name="RunTestsButton" Grid.Column="3" Content="▶ Run Tests" 
                        Click="RunTests_Click" Padding="15,8" 
                        Background="#22d3ee" Foreground="#000" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>
        
        <!-- Results List -->
        <Border Grid.Row="2" Background="#252540" CornerRadius="8" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ResultsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1a1a2e" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="{Binding StatusIcon}" 
                                               FontSize="16" VerticalAlignment="Center"/>
                                    
                                    <StackPanel Grid.Column="1" Margin="10,0">
                                        <TextBlock Text="{Binding TestName}" Foreground="#fff" 
                                                   FontWeight="SemiBold" FontSize="14"/>
                                        <TextBlock Text="{Binding Message}" Foreground="#888" 
                                                   FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    
                                    <Border Grid.Column="2" Background="{Binding TypeBackground}" 
                                            CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding OperationType}" Foreground="#fff" FontSize="11"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
        
        <!-- Footer -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="ViewLogsButton" Content="📋 View Logs" Click="ViewLogs_Click" 
                    Padding="15,8" Background="#333" Foreground="#fff" 
                    BorderThickness="0" Margin="0,0,10,0" Cursor="Hand"/>
            <Button Content="Close" Click="Close_Click" Padding="15,8" 
                    Background="#444" Foreground="#fff" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
