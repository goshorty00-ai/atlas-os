<Window x:Class="AtlasAI.FloatingHud.FloatingHudWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AtlasAI.Controls"
        Title="Atlas HUD"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Width="100" Height="120"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <!-- Floating HUD - Minimal always-present Atlas companion
         Pure presence visualization, no control actions -->
    
    <Grid x:Name="HudContainer">
        <!-- Subtle background glow (only visible on hover) -->
        <Border x:Name="HoverGlow" 
                CornerRadius="50"
                Opacity="0"
                Margin="5">
            <Border.Background>
                <RadialGradientBrush>
                    <GradientStop Color="#203B0000" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Border.Background>
        </Border>
        
        <!-- Mini HoloCore (scaled down) -->
        <Viewbox x:Name="CoreViewbox" 
                 Width="80" Height="80"
                 VerticalAlignment="Top"
                 Margin="0,5,0,0">
            <controls:HoloCoreControl x:Name="MiniCore"
                                      Width="220" Height="220"/>
        </Viewbox>
        
        <!-- Persona status label -->
        <TextBlock x:Name="StatusLabel"
                   Text="ONLINE"
                   FontFamily="Consolas"
                   FontSize="9"
                   FontWeight="SemiBold"
                   Foreground="#6022d3ee"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,8"/>
    </Grid>
</Window>
