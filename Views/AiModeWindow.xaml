<Window x:Class="AtlasAI.Views.AiModeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#0c0c12"
        Foreground="#e2e8f0">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="AI MODE"
                   FontWeight="SemiBold"
                   FontSize="14"
                   Margin="0,0,0,12"/>

        <CheckBox Grid.Row="1"
                  x:Name="AutoModeCheckBox"
                  Content="Auto mode (cheap for simple, smart for complex)"
                  Margin="0,0,0,12"
                  Checked="AutoModeCheckBox_Changed"
                  Unchecked="AutoModeCheckBox_Changed"/>

        <TextBlock Grid.Row="2" Text="Provider" Opacity="0.9" Visibility="Collapsed"/>
        <ComboBox Grid.Row="3"
                  x:Name="ProviderCombo"
                  MinWidth="360"
                  Margin="0,6,0,12"
                  Visibility="Collapsed"
                  SelectionChanged="ProviderCombo_SelectionChanged"/>

        <TextBlock Grid.Row="4" Text="Manual model" Opacity="0.9"/>
        <ComboBox Grid.Row="5"
                  x:Name="ModelCombo"
                  MinWidth="360"
                  Margin="0,6,0,0"
                  SelectionChanged="ModelCombo_SelectionChanged"/>

        <TextBlock Grid.Row="6" Text="Auto cheap model" Opacity="0.9" Margin="0,12,0,0"/>
        <ComboBox Grid.Row="7"
                  x:Name="AutoCheapModelCombo"
                  MinWidth="360"
                  Margin="0,6,0,0"
                  SelectionChanged="AutoCheapModelCombo_SelectionChanged"/>

        <TextBlock Grid.Row="8" Text="Auto smart model" Opacity="0.9" Margin="0,12,0,0"/>
        <ComboBox Grid.Row="9"
                  x:Name="AutoSmartModelCombo"
                  MinWidth="360"
                  Margin="0,6,0,0"
                  SelectionChanged="AutoSmartModelCombo_SelectionChanged"/>
    </Grid>
</Window>
