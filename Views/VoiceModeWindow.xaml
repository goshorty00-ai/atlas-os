<Window x:Class="AtlasAI.Views.VoiceModeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Voice"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="0" GlassFrameThickness="0" CornerRadius="16"/>
    </shell:WindowChrome.WindowChrome>

    <Border CornerRadius="16"
            Background="#0C0C12"
            BorderBrush="#331E293B"
            BorderThickness="1"
            Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0"
                       LastChildFill="True"
                       Margin="0,0,0,14"
                       PreviewMouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="VOICE"
                           Foreground="{DynamicResource AtlasTextPrimaryBrush}"
                           FontWeight="SemiBold"
                           FontSize="14"
                           VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right"
                        Content="✕"
                        Width="36"
                        Height="32"
                        Padding="0"
                        Margin="14,0,0,0"
                        Command="{x:Static SystemCommands.CloseWindowCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Style="{DynamicResource HeaderActionButtonStyle}"
                        BorderBrush="#40111A24"/>
            </DockPanel>

            <TextBlock Grid.Row="1"
                       Text="Global voice (ElevenLabs)"
                       Foreground="{DynamicResource AtlasTextSecondaryBrush}"
                       FontSize="12"/>

            <ComboBox Grid.Row="2"
                      x:Name="VoiceCombo"
                      MinWidth="420"
                      Margin="0,8,0,14"
                      Style="{StaticResource AtlasComboBox}"
                      SelectionChanged="VoiceCombo_SelectionChanged"/>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="RefreshButton"
                        Content="Refresh"
                        Padding="18,10"
                        Margin="0,0,12,0"
                        Style="{DynamicResource HeaderActionButtonStyle}"
                        BorderBrush="#40F59E0B"
                        Click="RefreshButton_Click">
                    <Button.Foreground>
                        <DynamicResource ResourceKey="AtlasTextPrimaryBrush"/>
                    </Button.Foreground>
                </Button>
                <Button x:Name="PreviewButton"
                        Content="Preview"
                        Padding="18,10"
                        Style="{DynamicResource HeaderActionButtonStyle}"
                        BorderBrush="#40F59E0B"
                        Click="PreviewButton_Click">
                    <Button.Foreground>
                        <DynamicResource ResourceKey="AtlasTextPrimaryBrush"/>
                    </Button.Foreground>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
