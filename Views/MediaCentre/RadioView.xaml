<UserControl x:Class="AtlasAI.Views.MediaCentre.RadioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Station Grid -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="24">
            <StackPanel>
                <!-- All Stations -->
                <TextBlock Text="ALL STATIONS"
                           Foreground="{StaticResource NeoTextPrimary}"
                           FontFamily="{StaticResource NeoFontFamily}"
                           FontSize="18" FontWeight="Bold"
                           Margin="0,0,0,16"/>

                <ItemsControl ItemsSource="{Binding LibraryItems}" Margin="0,0,0,32">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.PlayItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Margin="0,0,16,16"
                                    Width="160"
                                    Cursor="Hand">
                                <Border Background="{StaticResource NeoGlass12}"
                                        BorderBrush="{StaticResource NeoBorderNeon}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource NeoRadius16}"
                                        Padding="16">
                                    <StackPanel>
                                        <Border Width="128" Height="128" CornerRadius="{StaticResource NeoRadius12}"
                                                Background="{StaticResource NeoGlowCyanSoft}" ClipToBounds="True"
                                                HorizontalAlignment="Center">
                                            <Image Source="{Binding CoverUrl}" Stretch="Uniform"/>
                                        </Border>

                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{StaticResource NeoTextPrimary}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   TextAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,12,0,4"/>

                                        <TextBlock Text="{Binding Artist}"
                                                   Foreground="{StaticResource NeoTextSecondary}"
                                                   FontSize="12"
                                                   TextAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- RIGHT: Now Playing Station -->
        <Border Grid.Column="1"
                Background="{StaticResource NeoBgDeep}"
                BorderBrush="{StaticResource NeoBorderGlass}"
                BorderThickness="1,0,0,0"
                Padding="32">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="NOW STREAMING"
                               Foreground="{StaticResource NeoTextTertiary}"
                               FontSize="11" FontWeight="Bold"
                               TextAlignment="Center"
                               Margin="0,0,0,24"/>
                    
                    <!-- Station Logo -->
                    <Border Width="240" Height="240" CornerRadius="{StaticResource NeoRadius16}"
                            Background="{StaticResource NeoGlass12}"
                            BorderBrush="{StaticResource NeoBorderNeon}"
                            BorderThickness="2"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,32">
                        <Border.Effect>
                            <DropShadowEffect Color="#8022D3EE" BlurRadius="32" ShadowDepth="0"/>
                        </Border.Effect>
                        <Image Source="{Binding NowPlayingCoverImage}" Stretch="Uniform" Margin="32"/>
                    </Border>
                    
                    <!-- Station Info -->
                    <TextBlock Text="{Binding NowPlayingTitle}"
                               Foreground="{StaticResource NeoTextPrimary}"
                               FontSize="24" FontWeight="Bold"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,0,8"/>
                    
                    <TextBlock Text="{Binding NowPlayingArtist}"
                               Foreground="{StaticResource NeoTextSecondary}"
                               FontSize="16"
                               TextAlignment="Center"
                               Margin="0,0,0,24"/>
                    
                    <!-- Now Playing Track Info -->
                    <Border Background="{StaticResource NeoGlass12}"
                            BorderBrush="{StaticResource NeoBorderGlass}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource NeoRadius12}"
                            Padding="20"
                            Margin="0,0,0,32">
                        <StackPanel>
                            <TextBlock Text="NOW PLAYING"
                                       Foreground="{StaticResource NeoTextTertiary}"
                                       FontSize="10" FontWeight="Bold"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding NowPlayingTitle}"
                                       Foreground="{StaticResource NeoTextPrimary}"
                                       FontSize="16" FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"/>
                            <TextBlock Text="{Binding NowPlayingArtist}"
                                       Foreground="{StaticResource NeoTextSecondary}"
                                       FontSize="14"
                                       TextAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Playback Controls -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Style="{StaticResource NeoIconButton}" Width="48" Height="48" Margin="8"
                                Command="{Binding ToggleNowPlayingFavoriteCommand}">
                            <Path Data="M12,21.35L10.55,20.03C5.4,15.36 2,12.27 2,8.5C2,5.41 4.42,3 7.5,3C9.24,3 10.91,3.81 12,5.08C13.09,3.81 14.76,3 16.5,3C19.58,3 22,5.41 22,8.5C22,12.27 18.6,15.36 13.45,20.03L12,21.35Z"
                                  Fill="{StaticResource NeoTextSecondary}" Width="20" Height="20"/>
                        </Button>

                        <Button Style="{StaticResource NeoIconButton}" Width="80" Height="80"
                                Command="{Binding TogglePlayPauseCommand}"
                                Background="{StaticResource NeoGlowCyanSoft}"
                                BorderBrush="{StaticResource NeoBorderNeon}"
                                BorderThickness="2">
                            <Button.Effect>
                                <DropShadowEffect Color="#8022D3EE" BlurRadius="24" ShadowDepth="0"/>
                            </Button.Effect>
                            <TextBlock Text="{Binding PlaybackIcon}" Foreground="{StaticResource NeoCyanIce}" FontSize="28"/>
                        </Button>

                        <Button Style="{StaticResource NeoIconButton}" Width="48" Height="48" Margin="8"
                                Command="{Binding NextCommand}">
                            <Path Data="M6,18V6L11,11V6H13V18H11V13L6,18Z"
                                  Fill="{StaticResource NeoTextSecondary}" Width="20" Height="20"/>
                        </Button>
                    </StackPanel>
                    
                    <!-- Volume Control -->
                    <Grid Margin="0,32,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <Path Grid.Column="0" 
                              Data="M14,3.23V5.29C16.89,6.15 19,8.83 19,12C19,15.17 16.89,17.84 14,18.7V20.77C18,19.86 21,16.28 21,12C21,7.72 18,4.14 14,3.23M16.5,12C16.5,10.23 15.5,8.71 14,7.97V16C15.5,15.29 16.5,13.76 16.5,12M3,9V15H7L12,20V4L7,9H3Z"
                              Fill="{StaticResource NeoTextSecondary}" Width="16" Height="16" Margin="0,0,12,0"/>
                        
                        <Slider Grid.Column="1" 
                                Minimum="0" Maximum="100" 
                                Value="{Binding Volume}"
                                VerticalAlignment="Center"/>
                        
                        <TextBlock Grid.Column="2" 
                                   Text="{Binding Volume, StringFormat={}{0}%}"
                                   Foreground="{StaticResource NeoTextTertiary}"
                                   FontSize="12" Margin="12,0,0,0"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
