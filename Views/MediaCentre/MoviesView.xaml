<UserControl x:Class="AtlasAI.Views.MediaCentre.MoviesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             Background="{StaticResource MediaCentreDeepBlueGradient}">

    <UserControl.Resources>
        <Style x:Key="PosterCardButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <EventSetter Event="PreviewMouseRightButtonUp" Handler="PosterCard_RightClickOpenMenu"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Card"
                                    Background="{StaticResource NeoGlass10}"
                                    BorderBrush="#22D3EE"
                                    BorderThickness="1.5"
                                    CornerRadius="{StaticResource NeoRadius16}"
                                    ClipToBounds="True">
                                <ContentPresenter/>
                            </Border>

                            <Border x:Name="SelectedRing"
                                    CornerRadius="{StaticResource NeoRadius16}"
                                    BorderBrush="#F97316"
                                    BorderThickness="2.25"
                                    Opacity="0"
                                    IsHitTestVisible="False"/>

                            <Border x:Name="SelectedBadge"
                                    Width="18"
                                    Height="18"
                                    Background="#F97316"
                                    CornerRadius="9"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Margin="8"
                                    Opacity="0"
                                    IsHitTestVisible="False">
                                <TextBlock Text="✓"
                                           Foreground="#000000"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.03" ScaleY="1.03"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Card" Property="BorderBrush" Value="#22D3EE"/>
                                <Setter TargetName="Card" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#22D3EE" BlurRadius="22" ShadowDepth="0" Opacity="0.35"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="SelectedRing" Property="Opacity" Value="1"/>
                                <Setter TargetName="SelectedBadge" Property="Opacity" Value="1"/>
                                <Setter TargetName="Card" Property="BorderBrush" Value="#F97316"/>
                                <Setter TargetName="Card" Property="BorderThickness" Value="2.25"/>
                                <Setter TargetName="Card" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#F97316" BlurRadius="24" ShadowDepth="0" Opacity="0.40"/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="16,16,16,10">
            <TextBlock Text="MOVIES"
                       Foreground="{StaticResource NeoTextPrimary}"
                       FontFamily="{StaticResource NeoFontFamily}"
                       FontSize="16"
                       FontWeight="SemiBold"/>
            <TextBlock Text="{Binding VisibleCountText}"
                       Foreground="{StaticResource NeoTextSecondary}"
                       FontFamily="{StaticResource NeoFontFamily}"
                       FontSize="12"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="16,0,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360" MinWidth="320" MaxWidth="380"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,0,0,0">
                <ItemsControl ItemsSource="{Binding LibraryItems}"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource PosterCardButton}"
                                    Width="148"
                                    Margin="0,0,6,6"
                                    ToolTip="{Binding Title}"
                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Command="{Binding DataContext.SelectPreviewItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}">
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Play"
                                                  Command="{Binding PlacementTarget.Tag.PlayItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Streams"
                                                  Command="{Binding PlacementTarget.Tag.OpenStreamsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Download"
                                                  Command="{Binding PlacementTarget.Tag.DownloadItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Add to queue"
                                                  Command="{Binding PlacementTarget.Tag.AddToQueueCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Play next"
                                                  Command="{Binding PlacementTarget.Tag.QueueNextCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="AI optimize"
                                                  Command="{Binding PlacementTarget.Tag.OptimizeItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Edit info"
                                                  Command="{Binding PlacementTarget.Tag.EditItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <Separator/>
                                        <MenuItem Header="Set cover..."
                                                  Command="{Binding PlacementTarget.Tag.SetCoverCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <Separator/>
                                        <MenuItem Header="Show info"
                                                  Command="{Binding PlacementTarget.Tag.ShowItemInfoCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Open folder"
                                                  Command="{Binding PlacementTarget.Tag.OpenItemFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <Separator/>
                                        <MenuItem Header="Remove from library"
                                                  Command="{Binding PlacementTarget.Tag.RemoveFromLibraryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                                <Button.InputBindings>
                                    <MouseBinding Gesture="LeftDoubleClick"
                                                 Command="{Binding DataContext.OpenItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                 CommandParameter="{Binding}"/>
                                </Button.InputBindings>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="168"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Rectangle RadiusX="16" RadiusY="16">
                                            <Rectangle.Fill>
                                                <ImageBrush ImageSource="{Binding CoverImage}" Stretch="UniformToFill" AlignmentY="Top" AlignmentX="Center"/>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                        <Border VerticalAlignment="Bottom" Padding="10,8">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0.5,1" EndPoint="0.5,0">
                                                    <GradientStop Color="#F20A0E14" Offset="0"/>
                                                    <GradientStop Color="#000A0E14" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Border Background="#20111A24"
                                                    BorderBrush="#22D3EE55"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="8,2"
                                                    HorizontalAlignment="Left">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="★" Foreground="{StaticResource NeoCyanIce}" FontSize="10"/>
                                                    <TextBlock Text="{Binding Rating, StringFormat={}{0:0.0}}" Foreground="{StaticResource NeoTextPrimary}" FontSize="10" Margin="6,0,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </Border>
                                    </Grid>

                                    <StackPanel Grid.Row="1" Margin="10,8,10,10">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{StaticResource NeoTextPrimary}"
                                                   FontFamily="{StaticResource NeoFontFamily}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Column="1"
                    Background="{StaticResource NeoGlass12}"
                    BorderBrush="#22D3EE66"
                    BorderThickness="1"
                    CornerRadius="{StaticResource NeoRadius16}"
                    ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Rectangle Grid.Row="0" Grid.RowSpan="3" RadiusX="16" RadiusY="16" Fill="#0A0E14" IsHitTestVisible="False"/>
                    <Rectangle Grid.Row="0" Grid.RowSpan="3" RadiusX="16" RadiusY="16" Opacity="0.32" IsHitTestVisible="False">
                        <Rectangle.Fill>
                            <ImageBrush ImageSource="{Binding PreviewBackdropImage}" Stretch="UniformToFill"/>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Rectangle Grid.Row="0" Grid.RowSpan="3" RadiusX="16" RadiusY="16" IsHitTestVisible="False">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#E00A0E14" Offset="0"/>
                                <GradientStop Color="#C00A0E14" Offset="0.45"/>
                                <GradientStop Color="#F00A0E14" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <Grid Grid.Row="0" Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="76"
                                Height="114"
                                CornerRadius="16"
                                BorderBrush="#22D3EE66"
                                BorderThickness="1"
                                Background="{StaticResource NeoGlass12}"
                                ClipToBounds="True">
                            <Rectangle RadiusX="16" RadiusY="16">
                                <Rectangle.Fill>
                                    <ImageBrush ImageSource="{Binding PreviewItem.CoverImage}" Stretch="UniformToFill" AlignmentY="Top" AlignmentX="Center"/>
                                </Rectangle.Fill>
                            </Rectangle>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding PreviewItem.Title}"
                                       Foreground="{StaticResource NeoTextPrimary}"
                                       FontFamily="{StaticResource NeoFontFamily}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Border Background="#20111A24"
                                        BorderBrush="#22D3EE55"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="8,2"
                                        Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="★" Foreground="{StaticResource NeoCyanIce}" FontSize="10"/>
                                        <TextBlock Text="{Binding PreviewItem.Rating, StringFormat={}{0:0.0}}" Foreground="{StaticResource NeoTextPrimary}" FontSize="10" Margin="6,0,0,0"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="{Binding PreviewItem.Year}" Foreground="{StaticResource NeoTextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Text="  ·  " Foreground="{StaticResource NeoTextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding PreviewRuntimeText}" Foreground="{StaticResource NeoTextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="18,16,18,18">
                            <TextBlock Foreground="{StaticResource NeoTextPrimary}"
                                       FontFamily="{StaticResource NeoFontFamily}"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       MaxHeight="140">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding PreviewOverview}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PreviewOverview}" Value="{x:Null}">
                                                <Setter Property="Text" Value="No information available."/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PreviewOverview}" Value="">
                                                <Setter Property="Text" Value="No information available."/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBlock Text="GENRES"
                                       Foreground="{StaticResource NeoTextTertiary}"
                                       FontFamily="{StaticResource NeoFontFamily}"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Margin="0,18,0,8"/>
                            <ItemsControl ItemsSource="{Binding PreviewItem.Genres}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource NeoGlass10}"
                                                BorderBrush="#22D3EE55"
                                                BorderThickness="1"
                                                CornerRadius="14"
                                                Padding="12,6"
                                                Margin="0,0,10,10">
                                            <TextBlock Text="{Binding}"
                                                       Foreground="{StaticResource NeoTextPrimary}"
                                                       FontFamily="{StaticResource NeoFontFamily}"
                                                       FontSize="12"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="2" Margin="18,0,18,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Fav"
                                Command="{Binding ToggleItemFavoriteCommand}"
                                CommandParameter="{Binding PreviewItem}"
                                Style="{StaticResource NeoPrimaryButton}"
                                Height="28"
                                MinWidth="64"
                                Padding="10,0"/>

                        <Button Grid.Column="1"
                                Content="Trailer"
                                Command="{Binding PlayPreviewTrailerCommand}"
                                Style="{StaticResource NeoPrimaryButton}"
                                Height="28"
                                MinWidth="72"
                                Padding="10,0"
                                Margin="10,0,0,0"/>

                        <Button Grid.Column="3"
                                Content="Play"
                                Command="{Binding PlayItemCommand}"
                                CommandParameter="{Binding PreviewItem}"
                                Style="{StaticResource NeoPrimaryButton}"
                                Height="28"
                                MinWidth="72"
                                Padding="10,0"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
