<UserControl x:Class="AtlasAI.Views.MediaCentre.DiscoveryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">
    <UserControl.Resources>
    </UserControl.Resources>
    <Grid x:Name="RootHost" Background="#080A10">
        <wv2:WebView2 x:Name="DiscoveryFigmaWebView" />

        <Border x:Name="UnavailableOverlay"
                Background="#E6101621"
                BorderBrush="#3342D7EE"
                BorderThickness="1"
                CornerRadius="18"
                Padding="28"
                Margin="32"
                MaxWidth="720"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="Discovery Unavailable"
                           FontSize="30"
                           FontWeight="SemiBold"
                           Foreground="#FFEAF7FF"
                           Margin="0,0,0,10"/>
                <TextBlock x:Name="UnavailableSummaryText"
                           Text="Live discovery data is not available."
                           FontSize="15"
                           TextWrapping="Wrap"
                           Foreground="#FFB8CBD6"
                           Margin="0,0,0,14"/>
                <TextBlock Text="Atlas will only show this surface when a real discovery feed is available. Mock trailers, news, and featured media are intentionally hidden from the live path."
                           FontSize="14"
                           TextWrapping="Wrap"
                           Foreground="#FF8DA4B2"
                           Margin="0,0,0,18"/>
                <Button Content="Retry discovery"
                        Width="160"
                        Height="38"
                        HorizontalAlignment="Left"
                        Click="RetryDiscovery_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
