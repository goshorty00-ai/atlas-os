<UserControl x:Class="AtlasAI.Views.MediaCentre.ServersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="#080A10">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid x:Name="RootHost" Background="#080A10">
        <wv2:WebView2 x:Name="ServersFigmaWebView" />

        <!-- Addon Manager Overlay Container (hidden by default) -->
        <ContentControl x:Name="AddonManagerOverlay" 
                        Visibility="Collapsed"
                        Panel.ZIndex="999"
                        Background="#080A10"/>

        <!-- Minimal Transparent Stream Overlay -->
        <Border Background="#CC000000" 
                Visibility="{Binding IsStreamsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Padding="20" CornerRadius="10"
                Panel.ZIndex="1000">
            <StackPanel>
                <TextBlock Text="Finding Sources..." 
                           Foreground="#22D3EE" 
                           FontSize="16" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,10"/>
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#33FFFFFF" Foreground="#22D3EE" BorderThickness="0"/>
                <TextBlock Text="{Binding StreamsStatusText}" 
                           Foreground="#888" 
                           FontSize="12" 
                           HorizontalAlignment="Center" 
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
