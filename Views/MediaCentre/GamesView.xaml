<UserControl x:Class="AtlasAI.Views.MediaCentre.GamesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="420"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Games Grid -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="24">
            <StackPanel>
                <Grid Margin="0,0,0,24">
                    <TextBlock Text="GAME LIBRARY"
                               Foreground="{StaticResource NeoTextPrimary}"
                               FontFamily="{StaticResource NeoFontFamily}"
                               FontSize="18" FontWeight="Bold"/>
                    
                    <Button Style="{StaticResource NeoIconButton}" 
                            HorizontalAlignment="Right"
                            Command="{Binding DiscoverGamesCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                                  Fill="{StaticResource NeoCyanIce}" Width="16" Height="16" Margin="0,0,8,0"/>
                            <TextBlock Text="SYNC GAMES" Foreground="{StaticResource NeoCyanIce}" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </Grid>
                
                <ItemsControl ItemsSource="{Binding LibraryItems}"
                              VirtualizingPanel.IsVirtualizing="True">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.SelectPreviewItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Margin="0,0,16,16"
                                    Width="220"
                                    Cursor="Hand">
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Play"
                                                  Command="{Binding DataContext.PlayItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                        <MenuItem Header="Play Next"
                                                  Command="{Binding DataContext.QueueNextCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                        <MenuItem Header="Add to Queue"
                                                  Command="{Binding DataContext.AddToQueueCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                        <Separator/>
                                        <MenuItem Header="Edit Item..."
                                                  Command="{Binding DataContext.EditItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                        <MenuItem Header="Change Cover..."
                                                  Command="{Binding DataContext.ChangeCoverCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                        <MenuItem Header="Rescan Metadata"
                                                  Command="{Binding DataContext.RescanMetadataCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                        <Separator/>
                                        <MenuItem Header="Remove from Library"
                                                  Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                                <Border CornerRadius="{StaticResource NeoRadius16}">
                                    <Grid>
                                        <!-- Game Cover -->
                                        <Border Width="220" Height="310" 
                                                Background="{StaticResource NeoGlass12}"
                                                CornerRadius="{StaticResource NeoRadius16}"
                                                ClipToBounds="True">
                                            <Image Source="{Binding CoverUrl}" Stretch="UniformToFill"/>
                                        </Border>
                                        
                                        <!-- Gradient Overlay -->
                                        <Border VerticalAlignment="Bottom"
                                                CornerRadius="0,0,16,16"
                                                Padding="16">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0.5,1" EndPoint="0.5,0">
                                                    <GradientStop Color="#CC0F172A" Offset="0"/>
                                                    <GradientStop Color="#000F172A" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="{StaticResource NeoTextPrimary}"
                                                           FontSize="14" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                
                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                    <Border Background="{StaticResource NeoGlowCyanSoft}"
                                                            BorderBrush="{StaticResource NeoBorderNeon}"
                                                            BorderThickness="1"
                                                            CornerRadius="6" Padding="6,2" Margin="0,0,8,0">
                                                        <TextBlock Text="{Binding Subtitle}"
                                                                   Foreground="{StaticResource NeoCyanIce}"
                                                                   FontSize="10" FontWeight="SemiBold"/>
                                                    </Border>
                                                    
                                                    <TextBlock Text="{Binding Year}"
                                                               Foreground="{StaticResource NeoTextTertiary}"
                                                               FontSize="12" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- RIGHT: Game Details Panel -->
        <Border Grid.Column="1"
                Background="{StaticResource NeoBgDeep}"
                BorderBrush="{StaticResource NeoBorderGlass}"
                BorderThickness="1,0,0,0"
                Padding="32">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Game Cover Large -->
                    <Border Width="320" Height="450" 
                            Background="{StaticResource NeoGlass12}"
                            CornerRadius="{StaticResource NeoRadius16}"
                            ClipToBounds="True"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,24">
                        <Image Source="{Binding PreviewItem.CoverUrl}" Stretch="UniformToFill"/>
                    </Border>
                    
                    <!-- Game Title -->
                    <TextBlock Text="{Binding PreviewItem.Title}"
                               Foreground="{StaticResource NeoTextPrimary}"
                               FontSize="24" FontWeight="Bold"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,0,0,12"/>
                    
                    <!-- Metadata Pills -->
                    <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,24">
                        <Border Background="{StaticResource NeoGlass12}"
                                BorderBrush="{StaticResource NeoBorderGlass}"
                                BorderThickness="1"
                                CornerRadius="10" Padding="12,6" Margin="4">
                            <TextBlock Text="{Binding PreviewItem.Subtitle}"
                                       Foreground="{StaticResource NeoTextPrimary}"
                                       FontSize="12"/>
                        </Border>

                        <Border Background="{StaticResource NeoGlass12}"
                                BorderBrush="{StaticResource NeoBorderGlass}"
                                BorderThickness="1"
                                CornerRadius="10" Padding="12,6" Margin="4">
                            <TextBlock Text="{Binding PreviewItem.Year}"
                                       Foreground="{StaticResource NeoTextPrimary}"
                                       FontSize="12"/>
                        </Border>

                        <Border Background="{StaticResource NeoGlass12}"
                                BorderBrush="{StaticResource NeoBorderGlass}"
                                BorderThickness="1"
                                CornerRadius="10" Padding="12,6" Margin="4">
                            <TextBlock Text="{Binding PreviewItem.Artist}"
                                       Foreground="{StaticResource NeoTextPrimary}"
                                       FontSize="12"/>
                        </Border>
                    </WrapPanel>

                    <!-- Play Button -->
                    <Border Background="{StaticResource NeoGlowCyanSoft}"
                            BorderBrush="{StaticResource NeoBorderNeon}"
                            BorderThickness="2"
                            CornerRadius="16"
                            Height="64"
                            Margin="0,0,0,24">
                        <Border.Effect>
                            <DropShadowEffect Color="#8022D3EE" BlurRadius="24" ShadowDepth="0"/>
                        </Border.Effect>
                        <Button Command="{Binding PlayItemCommand}"
                                CommandParameter="{Binding PreviewItem}"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M8,5.14V19.14L19,12.14L8,5.14Z"
                                      Fill="{StaticResource NeoCyanIce}"
                                      Width="24" Height="24" Margin="0,0,12,0"/>
                                <TextBlock Text="LAUNCH GAME"
                                           Foreground="{StaticResource NeoCyanIce}"
                                           FontSize="16" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Border>
                    
                    <!-- Description -->
                    <Border Background="{StaticResource NeoGlass10}"
                            BorderBrush="{StaticResource NeoBorderGlass}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource NeoRadius12}"
                            Padding="20"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="ABOUT"
                                       Foreground="{StaticResource NeoTextTertiary}"
                                       FontSize="11" FontWeight="Bold"
                                       Margin="0,0,0,12"/>
                            <TextBlock Text="{Binding PreviewItem.Metadata}"
                                       Foreground="{StaticResource NeoTextSecondary}"
                                       FontSize="14" TextWrapping="Wrap"
                                       LineHeight="22"/>
                        </StackPanel>
                    </Border>
                    
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </UserControl>
