<UserControl x:Class="AtlasAI.Views.MediaCentre.AppsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1280">
    <UserControl.Resources>
        <Style x:Key="HeaderActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="BorderBrush" Value="#2230A6B8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#22D3EE"/>
            <Setter Property="FontFamily" Value="{StaticResource AtlasFontMono}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#101C2E"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#6622D3EE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#9922D3EE"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid x:Name="RootGrid" Margin="24,0,24,24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="AppsListColumn" Width="360"/>
            <ColumnDefinition x:Name="AppsListSpacerColumn" Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition x:Name="AppsHeaderSpacerRow" Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border x:Name="AppsHeaderBar"
                Grid.ColumnSpan="3"
                Grid.Row="0"
                Background="{StaticResource NeoGlass10}"
                BorderBrush="#2230A6B8"
                BorderThickness="1"
                CornerRadius="{StaticResource NeoRadius16}"
                Padding="12,10">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Style="{StaticResource HeaderActionButtonStyle}" Content="⟵" Click="Back_Click"/>
                    <Button Style="{StaticResource HeaderActionButtonStyle}" Content="⟶" Margin="8,0,0,0" Click="Forward_Click"/>
                    <Button Style="{StaticResource HeaderActionButtonStyle}" Content="⟳" Margin="8,0,0,0" Click="Refresh_Click"/>
                    <Button Style="{StaticResource HeaderActionButtonStyle}" Content="⌂" Margin="8,0,0,0" Click="Home_Click"/>
                    <Button x:Name="ExpandBtn" Style="{StaticResource HeaderActionButtonStyle}" Content="⤢" Margin="8,0,0,0" Click="Expand_Click"/>
                </StackPanel>

                <TextBlock x:Name="UrlText"
                           DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           FontFamily="{StaticResource NeoFontFamily}"
                           FontSize="12"
                           Foreground="{StaticResource NeoTextTertiary}"
                           TextTrimming="CharacterEllipsis"
                           Width="620"/>
            </DockPanel>
        </Border>

        <Border Grid.Column="0"
                Grid.Row="2"
                x:Name="AppsListHost"
                Background="{StaticResource NeoGlass10}"
                BorderBrush="#2230A6B8"
                BorderThickness="1"
                CornerRadius="{StaticResource NeoRadius16}"
                Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Background="#0B1220"
                        BorderBrush="#2230A6B8"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="10,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔎"
                                   FontSize="12"
                                   Foreground="#22D3EE"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBox x:Name="AppsSearchBox"
                                 Grid.Column="1"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource NeoTextPrimary}"
                                 CaretBrush="#22D3EE"
                                 FontFamily="{StaticResource NeoFontFamily}"
                                 FontSize="12"
                                 TextChanged="AppsSearchBox_TextChanged"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="AppsServicesList" ItemsSource="{Binding AppsServices}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.OpenAppsServiceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Margin="6"
                                        Padding="10,8"
                                        Background="#0B1220"
                                        BorderBrush="#2230A6B8"
                                        BorderThickness="1"
                                        Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="12"
                                                    Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Border Width="22" Height="22" CornerRadius="6" Background="#132133" Margin="0,0,8,0">
                                                        <Grid>
                                                            <Image Width="16"
                                                                   Height="16"
                                                                   Stretch="Uniform"
                                                                   Source="{Binding IconUrl}"/>
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontFamily="{StaticResource NeoFontFamily}"
                                                                       FontSize="10"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource NeoTextPrimary}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IconUrl}" Value="">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding IconUrl}" Value="{x:Null}">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Grid>
                                                    </Border>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontFamily="{StaticResource NeoFontFamily}"
                                                               Foreground="{StaticResource NeoTextPrimary}"
                                                               FontSize="12"
                                                               TextTrimming="CharacterEllipsis"
                                                               Width="230"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="BorderBrush" Value="#6622D3EE"/>
                                                    <Setter TargetName="bd" Property="Background" Value="#101C2E"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="bd" Property="BorderBrush" Value="#9922D3EE"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border x:Name="AppsBrowserHost"
                Grid.Column="2"
                Grid.Row="2"
                Background="#0B1220"
                BorderBrush="#2230A6B8"
                BorderThickness="1"
                CornerRadius="{StaticResource NeoRadius16}">
            <Grid>
                <wv2:WebView2 x:Name="AppsBrowser" DefaultBackgroundColor="Transparent"/>
                <Button x:Name="FullscreenExitBtn"
                        Content="✕"
                        Width="44"
                        Height="36"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,14,14,0"
                        Background="#660B1220"
                        BorderBrush="#5522D3EE"
                        BorderThickness="1"
                        Foreground="#E2E8F0"
                        Cursor="Hand"
                        Visibility="Collapsed"
                        Click="FullscreenExit_Click"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
