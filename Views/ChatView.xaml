<UserControl x:Class="AtlasAI.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AtlasAI.Views.Converters"
             xmlns:controls="clr-namespace:AtlasAI.Controls"
             Background="Transparent">

    <UserControl.Resources>
        <converters:WidthMultiplierConverter x:Key="WidthMultiplier"/>
        <converters:FileNameConverter x:Key="FileNameConverter"/>

        <DropShadowEffect x:Key="AiGlow" Color="#22D3EE" BlurRadius="10" ShadowDepth="0" Opacity="0.2"/>
        <DropShadowEffect x:Key="UserShadow" Color="#000000" BlurRadius="18" ShadowDepth="0" Opacity="0.35"/>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Background="Transparent" ClipToBounds="False">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer x:Name="MessageScrollViewer"
                          Grid.Row="0" Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="16,20,16,0">
                <ScrollViewer.Resources>
                    <Style TargetType="{x:Type ScrollBar}">
                        <Setter Property="Width" Value="0"/>
                        <Setter Property="Opacity" Value="0"/>
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="IsHitTestVisible" Value="False"/>
                    </Style>
                </ScrollViewer.Resources>
                <StackPanel>
                    <ListBox ItemsSource="{Binding Messages}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,12"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Focusable" Value="False"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter>
                                                <ContentPresenter.Triggers>
                                                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.18"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </ContentPresenter.Triggers>
                                            </ContentPresenter>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="Bubble"
                                        Padding="12,9"
                                        CornerRadius="8"
                                        BorderThickness="1"
                                        Background="#0f1419"
                                        BorderBrush="{StaticResource AtlasCyanGlowBrush}"
                                        HorizontalAlignment="Left"
                                        MaxWidth="{Binding ElementName=MessageScrollViewer, Path=ActualWidth, Converter={StaticResource WidthMultiplier}, ConverterParameter=0.65}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#22D3EE" BlurRadius="20" ShadowDepth="0" Opacity="0.10"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Orientation="Horizontal" Grid.Row="0">
                                            <TextBlock x:Name="SenderLabel"
                                                       Text="ATLAS"
                                                       FontFamily="{StaticResource AtlasFontMono}"
                                                       FontSize="10"
                                                       Foreground="#22d3ee"
                                                       Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding Timestamp, StringFormat={}{0:hh:mm tt}}"
                                                       FontFamily="{StaticResource AtlasFontMono}"
                                                       FontSize="10"
                                                       Foreground="#475569"/>
                                        </StackPanel>

                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding Content}"
                                                   FontFamily="{StaticResource AtlasFontMono}"
                                                   FontSize="14"
                                                   Foreground="#e2e8f0"
                                                   TextWrapping="Wrap"
                                                   Margin="0,10,0,0"/>
                                    </Grid>
                                </Border>

                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                        <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Right"/>
                                        <Setter TargetName="Bubble" Property="BorderBrush" Value="#64748B80"/>
                                        <Setter TargetName="Bubble" Property="Background" Value="#1E293B80"/>
                                        <Setter TargetName="SenderLabel" Property="Text" Value="USER"/>
                                        <Setter TargetName="SenderLabel" Property="Foreground" Value="#F97316"/>
                                        <Setter TargetName="Bubble" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#F97316" BlurRadius="16" ShadowDepth="0" Opacity="0.35"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Margin="0,0,0,18"
                            Padding="16,12"
                            HorizontalAlignment="Left"
                            MaxWidth="560"
                            Background="{StaticResource AtlasGlassBrush}"
                            BorderBrush="{StaticResource AtlasCyanGlowBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTyping}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <controls:TypingIndicatorControl/>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="1" Grid.Column="0"
                    Margin="16,10,16,14"
                    Background="#0f1419"
                    BorderBrush="#22d3ee30"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="4"
                    HorizontalAlignment="Center"
                    MinWidth="520"
                    MaxWidth="980">
                <Border.Width>
                    <Binding ElementName="RootGrid" Path="ActualWidth" Converter="{StaticResource WidthMultiplier}" ConverterParameter="0.58"/>
                </Border.Width>
                <Grid HorizontalAlignment="Stretch" MinHeight="36">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#0b0f14"
                            BorderBrush="#1f293780"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10"
                            Margin="0,0,0,10">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasAttachments}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <ItemsControl ItemsSource="{Binding Attachments}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0f1419"
                                            BorderBrush="#1f293780"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="10,6"
                                            Margin="0,0,8,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Converter={StaticResource FileNameConverter}}"
                                                       FontFamily="{StaticResource AtlasFontMono}"
                                                       FontSize="11"
                                                       Foreground="#94a3b8"
                                                       MaxWidth="280"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,0,8,0"/>
                                            <Button Style="{StaticResource GhostBtn}"
                                                    Width="22"
                                                    Height="22"
                                                    Tag="{Binding}"
                                                    Click="RemoveAttachment_Click">
                                                <TextBlock Text="✕" FontSize="12"/>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource AtlasIconButton}"
                                    Width="26"
                                    Height="26"
                                    ToolTip="Attachment"
                                    Click="AttachButton_Click">
                                <TextBlock Text="📎" FontSize="16"/>
                            </Button>
                            <Button Style="{StaticResource AtlasIconButton}"
                                    Width="26"
                                    Height="26"
                                    ToolTip="Test voice"
                                    Command="{Binding TestVoiceCommand}">
                                <TextBlock Text="🔊" FontSize="16"/>
                            </Button>
                            <Button Style="{StaticResource AtlasIconButton}"
                                    Width="26"
                                    Height="26"
                                    ToolTip="Settings"
                                    Click="SettingsButton_Click">
                                <TextBlock Text="⚙" FontSize="16"/>
                            </Button>
                            <Button Style="{StaticResource AtlasIconButton}"
                                    Width="26"
                                    Height="26"
                                    ToolTip="AI mode"
                                    Margin="8,0,0,0"
                                    Click="AiModeButton_Click">
                                <TextBlock Text="AI" FontSize="11" FontWeight="SemiBold"/>
                            </Button>
                            <Button Style="{StaticResource AtlasIconButton}"
                                    Width="26"
                                    Height="26"
                                    ToolTip="Voice"
                                    Margin="8,0,0,0"
                                    Click="VoiceModeButton_Click">
                                <TextBlock Text="VO" FontSize="10" FontWeight="SemiBold"/>
                            </Button>
                        </StackPanel>

                        <Grid Grid.Column="1" Margin="6,0">
                            <TextBox x:Name="InputBox"
                                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#0a0a0a"
                                     BorderThickness="0"
                                     Foreground="#e2e8f0"
                                     FontFamily="{StaticResource AtlasFontMono}"
                                     FontSize="11"
                                     VerticalContentAlignment="Center"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     PreviewKeyDown="InputBox_PreviewKeyDown"
                                     MinLines="1"
                                     MaxLines="2"
                                     Padding="5,5"
                                     VerticalScrollBarVisibility="Hidden"
                                     MaxLength="500"/>

                            <TextBlock Text="Enter command..."
                                       Foreground="#64748b"
                                       FontFamily="{StaticResource AtlasFontMono}"
                                       FontSize="12"
                                       IsHitTestVisible="False"
                                       Margin="2,0,0,0"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding InputText}" Value=""/>
                                                    <Condition Binding="{Binding ElementName=InputBox, Path=IsKeyboardFocusWithin}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <Button Grid.Column="2"
                                Width="26"
                                Height="26"
                                Command="{Binding ToggleRecordingCommand}"
                                Margin="0,0,6,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <TextBlock x:Name="icon" Text="🎙" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource AtlasTextSecondaryBrush}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="icon" Property="Foreground" Value="{StaticResource AtlasTextPrimaryBrush}"/>
                                                        <Setter TargetName="bd" Property="Background" Value="#10FFFFFF"/>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                                        <Setter TargetName="icon" Property="Foreground" Value="#FF0000"/>
                                                        <Setter TargetName="bd" Property="Background" Value="#20FF0000"/>
                                                        <Setter TargetName="bd" Property="BorderBrush" Value="#FF0000"/>
                                                        <Setter TargetName="bd" Property="BorderThickness" Value="1"/>
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Grid.Column="3"
                                    Width="26"
                                    Height="26"
                                    Click="SendButton_Click"
                                    Background="#22d3ee20"
                                    BorderThickness="0"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <TextBlock Text="&#xE724;"
                                                       FontFamily="{StaticResource AtlasFontIcon}"
                                                       FontSize="15"
                                                       Foreground="#22d3ee"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                    </Grid>

                    <TextBlock Grid.Row="2"
                               Text="{Binding VoiceStatusText}"
                               Foreground="{StaticResource AtlasTextMutedBrush}"
                               FontFamily="{StaticResource AtlasFontMono}"
                               FontSize="11"
                               Margin="10,0,0,0"
                               TextTrimming="CharacterEllipsis"
                               MaxHeight="16"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Orb overlay disabled in ChatView; ChatWindow hosts the production orb -->
        <Grid x:Name="OrbOverlay"
              HorizontalAlignment="Right"
              VerticalAlignment="Center"
              Panel.ZIndex="5000"
              IsHitTestVisible="False"
              Margin="0,0,48,0"
              Visibility="Collapsed"/>
    </Grid>
</UserControl>
