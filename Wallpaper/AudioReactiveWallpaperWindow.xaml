<Window x:Class="AtlasAI.Wallpaper.AudioReactiveWallpaperWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="False"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="Manual">
    <Grid x:Name="Root">
        <Rectangle x:Name="Backdrop"/>
        <Canvas x:Name="ParticleHost" IsHitTestVisible="False"/>
    </Grid>
</Window>
