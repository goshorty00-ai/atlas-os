<UserControl x:Class="AtlasAI.Agent.UI.AgentCommandPalette"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    
    <UserControl.Resources>
        <FontFamily x:Key="MainFont">Segoe UI Variable, Segoe UI</FontFamily>
        <FontFamily x:Key="MonoFont">Cascadia Code, Consolas</FontFamily>
    </UserControl.Resources>
    
    <Border Background="#0c0c12" CornerRadius="8" BorderBrush="#22d3ee40" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#22d3ee" BlurRadius="20" ShadowDepth="0" Opacity="0.2"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Search Input -->
            <Border Grid.Row="0" Background="#08080c" Padding="12" CornerRadius="8,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Text="⚡" FontSize="16" Foreground="#22d3ee" 
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    
                    <TextBox x:Name="SearchBox" Grid.Column="1" 
                             Background="Transparent" Foreground="#f1f5f9"
                             BorderThickness="0" FontSize="14" 
                             CaretBrush="#22d3ee" VerticalAlignment="Center"
                             TextChanged="SearchBox_TextChanged"
                             KeyDown="SearchBox_KeyDown">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Grid>
                                                <ScrollViewer x:Name="PART_ContentHost"/>
                                                <TextBlock x:Name="Placeholder" Text="Type a command... (system, network, apps, diagnose)"
                                                           Foreground="#64748b" IsHitTestVisible="False"
                                                           Visibility="Collapsed" VerticalAlignment="Center"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Grid>
            </Border>
            
            <!-- Agent Mode Indicator -->
            <Border Grid.Row="1" Background="#12121a" Padding="8,6" 
                    BorderBrush="#22d3ee20" BorderThickness="0,1,0,1">
                <StackPanel Orientation="Horizontal">
                    <Border x:Name="AgentModeBadge" Background="#22d3ee20" CornerRadius="4" Padding="8,3">
                        <TextBlock x:Name="AgentModeText" Text="AGENT MODE" FontSize="9" 
                                   Foreground="#22d3ee" FontWeight="Bold"
                                   FontFamily="{StaticResource MonoFont}"/>
                    </Border>
                    <TextBlock x:Name="HintText" Text="Press Enter to execute" FontSize="10"
                               Foreground="#64748b" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <!-- Suggestions List -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" MaxHeight="300">
                <ItemsControl x:Name="SuggestionsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="ItemBorder" Background="Transparent" Padding="12,10"
                                    Cursor="Hand" MouseLeftButtonDown="Suggestion_Click"
                                    MouseEnter="Suggestion_MouseEnter" MouseLeave="Suggestion_MouseLeave">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Text="{Binding Icon}" FontSize="16" 
                                               VerticalAlignment="Center"/>
                                    
                                    <StackPanel Grid.Column="1" Margin="8,0">
                                        <TextBlock Text="{Binding Title}" FontSize="13" 
                                                   Foreground="#f1f5f9" FontWeight="Medium"/>
                                        <TextBlock Text="{Binding Description}" FontSize="10"
                                                   Foreground="#64748b" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    
                                    <Border Grid.Column="2" Background="#22d3ee15" CornerRadius="4" 
                                            Padding="6,2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding KeywordsPreview}" FontSize="9"
                                                   Foreground="#22d3ee" FontFamily="{StaticResource MonoFont}"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="#22d3ee20"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
