<UserControl x:Class="AtlasAI.Agent.UI.AgentResultsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    
    <UserControl.Resources>
        <FontFamily x:Key="MainFont">Segoe UI Variable, Segoe UI</FontFamily>
        <FontFamily x:Key="MonoFont">Cascadia Code, Consolas</FontFamily>
        
        <SolidColorBrush x:Key="BgDeep" Color="#050508"/>
        <SolidColorBrush x:Key="BgDark" Color="#08080c"/>
        <SolidColorBrush x:Key="Surface" Color="#0c0c12"/>
        <SolidColorBrush x:Key="SurfaceHover" Color="#12121a"/>
        <SolidColorBrush x:Key="Cyan" Color="#22d3ee"/>
        <SolidColorBrush x:Key="Violet" Color="#8b5cf6"/>
        <SolidColorBrush x:Key="Green" Color="#22c55e"/>
        <SolidColorBrush x:Key="Yellow" Color="#f59e0b"/>
        <SolidColorBrush x:Key="Red" Color="#ef4444"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#f1f5f9"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#94a3b8"/>
        <SolidColorBrush x:Key="TextMuted" Color="#64748b"/>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource BgDark}" Padding="12,10"
                BorderBrush="#22d3ee30" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚡" FontSize="14" Foreground="{StaticResource Cyan}" 
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="AGENT RESULTS" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource Cyan}" VerticalAlignment="Center"
                               FontFamily="{StaticResource MonoFont}"/>
                </StackPanel>
                <Button x:Name="ClearBtn" Content="Clear" HorizontalAlignment="Right"
                        Click="Clear_Click" Background="Transparent" Foreground="{StaticResource TextMuted}"
                        BorderThickness="0" Padding="8,4" FontSize="10" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" 
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#16161f"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
        
        <!-- Results Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
            <StackPanel x:Name="ResultsContainer" Margin="4"/>
        </ScrollViewer>
        
        <!-- Activity Feed -->
        <Border Grid.Row="2" Background="{StaticResource BgDark}" Padding="8"
                BorderBrush="#22d3ee20" BorderThickness="0,1,0,0" MaxHeight="120">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Text="ACTIVITY" FontSize="9" Foreground="{StaticResource TextMuted}"
                           FontFamily="{StaticResource MonoFont}" Margin="4,0,0,6"/>
                
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="80">
                    <ItemsControl x:Name="ActivityList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="4,2" Margin="0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding TimeStr}" FontSize="9" 
                                                   Foreground="#64748b" FontFamily="Cascadia Code"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Title}" FontSize="9"
                                                   Foreground="#94a3b8" Margin="8,0"/>
                                        <TextBlock Grid.Column="2" Text="{Binding DurationStr}" FontSize="9"
                                                   Foreground="#22d3ee" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
