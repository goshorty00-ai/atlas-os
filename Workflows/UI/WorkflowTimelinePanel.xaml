<UserControl x:Class="AtlasAI.Workflows.UI.WorkflowTimelinePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AtlasAI.Workflows.UI"
             Background="Transparent">

    <!-- Workflow Timeline Panel - Displays workflow progress as vertical timeline
         User controls execution via "Run Next Step" button
         SAFETY: Display only, no system operations -->

    <UserControl.Resources>
        <!-- Null to Collapsed converter -->
        <local:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>
        
        <!-- Status colors -->
        <SolidColorBrush x:Key="PendingBrush" Color="#64748b"/>
        <SolidColorBrush x:Key="RunningBrush" Color="#f59e0b"/>
        <SolidColorBrush x:Key="CompleteBrush" Color="#22c55e"/>
        <SolidColorBrush x:Key="FailedBrush" Color="#ef4444"/>
        <SolidColorBrush x:Key="SkippedBrush" Color="#94a3b8"/>
        <SolidColorBrush x:Key="CyanAccent" Color="#22d3ee"/>
        
        <!-- Step item template -->
        <DataTemplate x:Key="StepTemplate">
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Timeline connector and status indicator -->
                <Grid Grid.Column="0">
                    <!-- Vertical line (connector) -->
                    <Border Width="2" 
                            Background="#2a2a2a"
                            HorizontalAlignment="Center"
                            Margin="0,-4,0,-4"/>
                    
                    <!-- Status circle -->
                    <Border x:Name="StatusCircle"
                            Width="20" Height="20"
                            CornerRadius="10"
                            Background="#1a1a1a"
                            BorderThickness="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding StatusIcon}"
                                   FontSize="10"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="White"/>
                    </Border>
                </Grid>
                
                <!-- Step content -->
                <Border Grid.Column="1"
                        Background="#1a1a1a"
                        CornerRadius="6"
                        Padding="10,8"
                        Margin="8,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Step header -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock Text="{Binding Icon}"
                                       FontSize="14"
                                       Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding Description}"
                                       FontSize="12"
                                       FontWeight="Medium"
                                       Foreground="#e2e8f0"/>
                            <TextBlock Text="{Binding EstimatedDuration}"
                                       FontSize="10"
                                       Foreground="#64748b"
                                       Margin="8,2,0,0"/>
                        </StackPanel>
                        
                        <!-- Type badge -->
                        <Border Grid.Row="1"
                                Background="#2a2a2a"
                                CornerRadius="3"
                                Padding="4,2"
                                HorizontalAlignment="Left"
                                Margin="0,4,0,0">
                            <TextBlock Text="{Binding TypeIcon}"
                                       FontSize="9"
                                       Foreground="#94a3b8"/>
                        </Border>
                        
                        <!-- Result summary (if complete) -->
                        <TextBlock Grid.Row="2"
                                   Text="{Binding ResultSummary}"
                                   FontSize="11"
                                   Foreground="#94a3b8"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"
                                   Visibility="{Binding ResultSummary, Converter={StaticResource NullToCollapsedConverter}}"/>
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Border Background="#0d0d0d"
            CornerRadius="8"
            Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="WorkflowIcon"
                           Grid.Column="0"
                           Text="🔗"
                           FontSize="18"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="WorkflowTitle"
                               Text="No Workflow Active"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#e2e8f0"/>
                    <TextBlock x:Name="WorkflowDescription"
                               Text="Select a workflow to begin"
                               FontSize="11"
                               Foreground="#64748b"/>
                </StackPanel>
                
                <!-- Cancel button -->
                <Button x:Name="CancelButton"
                        Grid.Column="2"
                        Content="✕"
                        Width="24" Height="24"
                        Background="Transparent"
                        Foreground="#64748b"
                        BorderThickness="0"
                        FontSize="12"
                        Cursor="Hand"
                        Click="CancelButton_Click"
                        Visibility="Collapsed"
                        ToolTip="Cancel workflow"/>
            </Grid>
            
            <!-- Timeline (steps list) -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="StepsItemsControl"
                              ItemTemplate="{StaticResource StepTemplate}"/>
            </ScrollViewer>
            
            <!-- Progress bar -->
            <Grid Grid.Row="2" Margin="0,12,0,8">
                <Border Background="#2a2a2a"
                        CornerRadius="3"
                        Height="6"/>
                <Border x:Name="ProgressBar"
                        Background="{StaticResource CyanAccent}"
                        CornerRadius="3"
                        Height="6"
                        HorizontalAlignment="Left"
                        Width="0"/>
            </Grid>
            
            <!-- Action buttons -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Status text -->
                <TextBlock x:Name="StatusText"
                           Grid.Column="0"
                           Text="Ready"
                           FontSize="11"
                           Foreground="#64748b"
                           VerticalAlignment="Center"/>
                
                <!-- Run Next Step button -->
                <Button x:Name="RunNextButton"
                        Grid.Column="1"
                        Content="▶ Run Next Step"
                        Background="#22d3ee"
                        Foreground="#0d0d0d"
                        FontWeight="SemiBold"
                        FontSize="12"
                        Padding="12,6"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="RunNextButton_Click"
                        IsEnabled="False">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#38bdf8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
            
            <!-- Empty state overlay -->
            <Border x:Name="EmptyState"
                    Grid.Row="1"
                    Background="#0d0d0d"
                    Visibility="Visible">
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <TextBlock Text="🔗"
                               FontSize="32"
                               HorizontalAlignment="Center"
                               Opacity="0.3"/>
                    <TextBlock Text="No workflow active"
                               FontSize="12"
                               Foreground="#64748b"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                    <TextBlock Text="Search for a workflow in the command palette"
                               FontSize="10"
                               Foreground="#4a5568"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
