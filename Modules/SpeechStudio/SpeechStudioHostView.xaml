<UserControl x:Class="AtlasAI.Modules.SpeechStudio.SpeechStudioHostView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="Transparent">
    <Grid Background="Transparent">
        <wv2:WebView2 x:Name="SpeechStudioWebView" Margin="0" />

        <Border x:Name="MissingUiOverlay"
                Background="#CC0A0E14"
                Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="760">
                <TextBlock Text="Speech Studio UI not built"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AtlasCyanBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Build the Figma Smart Home app in Figma/AI_Smart_Home and restart Atlas."
                           Margin="0,10,0,0"
                           FontSize="14"
                           Foreground="{DynamicResource AtlasTextSecondaryBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>