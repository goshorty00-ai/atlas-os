<UserControl x:Class="AtlasAI.Modules.AiChef.AiChefHostView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#09090B">
    <UserControl.Resources>
        <!-- Dark TextBox -->
        <Style x:Key="DarkTB" TargetType="TextBox">
            <Setter Property="Background" Value="#18181B"/>
            <Setter Property="Foreground" Value="#F4F4F5"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="#FBBF24"/>
            <Setter Property="SelectionBrush" Value="#B45309"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Filter chip ToggleButton -->
        <Style x:Key="Chip" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,0,5,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#27272A"/>
            <Setter Property="Foreground" Value="#A1A1AA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <TextBlock x:Name="Txt" Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#451A03"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FBBF24"/>
                                <Setter Property="Foreground" Value="#FBBF24"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3F3F46"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active nav tab (amber gradient) -->
        <Style x:Key="NavActive" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#09090B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,9"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#F59E0B" Offset="0"/>
                                    <GradientStop Color="#D97706" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Inactive nav tab -->
        <Style x:Key="NavInactive" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#A1A1AA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="Padding" Value="20,9"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#27272A"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3F3F46"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Quick action button -->
        <Style x:Key="QuickActionBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#18181B"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#27272A"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#92400E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Generate / Ask Chef button -->
        <Style x:Key="AmberBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FDE68A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#B45309"/>
            <Setter Property="Padding" Value="0,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#292100"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3B2F00"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox -->
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#18181B"/>
            <Setter Property="Foreground" Value="#F4F4F5"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Nav tabs row -->
            <RowDefinition Height="Auto"/>
            <!-- Content -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" BorderBrush="#27272A" BorderThickness="0,0,0,1">
            <Border.Background>
                <SolidColorBrush Color="#111113"/>
            </Border.Background>
            <Grid Margin="28,18,28,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock FontSize="28" FontWeight="Bold">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FBBF24" Offset="0"/>
                                <GradientStop Color="#D97706" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                        AI Chef Studio
                    </TextBlock>
                    <TextBlock Text="Create recipes, plan meals, cook step-by-step, and shop smarter"
                               Foreground="#71717A" FontSize="12" Margin="0,3,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Online -->
                    <Border Background="#14532D" BorderBrush="#166534" BorderThickness="1" CornerRadius="20" Padding="12,5" Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="#4ADE80" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="AI Chef Online" Foreground="#4ADE80" FontSize="11"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#1C1917" BorderBrush="#44403C" BorderThickness="1" CornerRadius="20" Padding="12,5" Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="#D97706" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Pantry Connected" Foreground="#A8A29E" FontSize="11"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#1C1917" BorderBrush="#44403C" BorderThickness="1" CornerRadius="20" Padding="12,5" Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="#D97706" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Timer Ready" Foreground="#A8A29E" FontSize="11"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#1C1917" BorderBrush="#44403C" BorderThickness="1" CornerRadius="20" Padding="12,5" Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="#D97706" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Voice Guide Ready" Foreground="#A8A29E" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ NAV TABS ═══ -->
        <Border Grid.Row="1" BorderBrush="#27272A" BorderThickness="0,0,0,1">
            <Border.Background><SolidColorBrush Color="#0D0D0F"/></Border.Background>
            <StackPanel Orientation="Horizontal" Margin="24,10,24,10">
                <Button x:Name="TabRecipeBtn"    Tag="recipe"    Content="New Recipe"    Click="Tab_Click" Margin="0,0,8,0"/>
                <Button x:Name="TabCookingBtn"   Tag="cooking"   Content="Cooking Mode"  Click="Tab_Click" Margin="0,0,8,0" IsEnabled="False"/>
                <Button x:Name="TabMealPlanBtn"  Tag="meal-plan" Content="Meal Plan"     Click="Tab_Click" Margin="0,0,8,0"/>
                <Button x:Name="TabShoppingBtn"  Tag="shopping"  Content="Shopping List" Click="Tab_Click" Margin="0,0,8,0"/>
                <Button x:Name="TabSavedBtn"     Tag="saved"     Content="Saved Recipes" Click="Tab_Click" Margin="0,0,8,0"/>
            </StackPanel>
        </Border>

        <!-- ═══ CONTENT AREA ═══ -->
        <Grid Grid.Row="2">

            <!-- ── RECIPE VIEW ── -->
            <Grid x:Name="RecipeView">
                <Grid.ColumnDefinitions>
                    <!-- Generator panel -->
                    <ColumnDefinition Width="320"/>
                    <!-- Main workspace -->
                    <ColumnDefinition Width="*"/>
                    <!-- AI Assistant panel -->
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Generator -->
                <Border Grid.Column="0" BorderBrush="#27272A" BorderThickness="0,0,1,0">
                    <Border.Background><SolidColorBrush Color="#0D0D0F"/></Border.Background>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="20,20,20,24">
                            <TextBlock Text="What do you want to cook?" Foreground="#F4F4F5"
                                       FontSize="17" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="Describe your dish or let AI surprise you"
                                       Foreground="#71717A" FontSize="12" Margin="0,0,0,12"/>

                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="PromptBox" Grid.Column="0" Style="{StaticResource DarkTB}"
                                         Height="90" AcceptsReturn="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"/>
                                <Button x:Name="PromptMicBtn" Grid.Column="1"
                                        Content="🎤"
                                        Width="32" Height="32"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Top"
                                        ToolTip="Recipe mic"
                                        Background="#18181B"
                                        Foreground="#FDE68A"
                                        BorderBrush="#3F3F46"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        Click="PromptMicBtn_Click"/>
                            </Grid>
                            <TextBlock x:Name="PromptMicNote"
                                       Text=""
                                       Visibility="Collapsed"
                                       Foreground="#FDE68A"
                                       FontSize="10"
                                       Margin="0,0,0,16"/>

                            <TextBlock Text="Cuisine" Foreground="#D4D4D8" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <WrapPanel x:Name="CuisinePanel" Margin="0,0,0,16"/>

                            <TextBlock Text="Meal Type" Foreground="#D4D4D8" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <WrapPanel x:Name="MealTypePanel" Margin="0,0,0,16"/>

                            <TextBlock Text="Dietary Preferences" Foreground="#D4D4D8" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <WrapPanel x:Name="DietPanel" Margin="0,0,0,16"/>

                            <TextBlock Text="Skill Level" Foreground="#D4D4D8" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <WrapPanel x:Name="SkillPanel" Margin="0,0,0,16"/>

                            <TextBlock Text="Time Available" Foreground="#D4D4D8" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <WrapPanel x:Name="TimePanel" Margin="0,0,0,16"/>

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Servings" Foreground="#D4D4D8" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="ServingsCombo" Style="{StaticResource DarkCombo}">
                                        <ComboBoxItem Content="1"/>
                                        <ComboBoxItem Content="2" IsSelected="True"/>
                                        <ComboBoxItem Content="4"/>
                                        <ComboBoxItem Content="6"/>
                                        <ComboBoxItem Content="8"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Budget" Foreground="#D4D4D8" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="BudgetCombo" Style="{StaticResource DarkCombo}">
                                        <ComboBoxItem Content="Budget"/>
                                        <ComboBoxItem Content="Medium" IsSelected="True"/>
                                        <ComboBoxItem Content="Premium"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <Button x:Name="GenerateBtn" Style="{StaticResource AmberBtn}"
                                    Content="✦  Generate Recipe" Click="GenerateBtn_Click"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- CENTRE: Recipe workspace -->
                <Grid Grid.Column="1">
                    <!-- Empty state -->
                    <Grid x:Name="EmptyState" VerticalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center" MaxWidth="520">
                            <TextBlock Text="👨‍🍳" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                            <TextBlock Text="Ready to Create Something Delicious?" Foreground="#E4E4E7"
                                       FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                            <TextBlock Foreground="#71717A" FontSize="13" HorizontalAlignment="Center"
                                       TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,24"
                                       Text="Use the panel on the left to describe what you want to cook. Choose your cuisine, dietary preferences, and cooking time, then let the AI Chef create the perfect recipe for you."/>
                            <!-- Suggestion cards grid -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border x:Name="Sugg1" Grid.Column="0" Grid.Row="0" Background="#18181B" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="10" Padding="16,14" Cursor="Hand">
                                    <TextBlock Text="I want to make pasta for dinner tonight" Foreground="#D4D4D8" FontSize="13" TextWrapping="Wrap"/>
                                </Border>
                                <Border x:Name="Sugg2" Grid.Column="2" Grid.Row="0" Background="#18181B" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="10" Padding="16,14" Cursor="Hand">
                                    <TextBlock Text="Quick healthy breakfast under 10 minutes" Foreground="#D4D4D8" FontSize="13" TextWrapping="Wrap"/>
                                </Border>
                                <Border x:Name="Sugg3" Grid.Column="0" Grid.Row="2" Background="#18181B" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="10" Padding="16,14" Cursor="Hand">
                                    <TextBlock Text="High-protein meal prep for the week" Foreground="#D4D4D8" FontSize="13" TextWrapping="Wrap"/>
                                </Border>
                                <Border x:Name="Sugg4" Grid.Column="2" Grid.Row="2" Background="#18181B" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="10" Padding="16,14" Cursor="Hand">
                                    <TextBlock Text="Something impressive for a date night" Foreground="#D4D4D8" FontSize="13" TextWrapping="Wrap"/>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- Loading state -->
                    <StackPanel x:Name="LoadingState" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Width="64" Height="64" CornerRadius="32"
                                BorderBrush="#FBBF24" BorderThickness="4" Margin="0,0,0,20" HorizontalAlignment="Center">
                            <Border.RenderTransform><RotateTransform/></Border.RenderTransform>
                        </Border>
                        <TextBlock Text="Crafting Your Recipe" Foreground="#E4E4E7" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="The AI Chef is working on something delicious..." Foreground="#71717A" FontSize="13" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- Recipe card -->
                    <ScrollViewer x:Name="RecipeCardScroll" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  Padding="28,24">
                        <StackPanel x:Name="RecipeCardPanel"/>
                    </ScrollViewer>
                </Grid>

                <!-- RIGHT: AI Chef Assistant -->
                <Border Grid.Column="2" BorderBrush="#27272A" BorderThickness="1,0,0,0">
                    <Border.Background><SolidColorBrush Color="#0D0D0F"/></Border.Background>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="20,20,20,24">
                            <TextBlock Text="AI Chef Assistant" Foreground="#F4F4F5"
                                       FontSize="17" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="Ask the chef to modify, improve, or answer questions about your recipe"
                                       Foreground="#71717A" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,20"/>

                            <!-- Ask the chef input -->
                            <TextBlock Text="Ask the chef..." Foreground="#D4D4D8" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="AiPromptBox" Grid.Column="0" Style="{StaticResource DarkTB}"
                                         Height="80" AcceptsReturn="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" Margin="0,0,0,8"/>
                                <Button x:Name="AiPromptMicBtn" Grid.Column="1"
                                        Content="🎤"
                                        Width="32" Height="32"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Top"
                                        ToolTip="Chef chat mic"
                                        Background="#18181B"
                                        Foreground="#FDE68A"
                                        BorderBrush="#3F3F46"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        Click="AiPromptMicBtn_Click"/>
                            </Grid>
                            <TextBlock x:Name="AiPromptMicNote"
                                       Text=""
                                       Visibility="Collapsed"
                                       Foreground="#FDE68A"
                                       FontSize="10"
                                       Margin="0,0,0,8"/>
                            <Button x:Name="AskChefBtn" Content="Ask Chef" Style="{StaticResource AmberBtn}"
                                    Click="AskChef_Click" IsEnabled="False"/>

                            <!-- AI response area -->
                            <Border x:Name="AiResponseBorder" Visibility="Collapsed"
                                    Background="#0F2017" BorderBrush="#1A4A2A" BorderThickness="1"
                                    CornerRadius="8" Padding="14,12" Margin="0,14,0,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="🤖 " FontSize="16"/>
                                        <TextBlock x:Name="AiResponseText" Foreground="#D4D4D8"
                                                   FontSize="12" TextWrapping="Wrap" VerticalAlignment="Top"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Quick Actions -->
                            <TextBlock Text="Quick Actions" Foreground="#D4D4D8" FontSize="13" FontWeight="SemiBold" Margin="0,20,0,12"/>
                            <StackPanel x:Name="QuickActionsPanel"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ── COOKING MODE VIEW ── -->
            <Grid x:Name="CookingView" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="40">
                    <StackPanel x:Name="CookingPanel"/>
                </ScrollViewer>
            </Grid>

            <!-- ── MEAL PLAN VIEW ── -->
            <Grid x:Name="MealPlanView" Visibility="Collapsed" Background="#09090B">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="400">
                    <TextBlock Text="📅" FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="Meal Planner" Foreground="#F4F4F5" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Generate a recipe first, then add it to your weekly meal plan."
                               Foreground="#71717A" FontSize="13" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,20"/>
                    <Button Content="Go back to Recipe Generator" Click="BackToRecipe_Click"
                            HorizontalAlignment="Center" Style="{StaticResource NavInactive}"
                            Foreground="#F4F4F5"/>
                </StackPanel>
            </Grid>

            <!-- ── SHOPPING LIST VIEW ── -->
            <Grid x:Name="ShoppingView" Visibility="Collapsed" Background="#09090B">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#111113" BorderBrush="#27272A" BorderThickness="0,0,0,1" Padding="28,16">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Shopping List" Foreground="#F4F4F5" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button x:Name="ClearShoppingBtn" Content="Clear All" Click="ClearShopping_Click"
                                Margin="16,0,0,0" Style="{StaticResource NavInactive}"
                                Foreground="#FCA5A5" BorderBrush="#7F1D1D" Padding="12,6" FontSize="12"/>
                    </StackPanel>
                </Border>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,16">
                    <StackPanel x:Name="ShoppingListPanel">
                        <TextBlock Text="No items yet. Generate a recipe and it will be added here."
                                   Foreground="#71717A" FontSize="13" Margin="0,20,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ── SAVED RECIPES VIEW ── -->
            <Grid x:Name="SavedView" Visibility="Collapsed" Background="#09090B">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#111113" BorderBrush="#27272A" BorderThickness="0,0,0,1" Padding="28,16">
                    <TextBlock Text="Saved Recipes" Foreground="#F4F4F5" FontSize="18" FontWeight="Bold"/>
                </Border>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <WrapPanel x:Name="SavedRecipesPanel" Margin="20" Orientation="Horizontal"/>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
