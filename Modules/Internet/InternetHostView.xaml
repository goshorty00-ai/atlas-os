<UserControl x:Class="AtlasAI.Modules.Internet.InternetHostView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="#070C16">
    <UserControl.Resources>
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#12263A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#18344D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopChipBtn" TargetType="Button" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Width" Value="Auto"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Background" Value="#0E1A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#1B3A52"/>
            <Setter Property="Foreground" Value="#88C6DF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="13"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#12304A"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00D1FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SideBtn" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#10243A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#18344D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AiCard" TargetType="Button">
            <Setter Property="Background" Value="#0E1827"/>
            <Setter Property="BorderBrush" Value="#1C3148"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#A2BDCF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="9,7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#13324A"/>
                                <Setter Property="BorderBrush" Value="#00D1FF"/>
                                <Setter Property="Foreground" Value="#E6F7FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AddressBarPopupActionButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#DDECF8"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="33"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A3348"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22435F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="54"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="AiPanelColumn" Width="0"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#060B14" BorderBrush="#19324A" BorderThickness="0,0,1,0">
            <DockPanel Margin="6,8,6,8">
                <StackPanel DockPanel.Dock="Top" HorizontalAlignment="Center">
                    <Button Style="{StaticResource SideBtn}" Click="NewTabButton_Click" ToolTip="New Tab" Margin="0,0,0,4">
                        <TextBlock Text="&#x1F310;" FontSize="16" VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="TabsBtn" Style="{StaticResource SideBtn}" Click="ToggleTabList_Click" ToolTip="Tabs" Margin="0,0,0,4">
                        <TextBlock Text="&#9783;" Foreground="#97A7BA" FontSize="16"/>
                    </Button>
                    <Button x:Name="BookmarksBtn" Style="{StaticResource SideBtn}" Click="BookmarksBtn_Click" ToolTip="Bookmarks" Margin="0,0,0,4">
                        <TextBlock Text="&#9734;" Foreground="#97A7BA" FontSize="15"/>
                    </Button>
                    <Button x:Name="HistoryBtn" Style="{StaticResource SideBtn}" Click="HistoryBtn_Click" ToolTip="History" Margin="0,0,0,4">
                        <TextBlock Text="&#128337;" Foreground="#97A7BA" FontSize="15"/>
                    </Button>
                    <Button Style="{StaticResource SideBtn}" Click="DownloadsBtn_Click" ToolTip="Downloads" Margin="0,0,0,4">
                        <TextBlock Text="&#8659;" Foreground="#97A7BA" FontSize="17"/>
                    </Button>
                    <Button Style="{StaticResource SideBtn}" Click="OpenRecentSessions_Click" ToolTip="Workspaces" Margin="0,0,0,4">
                        <TextBlock Text="&#128190;" Foreground="#97A7BA" FontSize="14"/>
                    </Button>
                    <Button x:Name="PasswordsBtn" Style="{StaticResource SideBtn}" Click="PasswordsBtn_Click" ToolTip="Password Manager" Margin="0,0,0,4">
                        <TextBlock Text="&#128273;" Foreground="#97A7BA" FontSize="15"/>
                    </Button>
                    <Button Style="{StaticResource SideBtn}" Click="ResearchMode_Click" ToolTip="Research Mode" Margin="0,0,0,4">
                        <TextBlock Text="&#128270;" Foreground="#00D1FF" FontSize="15"/>
                    </Button>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" HorizontalAlignment="Center">
                    <Button Style="{StaticResource SideBtn}" Click="AiToggleBtn_Click" ToolTip="AI Workspace">
                        <TextBlock Text="&#10024;" Foreground="#00D1FF" FontSize="14"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#0A1320" BorderBrush="#1C3148" BorderThickness="0,0,0,1">
                <Grid Margin="8,0,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" Margin="0,0,8,0" VerticalAlignment="Center">
                            <StackPanel x:Name="TabsPanel" Orientation="Horizontal" VerticalAlignment="Center"/>
                        </ScrollViewer>

                        <Button x:Name="NewTabBtn" Grid.Column="1" Width="26" Height="26" Style="{StaticResource NavBtn}" Click="NewTabButton_Click" ToolTip="New Tab">
                            <TextBlock Text="+" Foreground="#97A7BA" FontSize="16"/>
                        </Button>
                    </Grid>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource TopChipBtn}" Click="AiSave_Click" ToolTip="Save workspace">
                            <TextBlock Text="Save Workspace" FontSize="11" Foreground="#91D9F0"/>
                        </Button>

                        <Button x:Name="ProfileBtn" Style="{StaticResource TopChipBtn}" Padding="8,0" Margin="0,0,6,0" Click="ProfileBtn_Click" ToolTip="Open profiles overlay">
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="ProfileAvatar" Width="18" Height="18" CornerRadius="9" Background="#1C6EBF" Margin="0,0,5,0">
                                    <TextBlock x:Name="ProfileInitial" Text="P" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="ProfileName" Text="Default" Foreground="#C8D8EA" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text=" Open" Foreground="#97A7BA" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="AiToggleBtn" Style="{StaticResource TopChipBtn}" Margin="0" Click="AiToggleBtn_Click" ToolTip="Toggle AI workspace">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#10024;" FontSize="11" Margin="0,0,4,0"/>
                                <TextBlock x:Name="AiToggleText" Text="AI" Foreground="#00D1FF" FontSize="11"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Background="#0D1726" BorderBrush="#1C3148" BorderThickness="0,0,0,1">
                <Grid Margin="6,4,6,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BackButton" Style="{StaticResource NavBtn}" Click="BackButton_Click" ToolTip="Back" Margin="1,0">
                            <TextBlock Text="&#8592;" Foreground="#97A7BA" FontSize="14"/>
                        </Button>
                        <Button x:Name="ForwardButton" Style="{StaticResource NavBtn}" Click="ForwardButton_Click" ToolTip="Forward" Margin="1,0">
                            <TextBlock Text="&#8594;" Foreground="#97A7BA" FontSize="14"/>
                        </Button>
                        <Button x:Name="RefreshButton" Style="{StaticResource NavBtn}" Click="RefreshButton_Click" ToolTip="Refresh" Margin="1,0">
                            <TextBlock x:Name="RefreshIcon" Text="&#8635;" Foreground="#97A7BA" FontSize="15"/>
                        </Button>
                    </StackPanel>

                    <Border Grid.Row="0" Grid.Column="1" Background="#0A1525" CornerRadius="8" BorderBrush="#1C3A54" BorderThickness="1" Height="30" Margin="6,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="SecurityIcon" Grid.Column="0" Text="&#128274;" FontSize="10" VerticalAlignment="Center" Margin="8,0,4,0" Foreground="#4CAF50"/>
                            <TextBox x:Name="AddressBar" Grid.Column="1" Background="Transparent" Foreground="#E6EEF7" BorderThickness="0" VerticalAlignment="Center" Padding="0,0,8,0" FontSize="12" CaretBrush="#00D1FF" SelectionBrush="#1C4A6E" KeyDown="AddressBar_KeyDown" GotFocus="AddressBar_GotFocus" PreviewMouseRightButtonUp="AddressBar_PreviewMouseRightButtonUp" ContextMenu="{x:Null}" Text="https://www.google.com"/>
                            <Button x:Name="AddressBarMicBtn" Grid.Column="2" Style="{StaticResource NavBtn}" Click="AddressBarMicBtn_Click" ToolTip="Address mic" Width="24" Height="24" Margin="0,0,2,0">
                                <TextBlock Text="&#127908;" Foreground="#97A7BA" FontSize="12"/>
                            </Button>
                            <TextBlock x:Name="AddressBarMicNote" Grid.Column="3" Text="" Visibility="Collapsed" Foreground="#97A7BA" FontSize="10" VerticalAlignment="Center" Margin="4,0,8,0"/>
                        </Grid>
                    </Border>

                    <Popup x:Name="AddressBarContextPopup"
                           Grid.Row="0"
                           PlacementTarget="{Binding ElementName=AddressBar}"
                           Placement="Bottom"
                           StaysOpen="False"
                           AllowsTransparency="True"
                           PopupAnimation="Fade"
                           HorizontalOffset="0"
                           VerticalOffset="2">
                        <Border Background="#101826"
                                BorderBrush="#2A9CC6"
                                BorderThickness="1"
                                CornerRadius="10"
                                MinWidth="236"
                                Padding="6">
                            <StackPanel>
                                <Button Content="Cut" Style="{StaticResource AddressBarPopupActionButton}" Click="AddressBarCtx_Cut_Click"/>
                                <Button Content="Copy" Style="{StaticResource AddressBarPopupActionButton}" Click="AddressBarCtx_Copy_Click"/>
                                <Button Content="Paste" Style="{StaticResource AddressBarPopupActionButton}" Click="AddressBarCtx_Paste_Click"/>
                                <Button Content="Paste and Go" Style="{StaticResource AddressBarPopupActionButton}" Click="AddressBarCtx_PasteAndGo_Click"/>
                                <Border Height="1" Background="#2B4C63" Margin="8,4"/>
                                <Button Content="Clear" Style="{StaticResource AddressBarPopupActionButton}" Click="AddressBarCtx_Clear_Click"/>
                                <Button Content="Copy Current URL" Style="{StaticResource AddressBarPopupActionButton}" Click="AddressBarCtx_CopyCurrentUrl_Click"/>
                                <Button Content="Open in New Tab" Style="{StaticResource AddressBarPopupActionButton}" Click="AddressBarCtx_OpenInNewTab_Click"/>
                            </StackPanel>
                        </Border>
                    </Popup>

                    <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BookmarkPageBtn" Style="{StaticResource NavBtn}" Click="BookmarkPageBtn_Click" ToolTip="Bookmark this page" Margin="1,0">
                            <TextBlock x:Name="BookmarkIcon" Text="&#9734;" Foreground="#97A7BA" FontSize="13"/>
                        </Button>
                        <Button Style="{StaticResource NavBtn}" Click="AiResearch_Click" ToolTip="Research mode" Margin="1,0">
                            <TextBlock Text="&#128269;" Foreground="#97A7BA" FontSize="12"/>
                        </Button>
                        <Button Style="{StaticResource NavBtn}" Click="AiSave_Click" ToolTip="Save workspace" Margin="1,0">
                            <TextBlock Text="&#128190;" Foreground="#97A7BA" FontSize="12"/>
                        </Button>
                        <Button x:Name="HomeButton" Style="{StaticResource NavBtn}" Click="HomeButton_Click" ToolTip="Home" Margin="1,0">
                            <TextBlock Text="&#8962;" Foreground="#97A7BA" FontSize="15"/>
                        </Button>
                    </StackPanel>

                    <Border x:Name="BookmarksTrayBorder" Grid.Row="1" Grid.ColumnSpan="3" Background="#091320" BorderBrush="#173149" BorderThickness="1" CornerRadius="6" Margin="0,4,0,0" Visibility="Visible">
                        <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" Margin="4,0">
                            <StackPanel x:Name="BookmarksBar" Orientation="Horizontal" VerticalAlignment="Center"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="8,8,8,8">
                <Border Background="#060E18" BorderBrush="#173149" BorderThickness="1" CornerRadius="10">
                    <Grid Margin="4">
                        <wv2:WebView2 x:Name="BrowserWebView"/>
                        <Border x:Name="LoadingOverlay" Background="#CC090F1A" Visibility="Visible" CornerRadius="8">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="AI Browser Hub" Foreground="#00D1FF" FontSize="20" FontWeight="SemiBold" TextAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="Initializing workspace..." Foreground="#97A7BA" FontSize="13" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border x:Name="BookmarksPanel" HorizontalAlignment="Right" Width="300" Margin="0,4,4,4" Background="#091524" BorderBrush="#1C3A54" BorderThickness="1" CornerRadius="10" Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Padding="12,10" BorderBrush="#1C3A54" BorderThickness="0,0,0,1">
                            <Grid>
                                <TextBlock Text="Bookmarks" Foreground="#E6EEF7" FontSize="13" FontWeight="SemiBold"/>
                                <Button HorizontalAlignment="Right" Style="{StaticResource NavBtn}" Click="CloseBookmarks_Click">
                                    <TextBlock Text="&#10005;" Foreground="#97A7BA" FontSize="11"/>
                                </Button>
                            </Grid>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="BookmarksList" Margin="8"/>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Popup x:Name="TabsPopup"
                       PlacementTarget="{Binding ElementName=TabsBtn}"
                       Placement="Right"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade"
                       HorizontalOffset="6"
                       VerticalOffset="0">
                    <Border Background="#0D111A" BorderBrush="#1C6EBF" BorderThickness="1" CornerRadius="12" Width="340" MaxHeight="460" Padding="0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Color="Black" Opacity="0.6"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="14,12,8,8">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#9783;" Foreground="#00D1FF" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Open Tabs" Foreground="#E6EEF7" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <Border Background="#10243A" CornerRadius="8" Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="TabsPopupCount" Text="0" Foreground="#97A7BA" FontSize="11"/>
                                    </Border>
                                </StackPanel>
                                <Button HorizontalAlignment="Right" VerticalAlignment="Top" Style="{StaticResource NavBtn}" Width="24" Height="24" Click="CloseTabsPopup_Click">
                                    <TextBlock Text="&#10005;" Foreground="#97A7BA" FontSize="11"/>
                                </Button>
                            </Grid>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="360">
                                <StackPanel x:Name="TabsPopupList" Margin="6,0,6,6"/>
                            </ScrollViewer>

                            <Border Grid.Row="2" Background="#091320" BorderBrush="#1C2A3A" BorderThickness="0,1,0,0" CornerRadius="0,0,12,12">
                                <Button Style="{StaticResource NavBtn}" Width="Auto" Height="32" Margin="6" HorizontalAlignment="Stretch" Click="TabsPopupNewTab_Click">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="+" Foreground="#00D1FF" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="New Tab" Foreground="#00D1FF" FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Border>
                        </Grid>
                    </Border>
                </Popup>

                <Popup x:Name="HistoryPopup"
                       PlacementTarget="{Binding ElementName=HistoryBtn}"
                       Placement="Right"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade"
                       HorizontalOffset="6"
                       VerticalOffset="0">
                    <Border Background="#0D111A" BorderBrush="#1C6EBF" BorderThickness="1" CornerRadius="12" Width="360" MaxHeight="460" Padding="0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Color="Black" Opacity="0.6"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="14,12,8,4">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#128337;" Foreground="#00D1FF" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="History" Foreground="#E6EEF7" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <Border Background="#10243A" CornerRadius="8" Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="HistoryPopupCount" Text="0" Foreground="#97A7BA" FontSize="11"/>
                                    </Border>
                                </StackPanel>
                                <Button HorizontalAlignment="Right" VerticalAlignment="Top" Style="{StaticResource NavBtn}" Width="24" Height="24" Click="CloseHistoryPopup_Click">
                                    <TextBlock Text="&#10005;" Foreground="#97A7BA" FontSize="11"/>
                                </Button>
                            </Grid>

                            <TextBlock Grid.Row="1" Text="Current session history" Foreground="#97A7BA" FontSize="10" FontWeight="SemiBold" Margin="16,0,16,8"/>

                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" MaxHeight="380">
                                <StackPanel x:Name="HistoryPopupList" Margin="6,0,6,8"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Popup>

                <Popup x:Name="PasswordsPopup"
                       PlacementTarget="{Binding ElementName=PasswordsBtn}"
                       Placement="Right"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade"
                       HorizontalOffset="6"
                       VerticalOffset="0">
                    <Border Background="#0D111A" BorderBrush="#1C6EBF" BorderThickness="1" CornerRadius="12" Width="360" Padding="0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Color="Black" Opacity="0.6"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="14,12,8,4">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#128273;" Foreground="#00D1FF" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Password Manager" Foreground="#E6EEF7" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button HorizontalAlignment="Right" VerticalAlignment="Top" Style="{StaticResource NavBtn}" Width="24" Height="24" Click="ClosePasswordsPopup_Click">
                                    <TextBlock Text="&#10005;" Foreground="#97A7BA" FontSize="11"/>
                                </Button>
                            </Grid>

                            <StackPanel Grid.Row="1" Margin="16,4,16,12">
                                <TextBlock Text="Atlas does not currently store website logins." Foreground="#C8D8EA" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                <TextBlock Text="Google Password Manager opens in your signed-in Google account." Foreground="#97A7BA" FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Margin="10,0,10,12">
                                <Button Style="{StaticResource NavBtn}" Width="Auto" Height="34" Margin="0,0,0,6" HorizontalAlignment="Stretch" Click="OpenGooglePasswordManager_Click">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="&#128273;" Foreground="#00D1FF" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Open Google Password Manager" Foreground="#00D1FF" FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource NavBtn}" Width="Auto" Height="34" Margin="0,0,0,6" HorizontalAlignment="Stretch" Click="OpenWindowsCredentialManager_Click">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="&#128274;" Foreground="#97A7BA" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Open Windows Credential Manager" Foreground="#C8D8EA" FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource NavBtn}" Width="Auto" Height="30" HorizontalAlignment="Stretch" Click="ClosePasswordsPopup_Click">
                                    <TextBlock Text="Close" Foreground="#97A7BA" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Popup>

                <Popup x:Name="ProfilePickerPopup"
                       PlacementTarget="{Binding ElementName=ProfileBtn}"
                       Placement="Bottom"
                       StaysOpen="True"
                       AllowsTransparency="True"
                       PopupAnimation="Fade"
                       HorizontalOffset="-560"
                       VerticalOffset="8">
                    <Border Background="#0D111A" BorderBrush="#1C2A3A" BorderThickness="1" CornerRadius="12" Width="700" MaxHeight="560" Padding="0,0,0,16">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Color="Black" Opacity="0.6"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="24,20,24,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Who's using Atlas Browser?" Foreground="#E6EEF7" FontSize="22" FontWeight="SemiBold" TextAlignment="Center"/>
                                    <TextBlock Text="Each profile has its own bookmarks, history and settings." Foreground="#97A7BA" FontSize="13" TextAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                </StackPanel>
                                <Button HorizontalAlignment="Right" VerticalAlignment="Top" Style="{StaticResource NavBtn}" Click="CloseProfilePicker_Click">
                                    <TextBlock Text="&#10005;" Foreground="#97A7BA" FontSize="14"/>
                                </Button>
                            </Grid>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="16,16,16,0" MaxHeight="380">
                                <WrapPanel x:Name="ProfilesGrid" Orientation="Horizontal" HorizontalAlignment="Center"/>
                            </ScrollViewer>

                            <Border Grid.Row="2" Height="1" Background="#1C2A3A" Margin="24,12,24,0"/>
                            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                                <Button Style="{StaticResource NavBtn}" Width="Auto" Padding="20,8" Click="AddProfileBtn_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="+ " Foreground="#00D1FF" FontSize="14" VerticalAlignment="Center"/>
                                        <TextBlock Text="Add Profile" Foreground="#00D1FF" FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Popup>

                <Popup x:Name="AddProfilePopup"
                       PlacementTarget="{Binding ElementName=ProfileBtn}"
                       Placement="Bottom"
                       StaysOpen="True"
                       AllowsTransparency="True"
                       PopupAnimation="Fade"
                       HorizontalOffset="-300"
                       VerticalOffset="8">
                    <Border Background="#0D111A" BorderBrush="#1C2A3A" BorderThickness="1" CornerRadius="12" Width="360" Padding="28">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Color="Black" Opacity="0.6"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="New Profile" Foreground="#E6EEF7" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            <TextBlock Text="Choose colour" Foreground="#97A7BA" FontSize="12" Margin="0,0,0,6"/>
                            <StackPanel x:Name="ColourPicker" Orientation="Horizontal" Margin="0,0,0,16"/>
                            <TextBlock Text="Name" Foreground="#97A7BA" FontSize="12" Margin="0,0,0,6"/>
                            <Border Background="#0A1525" CornerRadius="8" BorderBrush="#1C2A3A" BorderThickness="1" Height="36">
                                <TextBox x:Name="NewProfileNameBox" Background="Transparent" Foreground="#E6EEF7" BorderThickness="0" VerticalAlignment="Center" Padding="10,0" FontSize="13" CaretBrush="#00D1FF" KeyDown="NewProfileNameBox_KeyDown"/>
                            </Border>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                                <Button Style="{StaticResource NavBtn}" Width="Auto" Padding="16,6" Margin="0,0,8,0" Click="CancelAddProfile_Click">
                                    <TextBlock Text="Cancel" Foreground="#97A7BA" FontSize="12"/>
                                </Button>
                                <Button Style="{StaticResource NavBtn}" Width="Auto" Padding="16,6" Background="#0D2A4A" Click="ConfirmAddProfile_Click">
                                    <TextBlock Text="Create" Foreground="#00D1FF" FontSize="12" FontWeight="SemiBold"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
        </Grid>

        <Border Grid.Column="2" Background="#07111E" BorderBrush="#1C3148" BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="12,10" BorderBrush="#1C3148" BorderThickness="0,0,0,1">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#10024;" FontSize="13" Margin="0,0,6,0"/>
                            <TextBlock Text="Atlas Page Intelligence" Foreground="#E6EEF7" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" Style="{StaticResource NavBtn}" Click="AiToggleBtn_Click">
                            <TextBlock Text="&#10005;" Foreground="#97A7BA" FontSize="11"/>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10,8,10,8">
                    <StackPanel>
                        <Border Background="#0D1A2A" BorderBrush="#1C3A54" BorderThickness="1" CornerRadius="8" Padding="10,8">
                            <StackPanel>
                                <TextBlock Text="PAGE SUMMARY" Foreground="#00D1FF" FontSize="10" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock x:Name="AiCurrentPage" Text="-" Foreground="#E6EEF7" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                <ProgressBar x:Name="AiProgress" Height="3" Margin="0,6,0,0" Background="#1C2A3A" Foreground="#00D1FF" BorderThickness="0" Value="0" Maximum="100"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="QUICK ACTIONS" Foreground="#97A7BA" FontSize="10" FontWeight="Bold" Margin="0,10,0,8"/>
                        <UniformGrid Columns="2" HorizontalAlignment="Stretch">
                            <Button Style="{StaticResource AiCard}" Margin="0,0,4,4" Click="AiSummarize_Click"><TextBlock Text="Summarize Page"/></Button>
                            <Button Style="{StaticResource AiCard}" Margin="4,0,0,4" Click="AiCompare_Click"><TextBlock Text="Compare Tabs"/></Button>
                            <Button Style="{StaticResource AiCard}" Margin="0,0,4,4" Click="AiSave_Click"><TextBlock Text="Save Workspace"/></Button>
                            <Button Style="{StaticResource AiCard}" Margin="4,0,0,4" Click="ResearchMode_Click"><TextBlock Text="Research Mode"/></Button>
                            <Button Style="{StaticResource AiCard}" Margin="0,0,4,4" Click="OpenRecentSessions_Click"><TextBlock Text="Recent Sessions"/></Button>
                            <Button Style="{StaticResource AiCard}" Margin="4,0,0,4" Click="AiExtract_Click"><TextBlock Text="Extract Data"/></Button>
                        </UniformGrid>

                        <TextBlock Text="ASSET ROUTING" Foreground="#97A7BA" FontSize="10" FontWeight="Bold" Margin="0,10,0,6"/>
                        <Border Background="#0B1624" BorderBrush="#1C3148" BorderThickness="1" CornerRadius="8" Padding="8">
                            <StackPanel>
                                <TextBlock x:Name="DetectedAssetHint" Text="Detects downloadable/media links on current page." Foreground="#7FA0B6" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                <UniformGrid Columns="2" HorizontalAlignment="Stretch">
                                    <Button Style="{StaticResource AiCard}" Margin="0,0,4,4" Click="SendToDownloader_Click"><TextBlock Text="Send to Downloader" TextWrapping="Wrap"/></Button>
                                    <Button Style="{StaticResource AiCard}" Margin="4,0,0,4" Click="CopyAssetLink_Click"><TextBlock Text="Copy Link"/></Button>
                                    <Button Style="{StaticResource AiCard}" Margin="0,0,4,0" Click="OpenInMediaHub_Click"><TextBlock Text="Open in Media Hub" TextWrapping="Wrap"/></Button>
                                    <Button Style="{StaticResource AiCard}" Margin="4,0,0,0" Click="SaveAssetLink_Click"><TextBlock Text="Save Link"/></Button>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="EMAIL ROUTING" Foreground="#97A7BA" FontSize="10" FontWeight="Bold" Margin="0,10,0,6"/>
                        <Border Background="#0B1624" BorderBrush="#1C3148" BorderThickness="1" CornerRadius="8" Padding="8">
                            <StackPanel>
                                <TextBlock x:Name="DetectedEmailHint" Text="Detects mailto/email context on current page." Foreground="#7FA0B6" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                <UniformGrid Columns="1" HorizontalAlignment="Stretch">
                                    <Button Style="{StaticResource AiCard}" Margin="0,0,0,4" Click="OpenInEmailSection_Click"><TextBlock Text="Open in Email section"/></Button>
                                    <Button Style="{StaticResource AiCard}" Margin="0,0,0,4" Click="CopyEmail_Click"><TextBlock Text="Copy email"/></Button>
                                    <Button Style="{StaticResource AiCard}" Click="CreateDraftInEmail_Click"><TextBlock Text="Create draft in Email section" TextWrapping="Wrap"/></Button>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="ASK ATLAS" Foreground="#97A7BA" FontSize="10" FontWeight="Bold" Margin="0,10,0,6"/>
                        <Border Background="#0B1624" BorderBrush="#1C3148" BorderThickness="1" CornerRadius="8" Padding="8,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="AiAskBox" Grid.Column="0" Background="Transparent" Foreground="#D8EAF6" BorderThickness="0" FontSize="12" CaretBrush="#00D1FF"/>
                                <Button x:Name="AiAskMicBtn" Grid.Column="1" Style="{StaticResource NavBtn}" Click="AiAskMicBtn_Click" ToolTip="Ask Atlas mic" Width="24" Height="24" Margin="0,0,2,0">
                                    <TextBlock Text="&#127908;" Foreground="#97A7BA" FontSize="12"/>
                                </Button>
                                <Button Grid.Column="2" Style="{StaticResource NavBtn}" Click="AiAsk_Click" ToolTip="Ask Atlas">
                                    <TextBlock Text="&#10148;" Foreground="#00D1FF" FontSize="12"/>
                                </Button>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="AiAskMicNote" Text="" Visibility="Collapsed" Foreground="#97A7BA" FontSize="10" Margin="2,2,0,0"/>

                        <TextBlock Text="QUICK NOTES" Foreground="#97A7BA" FontSize="10" FontWeight="Bold" Margin="0,10,0,6"/>
                        <Border Background="#0B1624" BorderBrush="#1C3148" BorderThickness="1" CornerRadius="8" Padding="6">
                            <StackPanel>
                                <TextBox x:Name="NotesBox" Background="Transparent" Foreground="#C8D8EA" BorderThickness="0" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="64" MaxHeight="120" CaretBrush="#00D1FF"/>
                                <Button HorizontalAlignment="Right" Style="{StaticResource NavBtn}" Width="Auto" Padding="10,0" Click="SaveNotes_Click" ToolTip="Save notes">
                                    <TextBlock Text="Save" Foreground="#00D1FF" FontSize="11"/>
                                </Button>
                            </StackPanel>
                        </Border>

                        <Border x:Name="AiResultBorder" Margin="0,10,0,0" Background="#0D1A2A" CornerRadius="8" BorderBrush="#1C3148" BorderThickness="1" Padding="10" Visibility="Collapsed">
                            <TextBlock x:Name="AiResultText" Foreground="#E6EEF7" FontSize="12" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Padding="10,7" BorderBrush="#1C3148" BorderThickness="0,1,0,0">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#9899;" Foreground="#00D1FF" FontSize="9" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="WORKSPACE CONFIDENCE" Foreground="#97A7BA" FontSize="10" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" Background="#0D1A2A" CornerRadius="4" BorderBrush="#1C3148" BorderThickness="1" Padding="8,2">
                            <TextBlock x:Name="ConfidenceText" Text="-" Foreground="#00D1FF" FontSize="10"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
