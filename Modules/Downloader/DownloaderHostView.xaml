<UserControl x:Class="AtlasAI.Modules.Downloader.DownloaderHostView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AtlasAI.Controls"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="Transparent">
    <Grid Background="Transparent">
        <wv2:WebView2 x:Name="DownloaderWebView" Margin="0" />

        <Button Click="RestoreShellChrome_Click"
                Width="26"
                Height="26"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,12,12,0"
                Padding="0"
                Background="#1A0F172A"
                Foreground="#EAF2F8"
                BorderBrush="#331E293B"
                BorderThickness="1"
                ToolTip="Restore Atlas header and sidebar"
                Content="˄"
                Panel.ZIndex="12"/>

        <!-- Mini-player overlay (themed) -->
        <Border HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="18"
                Background="Transparent"
                IsHitTestVisible="False">
            <controls:SimpleMediaPlayerControl x:Name="DownloaderPlayer"
                                               IsMiniPlayer="True"
                                               Width="420"
                                               Height="110"
                                               Visibility="Collapsed"
                                               IsHitTestVisible="True" />
        </Border>
    </Grid>
</UserControl>
