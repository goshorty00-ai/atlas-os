  <Target Name="CopyReactBuildToOutput" AfterTargets="Build">
    <PropertyGroup>
      <!-- SolutionDir is not set when building the project directly (e.g., run-dev.ps1). -->
      <ReactDistDir>$(MSBuildProjectDirectory)\Figma\Mediahub\dist</ReactDistDir>
      <!-- Copy into both the app-local Figma folder and WebView2 data folder so the runtime always sees the latest UI. -->
      <RuntimeWebViewDir>$(TargetDir)Figma\Media Streamer\dist</RuntimeWebViewDir>
      <PublishWebViewDir>$(TargetDir)Atlas_v2.exe.WebView2</PublishWebViewDir>
    </PropertyGroup>
    <Message Importance="high" Text="Copying React build to $(RuntimeWebViewDir) and $(PublishWebViewDir)" />
    <RemoveDir Directories="$(RuntimeWebViewDir);$(PublishWebViewDir)" />
    <MakeDir Directories="$(RuntimeWebViewDir);$(PublishWebViewDir)" />
    <ItemGroup>
      <ReactFiles Include="$(ReactDistDir)\**\*.*" />
    </ItemGroup>
    <Copy SourceFiles="@(ReactFiles)" DestinationFolder="$(RuntimeWebViewDir)\%(RecursiveDir)" SkipUnchangedFiles="false" />
    <Copy SourceFiles="@(ReactFiles)" DestinationFolder="$(PublishWebViewDir)\%(RecursiveDir)" SkipUnchangedFiles="false" />
  </Target>

  <Target Name="CopyDjBuildToOutput" AfterTargets="Build"
          Condition="Exists('$(MSBuildProjectDirectory)\Figma\djcode\dist\index.html')">
    <PropertyGroup>
      <DjDistDir>$(MSBuildProjectDirectory)\Figma\djcode\dist</DjDistDir>
      <DjRuntimeDir>$(TargetDir)Figma\djcode\dist</DjRuntimeDir>
      <DjWebViewDir>$(TargetDir)Atlas_v2.exe.WebView2\djcode\dist</DjWebViewDir>
