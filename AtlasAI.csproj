      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <!-- FFmpeg Binaries -->
    <Content Include="ffmpeg\**">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <!-- yt-dlp Binaries -->
    <Content Include="yt-dlp\**">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <Target Name="BuildEmbeddedUi" BeforeTargets="Build"
          Condition="'$(BuildEmbeddedUi)' == 'true' and Exists('$(EmbeddedUiDir)\package.json')">
    <Message Importance="high" Text="[Atlas] Building embedded UI (Vite)…" />

    <Exec WorkingDirectory="$(EmbeddedUiDir)" Command="cmd /c npm --version" ContinueOnError="WarnAndContinue" />
    <Exec WorkingDirectory="$(EmbeddedUiDir)" Command="cmd /c if not exist node_modules npm install" ContinueOnError="WarnAndContinue" />
    <Exec WorkingDirectory="$(EmbeddedUiDir)" Command="cmd /c npm run build" ContinueOnError="WarnAndContinue" />
  </Target>

