    </ItemGroup>
    <Copy SourceFiles="@(DjFiles)" DestinationFolder="$(DjRuntimeDir)\%(RecursiveDir)" SkipUnchangedFiles="false" />
    <Copy SourceFiles="@(DjFiles)" DestinationFolder="$(DjWebViewDir)\%(RecursiveDir)" SkipUnchangedFiles="false" />
  </Target>

  <Target Name="CopyFileExplorerBuildToOutput" AfterTargets="Build"
