<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <UseWPF>true</UseWPF>
    <WarningLevel>0</WarningLevel>
    <UseWindowsForms>true</UseWindowsForms>
    <UseAppHost>true</UseAppHost>
    <SelfContained>true</SelfContained>
    <AssemblyName>Atlas_v2</AssemblyName>
    <AssemblyTitle>Atlas</AssemblyTitle>
    <ApplicationTitle>Atlas</ApplicationTitle>
    <Product>Atlas</Product>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <!-- Use a single, stable output folder for now (build/run/publish) -->
    <OutputPath>$(MSBuildProjectDirectory)\bin\x64\</OutputPath>
    <PublishDir>$(MSBuildProjectDirectory)\bin\x64\</PublishDir>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <AppendRuntimeIdentifierToOutputPath>false</AppendRuntimeIdentifierToOutputPath>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>atlas.ico</ApplicationIcon>
    <AllowUnsafeBlocks>false</AllowUnsafeBlocks>
    <AtlasPersonal Condition="'$(AtlasPersonal)' == ''">true</AtlasPersonal>
    <!-- Debug builds should be fast and stable by default. Enable embedded UI build explicitly with -p:BuildEmbeddedUi=true when needed. -->
    <BuildEmbeddedUi Condition="'$(BuildEmbeddedUi)' == '' and '$(Configuration)' != 'Release'">false</BuildEmbeddedUi>
    <EmbeddedUiDir>$(MSBuildProjectDirectory)\Figma\Futuristic AI Command Center (6)</EmbeddedUiDir>
  </PropertyGroup>

  <PropertyGroup Condition="'$(AtlasPersonal)' == 'true'">
    <DefineConstants>$(DefineConstants);ATLAS_PERSONAL;PERSONAL_BUILD</DefineConstants>
  </PropertyGroup>

  <PropertyGroup Condition="'$(AtlasPersonal)' != 'true'">
    <DefineConstants>$(DefineConstants);ATLAS_PUBLIC</DefineConstants>
  </PropertyGroup>
  
  <!-- Only use single file for Release builds -->
  <PropertyGroup Condition="'$(Configuration)' == 'Release'">
    <Optimize>true</Optimize>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <PublishReadyToRun>true</PublishReadyToRun>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <!-- Required so embedded UI files (dist) are available at runtime -->
    <IncludeAllContentForSelfExtract>true</IncludeAllContentForSelfExtract>
  </PropertyGroup>
  
  <!-- Exclude separate project folders to avoid duplicate compilation -->
  <ItemGroup>
    <Compile Remove="_trae_backup\**\*.cs" />
    <Compile Remove="_trae_backup/**/*.cs" />
    <Page Remove="_trae_backup\**\*.xaml" />
    <Page Remove="_trae_backup/**/*.xaml" />
    <ApplicationDefinition Remove="_trae_backup\**\*.xaml" />
    <ApplicationDefinition Remove="_trae_backup/**/*.xaml" />
    <None Remove="_trae_backup\**\*" />
    <None Remove="_trae_backup/**/*" />

    <Compile Remove="_buildtmp\**\*.cs" />
    <Compile Remove="_buildtmp/**/*.cs" />
    <None Remove="_buildtmp\**\*" />
    <None Remove="_buildtmp/**/*" />

    <Compile Remove="_builds\**\*.cs" />
    <Compile Remove="_builds/**/*.cs" />
    <None Remove="_builds\**\*" />
    <None Remove="_builds/**/*" />

    <Compile Remove="AtlasAIChatWindow\**\*.cs" />
    <Compile Remove="AtlasAIChatWindow/**/*.cs" />
    <Page Remove="AtlasAIChatWindow\*.xaml" />
    <Page Remove="AtlasAIChatWindow/*.xaml" />
    <Page Remove="AtlasAIChatWindow\**\*.xaml" />
    <Page Remove="AtlasAIChatWindow/**/*.xaml" />
    <ApplicationDefinition Remove="AtlasAIChatWindow\App.xaml" />
    <None Remove="AtlasAIChatWindow\**\*" />

    <!-- Ensure exclusion also matches forward-slash item paths (some tooling normalizes this way) -->
    <None Remove="AtlasAIChatWindow/**/*" />

    <Compile Remove="WPFApplication\**\*.cs" />
    <Compile Remove="WPFApplication/**/*.cs" />
    <Page Remove="WPFApplication\**\*.xaml" />
    <Page Remove="WPFApplication/**/*.xaml" />
    <ApplicationDefinition Remove="WPFApplication\App.xaml" />
    <None Remove="WPFApplication\**\*" />
    <None Remove="WPFApplication/**/*" />

    <Compile Remove="AtlasAI.Build/**/*.cs" />
    <Compile Remove="AtlasAI.Core/**/*.cs" />
    <Compile Remove="AtlasAI.UI/**/*.cs" />
    <Compile Remove="AtlasAI.Personal/**/*.cs" />
    <Compile Remove="AtlasAI.Public/**/*.cs" />
    <Compile Remove="AtlasAI.Modules.*/**/*.cs" />
    <Compile Remove="Tests/**/*.cs" />
    <Compile Remove="ManualSettingsTest.cs" />
    <Compile Remove="UI/Pages/CreatePage.xaml.cs" />
    
    <Page Remove="AtlasAI.Build/**/*.xaml" />
    <Page Remove="AtlasAI.Core/**/*.xaml" />
    <Page Remove="AtlasAI.UI/**/*.xaml" />
    <Page Remove="AtlasAI.Personal/**/*.xaml" />
    <Page Remove="AtlasAI.Public/**/*.xaml" />
    <Page Remove="AtlasAI.Modules.*/**/*.xaml" />
    <Page Remove="UI/Pages/CreatePage.xaml" />
  </ItemGroup>
  
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="8.0.0" />
    <PackageReference Include="LibVLCSharp.WPF" Version="3.8.5" />
    <PackageReference Include="VideoLAN.LibVLC.Windows" Version="3.0.20" />
    <PackageReference Include="FFME.Windows" Version="4.4.350" />
    <PackageReference Include="LottieSharp" Version="2.4.3" />
    <PackageReference Include="System.Speech" Version="8.0.0" />
    <PackageReference Include="System.Management" Version="8.0.0" />
    <PackageReference Include="System.ServiceProcess.ServiceController" Version="8.0.0" />
    <PackageReference Include="WPF-UI" Version="3.0.5" />
    <PackageReference Include="NAudio" Version="2.2.1" />
    <PackageReference Include="SoundTouch.Net" Version="2.3.2" />
    <PackageReference Include="Microsoft.Data.Sqlite" Version="8.0.0" />
    <PackageReference Include="TaskScheduler" Version="2.11.0" />
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.2420.47" />
    <PackageReference Include="TagLibSharp" Version="2.3.0" />
    <!-- Document generation -->
    <PackageReference Include="DocumentFormat.OpenXml" Version="3.0.1" />
    <!-- Roslyn for symbol indexing -->
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.8.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" Version="4.8.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.Workspaces.MSBuild" Version="4.8.0" />
    <PackageReference Include="QRCoder" Version="1.6.0" />
  </ItemGroup>
