    <Message Importance="high" Text="Copying DJ build to $(DjRuntimeDir) and $(DjWebViewDir)" />
    <RemoveDir Directories="$(DjRuntimeDir);$(DjWebViewDir)" />
    <MakeDir Directories="$(DjRuntimeDir);$(DjWebViewDir)" />
    <ItemGroup>
