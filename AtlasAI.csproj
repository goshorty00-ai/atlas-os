  <!--
    IMPORTANT:
    The Vite build regenerates hashed filenames in dist/. If we include dist/** as Content at project-evaluation time,
    MSBuild can capture a stale file list and then fail copying missing files (MSB3030) after npm build rewrites dist.
    To avoid that, include the Command Center dist content dynamically right before output-copy items are gathered.
  -->
  <Target Name="IncludeEmbeddedCommandCenterUi" BeforeTargets="GetCopyToOutputDirectoryItems">
    <ItemGroup Condition="Exists('$(MSBuildProjectDirectory)\Figma\Futuristic AI Command Center (6)\dist\index.html')">
      <Content Include="Figma\Futuristic AI Command Center (6)\dist\**\*.*">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
        <ExcludeFromSingleFile>false</ExcludeFromSingleFile>
      </Content>
    </ItemGroup>
  </Target>

  <Target Name="IncludeEmbeddedMediaStreamerUi" BeforeTargets="GetCopyToOutputDirectoryItems">
    <ItemGroup Condition="Exists('$(MSBuildProjectDirectory)\Figma\Mediahub\dist\index.html')">
      <Content Include="Figma\Mediahub\dist\**\*.*">
