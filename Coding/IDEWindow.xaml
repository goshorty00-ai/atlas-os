<Window x:Class="AtlasAI.Coding.IDEWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Atlas IDE" Height="900" Width="1400"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#0a0a0f"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Icon="pack://application:,,,/atlas.ico"
        PreviewKeyDown="IDEWindow_PreviewKeyDown">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="8" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>
    
    <Window.Resources>
        <!-- Atlas Theme Colors -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="#0a0a0f"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#080810"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#0f0f1a"/>
        <SolidColorBrush x:Key="CyanBrush" Color="#00d4ff"/>
        <SolidColorBrush x:Key="PurpleBrush" Color="#b967ff"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#00ff9f"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#ffaa00"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#ff1493"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#e0e0e8"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#8b8b9a"/>
        <SolidColorBrush x:Key="TextDimBrush" Color="#6b7280"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#1e293b"/>
        
        <SolidColorBrush x:Key="NeonOrangeBrush" Color="#ff7f2a"/>
        <SolidColorBrush x:Key="NeonOrangeGlowBrush" Color="#ff7f2a"/>
        
        <!-- ContextMenu Dark Theme (IDE scope only) -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="#0a0a0f"/>
            <Setter Property="BorderBrush" Value="#40ff7f2a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#ff7f2a" BlurRadius="16" ShadowDepth="0" Opacity="0.25"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Separator">
            <Setter Property="Margin" Value="6,4"/>
            <Setter Property="Background" Value="#1e293b"/>
            <Setter Property="Height" Value="1"/>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="#ffb366"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#22ff7f2a"/>
                                <Setter Property="Foreground" Value="#ff7f2a"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#6b7280"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8b8b9a"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1a1a24"/>
                            </Trigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="close"/>
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="bd" Property="Background" Value="#ff1493"/>
                                <Setter Property="Foreground" Value="White"/>
                            </MultiDataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8b8b9a"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1a1a24"/>
                                <Setter Property="Foreground" Value="#00d4ff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="RunButton" TargetType="Button">
            <Setter Property="Foreground" Value="#0a0a0f"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#00d4ff" Offset="0"/>
                                    <GradientStop Color="#00ffff" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#00d4ff" BlurRadius="10" ShadowDepth="0" Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00d4ff" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="DebugButton" TargetType="Button">
            <Setter Property="Foreground" Value="#e0e0e8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                Background="#26b967ff" BorderBrush="#4db967ff" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="#b967ff" BlurRadius="8" ShadowDepth="0" Opacity="0.2"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#40b967ff"/>
                                <Setter TargetName="bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#b967ff" BlurRadius="15" ShadowDepth="0" Opacity="0.4"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Dark ComboBox Style -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#080810"/>
            <Setter Property="Foreground" Value="#e0e0e8"/>
            <Setter Property="BorderBrush" Value="#3300d4ff"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          ClickMode="Press"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                CornerRadius="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1" Data="M0,0 L4,4 L8,0" Stroke="#8b8b9a" StrokeThickness="1.5"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,1,0,0"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,4,24,4"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder"
                                        Background="#0a0a0f"
                                        BorderBrush="#3300d4ff"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,2,0,0"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Padding="2">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Dark ComboBoxItem Style -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#e0e0e8"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1a1a24"/>
                                <Setter Property="Foreground" Value="#00d4ff"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1500d4ff"/>
                                <Setter Property="Foreground" Value="#00d4ff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Dark ListBoxItem Style -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#e0e0e8"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1a1a24"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1500d4ff"/>
                                <Setter Property="Foreground" Value="#00d4ff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Dark TreeViewItem Style -->
        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="#e0e0e8"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1500d4ff"/>
                    <Setter Property="Foreground" Value="#00d4ff"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0d0d1a"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid PreviewKeyDown="IDEWindow_PreviewKeyDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Background="#080810" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                BorderBrush="#1a00d4ff" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Logo & Project -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="☰" FontSize="16" Foreground="#8b8b9a" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="WindowTitle" FontSize="16" FontWeight="Bold" VerticalAlignment="Center">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#ff7f2a" Offset="0"/>
                                <GradientStop Color="#ff9e4a" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                        <Run Text="ATLAS IDE"/>
                    </TextBlock>
                    
                    <!-- Project Switcher -->
                    <Border Margin="16,0,0,0" Background="#1a00d4ff" CornerRadius="6" Padding="10,4" 
                            BorderBrush="#3300d4ff" BorderThickness="1" Cursor="Hand"
                            MouseLeftButtonUp="ProjectSwitcher_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📁" FontSize="12" Foreground="#00d4ff" Margin="0,0,6,0"/>
                            <TextBlock x:Name="ProjectName" Text="my-project" FontSize="12" Foreground="#e0e0e8"/>
                            <TextBlock Text=" ▼" FontSize="8" Foreground="#8b8b9a" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <!-- Command Palette -->
                <Border x:Name="CommandPaletteContainer" Grid.Column="1" Margin="24,8" MaxWidth="500" HorizontalAlignment="Center">
                    <Grid>
                        <Border Background="#1a1a24" CornerRadius="10" BorderBrush="#3300d4ff" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="#00d4ff" BlurRadius="14" ShadowDepth="0" Opacity="0.25"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🔍" FontSize="12" Foreground="#8b8b9a" Margin="12,0,8,0" VerticalAlignment="Center"/>
                                <TextBox x:Name="CommandPalette" Grid.Column="1" Background="Transparent" 
                                         Foreground="#e0e0e8" BorderThickness="0" FontSize="12" VerticalAlignment="Center"
                                         CaretBrush="#00d4ff"
                                         TextChanged="CommandPalette_TextChanged"
                                         KeyDown="CommandPalette_KeyDown"
                                         LostKeyboardFocus="CommandPalette_LostKeyboardFocus">
                                    <TextBox.Triggers>
                                        <EventTrigger RoutedEvent="GotKeyboardFocus">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="CommandPaletteContainer"
                                                                     Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)"
                                                                     To="22" Duration="0:0:0.12"/>
                                                    <DoubleAnimation Storyboard.TargetName="CommandPaletteContainer"
                                                                     Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)"
                                                                     To="0.45" Duration="0:0:0.12"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                        <EventTrigger RoutedEvent="LostKeyboardFocus">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="CommandPaletteContainer"
                                                                     Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)"
                                                                     To="14" Duration="0:0:0.12"/>
                                                    <DoubleAnimation Storyboard.TargetName="CommandPaletteContainer"
                                                                     Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)"
                                                                     To="0.25" Duration="0:0:0.12"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </TextBox.Triggers>
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                                <VisualBrush.Visual>
                                                                    <TextBlock Text="Search or type a command... (Ctrl+P)" 
                                                                               Foreground="#6b7280" FontSize="12"/>
                                                                </VisualBrush.Visual>
                                                            </VisualBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                <Border Grid.Column="2" Background="#0a0a0f" CornerRadius="4" Padding="6,2" Margin="8,0,8,0"
                                        BorderBrush="#3300d4ff" BorderThickness="1">
                                    <TextBlock Text="Ctrl+P" FontSize="10" Foreground="#8b8b9a"/>
                                </Border>
                            </Grid>
                        </Border>
                        <Popup x:Name="CommandPalettePopup"
                               PlacementTarget="{Binding ElementName=CommandPalette}"
                               Placement="Bottom"
                               StaysOpen="True"
                               AllowsTransparency="True"
                               PopupAnimation="Fade">
                            <Border Background="#0a0a0f" BorderBrush="#3300d4ff" BorderThickness="1"
                                    CornerRadius="10" Padding="6" Margin="0,8,0,0" Width="500">
                                <ListBox x:Name="CommandPaletteResults"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="#e0e0e8"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         MaxHeight="280"
                                         SelectionChanged="CommandPaletteResults_SelectionChanged"
                                         MouseDoubleClick="CommandPaletteResults_MouseDoubleClick">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="6,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Display}" Foreground="#e0e0e8"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Meta}" Foreground="#64748b" Margin="16,0,0,0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Popup>
                    </Grid>
                </Border>
                
                <!-- Run/Debug Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center">
                    <Button x:Name="RunBtn" Style="{StaticResource RunButton}" Click="Run_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▶" FontSize="10" Margin="0,0,6,0"/>
                            <TextBlock Text="Run"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="DebugBtn" Style="{StaticResource DebugButton}" Margin="8,0,0,0" Click="Debug_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🐛" FontSize="10" Foreground="#b967ff" Margin="0,0,6,0"/>
                            <TextBlock Text="Debug"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="VsConnectBtn" Style="{StaticResource IconButton}" Width="32" Height="32"
                            Margin="10,0,0,0" Content="VS" ToolTip="Connect to Visual Studio" Click="ConnectVisualStudio_Click"/>
                    <Button x:Name="FocusModeBtn" Style="{StaticResource IconButton}" Width="32" Height="32"
                            Margin="6,0,0,0" Content="◱" ToolTip="Focus mode" Click="ToggleFocusMode_Click"/>
                </StackPanel>
                
                <!-- Window Controls -->
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Content="─" Click="Minimize_Click" Style="{StaticResource WindowControlButton}"/>
                    <Button Content="□" Click="Maximize_Click" Style="{StaticResource WindowControlButton}"/>
                    <Button Content="✕" Click="Close_Click" Style="{StaticResource WindowControlButton}" Tag="close"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="IconCol" Width="56"/>
                <ColumnDefinition x:Name="ExplorerCol" Width="240" MinWidth="180" MaxWidth="400"/>
                <ColumnDefinition x:Name="LeftSplitCol" Width="Auto"/>
                <ColumnDefinition x:Name="EditorCol" Width="*"/>
                <ColumnDefinition x:Name="RightSplitCol" Width="Auto"/>
                <ColumnDefinition x:Name="AIPanelCol" Width="380" MinWidth="300" MaxWidth="500"/>
            </Grid.ColumnDefinitions>
            
            <!-- Icon Sidebar -->
            <Border x:Name="IconSidebarBorder" Grid.Column="0" Background="#080810" BorderBrush="#1e293b" BorderThickness="0,0,1,0">
                <StackPanel Margin="0,8,0,0">
                    <Button x:Name="FilesIconBtn" Style="{StaticResource IconButton}" Width="40" Height="40" 
                            Content="📁" FontSize="18" ToolTip="Explorer" Click="FilesIcon_Click" Margin="8,4"/>
                    <Button x:Name="SearchIconBtn" Style="{StaticResource IconButton}" Width="40" Height="40" 
                            Content="🔍" FontSize="18" ToolTip="Search" Click="SearchIcon_Click" Margin="8,4"/>
                    <Button x:Name="GitIconBtn" Style="{StaticResource IconButton}" Width="40" Height="40" 
                            Content="⎇" FontSize="18" ToolTip="Source Control" Click="GitIcon_Click" Margin="8,4"/>
                    <Button x:Name="DebugIconBtn" Style="{StaticResource IconButton}" Width="40" Height="40" 
                            Content="🐛" FontSize="18" ToolTip="Debug" Click="DebugIcon_Click" Margin="8,4"/>
                    <Button x:Name="ExtIconBtn" Style="{StaticResource IconButton}" Width="40" Height="40" 
                            Content="🧩" FontSize="18" ToolTip="Extensions" Click="ExtIcon_Click" Margin="8,4"/>
                </StackPanel>
            </Border>

            <!-- File Explorer -->
            <Border x:Name="ExplorerBorder" Grid.Column="1" Background="#0a0a0f" BorderBrush="#1e293b" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="#080810" Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="EXPLORER" FontSize="11" Foreground="#8b8b9a" FontWeight="SemiBold"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="OpenFolderBtn" Content="📁" Click="OpenFolder_Click" ToolTip="Open Folder"
                                        Style="{StaticResource IconButton}" Width="24" Height="24" FontSize="12"/>
                                <Button x:Name="RefreshBtn" Content="🔄" Click="RefreshTree_Click" ToolTip="Refresh"
                                        Style="{StaticResource IconButton}" Width="24" Height="24" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <TreeView x:Name="FileTree" Grid.Row="1" Background="Transparent" BorderThickness="0"
                              Foreground="#e0e0e8" FontSize="12" Padding="4"
                              SelectedItemChanged="FileTree_SelectedItemChanged">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="Foreground" Value="#e0e0e8"/>
                                <Setter Property="Padding" Value="2"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </Grid>
            </Border>
            
            <GridSplitter x:Name="LeftSplitter" Grid.Column="2" Width="4" Background="Transparent" HorizontalAlignment="Center"/>
            
            <!-- Editor Area -->
            <Grid x:Name="EditorGrid" Grid.Column="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="180" MinHeight="100" MaxHeight="400"/>
                </Grid.RowDefinitions>
                
                <!-- Tab Bar -->
                <Border Grid.Row="0" Background="#080810" Padding="4,0">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="TabBar" Orientation="Horizontal"/>
                    </ScrollViewer>
                </Border>
                
                <!-- Monaco Editor -->
                <Border Grid.Row="1" Background="#1e1e1e">
                    <wv2:WebView2 x:Name="EditorWebView" DefaultBackgroundColor="#1e1e1e"/>
                </Border>
                
                <!-- Figma / Trae Web UI (hidden by default) -->
                <Border Grid.Row="1" Background="#0a0a0f" Visibility="Collapsed" x:Name="FigmaHostBorder">
                    <wv2:WebView2 x:Name="FigmaWebView" DefaultBackgroundColor="#0a0a0f"/>
                </Border>
                
                <GridSplitter Grid.Row="2" Height="4" Background="Transparent" HorizontalAlignment="Stretch"/>
                
                <!-- Terminal / Problems Panel -->
                <Border Grid.Row="3" Background="#080810" BorderBrush="#1e293b" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Border Grid.Row="0" Background="#0a0a0f" Padding="8,4">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="TerminalTabBtn" Content="TERMINAL" Click="TerminalTab_Click"
                                        Background="Transparent" Foreground="#00d4ff" BorderThickness="0" 
                                        FontSize="10" FontWeight="SemiBold" Padding="8,4" Cursor="Hand"/>
                                <Button x:Name="ProblemsTabBtn" Click="ProblemsTab_Click"
                                        Background="Transparent" Foreground="#8b8b9a" BorderThickness="0"
                                        FontSize="10" FontWeight="SemiBold" Padding="8,4" Cursor="Hand">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="PROBLEMS"/>
                                        <Border x:Name="ProblemsCount" Background="#ff1493" CornerRadius="8" 
                                                Padding="5,1" Margin="6,0,0,0" Visibility="Collapsed">
                                            <TextBlock x:Name="ProblemsCountText" Text="0" FontSize="9" Foreground="White"/>
                                        </Border>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="OutputTabBtn" Content="OUTPUT" Click="OutputTab_Click"
                                        Background="Transparent" Foreground="#8b8b9a" BorderThickness="0"
                                        FontSize="10" FontWeight="SemiBold" Padding="8,4" Cursor="Hand"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Terminal Content -->
                        <Grid Grid.Row="1" x:Name="TerminalPanel">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollViewer x:Name="TerminalScroller" VerticalScrollBarVisibility="Auto" Background="#0a0a0f">
                                <TextBlock x:Name="TerminalOutput" FontFamily="Consolas" FontSize="12" 
                                           Foreground="#e0e0e8" Padding="8" TextWrapping="Wrap"/>
                            </ScrollViewer>
                            <Border Grid.Row="1" Background="#080810" Padding="8,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="❯" Foreground="#00d4ff" FontFamily="Consolas" FontSize="12" 
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox x:Name="TerminalInput" Grid.Column="1" Background="Transparent" 
                                             Foreground="#e0e0e8" BorderThickness="0" FontFamily="Consolas" FontSize="12"
                                             KeyDown="TerminalInput_KeyDown" CaretBrush="#00d4ff"/>
                                </Grid>
                            </Border>
                        </Grid>
                        
                        <ScrollViewer Grid.Row="1" x:Name="ProblemsPanel" Visibility="Collapsed" Background="#0a0a0f">
                            <ItemsControl x:Name="ProblemsList" Padding="8"/>
                        </ScrollViewer>
                        
                        <ScrollViewer Grid.Row="1" x:Name="OutputPanel" Visibility="Collapsed" Background="#0a0a0f">
                            <TextBlock x:Name="OutputText" FontFamily="Consolas" FontSize="12" 
                                       Foreground="#e0e0e8" Padding="8" TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
            
            <GridSplitter x:Name="RightSplitter" Grid.Column="4" Width="4" Background="Transparent" HorizontalAlignment="Center"/>

            <!-- AI Assistant Panel - Agent Mode v2 -->
            <Border x:Name="AIPanelBorder" Grid.Column="5" BorderBrush="#3300d4ff" BorderThickness="1,0,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#fa0a0a0f" Offset="0"/>
                        <GradientStop Color="#fa0f0f19" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header -->
                    <Border Grid.Row="0" Padding="16,12">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#152B0000" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✨" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="AI ASSISTANT" FontSize="11" Foreground="#00d4ff" FontWeight="SemiBold"/>
                                </StackPanel>
                                <TextBlock Text="Build with Atlas AI" FontSize="10" Foreground="#8b8b9a" Margin="22,2,0,0"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="NewChatBtn" Content="➕" Style="{StaticResource IconButton}" 
                                        ToolTip="New chat" Click="ClearAI_Click"/>
                                <Button x:Name="ContextBtn" Content="📋" Style="{StaticResource IconButton}" 
                                        ToolTip="View Context" Click="ViewContext_Click"/>
                                <Button x:Name="SettingsAIBtn" Content="⚙" Style="{StaticResource IconButton}" 
                                        ToolTip="Settings" Click="SettingsAI_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- Cyan accent line -->
                    <Rectangle Grid.Row="0" Height="2" VerticalAlignment="Bottom">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#3B0000" Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    
                    <!-- Verification Options -->
                    <Border Grid.Row="1" Background="#080810" Padding="12,8" BorderBrush="#1e293b" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="VERIFICATION" FontSize="9" Foreground="#6b7280" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox x:Name="BuildCheck" Content="Build" IsChecked="True" Foreground="#8b8b9a" FontSize="11" Margin="0,0,12,0"/>
                                <CheckBox x:Name="TestsCheck" Content="Tests" Foreground="#8b8b9a" FontSize="11" Margin="0,0,12,0"/>
                                <CheckBox x:Name="LintCheck" Content="Lint" Foreground="#8b8b9a" FontSize="11"/>
                            </StackPanel>
                            <CheckBox x:Name="AutoRepairCheck" Content="Auto-repair once" IsChecked="True" 
                                      Foreground="#00ff9f" FontSize="11" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Grid.Row="2" Background="#0a0a0f" Padding="12,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <RadioButton x:Name="AgentModeBtn" Content="Agent" GroupName="AIMode" IsChecked="True"
                                             Foreground="#00d4ff" FontSize="11" Margin="0,0,16,0" Click="AIMode_Changed"/>
                                <RadioButton x:Name="AskModeBtn" Content="Ask" GroupName="AIMode"
                                             Foreground="#e0e0e8" FontSize="11" Margin="0,0,16,0" Click="AIMode_Changed"/>
                                <RadioButton x:Name="EditModeBtn" Content="Edit" GroupName="AIMode"
                                             Foreground="#e0e0e8" FontSize="11" Margin="0,0,16,0" Click="AIMode_Changed"/>
                                <RadioButton x:Name="FixModeBtn" Content="Fix" GroupName="AIMode"
                                             Foreground="#e0e0e8" FontSize="11" Click="AIMode_Changed"/>
                            </StackPanel>
                            <Grid Grid.Row="1" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="ROLE" Foreground="#6b7280" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox x:Name="AgentRoleCombo" Grid.Column="1" Height="26"
                                          SelectionChanged="AgentRoleCombo_SelectionChanged"
                                          Background="#080810" Foreground="#e0e0e8"
                                          BorderBrush="#3300d4ff" BorderThickness="1">
                                    <ComboBoxItem Content="Builder" IsSelected="True"/>
                                    <ComboBoxItem Content="Designer"/>
                                    <ComboBoxItem Content="Debugger"/>
                                    <ComboBoxItem Content="Architect"/>
                                </ComboBox>
                            </Grid>
                        </Grid>
                    </Border>
                    
                    <!-- Chat Area -->
                    <ScrollViewer Grid.Row="3" x:Name="AIChatScroller" VerticalScrollBarVisibility="Auto" Padding="12">
                        <StackPanel x:Name="AIChatPanel">
                            <!-- Empty State -->
                            <Border x:Name="AIEmptyState" Margin="0,40,0,0" HorizontalAlignment="Center">
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Width="80" Height="80" CornerRadius="16" HorizontalAlignment="Center" Margin="0,0,0,16">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#1a00d4ff" Offset="0"/>
                                                <GradientStop Color="#1ab967ff" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.Effect>
                                            <DropShadowEffect Color="#00d4ff" BlurRadius="30" ShadowDepth="0" Opacity="0.3"/>
                                        </Border.Effect>
                                        <TextBlock Text="✨" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    
                                    <TextBlock Text="Build with Atlas AI" FontSize="18" Foreground="#e0e0e8" 
                                               FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="AI responses may be inaccurate." FontSize="12" 
                                               Foreground="#8b8b9a" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    <TextBlock Text="Describe what you want to build, and I'll help you code it step by step." 
                                               FontSize="11" Foreground="#6b7280" 
                                               HorizontalAlignment="Center" Margin="0,16,0,0" TextWrapping="Wrap" MaxWidth="280"
                                               TextAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                    
                    <!-- Input Area -->
                    <Border Grid.Row="4" Padding="12" BorderBrush="#1e293b" BorderThickness="0,1,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                <GradientStop Color="#0800d4ff" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel>
                            <!-- Context Indicator -->
                            <Border x:Name="ContextIndicator" Background="#1a00d4ff" CornerRadius="4" 
                                    Padding="8,4" Margin="0,0,0,8" Visibility="Collapsed">
                                <TextBlock x:Name="ContextText" FontSize="10" Foreground="#00d4ff" TextTrimming="CharacterEllipsis"/>
                            </Border>
                            
                            <!-- Context Input -->
                            <Border Background="#0800d4ff" CornerRadius="6" Padding="8,6" Margin="0,0,0,8"
                                    BorderBrush="#3300d4ff" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="📎" FontSize="12" Foreground="#6b7280" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox x:Name="ContextInput" Grid.Column="1" Background="Transparent" 
                                             Foreground="#8b8b9a" BorderThickness="0" FontSize="12" VerticalAlignment="Center"
                                             CaretBrush="#00d4ff">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Style.Triggers>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                                    <VisualBrush.Visual>
                                                                        <TextBlock Text="Add Context..." Foreground="#6b7280" FontSize="12"/>
                                                                    </VisualBrush.Visual>
                                                                </VisualBrush>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Grid>
                            </Border>
                            
                            <!-- Main Input -->
                            <Border x:Name="AIInputContainer" CornerRadius="12" Padding="12" BorderThickness="2">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#1400d4ff" Offset="0"/>
                                        <GradientStop Color="#14b967ff" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#00d4ff" Opacity="0.5"/>
                                </Border.BorderBrush>
                                <Border.Effect>
                                    <DropShadowEffect Color="#00d4ff" BlurRadius="20" ShadowDepth="0" Opacity="0.25"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBox x:Name="AIInput" Background="Transparent" Foreground="#e0e0e8" 
                                             BorderThickness="0" FontSize="13" TextWrapping="Wrap"
                                             AcceptsReturn="True" MaxHeight="80" VerticalScrollBarVisibility="Auto"
                                             KeyDown="AIInput_KeyDown" TextChanged="AIInput_TextChanged"
                                             CaretBrush="#00d4ff">
                                        <TextBox.Triggers>
                                            <EventTrigger RoutedEvent="GotKeyboardFocus">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="AIInputContainer"
                                                                         Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)"
                                                                         To="28" Duration="0:0:0.12"/>
                                                        <DoubleAnimation Storyboard.TargetName="AIInputContainer"
                                                                         Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)"
                                                                         To="0.55" Duration="0:0:0.12"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                            <EventTrigger RoutedEvent="LostKeyboardFocus">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="AIInputContainer"
                                                                         Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)"
                                                                         To="20" Duration="0:0:0.12"/>
                                                        <DoubleAnimation Storyboard.TargetName="AIInputContainer"
                                                                         Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)"
                                                                         To="0.25" Duration="0:0:0.12"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </TextBox.Triggers>
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Style.Triggers>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                                    <VisualBrush.Visual>
                                                                        <TextBlock Text="Describe what to build next" 
                                                                                   Foreground="#6b7280" FontSize="13"/>
                                                                    </VisualBrush.Visual>
                                                                </VisualBrush>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    
                                    <!-- Send Button -->
                                    <Button Grid.Column="1" x:Name="SendAIBtn" Click="SendAI_Click" 
                                            Width="40" Height="40" Margin="8,0,0,0" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" CornerRadius="8">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#00d4ff" Offset="0"/>
                                                            <GradientStop Color="#b967ff" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#00d4ff" BlurRadius="15" ShadowDepth="0" Opacity="0.3"/>
                                                    </Border.Effect>
                                                    <TextBlock Text="➤" FontSize="16" Foreground="White" 
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect Color="#00d4ff" BlurRadius="25" ShadowDepth="0" Opacity="0.5"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        
        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#080810" Padding="12,4" BorderBrush="#1e293b" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Git Branch -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,16,0">
                    <TextBlock Text="⎇" Foreground="#00d4ff" FontSize="11" Margin="0,0,4,0"/>
                    <TextBlock x:Name="GitBranch" Text="main" FontSize="11" Foreground="#8b8b9a"/>
                </StackPanel>
                
                <!-- Sync Status -->
                <Border Grid.Column="1" Width="8" Height="8" CornerRadius="4" Background="#00ff9f" Margin="0,0,16,0"
                        ToolTip="Synced">
                    <Border.Effect>
                        <DropShadowEffect Color="#00ff9f" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                    </Border.Effect>
                </Border>
                
                <TextBlock x:Name="StatusText" Grid.Column="2" Text="Ready" FontSize="11" Foreground="#8b8b9a"/>
                
                <!-- Errors/Warnings -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="16,0">
                    <TextBlock Text="⚠" Foreground="#ff1493" FontSize="10" Margin="0,0,4,0"/>
                    <TextBlock x:Name="ErrorCount" Text="0" FontSize="11" Foreground="#ff1493" Margin="0,0,8,0"/>
                    <TextBlock Text="⚡" Foreground="#ffaa00" FontSize="10" Margin="0,0,4,0"/>
                    <TextBlock x:Name="WarningCount" Text="0" FontSize="11" Foreground="#ffaa00"/>
                </StackPanel>
                
                <TextBlock x:Name="CursorPosition" Grid.Column="4" Text="Ln 1, Col 1" FontSize="11" Foreground="#8b8b9a" Margin="16,0"/>
                <TextBlock x:Name="FileEncoding" Grid.Column="5" Text="UTF-8" FontSize="11" Foreground="#8b8b9a" Margin="16,0"/>
                <TextBlock x:Name="FileLanguage" Grid.Column="6" Text="C#" FontSize="11" Foreground="#00d4ff" Margin="16,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
