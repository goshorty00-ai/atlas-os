<UserControl x:Class="AtlasAI.Coding.Controls.DiffPreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="500">
    
    <UserControl.Resources>
        <!-- Diff line colors -->
        <SolidColorBrush x:Key="AdditionBg" Color="#1a2d1a"/>
        <SolidColorBrush x:Key="AdditionFg" Color="#4ade80"/>
        <SolidColorBrush x:Key="DeletionBg" Color="#2d1a1a"/>
        <SolidColorBrush x:Key="DeletionFg" Color="#f87171"/>
        <SolidColorBrush x:Key="ContextBg" Color="#0a0a0f"/>
        <SolidColorBrush x:Key="ContextFg" Color="#9ca3af"/>
        <SolidColorBrush x:Key="LineNumberFg" Color="#4b5563"/>
    </UserControl.Resources>
    
    <Border Background="#080810" CornerRadius="8" BorderBrush="#1a1a24" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Border Grid.Row="0" Background="#0f0f18" CornerRadius="8,8,0,0" Padding="12,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="FilePathText" Text="untitled" FontSize="12" 
                                       Foreground="#e0e0e0" FontFamily="Consolas" VerticalAlignment="Center"/>
                            <Border x:Name="ModeBadge" Background="#1a2e1a" CornerRadius="4" 
                                    Padding="6,2" Margin="10,0,0,0">
                                <TextBlock x:Name="ModeText" Text="SELECTION" FontSize="9" 
                                           FontWeight="SemiBold" Foreground="#4ade80"/>
                            </Border>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock x:Name="StatsText" Text="+0 -0" FontSize="11" 
                                       Foreground="#6b7280" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Button x:Name="CopyDiffButton" Content="📋" ToolTip="Copy Diff"
                                    Background="Transparent" BorderThickness="0" Foreground="#6b7280"
                                    FontSize="14" Cursor="Hand" Padding="4" Click="CopyDiffButton_Click"/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Intent Header -->
                    <Border Grid.Row="1" x:Name="IntentHeaderPanel" Background="#12121a" 
                            CornerRadius="4" Padding="8,6" Margin="0,8,0,0" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💡" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="IntentText" Text="" FontSize="11" 
                                       Foreground="#9ca3af" FontStyle="Italic" TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
            
            <!-- Diff Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <StackPanel x:Name="DiffContent" Margin="0">
                    <!-- Diff lines will be added dynamically -->
                    <TextBlock x:Name="EmptyMessage" Text="No changes to preview" 
                               Foreground="#6b7280" FontSize="12" TextAlignment="Center" 
                               Margin="0,40" Visibility="Visible"/>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Quick Actions Footer -->
            <Border Grid.Row="2" Background="#0f0f18" CornerRadius="0,0,8,8" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="RejectButton" Content="✕ Reject" 
                                Background="#2d1a1a" Foreground="#f87171" BorderThickness="0"
                                Padding="12,6" FontSize="11" Cursor="Hand" Margin="0,0,8,0"
                                Click="RejectButton_Click"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="OpenFileButton" Content="📂 Open File" 
                                Background="#1a1a24" Foreground="#9ca3af" BorderThickness="0"
                                Padding="12,6" FontSize="11" Cursor="Hand" Margin="0,0,8,0"
                                Click="OpenFileButton_Click" Visibility="Collapsed"/>
                        <Button x:Name="ApplyButton" Content="✓ Apply" 
                                Background="#1a2e1a" Foreground="#4ade80" BorderThickness="0"
                                Padding="16,6" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                                Click="ApplyButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
