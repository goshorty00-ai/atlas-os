<UserControl x:Class="AtlasAI.Coding.Controls.ChatQuickActionsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="400">
    
    <UserControl.Resources>
        <Style x:Key="QuickActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#1a1a24"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2a2a3a"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#252538"/>
                                <Setter Property="BorderBrush" Value="#3a3a4a"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1a1a24"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="ApplyBtn" TargetType="Button" BasedOn="{StaticResource QuickActionBtn}">
            <Setter Property="Background" Value="#1a2e1a"/>
            <Setter Property="Foreground" Value="#4ade80"/>
            <Setter Property="BorderBrush" Value="#2a4a2a"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#254025"/>
                    <Setter Property="BorderBrush" Value="#3a5a3a"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="StageBtn" TargetType="Button" BasedOn="{StaticResource QuickActionBtn}">
            <Setter Property="Background" Value="#1a1a2e"/>
            <Setter Property="Foreground" Value="#60a5fa"/>
            <Setter Property="BorderBrush" Value="#2a2a4a"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#252540"/>
                    <Setter Property="BorderBrush" Value="#3a3a5a"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    
    <Border Background="#0a0a0f" CornerRadius="8" Padding="8,6">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left: Context info -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border x:Name="SelectionBadge" Background="#1a2e1a" CornerRadius="4" 
                        Padding="6,2" Margin="0,0,8,0" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📝" FontSize="10" Margin="0,0,4,0"/>
                        <TextBlock x:Name="SelectionInfo" Text="Lines 1-10" FontSize="10" Foreground="#4ade80"/>
                    </StackPanel>
                </Border>
                <TextBlock x:Name="ContextText" Text="Ready to apply changes" 
                           FontSize="11" Foreground="#6b7280" VerticalAlignment="Center"/>
            </StackPanel>
            
            <!-- Right: Quick action buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="CopyDiffButton" Content="📋 Copy Diff" 
                        Style="{StaticResource QuickActionBtn}" 
                        Click="CopyDiffButton_Click" Visibility="Collapsed"/>
                
                <Button x:Name="OpenFileButton" Content="📂 Open" 
                        Style="{StaticResource QuickActionBtn}" 
                        Click="OpenFileButton_Click" Visibility="Collapsed"/>
                
                <Button x:Name="ApplyStageButton" Content="📦 Stage" 
                        Style="{StaticResource StageBtn}" 
                        Click="ApplyStageButton_Click" Visibility="Collapsed"
                        ToolTip="Stage changes for multi-file apply"/>
                
                <Button x:Name="ApplyButton" Content="✓ Apply" 
                        Style="{StaticResource ApplyBtn}" 
                        Click="ApplyButton_Click" IsEnabled="False"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
