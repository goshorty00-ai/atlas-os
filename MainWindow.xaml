<Window x:Class="AtlasAI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AtlasAI.Controls"
        Title="Atlas AI" Height="150" Width="150"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{StaticResource AtlasBackground}"
        Topmost="False"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Left="10"
        Top="10"
        Icon="atlas.ico"
        RenderOptions.BitmapScalingMode="HighQuality"
        RenderOptions.EdgeMode="Aliased"
        TextOptions.TextRenderingMode="Grayscale"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        CacheMode="BitmapCache">
    
    <!-- ORB REMOVED - User creating custom orb in Unreal Engine -->
    <Grid x:Name="AvatarContainer" RenderOptions.CachingHint="Cache" CacheMode="BitmapCache">
        <!-- Empty - No orb needed -->
        <Image Source="/atlas.ico" Width="64" Height="64" HorizontalAlignment="Center" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
    </Grid>
</Window>
