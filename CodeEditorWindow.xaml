<Window x:Class="AtlasAI.CodeEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AtlasAI.Coding.Controls"
        Title="Atlas IDE" Height="900" Width="1500"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#0a0a0f"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        Loaded="Window_Loaded">
    
    <Window.Resources>
        <!-- Atlas IDE Futuristic Theme Colors -->
        <!-- Background: #0a0a0f, Panel: #080810, Cyan: #00d4ff, Purple: #b967ff, Success: #00ff9f -->
        
        <!-- Toolbar button with cyan hover -->
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9ca3af"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" 
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1a1a24"/>
                                <Setter Property="Foreground" Value="#00d4ff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Cyan accent button (Run) -->
        <Style x:Key="CyanBtn" TargetType="Button">
            <Setter Property="Background" Value="#00d4ff"/>
            <Setter Property="Foreground" Value="#0a0a0f"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" 
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#33e0ff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Purple accent button (Debug) -->
        <Style x:Key="PurpleBtn" TargetType="Button">
            <Setter Property="Background" Value="#b967ff"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" 
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#c98aff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Green accent button (Send) -->
        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Background" Value="#00ff9f"/>
            <Setter Property="Foreground" Value="#0a0a0f"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" 
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#33ffb3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Toggle button style for verification options -->
        <Style x:Key="ToggleBtn" TargetType="ToggleButton">
            <Setter Property="Background" Value="#1a1a24"/>
            <Setter Property="Foreground" Value="#6b7280"/>
            <Setter Property="BorderBrush" Value="#2a2a3a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#00d4ff20"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#00d4ff"/>
                                <Setter Property="Foreground" Value="#00d4ff"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#00d4ff80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Tree view item style -->
        <Style x:Key="TreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Margin" Value="0,1"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#00d4ff20"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1a1a24"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Tab button style -->
        <Style x:Key="TabBtn" TargetType="Button">
            <Setter Property="Background" Value="#0f0f18"/>
            <Setter Property="Foreground" Value="#9ca3af"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" 
                                BorderBrush="#00d4ff00" BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1a1a24"/>
                                <Setter Property="Foreground" Value="#e0e0e0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Border CornerRadius="10" Background="#0a0a0f" BorderBrush="#00d4ff40" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>
            
            <!-- Top Header Bar - Futuristic Atlas IDE style -->
            <Border Grid.Row="0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#103B0000" Offset="0"/>
                        <GradientStop Color="#080810" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#3B0000" Offset="0.5"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.BorderThickness>
                    <Thickness>0,0,0,1</Thickness>
                </Border.BorderThickness>
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Left: Logo + Actions -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Atlas IDE Logo with glow -->
                        <Border Margin="0,0,16,0" Padding="8,4" CornerRadius="6">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#00d4ff20" Offset="0"/>
                                        <GradientStop Color="#b967ff20" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚡" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Atlas IDE" FontSize="15" FontWeight="Bold" VerticalAlignment="Center">
                                    <TextBlock.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#3B0000" Offset="0"/>
                                            <GradientStop Color="#1A0000" Offset="1"/>
                                        </LinearGradientBrush>
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <Button Content="📂 Open" Style="{StaticResource ToolBtn}" Click="OpenFolder_Click"/>
                        <Button Content="📄 New" Style="{StaticResource ToolBtn}" Click="NewFile_Click"/>
                        <Button Content="💾 Save" Style="{StaticResource ToolBtn}" Click="SaveFile_Click"/>
                        <Button Content="💾 Save All" Style="{StaticResource ToolBtn}" Click="SaveAll_Click"/>
                    </StackPanel>
                    
                    <!-- Center: Command Palette Search -->
                    <Border Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                            CornerRadius="8" Width="420">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#083B0000" Offset="0"/>
                                <GradientStop Color="#081A0000" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#00d4ff40"/>
                        </Border.BorderBrush>
                        <Border.BorderThickness>
                            <Thickness>1</Thickness>
                        </Border.BorderThickness>
                        <TextBox x:Name="SearchBox" Background="Transparent" Foreground="#e0e0e0" 
                                 BorderThickness="0" Padding="14,10" FontSize="13"
                                 CaretBrush="#00d4ff" KeyDown="SearchBox_KeyDown">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <VisualBrush Stretch="None" AlignmentX="Left">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="🔍 Search files, symbols, commands... (Ctrl+P)" Foreground="#6b7280" Margin="14,0"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Border>
                    
                    <!-- Right: Run/Debug + Window controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="▶ Run" Style="{StaticResource CyanBtn}" Click="RunCode_Click"/>
                        <Button Content="🐛 Debug" Style="{StaticResource PurpleBtn}" Click="DebugCode_Click" Margin="8,0,0,0"/>
                        <Button x:Name="TerminalToggle" Content="⌨" Style="{StaticResource ToolBtn}" Click="ToggleTerminal_Click" Margin="8,0,0,0" ToolTip="Terminal"/>
                        <Rectangle Width="1" Height="24" Fill="#2a2a3a" Margin="12,0"/>
                        <Button Content="─" Style="{StaticResource ToolBtn}" Click="Minimize_Click" Width="36"/>
                        <Button Content="□" Style="{StaticResource ToolBtn}" Click="Maximize_Click" Width="36"/>
                        <Button Content="✕" Style="{StaticResource ToolBtn}" Click="Close_Click" Width="36"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Main Content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="220" MinWidth="180"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition x:Name="AIPanelColumn" Width="380" MinWidth="300"/>
                </Grid.ColumnDefinitions>
                
                <!-- Icon Sidebar - Futuristic style -->
                <Border Background="#080810" BorderBrush="#1a1a24" BorderThickness="0,0,1,0">
                    <StackPanel Margin="0,12">
                        <Button Content="📁" Style="{StaticResource ToolBtn}" ToolTip="Explorer" Click="ShowExplorer_Click" FontSize="18" Padding="12,10"/>
                        <Button Content="🔍" Style="{StaticResource ToolBtn}" ToolTip="Search" Click="ShowSearch_Click" FontSize="18" Padding="12,10"/>
                        <Button Content="🔀" Style="{StaticResource ToolBtn}" ToolTip="Source Control" FontSize="18" Padding="12,10"/>
                        <Button Content="🐛" Style="{StaticResource ToolBtn}" ToolTip="Debug" FontSize="18" Padding="12,10"/>
                        <Button Content="📦" Style="{StaticResource ToolBtn}" ToolTip="Extensions" FontSize="18" Padding="12,10"/>
                        <Rectangle Height="1" Fill="#1a1a24" Margin="8,12"/>
                        <Button Content="🤖" Style="{StaticResource ToolBtn}" ToolTip="AI Agent" Click="ToggleAIPanel_Click" FontSize="18" Padding="12,10"/>
                        <Button Content="📊" Style="{StaticResource ToolBtn}" ToolTip="Context Manifest" Click="ShowContextManifest_Click" FontSize="18" Padding="12,10"/>
                    </StackPanel>
                </Border>
                
                <!-- File Explorer -->
                <Border Grid.Column="1" Background="#0a0a0f" BorderBrush="#1a1a24" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Border Padding="12,10" BorderBrush="#1a1a24" BorderThickness="0,0,0,1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#083B0000" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <TextBlock x:Name="WorkspaceLabel" Text="EXPLORER" FontSize="11" FontWeight="SemiBold" 
                                           Foreground="#00d4ff" VerticalAlignment="Center"/>
                                <Button Content="⟳" Style="{StaticResource ToolBtn}" HorizontalAlignment="Right" 
                                        Click="RefreshTree_Click" ToolTip="Refresh" Padding="6,4"/>
                            </Grid>
                        </Border>
                        
                        <TreeView x:Name="FileTree" Grid.Row="1" Background="Transparent" BorderThickness="0"
                                  ItemContainerStyle="{StaticResource TreeItemStyle}"
                                  SelectedItemChanged="FileTree_SelectedItemChanged"
                                  MouseDoubleClick="FileTree_MouseDoubleClick"
                                  Padding="8,4"/>
                    </Grid>
                </Border>
                
                <GridSplitter Grid.Column="2" Width="1" Background="#1a1a24" HorizontalAlignment="Center"/>
                
                <!-- Editor Area -->
                <Grid Grid.Column="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition x:Name="TerminalRow" Height="0"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Tabs -->
                    <Border Background="#080810" BorderBrush="#1a1a24" BorderThickness="0,0,0,1">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="TabBar" Orientation="Horizontal" Margin="4,0"/>
                        </ScrollViewer>
                    </Border>
                    
                    <!-- Code Editor -->
                    <Border Grid.Row="1" Background="#0a0a0f">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Line numbers -->
                            <Border Background="#080810" BorderBrush="#1a1a24" BorderThickness="0,0,1,0">
                                <TextBox x:Name="LineNumbers" IsReadOnly="True" Background="Transparent" 
                                         Foreground="#4a4a5a" BorderThickness="0" FontFamily="Cascadia Code, Consolas, monospace"
                                         FontSize="14" Padding="8,12" TextAlignment="Right"
                                         VerticalScrollBarVisibility="Hidden" Text="1"/>
                            </Border>
                            
                            <!-- Code text -->
                            <TextBox x:Name="CodeEditor" Grid.Column="1" 
                                     AcceptsReturn="True" AcceptsTab="True"
                                     Background="Transparent" Foreground="#e0e0e0"
                                     BorderThickness="0" FontFamily="Cascadia Code, Consolas, monospace"
                                     FontSize="14" Padding="12"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap"
                                     CaretBrush="#00d4ff"
                                     SelectionBrush="#00d4ff40"
                                     TextChanged="CodeEditor_TextChanged"
                                     PreviewKeyDown="CodeEditor_PreviewKeyDown"/>
                            
                            <!-- No file open message -->
                            <StackPanel x:Name="NoFileMessage" Grid.ColumnSpan="2" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="Visible">
                                <Border Width="80" Height="80" CornerRadius="16" Margin="0,0,0,20">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#203B0000" Offset="0"/>
                                            <GradientStop Color="#201A0000" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="⚡" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Welcome to Atlas IDE" 
                                           Foreground="#e0e0e0" FontSize="18" FontWeight="SemiBold" TextAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="Open a folder or file to start coding" 
                                           Foreground="#6b7280" FontSize="14" TextAlignment="Center" Margin="0,0,0,16"/>
                                <TextBlock Text="📂 Drag &amp; drop a folder here" 
                                           Foreground="#00d4ff" FontSize="13" TextAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- Terminal Panel -->
                    <Border x:Name="TerminalPanel" Grid.Row="2" Background="#080810" Visibility="Collapsed"
                            BorderBrush="#1a1a24" BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Terminal Header -->
                            <Border Padding="12,8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#083B0000" Offset="0"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="TERMINAL" FontSize="11" FontWeight="SemiBold" Foreground="#00d4ff" 
                                                   VerticalAlignment="Center"/>
                                        <Border Background="#1a1a24" CornerRadius="4" Padding="8,3" Margin="12,0,0,0">
                                            <TextBlock x:Name="TerminalShellLabel" Text="PowerShell" FontSize="11" Foreground="#9ca3af"/>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="🗑" Style="{StaticResource ToolBtn}" Click="ClearTerminal_Click" ToolTip="Clear" Padding="6,4"/>
                                        <Button Content="✕" Style="{StaticResource ToolBtn}" Click="CloseTerminal_Click" ToolTip="Close" Padding="6,4"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            
                            <!-- Terminal Output -->
                            <Border Grid.Row="1" Background="#0a0a0f">
                                <RichTextBox x:Name="TerminalRichOutput" IsReadOnly="True"
                                             Background="Transparent" Foreground="#e0e0e0"
                                             BorderThickness="0" FontFamily="Cascadia Code, Consolas, monospace"
                                             FontSize="13" Padding="12,8"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             IsDocumentEnabled="True">
                                    <RichTextBox.Resources>
                                        <Style TargetType="Paragraph">
                                            <Setter Property="Margin" Value="0,2"/>
                                        </Style>
                                    </RichTextBox.Resources>
                                </RichTextBox>
                            </Border>
                            
                            <!-- Terminal Input -->
                            <Border Grid.Row="2" Background="#080810" Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock x:Name="TerminalPromptDir" Text="~" Foreground="#00ff9f" 
                                                   FontFamily="Cascadia Code, Consolas" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text=" ❯ " Foreground="#00d4ff" FontFamily="Cascadia Code, Consolas" FontSize="13"/>
                                    </StackPanel>
                                    
                                    <TextBox x:Name="TerminalInput" Grid.Column="1" Background="Transparent" 
                                             Foreground="#e0e0e0" BorderThickness="0" FontFamily="Cascadia Code, Consolas"
                                             FontSize="13" CaretBrush="#00d4ff" VerticalAlignment="Center"
                                             PreviewKeyDown="TerminalInput_PreviewKeyDown"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                    
                    <GridSplitter x:Name="TerminalSplitter" Grid.Row="2" Height="1" Background="#1a1a24" 
                                  VerticalAlignment="Top" HorizontalAlignment="Stretch" Visibility="Collapsed"/>
                </Grid>
                
                <GridSplitter Grid.Column="4" Width="1" Background="#1a1a24" HorizontalAlignment="Center"/>
                
                <!-- AI Assistant Panel - Futuristic Agent Mode v2 -->
                <Border Grid.Column="5" BorderBrush="#00d4ff30" BorderThickness="1,0,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#0a0a0f" Offset="0"/>
                            <GradientStop Color="#080810" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- AI Panel Header -->
                        <Border Padding="16,14" BorderBrush="#00d4ff30" BorderThickness="0,0,0,1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#103B0000" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✨" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="AI ASSISTANT" FontSize="13" FontWeight="SemiBold" Foreground="#00d4ff" 
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="+" Style="{StaticResource ToolBtn}" Click="NewChat_Click" ToolTip="New Chat" Padding="6,4"/>
                                    <Button Content="⚙" Style="{StaticResource ToolBtn}" Click="AISettings_Click" ToolTip="Settings" Padding="6,4"/>
                                    <Button Content="🗑" Style="{StaticResource ToolBtn}" Click="ClearChat_Click" ToolTip="Clear" Padding="6,4"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <!-- Agent Mode v2 Controls -->
                        <Border Grid.Row="1" Padding="12,10" BorderBrush="#1a1a24" BorderThickness="0,0,0,1">
                            <StackPanel>
                                <!-- Verification Toggles -->
                                <TextBlock Text="VERIFICATION" FontSize="11" Foreground="#9ca3af" Margin="0,0,0,8" FontWeight="SemiBold"/>
                                <WrapPanel>
                                    <ToggleButton x:Name="BuildToggle" Content="🔨 Build" Style="{StaticResource ToggleBtn}" 
                                                  IsChecked="True" Margin="0,0,6,6" Click="VerificationToggle_Click" FontSize="12"/>
                                    <ToggleButton x:Name="TestToggle" Content="🧪 Test" Style="{StaticResource ToggleBtn}" 
                                                  IsChecked="False" Margin="0,0,6,6" Click="VerificationToggle_Click" FontSize="12"/>
                                    <ToggleButton x:Name="LintToggle" Content="📝 Lint" Style="{StaticResource ToggleBtn}" 
                                                  IsChecked="False" Margin="0,0,6,6" Click="VerificationToggle_Click" FontSize="12"/>
                                    <ToggleButton x:Name="AutoRepairToggle" Content="🔧 Auto-Repair" Style="{StaticResource ToggleBtn}" 
                                                  IsChecked="True" Margin="0,0,6,6" Click="VerificationToggle_Click" FontSize="12"/>
                                </WrapPanel>
                                
                                <!-- Context Budget Indicator -->
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ProgressBar x:Name="ContextBudgetBar" Height="4" Minimum="0" Maximum="100" Value="0"
                                                 Background="#1a1a24" Foreground="#00d4ff"/>
                                    <TextBlock x:Name="ContextBudgetText" Grid.Column="1" Text="0 / 25k" FontSize="12" 
                                               Foreground="#9ca3af" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        
                        <!-- Chat Messages -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" x:Name="ChatScrollViewer">
                            <StackPanel x:Name="AIChat" Margin="16">
                                <!-- Welcome message with gradient icon -->
                                <Border HorizontalAlignment="Center" Margin="0,20,0,20">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="64" Height="64" CornerRadius="16" Margin="0,0,0,16" HorizontalAlignment="Center">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#203B0000" Offset="0"/>
                                                    <GradientStop Color="#201A0000" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Border.BorderBrush>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#603B0000" Offset="0"/>
                                                    <GradientStop Color="#601A0000" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.BorderBrush>
                                            <Border.BorderThickness>
                                                <Thickness>1</Thickness>
                                            </Border.BorderThickness>
                                            <TextBlock Text="✨" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Build with Atlas AI" Foreground="#e0e0e0" FontSize="20" FontWeight="SemiBold" 
                                                   TextAlignment="Center" Margin="0,0,0,8"/>
                                        <TextBlock Text="AI responses may be inaccurate." Foreground="#9ca3af" FontSize="14" 
                                                   TextAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock Text="Describe what you want to build." Foreground="#b0b0b0" FontSize="14" 
                                                   TextAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                        
                        <!-- Diff Preview and Quick Actions -->
                        <StackPanel Grid.Row="3" x:Name="DiffActionsPanel" Visibility="Collapsed">
                            <controls:DiffPreviewControl x:Name="DiffPreview" MaxHeight="200"/>
                            <controls:ChatQuickActionsControl x:Name="ChatQuickActions"/>
                        </StackPanel>
                        
                        <!-- Input Area -->
                        <Border Grid.Row="4" Padding="14" BorderBrush="#00d4ff30" BorderThickness="0,1,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                    <GradientStop Color="#083B0000" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Context attachment bar -->
                                <Border Margin="0,0,0,10" Padding="10,8" CornerRadius="8"
                                        Background="#00d4ff08" BorderBrush="#00d4ff30" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="📎" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox x:Name="ContextInput" Grid.Column="1" Background="Transparent" 
                                                 Foreground="#b0b0b0" BorderThickness="0" FontSize="13"
                                                 CaretBrush="#00d4ff" VerticalAlignment="Center">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Style.Triggers>
                                                        <Trigger Property="Text" Value="">
                                                            <Setter Property="Background">
                                                                <Setter.Value>
                                                                    <VisualBrush Stretch="None" AlignmentX="Left">
                                                                        <VisualBrush.Visual>
                                                                            <TextBlock Text="Add context (files, symbols)..." Foreground="#6b7280" FontSize="13"/>
                                                                        </VisualBrush.Visual>
                                                                    </VisualBrush>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </Grid>
                                </Border>
                                
                                <!-- Main input -->
                                <Border Grid.Row="1" CornerRadius="12" Padding="14,12">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#00d4ff15" Offset="0"/>
                                            <GradientStop Color="#b967ff15" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#00d4ff50" Offset="0"/>
                                        <GradientStop Color="#b967ff50" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <Border.BorderThickness>
                                        <Thickness>1</Thickness>
                                    </Border.BorderThickness>
                                    <TextBox x:Name="AIInput" Background="Transparent" Foreground="#e0e0e0"
                                             BorderThickness="0" Padding="0"
                                             FontSize="15" AcceptsReturn="False" TextWrapping="Wrap"
                                             MaxHeight="100" VerticalScrollBarVisibility="Auto"
                                             CaretBrush="#00d4ff"
                                             PreviewKeyDown="AIInput_KeyDown">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Style.Triggers>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <VisualBrush Stretch="None" AlignmentX="Left" AlignmentY="Top">
                                                                    <VisualBrush.Visual>
                                                                        <TextBlock Text="Describe what to build next..." Foreground="#9ca3af" FontSize="15"/>
                                                                    </VisualBrush.Visual>
                                                                </VisualBrush>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Border>
                                
                                <!-- Action buttons -->
                                <Grid Grid.Row="2" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Agent mode selector -->
                                        <Border Background="#00d4ff15" BorderBrush="#00d4ff50" BorderThickness="1" 
                                                CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Agent" Foreground="#00d4ff" FontSize="12"/>
                                                <TextBlock Text=" ▼" Foreground="#00d4ff" FontSize="10"/>
                                            </StackPanel>
                                        </Border>
                                        
                                        <!-- Auto mode selector -->
                                        <Border Background="#b967ff15" BorderBrush="#b967ff50" BorderThickness="1" 
                                                CornerRadius="4" Padding="8,4">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Auto" Foreground="#b967ff" FontSize="12"/>
                                                <TextBlock Text=" ▼" Foreground="#b967ff" FontSize="10"/>
                                                                                    <!-- Inline mic note (auto-clears) -->
                                                                                    <TextBlock x:Name="CodeMicNote" Text="" Foreground="#6b7280" FontSize="11"
                                                                                               VerticalAlignment="Center" Margin="10,0,0,0" Visibility="Collapsed"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="📎" Style="{StaticResource ToolBtn}" Click="AttachFile_Click" 
                                                ToolTip="Attach file" Padding="8,6"/>
                                                            <!-- Mic button: fills AIInput only; no auto-run; shows "Mic not wired" if unwired -->
                                                            <Button x:Name="CodeMicBtn" Content="🎙" Style="{StaticResource ToolBtn}"
                                                                Click="CodeMicBtn_Click" ToolTip="Prompt mic" Padding="8,6"/>
                                        <Button x:Name="ApplyBtn" Content="✨ Apply" Style="{StaticResource PurpleBtn}" 
                                                Click="ApplyChanges_Click" Visibility="Collapsed" Margin="4,0"/>
                                        <Button Click="SendAI_Click" Margin="4,0,0,0" Padding="16,8" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#00d4ff" Offset="0"/>
                                                                <GradientStop Color="#b967ff" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <TextBlock Text="➤" Foreground="White" FontSize="14" FontWeight="Bold"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Opacity" Value="0.9"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
            
            <!-- Status Bar - Futuristic style -->
            <Border Grid.Row="2" Padding="12,4" BorderBrush="#00d4ff30" BorderThickness="0,1,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                        <GradientStop Color="#00d4ff08" Offset="0"/>
                        <GradientStop Color="#080810" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Verification status indicator -->
                    <Border x:Name="VerificationStatus" Background="#00ff9f20" CornerRadius="4" Padding="8,2" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="VerificationIcon" Text="✓" Foreground="#00ff9f" FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock x:Name="VerificationText" Text="Ready" Foreground="#00ff9f" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <TextBlock x:Name="StatusText" Grid.Column="1" Text="Atlas IDE v2.0" Foreground="#6b7280" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock x:Name="CursorPosition" Grid.Column="2" Text="Ln 1, Col 1" Foreground="#4a4a5a" FontSize="11" Margin="20,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="LanguageLabel" Grid.Column="3" Text="C#" Foreground="#00d4ff" FontSize="11" Margin="20,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="EncodingLabel" Grid.Column="4" Text="UTF-8" Foreground="#4a4a5a" FontSize="11" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    
                    <!-- Agent mode indicator -->
                    <Border Grid.Column="5" CornerRadius="4" Padding="8,2">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00d4ff20" Offset="0"/>
                                <GradientStop Color="#b967ff20" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="⚡ Agent Mode v2" FontSize="11" VerticalAlignment="Center">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#00d4ff" Offset="0"/>
                                    <GradientStop Color="#b967ff" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

