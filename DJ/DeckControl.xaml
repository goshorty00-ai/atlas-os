<UserControl x:Class="AtlasAI.DJ.DeckControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AtlasAI.DJ">
    <UserControl.Resources>
        <SolidColorBrush x:Key="AtlasAccentBrush" Color="#22D3EE"/>
        <LinearGradientBrush x:Key="DeckButtonBackground" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#18202A" Offset="0"/>
            <GradientStop Color="#0E1620" Offset="1"/>
        </LinearGradientBrush>
        <ControlTemplate x:Key="EmptyRepeatButton" TargetType="RepeatButton">
            <Border Background="Transparent" />
        </ControlTemplate>
        <Style x:Key="CircleIconButton" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="#14121a"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=Resources[AtlasAccentBrush].Color}" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=Resources[AtlasAccentBrush].Color}" BlurRadius="12" ShadowDepth="0" Opacity="0.6"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=Resources[AtlasAccentBrush].Color}" BlurRadius="16" ShadowDepth="0" Opacity="0.9"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="AccentSlider" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Track x:Name="PART_Track"
                                   Maximum="{TemplateBinding Maximum}"
                                   Minimum="{TemplateBinding Minimum}"
                                   Value="{TemplateBinding Value}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton IsEnabled="False" Template="{StaticResource EmptyRepeatButton}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="14" Height="14">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="{DynamicResource AtlasAccentBrush}" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton IsEnabled="False" Template="{StaticResource EmptyRepeatButton}"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Background" Value="{x:Null}"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="{StaticResource DeckButtonBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource AtlasTextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border x:Name="CardTop" CornerRadius="12" Padding="12" Background="{DynamicResource AtlasSurfaceBrush}" BorderBrush="{DynamicResource AtlasAccentBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid Margin="0,0,16,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Width="60" Height="60" CornerRadius="30" BorderBrush="{DynamicResource AtlasAccentBrush}" BorderThickness="2">
                        <Border.Effect>
                            <DropShadowEffect Color="#22D3EE" BlurRadius="50" ShadowDepth="0" Opacity="0.6"/>
                        </Border.Effect>
                        <Grid>
                            <Ellipse x:Name="Platter" Width="44" Height="44" Fill="{DynamicResource AtlasAccentBrush}" Opacity="0.2">
                                <Ellipse.RenderTransform>
                                    <RotateTransform x:Name="PlatterRot" Angle="0" CenterX="22" CenterY="22"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Rectangle x:Name="PlatterNotch" Width="2" Height="20" Fill="{DynamicResource AtlasAccentBrush}" VerticalAlignment="Top" Margin="0,10,0,0">
                                <Rectangle.RenderTransform>
                                    <RotateTransform x:Name="PlatterNotchRot" Angle="0" CenterX="1" CenterY="20"/>
                                </Rectangle.RenderTransform>
                            </Rectangle>
                            <Ellipse x:Name="Ring" Width="54" Height="54" Stroke="{DynamicResource AtlasAccentBrush}" StrokeThickness="2" Opacity="0.6">
                                <Ellipse.RenderTransform>
                                    <RotateTransform x:Name="RingRot" Angle="0" CenterX="27" CenterY="27"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Grid>
                    </Border>
                    <TextBlock Grid.Row="1" Text="PLATTER" Foreground="{DynamicResource AtlasTextMutedBrush}" FontSize="10" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </Grid>
                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="DeckTitle" Text="DECK" FontSize="16" Foreground="{DynamicResource AtlasTextPrimaryBrush}"/>
                    <TextBlock x:Name="DeckInfo" Text="" FontSize="12" Foreground="{DynamicResource AtlasTextMutedBrush}" Margin="0,2,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Style="{StaticResource CircleIconButton}" Content="⏮" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource CircleIconButton}" Content="⏯" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource CircleIconButton}" Content="⏭" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource CircleIconButton}" Content="⚙"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button x:Name="LoadBtn" Content="Load" Width="60" Height="28" Margin="0,0,8,0"/>
                        <Button x:Name="PlayBtn" Content="Play" Width="60" Height="28" Margin="0,0,8,0">
                            <Button.Effect>
                                <DropShadowEffect x:Name="PlayGlow" Color="#22D3EE" BlurRadius="0" ShadowDepth="0" Opacity="1"/>
                            </Button.Effect>
                        </Button>
                        <Button x:Name="PauseBtn" Content="Pause" Width="70" Height="28"/>
                    </StackPanel>
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock x:Name="TrackTitle" Text="" Foreground="{DynamicResource AtlasTextSecondaryBrush}" FontSize="13"/>
                        <TextBlock x:Name="TrackMeta" Text="" Foreground="{DynamicResource AtlasTextMutedBrush}" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <TextBlock Text="BPM" Foreground="{DynamicResource AtlasTextMutedBrush}" FontSize="10" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="DeckBpm" Text="0" Foreground="{DynamicResource AtlasTextPrimaryBrush}" FontSize="14" HorizontalAlignment="Right" Margin="0,0,0,8"/>
                    <TextBlock Text="TIME" Foreground="{DynamicResource AtlasTextMutedBrush}" FontSize="10" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="DeckDuration" Text="00:00" Foreground="{DynamicResource AtlasTextPrimaryBrush}" FontSize="14" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>
        <Border x:Name="CardMid" Grid.Row="1" Margin="0,12,0,0" CornerRadius="12" Padding="12" Background="{DynamicResource AtlasSurfaceBrush}" BorderBrush="{DynamicResource AtlasAccentBrush}" BorderThickness="1">
            <StackPanel>
                <local:WaveformDisplay x:Name="Wave" Height="96" Margin="0,0,0,8"/>
                <TextBlock Text="Channel Volume" Foreground="{DynamicResource AtlasTextMutedBrush}" FontSize="12"/>
                <Grid Margin="0,4,0,0">
                    <ProgressBar x:Name="VolFill" Minimum="0" Maximum="100" Height="6" Foreground="{DynamicResource AtlasAccentBrush}" Background="#10212F"/>
                    <Slider x:Name="VolSlider" Style="{StaticResource AccentSlider}" Minimum="0" Maximum="100" Value="80" />
                </Grid>
                <TextBlock Text="Pitch/Tempo" Foreground="{DynamicResource AtlasTextMutedBrush}" FontSize="12" Margin="0,8,0,0"/>
                <Grid Margin="0,4,0,0">
                    <ProgressBar x:Name="TempoFill" Minimum="0" Maximum="16" Height="6" Foreground="{DynamicResource AtlasAccentBrush}" Background="#10212F"/>
                    <Slider x:Name="TempoSlider" Style="{StaticResource AccentSlider}" Minimum="-8" Maximum="8" Value="0"/>
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button x:Name="CueIntroBtn" Content="INTRO" Width="64" Height="28" Margin="0,0,8,0"/>
                    <Button x:Name="CueDropBtn" Content="DROP" Width="64" Height="28" Margin="0,0,8,0"/>
                    <Button x:Name="CueBreakBtn" Content="BREAK" Width="64" Height="28" Margin="0,0,8,0"/>
                    <Button x:Name="CueBuildBtn" Content="BUILD" Width="64" Height="28"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button x:Name="LoopInBtn" Content="LOOP IN" Width="72" Height="28" Margin="0,0,8,0"/>
                    <Button x:Name="LoopOutBtn" Content="LOOP OUT" Width="80" Height="28" Margin="0,0,8,0"/>
                    <Button x:Name="LoopClearBtn" Content="CLEAR" Width="64" Height="28"/>
                </StackPanel>
            </StackPanel>
        </Border>
        <Border x:Name="CardBottom" Grid.Row="2" Margin="0,12,0,0" CornerRadius="12" Padding="12" Background="{DynamicResource AtlasSurfaceBrush}" BorderBrush="{DynamicResource AtlasAccentBrush}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="3-Band EQ" Foreground="{DynamicResource AtlasTextMutedBrush}" FontSize="12"/>
                <StackPanel Margin="0,8,0,0">
                    <TextBlock Text="High" Foreground="{DynamicResource AtlasTextMutedBrush}" FontSize="11"/>
                    <Grid>
                        <ProgressBar x:Name="EqHighFill" Minimum="0" Maximum="100" Height="6" Foreground="{DynamicResource AtlasAccentBrush}" Background="#0E1A24"/>
                        <Slider x:Name="EqHigh" Style="{StaticResource AccentSlider}" Minimum="0" Maximum="100" Value="50"/>
                    </Grid>
                    <TextBlock Text="Mid" Foreground="{DynamicResource AtlasTextMutedBrush}" FontSize="11" Margin="0,6,0,0"/>
                    <Grid>
                        <ProgressBar x:Name="EqMidFill" Value="{Binding ElementName=EqMid, Path=Value}" Minimum="0" Maximum="100" Height="6" Foreground="{DynamicResource AtlasAccentBrush}" Background="#0E1A24"/>
                        <Slider x:Name="EqMid" Style="{StaticResource AccentSlider}" Minimum="0" Maximum="100" Value="50"/>
                    </Grid>
                    <TextBlock Text="Low" Foreground="{DynamicResource AtlasTextMutedBrush}" FontSize="11" Margin="0,6,0,0"/>
                    <Grid>
                        <ProgressBar x:Name="EqLowFill" Minimum="0" Maximum="100" Height="6" Foreground="{DynamicResource AtlasAccentBrush}" Background="#0E1A24"/>
                        <Slider x:Name="EqLow" Style="{StaticResource AccentSlider}" Minimum="0" Maximum="100" Value="50"/>
                    </Grid>
                </StackPanel>
                <ProgressBar x:Name="Progress" Height="6" Margin="0,12,0,0" Minimum="0" Maximum="100"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
