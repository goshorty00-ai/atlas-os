<UserControl x:Class="AtlasAI.DJ.DjConsoleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">
    <Grid Background="{DynamicResource AtlasSpaceGradient}">
        <wv2:WebView2 x:Name="DjWebView" />

        <Button Click="RestoreShellChrome_Click"
                Width="26"
                Height="26"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,12,12,0"
                Padding="0"
                Background="#1A0F172A"
                Foreground="#EAF2F8"
                BorderBrush="#331E293B"
                BorderThickness="1"
                ToolTip="Restore Atlas header and sidebar"
                Content="˄"
                Panel.ZIndex="12"/>

        <Border x:Name="MissingUiOverlay"
                Background="#E60A0D12"
                Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="560">
                <TextBlock Text="DJ workspace unavailable"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center" />
                <TextBlock Margin="0,12,0,0"
                           Text="Atlas could not find the embedded DJ WebView bundle. Build Figma\djcode and rebuild Atlas so the dist files are copied into the desktop runtime output."
                           Foreground="#B8C0CC"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
