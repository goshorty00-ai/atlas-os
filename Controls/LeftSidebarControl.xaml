                    </RadioButton.ToolTip>
                    <RadioButton.Tag>Create</RadioButton.Tag>
                    <Grid Width="50" Height="50" IsHitTestVisible="False">
                        <Image Style="{StaticResource SidebarIconImage}">
                            <Image.Source>
                                <MultiBinding Converter="{StaticResource SidebarIconSourceConverter}">
                                    <Binding RelativeSource="{RelativeSource AncestorType=RadioButton}" Path="Tag"/>
                                    <Binding RelativeSource="{RelativeSource AncestorType=RadioButton}" Path="IsChecked"/>
                                    <Binding RelativeSource="{RelativeSource AncestorType=RadioButton}" Path="IsMouseOver"/>
                                </MultiBinding>
                            </Image.Source>
                        </Image>
                    </Grid>
                </RadioButton>

                <RadioButton x:Name="CodeButton"
                             GroupName="LeftSidebar"
                             Style="{StaticResource SidebarIconButton}"
                             Margin="0"
                             Checked="SidebarItem_Checked">
                    <RadioButton.ToolTip>
                        <ToolTip Style="{StaticResource SidebarTooltip}" Content="AI Code"/>
                    </RadioButton.ToolTip>
                    <RadioButton.Tag>Code</RadioButton.Tag>
                    <Grid Width="50" Height="50" IsHitTestVisible="False">
                        <Image Style="{StaticResource SidebarIconImage}">
                            <Image.Source>
                                <MultiBinding Converter="{StaticResource SidebarIconSourceConverter}">
                                    <Binding RelativeSource="{RelativeSource AncestorType=RadioButton}" Path="Tag"/>
                                    <Binding RelativeSource="{RelativeSource AncestorType=RadioButton}" Path="IsChecked"/>
                                    <Binding RelativeSource="{RelativeSource AncestorType=RadioButton}" Path="IsMouseOver"/>
                                </MultiBinding>
                            </Image.Source>
                        </Image>
                    </Grid>
                </RadioButton>

                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="1" Margin="0,0,0,6" HorizontalAlignment="Center">
                    <Button x:Name="SettingsButton"
                            Style="{StaticResource SidebarActionButton}"
                            Click="SettingsButton_Click">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource SidebarTooltip}" Content="Settings"/>
                        </Button.ToolTip>
                        <TextBlock Text="&#xE713;"
                                   FontFamily="{StaticResource AtlasFontIcon}"
                                   FontSize="18"
                                   Foreground="#22d3ee"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
