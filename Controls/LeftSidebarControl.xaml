                              HorizontalScrollBarVisibility="Disabled"
                              Focusable="True"
                              PreviewMouseWheel="SidebarScrollViewer_PreviewMouseWheel"
                              PreviewKeyDown="SidebarScrollViewer_PreviewKeyDown">
                    <ScrollViewer.Resources>
                        <Style TargetType="{x:Type ScrollBar}">
                            <Setter Property="Width" Value="0"/>
                            <Setter Property="Opacity" Value="0"/>
                            <Setter Property="Focusable" Value="False"/>
                            <Setter Property="IsHitTestVisible" Value="False"/>
                        </Style>
                    </ScrollViewer.Resources>
                    <StackPanel Margin="0,16,0,16" HorizontalAlignment="Center">
                <RadioButton x:Name="ChatButton"
                             GroupName="LeftSidebar"
                             Style="{StaticResource SidebarIconButton}"
                             Checked="SidebarItem_Checked">
                    <RadioButton.ToolTip>
                        <ToolTip Style="{StaticResource SidebarTooltip}" Content="AI Chat"/>
                    </RadioButton.ToolTip>
                    <RadioButton.Tag>Chat</RadioButton.Tag>
                    <Grid Width="50" Height="50" IsHitTestVisible="False">
                        <Image Style="{StaticResource SidebarIconImage}">
                            <Image.Source>
                                <MultiBinding Converter="{StaticResource SidebarIconSourceConverter}">
                                    <Binding RelativeSource="{RelativeSource AncestorType=RadioButton}" Path="Tag"/>
                                    <Binding RelativeSource="{RelativeSource AncestorType=RadioButton}" Path="IsChecked"/>
                                    <Binding RelativeSource="{RelativeSource AncestorType=RadioButton}" Path="IsMouseOver"/>
                                </MultiBinding>
                            </Image.Source>
                        </Image>
                    </Grid>
                </RadioButton>

