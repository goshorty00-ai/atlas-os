<UserControl x:Class="AtlasAI.Controls.SpeedometerGauge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="220"
             d:DesignWidth="180">
    <Grid HorizontalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Viewbox Height="96" Stretch="Uniform">
            <Grid Width="200" Height="120">
                <Path Data="M 30 100 A 70 70 0 0 1 170 100"
                      Stroke="#1E293B"
                      StrokeThickness="8"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Fill="Transparent"/>

                <Path x:Name="ProgressArc"
                      Data="M 30 100 A 70 70 0 0 1 170 100"
                      StrokeThickness="8"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Fill="Transparent">
                    <Path.Stroke>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#4D22D3EE" Offset="0"/>
                            <GradientStop x:Name="MidStop" Color="#9922D3EE" Offset="0.5"/>
                            <GradientStop Color="#4DF97316" Offset="1"/>
                        </LinearGradientBrush>
                    </Path.Stroke>
                    <Path.Effect>
                        <DropShadowEffect Color="#22D3EE" BlurRadius="6" ShadowDepth="0" Opacity="0.5"/>
                    </Path.Effect>
                </Path>

                <Line X1="38" Y1="100" X2="45" Y2="100" Stroke="#475569" StrokeThickness="2"/>
                <Line X1="56.16" Y1="56.16" X2="61.11" Y2="61.11" Stroke="#475569" StrokeThickness="2"/>
                <Line X1="100" Y1="38" X2="100" Y2="45" Stroke="#475569" StrokeThickness="2"/>
                <Line X1="143.84" Y1="56.16" X2="138.89" Y2="61.11" Stroke="#475569" StrokeThickness="2"/>
                <Line X1="162" Y1="100" X2="155" Y2="100" Stroke="#475569" StrokeThickness="2"/>

                <Line x:Name="NeedleLine"
                      X1="100" Y1="100" X2="100" Y2="45"
                      StrokeThickness="3"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round">
                    <Line.Effect>
                        <DropShadowEffect Color="#22D3EE" BlurRadius="6" ShadowDepth="0" Opacity="0.6"/>
                    </Line.Effect>
                    <Line.RenderTransform>
                        <RotateTransform x:Name="NeedleRotate" CenterX="100" CenterY="100" Angle="-90"/>
                    </Line.RenderTransform>
                </Line>

                <Ellipse Width="10" Height="10" Fill="#22D3EE" Canvas.Left="95" Canvas.Top="95" Opacity="0.9">
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="CenterPulse" CenterX="0.5" CenterY="0.5"/>
                    </Ellipse.RenderTransform>
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="CenterPulse"
                                                     Storyboard.TargetProperty="ScaleX"
                                                     From="1" To="1.25"
                                                     Duration="0:0:1"
                                                     AutoReverse="True"/>
                                    <DoubleAnimation Storyboard.TargetName="CenterPulse"
                                                     Storyboard.TargetProperty="ScaleY"
                                                     From="1" To="1.25"
                                                     Duration="0:0:1"
                                                     AutoReverse="True"/>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0.5" To="1"
                                                     Duration="0:0:1"
                                                     AutoReverse="True"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>

                <Canvas>
                    <Path x:Name="IconPath"
                          Width="24"
                          Height="24"
                          Stretch="Uniform"
                          Fill="#22D3EE"
                          Data="{Binding IconGeometry, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          Canvas.Left="88"
                          Canvas.Top="100"/>
                </Canvas>
            </Grid>
        </Viewbox>

        <TextBlock Grid.Row="1"
                   Text="{Binding ValueText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Foreground="{Binding StatusBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   FontFamily="{Binding MonoFontFamily, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   FontSize="32"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0"/>

        <TextBlock Grid.Row="2"
                   Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Foreground="#6B7280"
                   FontFamily="{Binding MonoFontFamily, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   FontSize="11"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Margin="0,4,0,0"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
            <Ellipse Width="6" Height="6" Fill="{Binding StatusBrush, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0.5" To="1"
                                                 Duration="0:0:1"
                                                 AutoReverse="True"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>
            <TextBlock Text="{Binding StatusText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Foreground="#475569"
                       FontFamily="{Binding MonoFontFamily, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontSize="10"
                       Margin="8,0,0,0"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>

