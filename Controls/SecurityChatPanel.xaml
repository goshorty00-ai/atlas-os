<UserControl x:Class="AtlasAI.Controls.SecurityChatPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="384">
    <Grid Background="#660B0F14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="16" BorderBrush="#1A22D3EE" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Security AI Assistant"
                           Foreground="#22D3EE"
                           FontFamily="{Binding MonoFontFamily, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontSize="14"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Ask about security status"
                           Foreground="#64748B"
                           FontFamily="{Binding MonoFontFamily, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontSize="11"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Padding="12" BorderBrush="#1A22D3EE" BorderThickness="0,1,0,1" Panel.ZIndex="10" MinHeight="72"
                PreviewMouseDown="InputArea_PreviewMouseDown">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Padding="8"
                        Background="#0F1419"
                        BorderBrush="#3322D3EE"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid>
                            <TextBox x:Name="InputBox"
                                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                     PreviewKeyDown="InputBox_PreviewKeyDown"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#CBD5E1"
                                     FontFamily="{Binding MonoFontFamily, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                     FontSize="12"
                                     VerticalContentAlignment="Center"
                                     Padding="6,4"
                                     MinHeight="34"
                                     CaretBrush="#22D3EE"/>
                            <TextBlock Text="Ask about security..."
                                       Foreground="#64748B"
                                       FontFamily="{Binding MonoFontFamily, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       FontSize="12"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding InputText}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <Button Grid.Column="1"
                                Command="{Binding SendCommand}"
                                Width="44"
                                Height="44"
                                Background="#1A22D3EE"
                                BorderThickness="0"
                                Margin="10,0,0,0"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="SendBorder"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="10">
                                        <Path Data="M2,12 L22,2 L14,22 L11,13 L2,12 Z"
                                              Fill="#22D3EE"
                                              Width="18"
                                              Height="18"
                                              Stretch="Uniform"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="SendBorder" Property="Background" Value="#3322D3EE"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Effect>
                                <DropShadowEffect Color="#22D3EE" BlurRadius="12" ShadowDepth="0" Opacity="0.3"/>
                            </Button.Effect>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer x:Name="MessagesScroll"
                      Grid.Row="2"
                      VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="16,12,16,16">
            <ItemsControl ItemsSource="{Binding Messages}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="Bubble"
                                Padding="12"
                                Margin="0,0,0,12"
                                CornerRadius="8"
                                BorderThickness="1"
                                MaxWidth="{Binding ElementName=MessagesScroll, Path=ActualWidth}">
                            <Border.RenderTransform>
                                <TranslateTransform Y="20"/>
                            </Border.RenderTransform>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                             From="20" To="0" Duration="0:0:0.3">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock x:Name="SenderText"
                                               FontFamily="{Binding DataContext.MonoFontFamily, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               FontSize="9"
                                               FontWeight="SemiBold"
                                               Text="ATLAS"
                                               Foreground="#22D3EE"/>
                                    <TextBlock Text="  " FontSize="9"/>
                                    <TextBlock FontFamily="{Binding DataContext.MonoFontFamily, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               FontSize="9"
                                               Foreground="#6B7280"
                                               Text="{Binding Timestamp, StringFormat={}{0:t}}"/>
                                </StackPanel>

                                <TextBlock Grid.Row="1"
                                           Text="{Binding Content}"
                                           TextWrapping="Wrap"
                                           Foreground="#CBD5E1"
                                           FontFamily="{Binding DataContext.MonoFontFamily, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           FontSize="12"
                                           LineHeight="18"/>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Bubble" Property="Background" Value="#801E293B"/>
                                <Setter TargetName="Bubble" Property="BorderBrush" Value="#80475569"/>
                                <Setter TargetName="SenderText" Property="Text" Value="USER"/>
                                <Setter TargetName="SenderText" Property="Foreground" Value="#FB923C"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsUser}" Value="False">
                                <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Left"/>
                                <Setter TargetName="Bubble" Property="Background" Value="#0F1419"/>
                                <Setter TargetName="Bubble" Property="BorderBrush" Value="#3322D3EE"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
