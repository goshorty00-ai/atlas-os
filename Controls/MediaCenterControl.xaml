                                                                BorderBrush="#40F59E0B"
                                                                Margin="10,0,0,0">
                                                            <TextBlock Text="PLAY" Foreground="{DynamicResource AtlasCyanBrush}" FontWeight="SemiBold" FontSize="11"/>
                                                        </Button>
                                                        <Button x:Name="DetailsStreamCopyButton"
                                                            Grid.Column="2"
                                                            Command="{Binding DataContext.CopyStreamSourceLinkCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{DynamicResource HeaderActionButtonStyle}"
                                                            BorderBrush="#4067E8F9"
                                                            Margin="8,0,0,0">
                                                            <TextBlock Text="COPY" Foreground="{DynamicResource AtlasCyanBrush}" FontWeight="SemiBold" FontSize="11"/>
                                                        </Button>
                                                        <Border Grid.Row="1"
                                                            Grid.ColumnSpan="3"
                                                                Height="1"
                                                                Background="#262BD3EE"
                                                                Opacity="0.35"
                                                                Margin="0,12,0,0"/>
                                                    </Grid>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding UrlOrPath}" Value="">
                                                        <Setter TargetName="DetailsStreamPlayButton" Property="Visibility" Value="Collapsed"/>
                                                        <Setter TargetName="DetailsStreamCopyButton" Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>

                                <TextBlock Grid.Row="2"
                                           Text="Tip: If this is empty, click REFRESH"
                                           Foreground="{DynamicResource AtlasTextMutedBrush}"
                                           FontSize="12"
                                           Margin="0,8,0,0"/>
                            </Grid>
                        </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.RowSpan="2"
                  Panel.ZIndex="50">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsLibraryOpen}" Value="True"/>
                                    <Condition Binding="{Binding IsPlaying}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Button Command="{Binding CloseLibraryCommand}" Background="#A0000000" BorderThickness="0"/>

                <Border BorderBrush="#40CC0000"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Margin="28">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0A0E14" Offset="0"/>
                            <GradientStop Color="#111A24" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

						<Border x:Name="MediaLibraryHeaderStrip" Grid.Row="0" BorderThickness="0,0,0,1" CornerRadius="0">
							<Border.Style>
								<Style TargetType="Border" BasedOn="{StaticResource GlassPanelBorderStyle}">
									<Setter Property="Visibility" Value="Visible"/>
									<Style.Triggers>
										<DataTrigger Binding="{Binding IsServersView}" Value="True">
											<Setter Property="Visibility" Value="Collapsed"/>
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</Border.Style>
                            <Grid Height="64" Margin="24,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Path Data="M20,6H12L10,4H4A2,2 0 0,0 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8A2,2 0 0,0 20,6Z"
                                          Fill="{DynamicResource AtlasCyanBrush}"
                                          Width="22"
                                          Height="22"
                                          Margin="0,0,12,0"/>
                                    <StackPanel>
                                        <TextBlock Text="MEDIA LIBRARY" Foreground="{DynamicResource AtlasCyanBrush}" FontSize="18" FontWeight="Bold" FontFamily="{DynamicResource AtlasFontPrimary}"/>
                                        <TextBlock Text="Complete Collection" Foreground="{DynamicResource AtlasTextMutedBrush}" FontSize="12" FontFamily="{DynamicResource AtlasFontPrimary}"/>
                                    </StackPanel>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Command="{Binding CloseLibraryCommand}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        Width="40"
                                        Height="40"
                                        Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="#80111A24" BorderBrush="#80475A6A" BorderThickness="1" CornerRadius="12">
                                                <TextBlock Text="✕" Foreground="{DynamicResource AtlasTextSecondaryBrush}" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="BorderBrush" Value="#60CC0000"/>
                                                    <Setter TargetName="bd" Property="Background" Value="#A0111A24"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                            <Border Padding="28">
                                <ItemsControl ItemsSource="{Binding Categories}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="4"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,18,18">
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Id}" Value="servers">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Id}" Value="Servers">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Id}" Value="SERVERS">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Grid>
                                                    <Border x:Name="card"
                                                            Height="200"
                                                            CornerRadius="18"
                                                            BorderBrush="#40CC0000"
                                                            BorderThickness="1">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#FF000000" Offset="0"/>
                                                                <GradientStop Color="#FF2B0000" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>

                                                        <Grid>
                                                            <Ellipse Stroke="#20CC0000"
                                                                     StrokeThickness="1"
                                                                     Opacity="0.7"
                                                                     Margin="28"
                                                                     RenderTransformOrigin="0.5,0.5"
                                                                     StrokeDashArray="2,6">
                                                                <Ellipse.RenderTransform>
                                                                    <RotateTransform x:Name="RingRotate" Angle="0"/>
                                                                </Ellipse.RenderTransform>
                                                                <Ellipse.Triggers>
                                                                    <EventTrigger RoutedEvent="Loaded">
                                                                        <BeginStoryboard>
                                                                            <Storyboard RepeatBehavior="Forever">
                                                                                <DoubleAnimation Storyboard.TargetName="RingRotate"
                                                                                                 Storyboard.TargetProperty="Angle"
                                                                                                 From="0"
                                                                                                 To="360"
                                                                                                 Duration="0:0:20"/>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </EventTrigger>
                                                                </Ellipse.Triggers>
                                                            </Ellipse>

                                                            <Path Data="{Binding IconGeometry}"
                                                                  Width="92"
                                                                  Height="92"
                                                                  Stretch="Uniform"
                                                                  Fill="#66CC0000"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>

                                                            <Border Background="#CC0A0E12"
                                                                    BorderBrush="#40CC0000"
                                                                    BorderThickness="1"
                                                                    CornerRadius="14"
                                                                    Padding="10,4"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Top"
                                                                    Margin="14">
                                                                <TextBlock Text="{Binding Count}"
                                                                           Foreground="{DynamicResource AtlasCyanBrush}"
                                                                           FontFamily="{DynamicResource AtlasFontPrimary}"
                                                                           FontSize="12"
                                                                           FontWeight="SemiBold"/>
                                                            </Border>

                                                            <Button Command="{Binding DataContext.ScanCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Background="Transparent"
                                                                    BorderThickness="0"
                                                                    Width="40"
                                                                    Height="40"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Bottom"
                                                                    Margin="12"
                                                                    Cursor="Hand">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="scanBd" Background="#80111A24" BorderBrush="#40CC0000" BorderThickness="1" CornerRadius="12">
                                                                            <Path Data="M20,6H12L10,4H4A2,2 0 0,0 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8A2,2 0 0,0 20,6Z"
                                                                                  Fill="{DynamicResource AtlasCyanBrush}"
                                                                                  Width="16"
                                                                                  Height="16"
                                                                                  Stretch="Uniform"
                                                                                  HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="scanBd" Property="BorderBrush" Value="#80CC0000"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsEnabled" Value="False">
                                                                                <Setter TargetName="scanBd" Property="Opacity" Value="0.45"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                                <Button.Style>
                                                                    <Style TargetType="Button">
                                                                        <Setter Property="IsEnabled" Value="True"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding DataContext.IsScanning, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                                                <Setter Property="IsEnabled" Value="False"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>
                                                        </Grid>
                                                    </Border>

                                                    <Button x:Name="SelectBtn"
                                                            Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Cursor="Hand"/>
                                                </Grid>

                                                <StackPanel Grid.Row="1" Margin="0,12,0,0" HorizontalAlignment="Center">
                                                    <TextBlock x:Name="LabelText"
                                                               Text="{Binding Label}"
                                                               Foreground="{DynamicResource AtlasTextPrimaryBrush}"
                                                               FontFamily="{DynamicResource AtlasFontPrimary}"
                                                               FontSize="16"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Subtitle}"
                                                               Foreground="{DynamicResource AtlasTextMutedBrush}"
                                                               FontFamily="{DynamicResource AtlasFontPrimary}"
                                                               FontSize="12"
                                                               Margin="0,4,0,0"
                                                               HorizontalAlignment="Center"/>
                                                </StackPanel>

                                            </Grid>
                                            <DataTemplate.Triggers>
                                                <Trigger SourceName="SelectBtn" Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="card" Property="BorderBrush" Value="#33556677"/>
                                                    <Setter TargetName="card" Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect Color="#000000" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Setter TargetName="LabelText" Property="Foreground" Value="{DynamicResource AtlasTextPrimaryBrush}"/>
                                                </Trigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        <Popup x:Name="MediaAiPopup"
               IsOpen="{Binding IsChatVisible}"
               PlacementTarget="{Binding ElementName=AiChatToggleButton}"
               Placement="Bottom"
               AllowsTransparency="True"
               StaysOpen="True"
               PopupAnimation="Fade"
               Focusable="True"
               DataContext="{Binding DataContext, ElementName=MediaCenterRoot}"
               Opened="MediaAiPopup_Opened">
            <Border Width="340" Height="480"
                    Margin="0,12,0,0"
                    Background="{DynamicResource AtlasSurfaceBrush}"
                    BorderBrush="#4022D3EE"
                    BorderThickness="1"
                    CornerRadius="16">
                <Grid FocusManager.IsFocusScope="True"
                      FocusManager.FocusedElement="{Binding ElementName=MediaAiInput}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Chat Header -->
                    <Grid Grid.Row="0" Margin="16">
                        <StackPanel>
                            <TextBlock Text="ATLAS MEDIA AGENT" Foreground="{DynamicResource AtlasCyanBrush}" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding MediaAgentStateText}"
                                       Foreground="{DynamicResource AtlasTextSecondaryBrush}"
                                       FontFamily="{DynamicResource AtlasFontMono}"
                                       FontSize="11"
                                       Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding MediaAgentLastError}"
                                       Foreground="#FFEF4444"
                                       FontFamily="{DynamicResource AtlasFontMono}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasMediaAgentError}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <Button Command="{Binding ToggleChatCommand}"
                                HorizontalAlignment="Right"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="4"
                                Cursor="Hand">
                            <TextBlock Text="✕" Foreground="{DynamicResource AtlasTextSecondaryBrush}"/>
                        </Button>
                    </Grid>

                    <!-- Chat Messages -->
                    <ScrollViewer x:Name="MediaAiChatScroll"
                                  Grid.Row="1"
                                  Margin="16,0,16,16"
                                  VerticalScrollBarVisibility="Auto"
                                  PreviewMouseWheel="MediaAiChatScroll_PreviewMouseWheel">
                        <StackPanel>
                            <Border Background="#1A0F172A" BorderBrush="#4022D3EE" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                                <TextBlock Text="{Binding MediaAgentContextSnapshot}"
                                           Foreground="{DynamicResource AtlasTextSecondaryBrush}"
                                           FontFamily="{DynamicResource AtlasFontMono}"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <WrapPanel Margin="0,0,0,10">
                                <Border Background="#220F172A" BorderBrush="#5522D3EE" BorderThickness="1" CornerRadius="12" Padding="8,4" Margin="0,0,6,6">
                                    <TextBlock Text="{Binding MediaAgentModeChip}" Foreground="{DynamicResource AtlasTextSecondaryBrush}" FontFamily="{DynamicResource AtlasFontMono}" FontSize="10"/>
                                </Border>
                                <Border Background="#220F172A" BorderBrush="#5522D3EE" BorderThickness="1" CornerRadius="12" Padding="8,4" Margin="0,0,6,6">
                                    <TextBlock Text="{Binding MediaAgentPlaybackChip}" Foreground="{DynamicResource AtlasTextSecondaryBrush}" FontFamily="{DynamicResource AtlasFontMono}" FontSize="10"/>
                                </Border>
                                <Border Background="#220F172A" BorderBrush="#5522D3EE" BorderThickness="1" CornerRadius="12" Padding="8,4" Margin="0,0,6,6">
                                    <TextBlock Text="{Binding MediaAgentQueueChip}" Foreground="{DynamicResource AtlasTextSecondaryBrush}" FontFamily="{DynamicResource AtlasFontMono}" FontSize="10"/>
                                </Border>
                                <Border Background="#220F172A" BorderBrush="#5522D3EE" BorderThickness="1" CornerRadius="12" Padding="8,4" Margin="0,0,6,6">
                                    <TextBlock Text="{Binding MediaAgentProviderChip}" Foreground="{DynamicResource AtlasTextSecondaryBrush}" FontFamily="{DynamicResource AtlasFontMono}" FontSize="10"/>
                                </Border>
                            </WrapPanel>

                            <Border Background="#1A111827" BorderBrush="#4038BDF8" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="{Binding MediaAgentResultStateText}"
                                               Foreground="{DynamicResource AtlasCyanBrush}"
                                               FontFamily="{DynamicResource AtlasFontMono}"
                                               FontSize="11"
                                               FontWeight="Bold"/>
                                    <TextBlock Text="{Binding MediaAgentResultSummary}"
                                               Foreground="{DynamicResource AtlasTextSecondaryBrush}"
                                               FontFamily="{DynamicResource AtlasFontMono}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Margin="0,2,0,4"/>
                                    <!-- Premium result cards (shown when structured items are available) -->
                                    <ItemsControl ItemsSource="{Binding MediaAgentResultItems}">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasMediaAgentResultItems}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#120A1020" BorderBrush="#3522D3EE" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,0,0,6">
                                                    <StackPanel>
                                                        <!-- Title + Source chip row -->
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" FontWeight="SemiBold" FontSize="12"
                                                                       Foreground="{DynamicResource AtlasTextPrimaryBrush}"
                                                                       FontFamily="{DynamicResource AtlasFontMono}"
                                                                       TextWrapping="Wrap">
                                                                <Run Text="{Binding Title, Mode=OneWay}"/>
                                                                <Run Text="{Binding YearText, Mode=OneWay}" Foreground="{DynamicResource AtlasTextSecondaryBrush}" FontSize="11"/>
                                                            </TextBlock>
                                                            <Border Grid.Column="1" Background="#33228BFF" BorderBrush="#5522D3EE" BorderThickness="1"
                                                                    CornerRadius="8" Padding="6,2" Margin="6,0,0,0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Provider}" Foreground="{DynamicResource AtlasCyanBrush}"
                                                                           FontFamily="{DynamicResource AtlasFontMono}" FontSize="9" FontWeight="Bold"/>
                                                            </Border>
                                                        </Grid>
                                                        <!-- Subtitle -->
                                                        <TextBlock Text="{Binding Subtitle}" Foreground="{DynamicResource AtlasTextSecondaryBrush}"
                                                                   FontFamily="{DynamicResource AtlasFontMono}" FontSize="10" TextWrapping="Wrap" Margin="0,2,0,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Subtitle}" Value=""><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <!-- Rating + Votes + Tags badges -->
                                                        <WrapPanel Margin="0,4,0,0">
                                                            <Border Background="#22FFD700" BorderBrush="#44FFD700" BorderThickness="1" CornerRadius="6" Padding="5,1" Margin="0,0,4,2">
                                                                <TextBlock Text="{Binding RatingText}" Foreground="#FFD700"
                                                                           FontFamily="{DynamicResource AtlasFontMono}" FontSize="10" FontWeight="Bold">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding RatingText}" Value=""><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>
                                                            <Border Background="#220F172A" BorderBrush="#3522D3EE" BorderThickness="1" CornerRadius="6" Padding="5,1" Margin="0,0,4,2">
                                                                <TextBlock Text="{Binding VotesText}" Foreground="{DynamicResource AtlasTextMutedBrush}"
                                                                           FontFamily="{DynamicResource AtlasFontMono}" FontSize="10">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding VotesText}" Value=""><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>
                                                            <Border Background="#220F172A" BorderBrush="#3522D3EE" BorderThickness="1" CornerRadius="6" Padding="5,1" Margin="0,0,0,2">
                                                                <TextBlock Text="{Binding TagsText}" Foreground="{DynamicResource AtlasTextMutedBrush}"
                                                                           FontFamily="{DynamicResource AtlasFontMono}" FontSize="10">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding TagsText}" Value=""><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>
                                                        </WrapPanel>
                                                        <!-- Similar reason (music) -->
                                                        <TextBlock Text="{Binding SimilarReason}" Foreground="{DynamicResource AtlasTextSecondaryBrush}"
                                                                   FontFamily="{DynamicResource AtlasFontMono}" FontSize="10" FontStyle="Italic"
                                                                   TextWrapping="Wrap" Margin="0,3,0,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding SimilarReason}" Value=""><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <Border Background="#1C065F46" BorderBrush="#3365C18C" BorderThickness="1" CornerRadius="6" Padding="5,1" Margin="0,4,0,0">
                                                            <TextBlock Text="{Binding LibraryStatusText}" Foreground="#9FE4B7"
                                                                       FontFamily="{DynamicResource AtlasFontMono}" FontSize="10">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding LibraryStatusText}" Value=""><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                        <!-- Overview -->
                                                        <TextBlock Text="{Binding Overview}" Foreground="{DynamicResource AtlasTextMutedBrush}"
                                                                   FontFamily="{DynamicResource AtlasFontMono}" FontSize="10"
                                                                   TextWrapping="Wrap" Margin="0,3,0,0" MaxHeight="48">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Overview}" Value=""><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <!-- Action buttons -->
                                                        <WrapPanel Margin="0,6,0,0">
                                                            <Button Content="Copy" Margin="0,0,4,0" Padding="6,2" Cursor="Hand"
                                                                    FontFamily="{DynamicResource AtlasFontMono}" FontSize="10"
                                                                    Background="#220A1020" BorderBrush="#3522D3EE" BorderThickness="1"
                                                                    Foreground="{DynamicResource AtlasTextSecondaryBrush}"
                                                                    Command="{Binding DataContext.MediaResultCopyTitleCommand, RelativeSource={RelativeSource AncestorType=Popup}}"
                                                                    CommandParameter="{Binding}"/>
                                                            <Button Content="Search Local" Margin="0,0,4,0" Padding="6,2" Cursor="Hand"
                                                                    FontFamily="{DynamicResource AtlasFontMono}" FontSize="10"
                                                                    Background="#220A1020" BorderBrush="#3522D3EE" BorderThickness="1"
                                                                    Foreground="{DynamicResource AtlasTextSecondaryBrush}"
                                                                    Command="{Binding DataContext.MediaResultSearchLocalCommand, RelativeSource={RelativeSource AncestorType=Popup}}"
                                                                    CommandParameter="{Binding}"/>
                                                            <Button Content="Find Similar" Margin="0,0,4,0" Padding="6,2" Cursor="Hand"
                                                                    FontFamily="{DynamicResource AtlasFontMono}" FontSize="10"
                                                                    Background="#220A1020" BorderBrush="#3522D3EE" BorderThickness="1"
                                                                    Foreground="{DynamicResource AtlasTextSecondaryBrush}"
                                                                    Command="{Binding DataContext.MediaResultFindSimilarCommand, RelativeSource={RelativeSource AncestorType=Popup}}"
                                                                    CommandParameter="{Binding}"/>
