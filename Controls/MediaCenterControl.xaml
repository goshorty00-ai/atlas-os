                                                                                   Foreground="{DynamicResource AtlasTextPrimaryBrush}"
                                                                                   FontSize="12"
                                                                                   FontWeight="SemiBold"/>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
