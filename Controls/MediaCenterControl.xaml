                                Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M9,3V4H4V6H5V19A2,2 0 0,0 7,21H17A2,2 0 0,0 19,19V6H20V4H15V3H9M7,6H17V19H7V6Z"
                                      Fill="{DynamicResource AtlasCyanBrush}"
                                      Width="14"
                                      Height="14"
                                      Margin="0,0,8,0"
                                      Stretch="Uniform"/>
                                <TextBlock Text="CLEAR" Foreground="{DynamicResource AtlasTextPrimaryBrush}" FontWeight="SemiBold" FontSize="11"/>
                            </StackPanel>
                        </Button>

                        <Path Data="M16,11.78L20.24,4.45L21.97,5.45L16.74,14.5L10.23,10.75L5.46,19H22V21H2V3H4V17.54L9.5,8L16,11.78Z"
                              Fill="{DynamicResource AtlasCyanBrush}"
                              Width="16"
                              Height="16"
                              Margin="0,0,8,0"
                              VerticalAlignment="Center"
                              Stretch="Uniform"/>
                        <TextBlock Text="{Binding VisibleCountText}" Foreground="{DynamicResource AtlasTextPrimaryBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>


                            </StackPanel>
                        </ScrollViewer>

                        <Button Grid.Column="2"
                                Click="ScrollHeaderActionsRight_Click"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                Margin="8,0,0,0"
                                Cursor="Hand">
                            <Border Background="#80111A24" BorderBrush="#40CC0000" BorderThickness="1" CornerRadius="10" Padding="10,6">
                                <TextBlock Text="►" Foreground="{DynamicResource AtlasTextSecondaryBrush}" FontSize="11"/>
                            </Border>
                        </Button>
                    </Grid>

                    <StackPanel Grid.Row="1"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                Orientation="Horizontal"
                                Margin="0,6,0,0"
                                Visibility="{Binding ShowScanProgressLine, Converter={StaticResource BoolToVis}}">
                        <Grid Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"
                              Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
                            <Path Stroke="{DynamicResource AtlasCyanBrush}"
                                  StrokeThickness="2"
                                  StrokeDashArray="2,3"
                                  Data="M7,1 A6,6 0 1 1 6.999,1"
                                  Stretch="Fill"
                                  RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <RotateTransform x:Name="ScanSpinnerRotate" Angle="0"/>
                                </Path.RenderTransform>
                                <Path.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="ScanSpinnerRotate"
                                                                 Storyboard.TargetProperty="Angle"
                                                                 From="0"
                                                                 To="360"
                                                                 Duration="0:0:1.1"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Path.Triggers>
                            </Path>
                        </Grid>
                        <TextBlock Text="{Binding ScanProgressText}"
                                   Foreground="{DynamicResource AtlasTextMutedBrush}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="520"
                                   ToolTip="{Binding ScanProgressText}"/>
                    </StackPanel>

                    <Border Grid.Row="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Visibility="Collapsed"
                            Background="#080A1016"
                            BorderBrush="#20CC0000"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12"
                            Margin="0,10,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox ItemsSource="{Binding MediaAiScopes}"
                                          SelectedValuePath="Value"
                                          DisplayMemberPath="Label"
                                          SelectedValue="{Binding SelectedMediaAiScope}"
                                          Style="{StaticResource AtlasPillComboBox}"
                                          Margin="0,0,10,0"/>

                                <TextBox Grid.Column="1"
                                         Text="{Binding MediaAiCommandText, UpdateSourceTrigger=PropertyChanged}"
                                         Background="#080A10"
                                         Foreground="{DynamicResource AtlasTextPrimaryBrush}"
                                         BorderBrush="#40CC0000"
                                         BorderThickness="1"
                                         Padding="10,6"
                                         Height="34"
                                         VerticalContentAlignment="Center"/>

                                <Button Grid.Column="2"
                                        Command="{Binding SendMediaAiCommand}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        Margin="10,0,0,0">
                                    <Border Background="#10CC0000"
                                            BorderBrush="#40CC0000"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="12,6">
                                        <TextBlock Text="ASK AI" Foreground="{DynamicResource AtlasCyanBrush}" FontWeight="SemiBold" FontSize="11"/>
                                    </Border>
                                </Button>

                                <Button Grid.Column="3"
                                        Command="{Binding CancelMediaAiCommand}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        Margin="10,0,0,0">
                                    <Border Background="#10101620"
                                            BorderBrush="#40CC0000"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="12,6">
                                        <TextBlock Text="CANCEL" Foreground="{DynamicResource AtlasTextSecondaryBrush}" FontWeight="SemiBold" FontSize="11"/>
                                    </Border>
                                </Button>
                            </Grid>

                            <Border Grid.Row="1"
                                    Background="#080A10"
                                    BorderBrush="#40CC0000"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Margin="0,10,0,0"
                                    Padding="10">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              MaxHeight="140">
                                    <ItemsControl ItemsSource="{Binding MediaAiChat}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,0,0,10">
                                                    <TextBlock Text="{Binding Role}"
                                                               Foreground="{DynamicResource AtlasTextMutedBrush}"
                                                               FontSize="10"/>
                                                    <TextBlock Text="{Binding Content}"
                                                               Foreground="{DynamicResource AtlasTextPrimaryBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ══════════════════════════════════════════════════════════
                     MAIN CONTENT HOST - Section Views (Movies, TV, Music, Radio, Games)
                     This ContentControl displays the current section based on CurrentSection
                ══════════════════════════════════════════════════════════ -->
                <ContentControl x:Name="MainSectionHost" 
                                Grid.Row="2" 
                                Style="{StaticResource MainSectionHostStyle}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Visibility="Visible"/>

                <!-- OLD BUILD CONTENT - HIDDEN - Replaced by new section views above -->
                                    <Grid Grid.Row="2" Visibility="Collapsed">
                    <ScrollViewer BorderThickness="0"
                                  Background="Transparent"
                                  ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.CanContentScroll="True"
                                  Visibility="{Binding IsMusicAlbumsView, Converter={StaticResource BoolToVis}}">
                        <ItemsControl ItemsSource="{Binding MusicAlbumRows}"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ItemsControl ItemsSource="{Binding Albums}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="4"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding DataContext.SelectAlbumCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Padding="0"
                                                        Margin="0,0,14,14"
                                                        Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        Cursor="Hand">
                                                    <Button.ContextMenu>
                                                        <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                                            <MenuItem Header="Edit info"
                                                                      Command="{Binding EditAlbumInfoCommand}"
                                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                            <MenuItem Header="AI optimize"
                                                                      Command="{Binding OptimizeAlbumCommand}"
                                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                            <MenuItem Header="Open folder"
                                                                      Command="{Binding OpenAlbumFolderCommand}"
                                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                            <Separator/>
                                                            <MenuItem Header="Remove album"
                                                                      Command="{Binding RemoveAlbumCommand}"
                                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        </ContextMenu>
                                                    </Button.ContextMenu>
                                                    <Border CornerRadius="16" BorderBrush="{DynamicResource AtlasOrangeBrush}" BorderThickness="1" Background="#80111A24" ClipToBounds="True">
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="#80FB923C" BlurRadius="28" ShadowDepth="0" Opacity="0.45"/>
                                                        </Border.Effect>
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="*"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                        <Grid>
                                                                <Border CornerRadius="16,16,0,0" ClipToBounds="True">
                                                                    <Grid>
                                                                        <Image Source="{Binding CoverImage}" Stretch="UniformToFill">
                                                                            <Image.OpacityMask>
                                                                                <VisualBrush>
                                                                                    <VisualBrush.Visual>
                                                                                        <Border Background="Black" 
                                                                                                Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Image}}"
                                                                                                Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Image}}"
                                                                                                CornerRadius="16,16,0,0"/>
                                                                                    </VisualBrush.Visual>
                                                                                </VisualBrush>
                                                                            </Image.OpacityMask>
                                                                        </Image>
                                                                        <!-- Strong Overlay to enforce corners visually -->
                                                                        <Border BorderBrush="#111A24" BorderThickness="4" CornerRadius="16,16,0,0"/>
                                                                    </Grid>
                                                                </Border>
                                                                <Border Background="#20111A24" CornerRadius="16,16,0,0"/>

                                                                <Border Background="#CC0A0E12"
                                                                        BorderBrush="{DynamicResource AtlasOrangeBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="14"
                                                                        Padding="10,4"
                                                                        HorizontalAlignment="Right"
                                                                        VerticalAlignment="Top"
                                                                        Margin="12">
                                                                    <TextBlock Text="{Binding TrackCount}"
                                                                               Foreground="{DynamicResource AtlasCyanBrush}"
                                                                               FontFamily="{DynamicResource AtlasFontPrimary}"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"/>
                                                                </Border>
                                                            </Grid>

                                                            <StackPanel Grid.Row="1" Margin="12">
                                                                <TextBlock Text="{Binding AlbumTitle}"
                                                                           Foreground="{DynamicResource AtlasTextPrimaryBrush}"
                                                                           FontFamily="{DynamicResource AtlasFontPrimary}"
                                                                           FontSize="14"
                                                                           FontWeight="Bold"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding Artist}"
                                                                           Foreground="{DynamicResource AtlasTextMutedBrush}"
                                                                           FontFamily="{DynamicResource AtlasFontPrimary}"
                                                                           FontSize="11"
                                                                           Margin="0,4,0,0"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Grid Visibility="{Binding IsAlbumTracksView, Converter={StaticResource BoolToVis}}">
                        <ListBox ItemsSource="{Binding LibraryItems}"
                                 SelectionMode="Extended"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,0,4"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    <Setter Property="ContextMenu">
                                        <Setter.Value>
                                            <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                                <MenuItem Header="Play"
                                                          Command="{Binding PlayItemCommand}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                <MenuItem Header="Streams"
                                                          Command="{Binding OpenStreamsCommand}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                <MenuItem Header="Add to queue"
                                                          Command="{Binding AddToQueueCommand}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                <MenuItem Header="Play next"
                                                          Command="{Binding QueueNextCommand}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                <MenuItem Header="AI optimize"
                                                          Command="{Binding OptimizeItemCommand}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                <MenuItem Header="Edit info"
                                                          Command="{Binding EditTrackInfoCommand}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                <MenuItem Header="Set cover..."
                                                          Command="{Binding SetCoverCommand}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                <Separator/>
                                                <MenuItem Header="Show info"
                                                          Command="{Binding ShowItemInfoCommand}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                <MenuItem Header="Open folder"
                                                          Command="{Binding OpenItemFolderCommand}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                <Separator/>
                                                <MenuItem Header="Remove from library"
                                                          Command="{Binding RemoveFromLibraryCommand}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            </ContextMenu>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#10111A24"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="#20CC0000"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <EventSetter Event="MouseDoubleClick" Handler="ListBoxItem_MouseDoubleClick"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="8,4" Background="Transparent">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Width="32"
                                                Height="32"
                                                CornerRadius="6"
                                                Background="Transparent"
                                                Margin="0,0,12,0">
                                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="True" UseLayoutRounding="True">
                                                <Border CornerRadius="6"
                                                        Background="{Binding AccentBrush}"
                                                        Opacity="0.16"/>
                                                <Image x:Name="TrackMusicIcon"
                                                       Width="18"
                                                       Height="18"
                                                       Stretch="Uniform"
                                                       SnapsToDevicePixels="True"
                                                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                                                       Source="pack://siteoforigin:,,,/Assets/MediaPlayer/Buttons/music.png">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                                <StackPanel x:Name="TrackMiniViz" Orientation="Horizontal" VerticalAlignment="Bottom" Visibility="Collapsed">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <Rectangle Width="3" Height="7" RadiusX="1.5" RadiusY="1.5" Fill="{DynamicResource AtlasCyanBrush}" Margin="1,0" VerticalAlignment="Bottom">
                                                        <Rectangle.Style>
                                                            <Style TargetType="Rectangle">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                                        <DataTrigger.EnterActions>
                                                                            <BeginStoryboard x:Name="MiniViz1Anim">
                                                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                                    <DoubleAnimation Storyboard.TargetProperty="Height" From="6" To="16" Duration="0:0:0.18"/>
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </DataTrigger.EnterActions>
                                                                        <DataTrigger.ExitActions>
                                                                            <StopStoryboard BeginStoryboardName="MiniViz1Anim"/>
                                                                        </DataTrigger.ExitActions>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Rectangle.Style>
                                                    </Rectangle>
                                                    <Rectangle Width="3" Height="11" RadiusX="1.5" RadiusY="1.5" Fill="{DynamicResource AtlasCyanBrush}" Margin="1,0" VerticalAlignment="Bottom">
                                                        <Rectangle.Style>
                                                            <Style TargetType="Rectangle">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                                        <DataTrigger.EnterActions>
                                                                            <BeginStoryboard x:Name="MiniViz2Anim">
                                                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                                    <DoubleAnimation Storyboard.TargetProperty="Height" From="8" To="20" Duration="0:0:0.14"/>
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </DataTrigger.EnterActions>
                                                                        <DataTrigger.ExitActions>
                                                                            <StopStoryboard BeginStoryboardName="MiniViz2Anim"/>
                                                                        </DataTrigger.ExitActions>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Rectangle.Style>
                                                    </Rectangle>
                                                    <Rectangle Width="3" Height="8" RadiusX="1.5" RadiusY="1.5" Fill="{DynamicResource AtlasCyanBrush}" Margin="1,0" VerticalAlignment="Bottom">
                                                        <Rectangle.Style>
                                                            <Style TargetType="Rectangle">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                                        <DataTrigger.EnterActions>
                                                                            <BeginStoryboard x:Name="MiniViz3Anim">
                                                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                                    <DoubleAnimation Storyboard.TargetProperty="Height" From="7" To="18" Duration="0:0:0.22"/>
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </DataTrigger.EnterActions>
                                                                        <DataTrigger.ExitActions>
                                                                            <StopStoryboard BeginStoryboardName="MiniViz3Anim"/>
                                                                        </DataTrigger.ExitActions>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Rectangle.Style>
                                                    </Rectangle>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{DynamicResource AtlasTextPrimaryBrush}"
                                                       FontSize="13"
                                                       FontWeight="Medium"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="{Binding Artist}" Foreground="{DynamicResource AtlasTextSecondaryBrush}" FontSize="11"/>
                                                <TextBlock Text=" · " Foreground="{DynamicResource AtlasTextMutedBrush}" FontSize="11" Margin="4,0"/>
                                                <TextBlock Text="{Binding Album}" Foreground="{DynamicResource AtlasTextMutedBrush}" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <Grid Grid.Column="2" VerticalAlignment="Center" Margin="14,0,14,0">
                                            <TextBlock Text="{Binding DurationText}"
                                                       Foreground="{DynamicResource AtlasTextMutedBrush}"
                                                       FontSize="11"
                                                       HorizontalAlignment="Right">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Effect" Value="{x:Null}"/>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Visibility="Collapsed">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <Ellipse Width="12"
                                                         Height="12"
                                                         Stroke="{DynamicResource AtlasCyanBrush}"
                                                         StrokeThickness="2"
                                                         StrokeDashArray="2 6"
                                                         Opacity="0.9"
