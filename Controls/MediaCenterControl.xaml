<UserControl x:Class="AtlasAI.Controls.MediaCenterControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AtlasAI.Controls"
             xmlns:mc="clr-namespace:AtlasAI.Controls.MediaCentre"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:converters="clr-namespace:AtlasAI.Views.Converters"
             xmlns:lottie="clr-namespace:LottieSharp.WPF;assembly=LottieSharp"
             xmlns:vm="clr-namespace:AtlasAI.Views.ViewModels"
             xmlns:views="clr-namespace:AtlasAI.Views.MediaCentre"
             x:Name="MediaCenterRoot"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
              Background="{StaticResource MediaCentreDeepBlueGradient}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:NullToBoolConverter x:Key="NullToBool"/>
        <converters:StreamsInfoTextConverter x:Key="StreamsInfoText"/>
        <converters:MediaCategoryToLottiePathConverter x:Key="MediaCategoryToLottiePath"/>

        <!-- ══════════════════════════════════════════════════════════
             SECTION VIEW DATA TEMPLATES
             Maps the MediaCentreViewModel to section-specific Views
        ══════════════════════════════════════════════════════════ -->
        <Style x:Key="MainSectionHostStyle" TargetType="ContentControl">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedCategory.Id}" Value="movies">
                    <Setter Property="Content">
                        <Setter.Value>
                            <views:MoviesView/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding SelectedCategory.Id}" Value="tv">
                    <Setter Property="Content">
                        <Setter.Value>
                            <views:TvView/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding SelectedCategory.Id}" Value="music">
                    <Setter Property="Content">
                        <Setter.Value>
                            <views:MusicView/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding SelectedCategory.Id}" Value="radio">
                    <Setter Property="Content">
                        <Setter.Value>
                            <views:RadioView/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding SelectedCategory.Id}" Value="games">
                    <Setter Property="Content">
                        <Setter.Value>
                            <views:GamesView/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding SelectedCategory.Id}" Value="servers">
                    <Setter Property="Content">
                        <Setter.Value>
                            <views:ServersView/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding SelectedCategory.Id}" Value="karaoke">
                    <Setter Property="Content">
                        <Setter.Value>
                            <views:KaraokeView/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding SelectedCategory.Id}" Value="apps">
                    <Setter Property="Content">
                        <Setter.Value>
                            <views:AppsView/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding SelectedCategory.Id}" Value="addons">
                    <Setter Property="Content">
                        <Setter.Value>
                            <views:AddonsView/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding SelectedCategory.Id}" Value="discovery">
                    <Setter Property="Content">
                        <Setter.Value>
                            <views:DiscoveryView/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <!-- Default / Fallback -->
                <DataTrigger Binding="{Binding SelectedCategory}" Value="{x:Null}">
                    <Setter Property="Content">
                        <Setter.Value>
                            <Grid Background="#101010" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                                <TextBlock Text="No Category Selected" Foreground="#666" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="16"/>
                            </Grid>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <!-- Force show debug info on top of everything -->
                <!-- <DataTrigger Binding="{Binding SelectedCategory.Id}" Value="servers">
                    <Setter Property="Content">
                        <Setter.Value>
                             <Grid Background="Transparent">
                                <views:ServersView/>
                                <TextBlock Text="DEBUG: SERVERS VIEW LOADED" Foreground="Magenta" VerticalAlignment="Top" HorizontalAlignment="Left" FontSize="20" IsHitTestVisible="False"/>
                             </Grid>
                        </Setter.Value>
                    </Setter>
                </DataTrigger> -->
            </Style.Triggers>
        </Style>

        <Style TargetType="ScrollBar" BasedOn="{StaticResource AtlasScrollBar}"/>
        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="ListView">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="ItemsControl">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AtlasTextPrimaryBrush}"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="Effect" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="FontFamily" Value="{StaticResource AtlasFontIcon}">
                    <Setter Property="Foreground" Value="{DynamicResource AtlasCyanBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AtlasTextBoxSmall" TargetType="TextBox" BasedOn="{StaticResource AtlasTextBox}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Height" Value="32"/>
        </Style>

        <Style x:Key="MediaAiInputBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#0F141D"/>
            <Setter Property="BorderBrush" Value="#4022D3EE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="{DynamicResource AtlasCyanBrush}"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource AtlasCyanGlowBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AtlasCyanBrush}"/>
                                <Setter TargetName="bd" Property="Background" Value="#1A202C"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="CaretBrush" Value="{DynamicResource AtlasCyanBrush}"/>
                                <Setter TargetName="bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#8022D3EE" BlurRadius="8" ShadowDepth="0" Opacity="0.1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AtlasBorderLightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AddonBrowserComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="Background" Value="#11182F"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1E2B55"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#243C77"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AddonBrowserComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="Background" Value="#171B37"/>
            <Setter Property="BorderBrush" Value="#2A366F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource AddonBrowserComboBoxItemStyle}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter x:Name="ContentSite"
                                                      Margin="14,0,8,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      IsHitTestVisible="False"/>
                                    <TextBox x:Name="PART_EditableTextBox"
                                             Margin="14,0,8,0"
                                             VerticalContentAlignment="Center"
                                             HorizontalContentAlignment="Left"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{TemplateBinding Foreground}"
                                             Visibility="Hidden"/>
                                    <ToggleButton Grid.Column="1"
                                                  Focusable="False"
                                                  ClickMode="Press"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                        <TextBlock Text="⌄"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#C7D2FE"
                                                   FontSize="13"/>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border Margin="0,6,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="320"
                                        Background="#0B1024"
                                        BorderBrush="#2A366F"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#22D3EE"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#22D3EE"/>
                            </Trigger>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CategoryTabButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="#12151C"/>
                <Setter Property="Foreground" Value="{DynamicResource AtlasTextSecondaryBrush}"/>
                <Setter Property="BorderBrush" Value="#20333A45"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="MinHeight" Value="32"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Arial"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource AtlasTextPrimaryBrush}"/>
                                    <Setter TargetName="bd" Property="BorderBrush" Value="#33556677"/>
                                    <Setter TargetName="bd" Property="Background" Value="#171B24"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource AtlasTextPrimaryBrush}"/>
                                    <Setter TargetName="bd" Property="Background" Value="#1A1F2A"/>
                                    <Setter TargetName="bd" Property="BorderBrush" Value="#33556677"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource AtlasTextPrimaryBrush}"/>
                                    <Setter TargetName="bd" Property="Background" Value="#171B24"/>
                                    <Setter TargetName="bd" Property="BorderBrush" Value="#33556677"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="HeaderActionDiscreetButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource AtlasTextSecondaryBrush}"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="MinHeight" Value="32"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Arial"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="BorderBrush" Value="#20333A45"/>
                                    <Setter TargetName="bd" Property="Background" Value="#12151C"/>
                                    <Setter Property="Foreground" Value="{DynamicResource AtlasTextPrimaryBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#1A1F2A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="HeaderActionButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="#12151C"/>
                <Setter Property="Foreground" Value="{DynamicResource AtlasTextSecondaryBrush}"/>
                <Setter Property="BorderBrush" Value="#20333A45"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="MinHeight" Value="32"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Arial"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="BorderBrush" Value="#33556677"/>
                                    <Setter TargetName="bd" Property="Background" Value="#171B24"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#1A1F2A"/>
                                    <Setter TargetName="bd" Property="BorderBrush" Value="#33556677"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="HeaderActionToggleButtonStyle" TargetType="ToggleButton">
                <Setter Property="Background" Value="#12151C"/>
                <Setter Property="Foreground" Value="{DynamicResource AtlasTextSecondaryBrush}"/>
                <Setter Property="BorderBrush" Value="#20333A45"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="MinHeight" Value="32"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Arial"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="BorderBrush" Value="#33556677"/>
                                    <Setter TargetName="bd" Property="Background" Value="#171B24"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#1A1F2A"/>
                                    <Setter TargetName="bd" Property="BorderBrush" Value="#33556677"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="bd" Property="BorderBrush" Value="#33556677"/>
                                    <Setter TargetName="bd" Property="Background" Value="#171B24"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="GlassPanelBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="#101015"/>
                <Setter Property="BorderBrush" Value="#20333A45"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="16"/>
            </Style>

            <Style x:Key="LibraryTileBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="#12151C"/>
                <Setter Property="BorderBrush" Value="#20333A45"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="14"/>
                <Setter Property="Padding" Value="18"/>
                <Setter Property="Height" Value="180"/>
            </Style>

            <!-- Actions Dropdown Item Style -->
            <Style x:Key="NeoActionDropdownItem" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource NeoTextPrimary}"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="12,10"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontFamily" Value="{StaticResource NeoFontFamily}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Margin" Value="0,2"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"/>
                                <Border.Effect>
                                    <DropShadowEffect Color="#FF7700" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                                </Border.Effect>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource NeoGlass16}"/>
                                    <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource NeoBorderNeon}"/>
                                    <Setter TargetName="bd" Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="#8022D3EE" BlurRadius="12" ShadowDepth="0" Opacity="0.3"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource NeoGlassElevated}"/>
                                    <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource NeoCyanIce}"/>
                                    <Setter TargetName="bd" Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="#FF7700" BlurRadius="16" ShadowDepth="0" Opacity="0.5"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="Background" Value="Transparent"/>
                <Style.Triggers>
                    <!-- Servers should be fully opaque so the video wallpaper cannot bleed through any gaps -->
                    <DataTrigger Binding="{Binding IsServersView}" Value="True">
                        <Setter Property="Background" Value="#080A10"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <Grid.ColumnDefinitions>
            <!-- Col 0: ATLAS NEO navigation sidebar (fixed width) -->
            <ColumnDefinition x:Name="NeoNavColumn" Width="200"/>
            <!-- Col 1: header + content -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             ATLAS NEO — Vertical Navigation Sidebar (Col 0, all rows)
             Bound to Categories collection + SelectCategoryCommand
        ══════════════════════════════════════════════════════════ -->
        <Border x:Name="NeoNavSidebar"
                Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                Background="{StaticResource DeepSeaGradient}"
                BorderBrush="{StaticResource AtlasBorder}"
                BorderThickness="0,0,1,0"
                Panel.ZIndex="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Logo + branding block -->
                    <RowDefinition Height="*"/>     <!-- Categories list -->
                    <RowDefinition Height="Auto"/>  <!-- Footer controls -->
                </Grid.RowDefinitions>

                <!-- Logo / animations block -->
                <Border Grid.Row="0" Padding="0">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Width="176"
                                Height="104"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <lottie:LottieAnimationView x:Name="SidebarCategoryLottie"
                                                        AutoPlay="True"
                                                        RepeatCount="-1"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Stretch"
                                                        UseLayoutRounding="True"
                                                        SnapsToDevicePixels="True"
                                                        FileName="{Binding SelectedCategory.Id, Converter={StaticResource MediaCategoryToLottiePath}}"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Separator -->
                <Rectangle Grid.Row="0" Height="1"
                            Fill="{StaticResource NeoBorderGlass}"
                            VerticalAlignment="Bottom"/>

                <!-- Categories list — bound to existing Categories collection -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="0,12,0,12">
                    <ItemsControl ItemsSource="{Binding Categories}"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Each item = Button bound to SelectCategoryCommand -->
                                <Button Style="{StaticResource NeoNavSidebarItem}"
                                        Command="{Binding DataContext.SelectCategoryCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        FocusVisualStyle="{StaticResource NeoFocusVisual}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <!-- Category icon -->
                                        <Border Width="32" Height="32"
                                                CornerRadius="8"
                                                Margin="0,0,12,0"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource NeoGlowCyanSoft}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Viewbox Width="16" Height="16" Stretch="Uniform"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center">
                                                <Path Data="{Binding IconGeometry}"
                                                      Stretch="Uniform">
                                                    <Path.Style>
                                                        <Style TargetType="Path">
                                                            <Setter Property="Fill" Value="{StaticResource NeoTextSecondary}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="Fill" Value="{StaticResource NeoCyanIce}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                            </Viewbox>
                                        </Border>

                                        <!-- Label -->
                                        <TextBlock Text="{Binding Label}"
                                                   VerticalAlignment="Center"
                                                   FontFamily="{StaticResource NeoFontFamily}"
                                                   FontSize="14">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource NeoTextSecondary}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource NeoTextPrimary}"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- Count badge -->
                                        <Border Margin="8,0,0,0"
                                                CornerRadius="10"
                                                Padding="6,2"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding Count,
                                                             Converter={StaticResource NullToBool},
                                                             ConverterParameter=visibility}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource NeoGlass12}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource NeoGlowCyanSoft}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Count}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource NeoTextTertiary}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource NeoCyanIce}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Footer: AI chat toggle + close sidebar button -->
                <StackPanel Grid.Row="2" Orientation="Vertical"
                            Margin="8,8,8,16">
                    <Rectangle Height="1" Fill="{StaticResource NeoBorderGlass}" Margin="0,0,0,8"/>

                    <!-- Animations picker (in sidebar, not in the logo block) -->
                    <Button x:Name="SidebarLottiePickerButton"
                            Style="{StaticResource NeoNavSidebarItem}"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Center"
                            Click="SidebarLottiePickerButton_Click"
                            FocusVisualStyle="{StaticResource NeoFocusVisual}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="SidebarLottiePickerLabel"
                                       Text="Animations: Auto"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                                       Foreground="{StaticResource NeoTextSecondary}"
                                       FontFamily="{StaticResource NeoFontFamily}"
                                       FontSize="14"/>
                            <TextBlock Grid.Column="1"
                                       Text="˅"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource NeoTextSecondary}"
                                       FontSize="12"/>
                        </Grid>
                    </Button>

                    <Border x:Name="SidebarLottiePickerListHost"
                            Margin="0,6,0,10"
                            Background="{StaticResource NeoGlass12}"
                            BorderBrush="{StaticResource NeoBorderGlass}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="260">
                            <StackPanel x:Name="SidebarLottiePickerListPanel" Margin="0,4,0,4"/>
                        </ScrollViewer>
                    </Border>

                    <Button Style="{StaticResource NeoNavSidebarItem}"
                            Click="OpenShelfToolsSection_Click"
                            FocusVisualStyle="{StaticResource NeoFocusVisual}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="M4,6A2,2 0 0,1 6,4H18A2,2 0 0,1 20,6V10A2,2 0 0,1 18,12H6A2,2 0 0,1 4,10V6M4,14A2,2 0 0,1 6,12H18A2,2 0 0,1 20,14V18A2,2 0 0,1 18,20H6A2,2 0 0,1 4,18V14Z"
                                  Fill="{StaticResource NeoTextSecondary}"
                                  Width="16" Height="16" Stretch="Uniform"
                                  Margin="0,0,12,0"/>
                            <TextBlock Text="Shelf Tools"
                                       Foreground="{StaticResource NeoTextSecondary}"
                                       FontFamily="{StaticResource NeoFontFamily}"
                                       FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NeoNavSidebarItem}"
                            Command="{Binding ToggleChatCommand}"
                            FocusVisualStyle="{StaticResource NeoFocusVisual}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="M20,2H4A2,2 0 0,0 2,4V22L6,18H20A2,2 0 0,0 22,16V4A2,2 0 0,0 20,2M20,16H6L4,18V4H20"
                                  Fill="{StaticResource NeoTextSecondary}"
                                  Width="16" Height="16" Stretch="Uniform"
                                  Margin="0,0,12,0"/>
                            <TextBlock Text="AI Chat"
                                       Foreground="{StaticResource NeoTextSecondary}"
                                       FontFamily="{StaticResource NeoFontFamily}"
                                       FontSize="14"/>
                        </StackPanel>
                    </Button>
                    <!-- Close sidebar button (hides completely) -->
                    <Button x:Name="NeoNavCloseBtn"
                            Style="{StaticResource NeoNavSidebarItem}"
                            Click="NeoNavClose_Click"
                            FocusVisualStyle="{StaticResource NeoFocusVisual}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                                  Fill="{StaticResource NeoTextSecondary}"
                                  Width="16" Height="16" Stretch="Uniform"
                                  Margin="0,0,12,0"/>
                            <TextBlock Text="Close Sidebar"
                                       Foreground="{StaticResource NeoTextSecondary}"
                                       FontFamily="{StaticResource NeoFontFamily}"
                                       FontSize="14"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Figma WebView full-bleed in content area -->
        <wv2:WebView2 x:Name="ServersFigmaWebView"
                      Grid.Column="1" Grid.Row="1"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Margin="0"/>

        <!-- Sidebar re-open tab (shown only when sidebar is fully closed) -->
        <Button x:Name="NeoNavReopenTab"
                Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"
                HorizontalAlignment="Left" VerticalAlignment="Center"
                Width="16" Height="80"
            Panel.ZIndex="1000"
                Visibility="Collapsed"
                Click="NeoNavReopen_Click"
                ToolTip="Open Sidebar"
                BorderThickness="0"
                Background="Transparent">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <!-- Extend the header accent line under the reopen tab to avoid the "missing blue" gap -->
                        <Border Height="2"
                                VerticalAlignment="Top"
                                Background="{StaticResource AtlasAccent}"
                                Opacity="0.4"/>
                        <Border Margin="0,2,0,0"
                                Background="{StaticResource NeoGlass12}"
                                BorderBrush="{StaticResource NeoBorderNeon}"
                                BorderThickness="0,1,1,1"
                                CornerRadius="0,8,8,0">
                            <Path Data="M8,5V19L19,12L8,5Z"
                                  Fill="{StaticResource NeoTextSecondary}"
                                  Width="7" Height="7" Stretch="Uniform"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- ══════════════════════════════════════════════════════════
             ATLAS NEO — Top Header (Col 1, Row 0)
             Replaces horizontal category tabs with search + status
        ══════════════════════════════════════════════════════════ -->
        <Grid x:Name="HeaderContainer" Grid.Column="1" Grid.Row="0">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFigmaWebViewActive}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Height="2"
                    VerticalAlignment="Top"
                    Background="{StaticResource AtlasAccent}"
                    Opacity="0.18"
                    Panel.ZIndex="50"/>
            <Border x:Name="NeoHeader"
                    BorderBrush="{StaticResource AtlasBorder}"
                    BorderThickness="0,0,0,1"
                    MinHeight="96">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFigmaWebViewActive}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <!-- Keep the second header visible on Servers (search + load more live here) -->
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0A1020" Offset="0"/>
                        <GradientStop Color="#070B14" Offset="0.55"/>
                        <GradientStop Color="#05070C" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid x:Name="NeoHeaderLayoutGrid" Margin="40,0,24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0"
                       Source="/Assets/Logos/Atlas_MediaHub.png"
                      Height="68"
                      Margin="0,0,24,0"
                       VerticalAlignment="Center"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"/>

                <!-- Right: Status indicators + Header actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="16,0,0,0">
                    <!-- Scan progress indicator (visible during library scan) -->
                    <Border Background="{StaticResource NeoGlass12}"
                            BorderBrush="{StaticResource NeoBorderGlass}"
                            BorderThickness="1" CornerRadius="8"
                            Padding="12,6" Margin="0,0,12,0"
                            VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding ShowScanProgressLine}" Value="True"/>
                                            <Condition Binding="{Binding SelectedCategory.Id}" Value="movies"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding ShowScanProgressLine}" Value="True"/>
                                            <Condition Binding="{Binding SelectedCategory.Id}" Value="tv"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding ShowScanProgressLine}" Value="True"/>
                                            <Condition Binding="{Binding SelectedCategory.Id}" Value="music"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding ScanProgressText}"
                                       Foreground="{StaticResource NeoCyanIce}"
                                       FontFamily="{StaticResource NeoFontFamily}"
                                       FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <!-- Library count -->
                    <Border Background="{StaticResource NeoGlass12}"
                            BorderBrush="{StaticResource NeoBorderGlass}"
                            BorderThickness="1" CornerRadius="8"
                            Padding="12,6" Margin="0,0,8,0"
                            VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedCategory.Id}" Value="movies">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedCategory.Id}" Value="tv">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedCategory.Id}" Value="music">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding LibraryCountText}"
                                       Foreground="{StaticResource NeoTextSecondary}"
                                       FontFamily="{StaticResource NeoFontFamily}"
                                       FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <!-- ACTIONS pill dropdown (smaller + directly after count) -->
                    <Grid VerticalAlignment="Center" Margin="0,0,8,0">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedCategory.Id}" Value="movies">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedCategory.Id}" Value="tv">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedCategory.Id}" Value="music">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <ToggleButton x:Name="ActionsDropdownToggle"
                                      Background="{StaticResource NeoGlass12}"
                                      BorderBrush="{StaticResource NeoBorderNeon}"
                                      BorderThickness="1"
                                      Padding="12,8"
                                      MinWidth="96"
                                      Height="40"
                                      Cursor="Hand"
                                      Click="ActionsDropdown_Click">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="bd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="14"
                                            Padding="{TemplateBinding Padding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="ACTIONS"
                                                       Foreground="{StaticResource NeoTextPrimary}"
                                                       FontFamily="{StaticResource NeoFontFamily}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Left"/>
                                            <Path Grid.Column="1"
                                                  Data="M7,10L12,15L17,10H7Z"
                                                  Fill="{StaticResource NeoCyanIce}"
                                                  Width="10" Height="10"
                                                  Stretch="Uniform"
                                                  Margin="8,0,0,0"
                                                  VerticalAlignment="Center"/>
                                        </Grid>
                                        <Border.Effect>
                                            <DropShadowEffect Color="#8022D3EE" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                                        </Border.Effect>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{StaticResource NeoGlass16}"/>
                                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource NeoCyanIce}"/>
                                            <Setter TargetName="bd" Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="#8022D3EE" BlurRadius="16" ShadowDepth="0" Opacity="0.4"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{StaticResource NeoGlass16}"/>
                                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource NeoCyanIce}"/>
                                            <Setter TargetName="bd" Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="#8022D3EE" BlurRadius="18" ShadowDepth="0" Opacity="0.5"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <!-- Dropdown Popup -->
                        <Popup x:Name="ActionsDropdownPopup"
                               PlacementTarget="{Binding ElementName=ActionsDropdownToggle}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="False"
                               VerticalOffset="8"
                               IsOpen="{Binding IsChecked, ElementName=ActionsDropdownToggle, Mode=TwoWay}">
                            <Border Background="#0E1420"
                                    BorderBrush="{StaticResource NeoBorderNeon}"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Padding="8"
                                    MinWidth="200">
                                <StackPanel>
                                    <!-- Add Media -->
                                    <Button Command="{Binding ScanSelectedCategoryCommand}"
                                            Style="{StaticResource NeoActionDropdownItem}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M20,6H12L10,4H4A2,2 0 0,0 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8A2,2 0 0,0 20,6Z"
                                                  Fill="{StaticResource NeoCyanIce}"
                                                  Width="14" Height="14"
                                                  Margin="0,0,10,0"
                                                  Stretch="Uniform"/>
                                            <TextBlock Text="Add Media" Foreground="{StaticResource NeoTextPrimary}" FontSize="13"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- AI Optimize -->
                                    <Button Command="{Binding OptimizeLibraryCommand}"
                                            Style="{StaticResource NeoActionDropdownItem}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M12,2L14.09,8.26L20.78,8.27L15.36,12.14L17.45,18.4L12,14.53L6.55,18.4L8.64,12.14L3.22,8.27L9.91,8.26L12,2Z"
                                                  Fill="{StaticResource NeoCyanIce}"
                                                  Width="14" Height="14"
                                                  Margin="0,0,10,0"
                                                  Stretch="Uniform"/>
                                            <TextBlock Text="AI Optimize" Foreground="{StaticResource NeoTextPrimary}" FontSize="13"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- AI Mode -->
                                    <Button Click="AiModeButton_Click"
                                            Style="{StaticResource NeoActionDropdownItem}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M7,10H9V12H7V10M11,10H13V12H11V10M15,10H17V12H15V10M8,14H16V16H8V14Z"
                                                  Fill="{StaticResource NeoCyanIce}"
                                                  Width="14" Height="14"
                                                  Margin="0,0,10,0"
                                                  Stretch="Uniform"/>
                                            <TextBlock Text="AI Mode" Foreground="{StaticResource NeoTextPrimary}" FontSize="13"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Voice -->
                                    <Button Click="VoiceModeButton_Click"
                                            Style="{StaticResource NeoActionDropdownItem}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M12,1A3,3 0 0,1 15,4V12A3,3 0 0,1 9,12V4A3,3 0 0,1 12,1M19,10V12A7,7 0 0,1 13,18.92V22H11V18.92A7,7 0 0,1 5,12V10H7V12A5,5 0 0,0 17,12V10H19Z"
                                                  Fill="{StaticResource NeoCyanIce}"
                                                  Width="14" Height="14"
                                                  Margin="0,0,10,0"
                                                  Stretch="Uniform"/>
                                            <TextBlock Text="Voice" Foreground="{StaticResource NeoTextPrimary}" FontSize="13"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Fix Albums -->
                                    <Button Command="{Binding FixMusicAlbumsCommand}"
                                            Style="{StaticResource NeoActionDropdownItem}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M12,6V9L16,13L14.59,14.41L11,10.83V6H12M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4Z"
                                                  Fill="{StaticResource NeoCyanIce}"
                                                  Width="14" Height="14"
                                                  Margin="0,0,10,0"
                                                  Stretch="Uniform"/>
                                            <TextBlock Text="Fix Albums" Foreground="{StaticResource NeoTextPrimary}" FontSize="13"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Play All -->
                                    <Button Command="{Binding PlayAllMusicCommand}"
                                            Style="{StaticResource NeoActionDropdownItem}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M8,5V19L19,12L8,5Z"
                                                  Fill="{StaticResource NeoCyanIce}"
                                                  Width="14" Height="14"
                                                  Margin="0,0,10,0"
                                                  Stretch="Uniform"/>
                                            <TextBlock Text="Play All" Foreground="{StaticResource NeoTextPrimary}" FontSize="13"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Undo -->
                                    <Button Command="{Binding UndoLastChangeCommand}"
                                            Style="{StaticResource NeoActionDropdownItem}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M12.5,8C9.47,8 6.89,9.72 5.56,12.22L3,9.5V16H9.5L6.84,13.34C7.9,11.5 10.03,10.25 12.5,10.25C15.81,10.25 18.57,12.55 19.26,15.64L21.45,15.14C20.54,11.2 16.92,8 12.5,8Z"
                                                  Fill="{StaticResource NeoCyanIce}"
                                                  Width="14" Height="14"
                                                  Margin="0,0,10,0"
                                                  Stretch="Uniform"/>
                                            <TextBlock Text="Undo" Foreground="{StaticResource NeoTextPrimary}" FontSize="13"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Clear -->
                                    <Button Command="{Binding ClearCategoryCommand}"
                                            Style="{StaticResource NeoActionDropdownItem}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M9,3V4H4V6H5V19A2,2 0 0,0 7,21H17A2,2 0 0,0 19,19V6H20V4H15V3H9M7,6H17V19H7V6Z"
                                                  Fill="{StaticResource NeoCyanIce}"
                                                  Width="14" Height="14"
                                                  Margin="0,0,10,0"
                                                  Stretch="Uniform"/>
                                            <TextBlock Text="Clear" Foreground="{StaticResource NeoTextPrimary}" FontSize="13"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>

                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Margin="16,0,0,0">
                    <Grid Width="300" VerticalAlignment="Center">
                        <Border Background="{StaticResource NeoGlass12}"
                                BorderBrush="{StaticResource NeoBorderGlass}"
                                BorderThickness="1"
                                CornerRadius="9"
                                Height="32"
                                Opacity="0.9">
                            <Grid>
                                <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"
                                      Fill="{StaticResource NeoTextTertiary}"
                                      Width="12" Height="12" Stretch="Uniform"
                                      HorizontalAlignment="Left" VerticalAlignment="Center"
                                      Margin="12,0,0,0"/>
                                <TextBox x:Name="TopSearchBox"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{StaticResource NeoTextPrimary}"
                                         CaretBrush="{StaticResource NeoCyanIce}"
                                         SelectionBrush="{StaticResource NeoGlowCyanSoft}"
                                         FontFamily="{StaticResource NeoFontFamily}"
                                         FontSize="12"
                                         VerticalContentAlignment="Center"
                                         Padding="34,0,52,0"
                                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                         TextChanged="TopSearchBox_TextChanged">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </Grid>
                        </Border>
                        <Border HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0"
                                Background="{StaticResource NeoGlass10}"
                                BorderBrush="{StaticResource NeoBorderGlass}"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="4,1"
                                Opacity="0.66"
                                IsHitTestVisible="False">
                            <TextBlock Text="CTRL+K"
                                       Foreground="{StaticResource NeoTextTertiary}"
                                       FontFamily="{StaticResource NeoFontFamily}"
                                       FontSize="8"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </Grid>

                    <Button Command="{Binding LoadMoreServerCatalogButtonCommand}"
                            Background="{StaticResource NeoGlass10}"
                            BorderBrush="{StaticResource NeoBorderGlass}"
                            BorderThickness="1"
                            Height="28"
                            MinWidth="72"
                            Padding="8,0"
                            VerticalAlignment="Center"
                            Margin="8,0,0,0"
                            Opacity="0.82">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource HeaderActionButtonStyle}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsServersView}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CanLoadMoreServerCatalog}" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CanLoadMoreServerCatalog}" Value="False">
                                        <Setter Property="Opacity" Value="0.55"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="LOAD MORE"
                                   Foreground="{DynamicResource AtlasCyanBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="8"/>
                    </Button>

                        <Button x:Name="MediaVoiceSpeechBtn"
                            Style="{StaticResource HeaderActionDiscreetButtonStyle}"
                            Width="30"
                            Height="30"
                            Margin="8,0,0,0"
                            Padding="0"
                            FontSize="13"
                            Visibility="Collapsed"
                            ToolTip="Speech output on/off"
                            Click="MediaVoiceSpeechBtn_Click"
                            Content="🔊"/>

                        <Button x:Name="MediaVoiceMicBtn"
                            Style="{StaticResource HeaderActionDiscreetButtonStyle}"
                            Width="30"
                            Height="30"
                            Margin="6,0,0,0"
                            Padding="0"
                            FontSize="13"
                            ToolTip="Mic not wired"
                            Click="MediaVoiceMicBtn_Click"
                            Content="🎤"/>

                        <TextBlock x:Name="MediaVoiceNoteText"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               FontFamily="{StaticResource NeoFontFamily}"
                               FontSize="10"
                               Foreground="#FBBF24"
                               Visibility="Collapsed"
                               Text=""/>

                </StackPanel>
            </Grid>
        </Border>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════
             Original TopNavBar kept for backward-compat event wiring.
             Hidden — all navigation now flows through NeoNavSidebar.
        ══════════════════════════════════════════════════════════ -->
        <Border x:Name="TopNavBar" Grid.Row="0" Grid.Column="1" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#802B0000"
                        BorderBrush="#40AA0000"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="8,4"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Width="160">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5A4.5,4.5 0 0,0 5,9.5A4.5,4.5 0 0,0 9.5,14A4.5,4.5 0 0,0 14,9.5A4.5,4.5 0 0,0 9.5,5Z"
                              Fill="{DynamicResource AtlasCyanBrush}"
                              Width="14"
                              Height="14"
                              Stretch="Uniform"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1"
                                 x:Name="LegacyTopSearchBox"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0"
                                 FontSize="12"
                                 Foreground="{DynamicResource AtlasTextPrimaryBrush}"
                                 CaretBrush="#AA0000"
                                 SelectionBrush="#40AA0000"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 TextChanged="TopSearchBox_TextChanged"/>
                    </Grid>
                </Border>

                <!-- Center: Categories -->
                <Grid Grid.Column="1" Margin="0,0,24,0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ScrollViewer x:Name="CategoryScrollViewer"
                                  Grid.Column="0"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  Focusable="False"
                                  PanningMode="HorizontalOnly"
                                  PreviewMouseWheel="HorizontalScrollViewer_PreviewMouseWheel">
                        <ItemsControl ItemsSource="{Binding Categories}" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{DynamicResource CategoryTabButtonStyle}"
                                                Margin="0,0,10,0">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Viewbox Width="14" Height="14" Stretch="Uniform" Margin="0,1,8,0" VerticalAlignment="Center">
                                                    <Path Data="{Binding IconGeometry}"
                                                          Stretch="Uniform"
                                                          Fill="{DynamicResource AtlasCyanBrush}"/>
                                                </Viewbox>
                                                <TextBlock Text="{Binding Label}"
                                                           Foreground="{DynamicResource AtlasTextPrimaryBrush}"
                                                           FontFamily="{DynamicResource AtlasFontPrimary}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- Right: Streams Mode + AI Chat Toggle -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="12,0,0,0">
                      <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0" Visibility="Collapsed">
                          <TextBlock Text="SOURCES" Foreground="{DynamicResource AtlasTextMutedBrush}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                          <ComboBox ItemsSource="{Binding StreamsModes}"
                                    SelectedValuePath="Value"
                                    DisplayMemberPath="Label"
                                    SelectedValue="{Binding SelectedStreamsMode}"
                                    Style="{StaticResource AtlasPillComboBox}"
                                    MinWidth="120"
                                    VerticalAlignment="Center"/>
                      </StackPanel>
                      <Button x:Name="AiChatToggleButton"
                              Command="{Binding ToggleChatCommand}"
                              Style="{DynamicResource HeaderActionButtonStyle}"
                              BorderBrush="#40AA0000">
                          <StackPanel Orientation="Horizontal">
                              <Path Data="M20,2H4A2,2 0 0,0 2,4V22L6,18H20A2,2 0 0,0 22,16V4A2,2 0 0,0 20,2M20,16H6L4,18V4H20"
                                    Fill="{DynamicResource AtlasCyanBrush}"
                                    Width="14" Height="14" Margin="0,0,8,0"
                                    Stretch="Uniform"/>
                              <TextBlock Text="AI CHAT" Foreground="{DynamicResource AtlasTextPrimaryBrush}" FontWeight="SemiBold" FontSize="11"/>
                          </StackPanel>
                      </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="LibraryContent" Grid.Row="1" Grid.Column="1">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Background" Value="Transparent"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsServersView}" Value="True">
                            <Setter Property="Background" Value="#080A10"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftSidebarColumn" Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="LeftSidebar" Grid.Column="0"
                    Margin="0,0,24,0"
                    Padding="22">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource GlassPanelBorderStyle}">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRadioView}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsFigmaWebViewActive}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border x:Name="NowPlayingVisualizerHost"
                            Grid.Row="0"
                            Margin="0,0,0,16"
                            Background="#141A24"
                            BorderBrush="#20CC0000"
                            BorderThickness="1"
                            CornerRadius="14">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Hidden"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <mc:AudioVisualizerControl x:Name="NowPlayingVisualizer"
                                                  Margin="12"
                                                  IsPlaying="{Binding IsPlaying}"/>
                    </Border>

                    <StackPanel Grid.Row="1" Margin="0,0,0,14">
                        <Grid Margin="0,0,0,10">
                            <Border HorizontalAlignment="Left" Background="#20CC0000" CornerRadius="12" Padding="12,6">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Path Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M11,8V16L17,12L11,8Z"
                                          Fill="{DynamicResource AtlasCyanBrush}"
                                          Width="12"
                                          Height="12"
                                          Stretch="Uniform"
                                          Margin="0,0,8,0"
                                          RenderTransformOrigin="0.5,0.5">
                                        <Path.RenderTransform>
                                            <RotateTransform Angle="0"/>
                                        </Path.RenderTransform>
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Opacity" Value="0.9"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard x:Name="NowPlayingLabelAnim">
                                                                <Storyboard RepeatBehavior="Forever">
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="0.55"
                                                                                     To="1"
                                                                                     Duration="0:0:0.8"
                                                                                     AutoReverse="True"/>
                                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(Path.RenderTransform).(RotateTransform.Angle)"
                                                                                                   Duration="0:0:5">
                                                                        <LinearDoubleKeyFrame Value="0" KeyTime="0:0:0"/>
                                                                        <LinearDoubleKeyFrame Value="360" KeyTime="0:0:0.8"/>
                                                                        <LinearDoubleKeyFrame Value="360" KeyTime="0:0:5"/>
                                                                    </DoubleAnimationUsingKeyFrames>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                        <DataTrigger.ExitActions>
                                                            <StopStoryboard BeginStoryboardName="NowPlayingLabelAnim"/>
                                                        </DataTrigger.ExitActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                    <TextBlock Text="NOW PLAYING" Foreground="{DynamicResource AtlasCyanBrush}" FontSize="10" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <ToggleButton HorizontalAlignment="Right"
                                          Width="34"
                                          Height="34"
                                          Background="Transparent"
                                          BorderBrush="{DynamicResource AtlasBorderBrush}"
                                          BorderThickness="1"
                                          IsChecked="{Binding NowPlayingFavorite}">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Opacity" Value="0.75"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="17"
                                                            Width="{TemplateBinding Width}"
                                                            Height="{TemplateBinding Height}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AtlasOrangeBrush}"/>
                                                            <Setter Property="Opacity" Value="1.0"/>
                                                        </Trigger>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AtlasOrangeBrush}"/>
                                                            <Setter Property="Opacity" Value="1.0"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ToggleButton.Style>
                                <Image Width="16"
                                       Height="16"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Source="pack://siteoforigin:,,,/Assets/MediaPlayer/Buttons/like.png"/>
                            </ToggleButton>
                        </Grid>
                        <TextBlock Text="{Binding NowPlayingTitle}" Foreground="{DynamicResource AtlasTextPrimaryBrush}" FontSize="22" FontWeight="Bold"
                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                        <TextBlock Text="{Binding NowPlayingArtist}" Foreground="{DynamicResource AtlasTextSecondaryBrush}" FontSize="13" Margin="0,4,0,0"
                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                        <TextBlock Text="{Binding NowPlayingAlbum}" Foreground="{DynamicResource AtlasTextMutedBrush}" FontSize="12" Margin="0,2,0,0"
                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                    </StackPanel>

                    <Grid Grid.Row="2" Margin="0,0,0,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <TextBlock Text="{Binding ProgressText}" Foreground="{DynamicResource AtlasTextMutedBrush}" FontSize="10"/>
                            <TextBlock Text="{Binding TotalText}" Foreground="{DynamicResource AtlasTextMutedBrush}" FontSize="10" HorizontalAlignment="Right"/>
                        </Grid>
                        <Slider Grid.Row="1"
                                x:Name="NowPlayingSeek"
                                Minimum="0"
                                Maximum="{Binding TotalSeconds}"
                                IsDirectionReversed="False"
                                Value="{Binding ProgressSeconds, Mode=TwoWay}"
                                Height="18"
                                VerticalAlignment="Center"
                                IsMoveToPointEnabled="True"
                                PreviewMouseLeftButtonDown="NowPlayingSeek_PreviewMouseLeftButtonDown"
                                PreviewMouseLeftButtonUp="NowPlayingSeek_PreviewMouseLeftButtonUp">
                            <Slider.Template>
                                <ControlTemplate TargetType="{x:Type Slider}">
                                    <Grid Height="18" SnapsToDevicePixels="True">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Track x:Name="PART_Track" IsDirectionReversed="False">
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton IsHitTestVisible="False" Focusable="False">
                                                    <RepeatButton.Template>
                                                        <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                            <Border Height="6"
                                                                    Background="{DynamicResource AtlasCyanBrush}"
                                                                    CornerRadius="3">
                                                                <Border.Effect>
                                                                    <DropShadowEffect Color="#8022D3EE" BlurRadius="14" ShadowDepth="0" Opacity="0"/>
                                                                </Border.Effect>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </RepeatButton.Template>
                                                </RepeatButton>
                                            </Track.DecreaseRepeatButton>
                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton IsHitTestVisible="False" Focusable="False">
                                                    <RepeatButton.Template>
                                                        <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                            <Border Height="6" Background="#30111A24" CornerRadius="3"/>
                                                        </ControlTemplate>
                                                    </RepeatButton.Template>
                                                </RepeatButton>
                                            </Track.IncreaseRepeatButton>
                                            <Track.Thumb>
                                                <Thumb Width="14" Height="14">
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="{x:Type Thumb}">
                                                            <Grid Width="14" Height="14">
                                                                <Ellipse Fill="#0AFFFFFF" Stroke="{DynamicResource AtlasCyanBrush}" StrokeThickness="2">
                                                                <Ellipse.Effect>
                                                                    <DropShadowEffect Color="#CC22D3EE" BlurRadius="18" ShadowDepth="0" Opacity="0"/>
                                                                </Ellipse.Effect>
                                                                </Ellipse>
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Slider.Template>
                        </Slider>
                    </Grid>

                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top">
                            <ToggleButton Style="{DynamicResource AtlasToggleButton}"
                                          IsChecked="{Binding ShuffleEnabled}"
                                          Margin="0,0,12,0"
                                          Width="46"
                                          Height="46"
                                          VerticalAlignment="Center">
                                <Grid Width="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=ActualWidth}"
                                      Height="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=ActualHeight}">
                                    <Viewbox Stretch="Uniform">
                                        <Image Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               Source="pack://siteoforigin:,,,/Assets/MediaPlayer/Buttons/shuffle.png"/>
                                    </Viewbox>
                                </Grid>
                            </ToggleButton>
                            <Button Style="{DynamicResource AtlasIconButton}" Command="{Binding PreviousCommand}" Margin="0,0,8,0" Width="46" Height="46">
                                <Grid Width="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=ActualWidth}"
                                      Height="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=ActualHeight}">
                                    <Viewbox Stretch="Uniform">
                                        <Image Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               Source="pack://siteoforigin:,,,/Assets/MediaPlayer/Buttons/prev.png"/>
                                    </Viewbox>
                                </Grid>
                            </Button>
                            <Button Command="{Binding TogglePlayPauseCommand}"
                                    Width="96"
                                    Height="96"
                                    FontSize="22"
                                    FontWeight="SemiBold"
                                    Background="Transparent"
                                    BorderBrush="{DynamicResource AtlasCyanBrush}"
                                    BorderThickness="2"
                                    Cursor="Hand"
                                    Margin="0,0,8,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="22">
                                            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                <Viewbox Stretch="Uniform">
                                                    <Image x:Name="NowPlayingPlayImg"
                                                           Stretch="Uniform"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           Source="pack://siteoforigin:,,,/Assets/MediaPlayer/Buttons/play.png"
                                                           Visibility="Visible"/>
                                                </Viewbox>
                                                <Viewbox Stretch="Uniform">
                                                    <Image x:Name="NowPlayingPauseImg"
                                                           Stretch="Uniform"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           Source="pack://siteoforigin:,,,/Assets/MediaPlayer/Buttons/pause.png"
                                                           Visibility="Collapsed"/>
                                                </Viewbox>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                <Setter TargetName="NowPlayingPlayImg" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="NowPlayingPauseImg" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Style="{DynamicResource AtlasIconButton}" Command="{Binding NextCommand}" Margin="0,0,12,0" Width="46" Height="46">
                                <Grid Width="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=ActualWidth}"
                                      Height="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=ActualHeight}">
                                    <Viewbox Stretch="Uniform">
                                        <Image Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               Source="pack://siteoforigin:,,,/Assets/MediaPlayer/Buttons/next.png"/>
                                    </Viewbox>
                                </Grid>
                            </Button>
                            <ToggleButton Style="{DynamicResource AtlasToggleButton}"
                                          IsChecked="{Binding RepeatEnabled}"
                                          Width="46"
                                          Height="46"
                                          VerticalAlignment="Center">
                                <Grid Width="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=ActualWidth}"
                                      Height="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=ActualHeight}">
                                    <Viewbox Stretch="Uniform">
                                        <Image Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               Source="pack://siteoforigin:,,,/Assets/MediaPlayer/Buttons/repeat.png"/>
                                    </Viewbox>
                                </Grid>
                            </ToggleButton>
                        </StackPanel>

                        <Border Grid.Row="1"
                                Width="168"
                                Height="168"
                                CornerRadius="18"
                                BorderBrush="#20CC0000"
                                BorderThickness="1"
                                Background="Transparent"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Margin="0,16,0,0">
                            <Image Source="{Binding NowPlayingCoverImage}"
                                   Stretch="UniformToFill"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"
                                   controls:RoundedClip.CornerRadius="18"/>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="4" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Image Grid.Column="0"
                               Width="18"
                               Height="18"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Source="pack://siteoforigin:,,,/Assets/MediaPlayer/Buttons/volume.png"/>
                        <Slider Grid.Column="1"
                                Minimum="0"
                                Maximum="100"
                                IsDirectionReversed="False"
                                Value="{Binding Volume}"
                                Height="20"
                                VerticalAlignment="Center">
                            <Slider.Template>
                                <ControlTemplate TargetType="{x:Type Slider}">
                                    <Grid Height="18" SnapsToDevicePixels="True">
                                        <Track x:Name="PART_Track" IsDirectionReversed="False">
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton IsHitTestVisible="False" Focusable="False">
                                                    <RepeatButton.Template>
                                                        <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                            <Border Height="6"
                                                                    Background="{DynamicResource AtlasCyanBrush}"
                                                                    CornerRadius="3">
                                                                <Border.Effect>
                                                                    <DropShadowEffect Color="#8022D3EE" BlurRadius="14" ShadowDepth="0" Opacity="0"/>
                                                                </Border.Effect>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </RepeatButton.Template>
                                                </RepeatButton>
                                            </Track.DecreaseRepeatButton>
                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton IsHitTestVisible="False" Focusable="False">
                                                    <RepeatButton.Template>
                                                        <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                            <Border Height="6" Background="#30111A24" CornerRadius="3"/>
                                                        </ControlTemplate>
                                                    </RepeatButton.Template>
                                                </RepeatButton>
                                            </Track.IncreaseRepeatButton>
                                            <Track.Thumb>
                                                <Thumb Width="14" Height="14">
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="{x:Type Thumb}">
                                                            <Grid Width="14" Height="14">
                                                                <Ellipse Fill="#0AFFFFFF" Stroke="{DynamicResource AtlasCyanBrush}" StrokeThickness="2">
