                                                                        <Image.Style>
                                                                            <Style TargetType="Image">
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Key}" Value="imdb">
                                                                                        <Setter Property="Source" Value="https://upload.wikimedia.org/wikipedia/commons/6/69/IMDB_Logo_2016.svg"/>
