                            <StackPanel Orientation="Horizontal">
                                <Path Data="M12.5,8C9.47,8 6.89,9.72 5.56,12.22L3,9.5V16H9.5L6.84,13.34C7.9,11.5 10.03,10.25 12.5,10.25C15.81,10.25 18.57,12.55 19.26,15.64L21.45,15.14C20.54,11.2 16.92,8 12.5,8Z"
                                      Fill="{DynamicResource AtlasCyanBrush}"
                                      Width="14"
                                      Height="14"
                                      Margin="0,0,8,0"
                                      Stretch="Uniform"/>
