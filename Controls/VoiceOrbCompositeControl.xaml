<UserControl x:Class="AtlasAI.Controls.VoiceOrbCompositeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AtlasAI.Controls"
             x:Name="Root"
             Width="150" Height="150">
    <Grid>
        <controls:AtlasCoreControl x:Name="Core"
                                   Width="{Binding ElementName=Root, Path=Width}"
                                   Height="{Binding ElementName=Root, Path=Height}"
                                   ShowStateLabel="False"/>
    </Grid>
</UserControl>
