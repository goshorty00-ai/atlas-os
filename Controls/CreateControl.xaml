<UserControl x:Class="AtlasAI.Controls.CreateControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1000"
             Background="Transparent">

    <Grid Margin="16">
        <Border Background="#0B1220"
                BorderBrush="#22314A"
                BorderThickness="1"
                CornerRadius="16"
                SnapsToDevicePixels="True">
            <Grid>
                <wv2:WebView2 x:Name="CreateWebView" />

                <Border x:Name="LoadingOverlay"
                        Background="#D90B1220"
                        CornerRadius="16"
                        Visibility="Visible">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="AI CREATE"
                                   Foreground="#8AA0B8"
                                   FontSize="12"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Loading Social Media Creator"
                                   Foreground="#E6EEF8"
                                   FontSize="28"
                                   Margin="0,8,0,12"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Preparing WebView2 and front-end bundle..."
                                   Foreground="#9FB3C8"
                                   FontSize="14"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>