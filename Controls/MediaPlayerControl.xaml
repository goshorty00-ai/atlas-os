<UserControl x:Class="AtlasAI.Controls.MediaPlayerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AtlasAI.Controls"
             xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
             Background="#050508"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             MinHeight="420">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Theme/Colors.xaml"/>
                <ResourceDictionary Source="../Theme/Typography.xaml"/>
                <ResourceDictionary Source="../Theme/Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Primary Transport Button Style -->
            <Style x:Key="PrimaryTransportButton" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource AtlasGlassBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AtlasCyanBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="50">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource AtlasCyanBrush}" />
                                    <Setter Property="BorderBrush" Value="{StaticResource AtlasCyanBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="{StaticResource AtlasCyanDimBrush}" />
                                    <Setter Property="BorderBrush" Value="{StaticResource AtlasCyanDimBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            
            <!-- Secondary Control Button Style -->
            <Style x:Key="SecondaryControlButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Opacity" Value="0.7" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Padding="0">
                                <ContentPresenter HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="1.0" />
                                    <Setter Property="Background" Value="{StaticResource AtlasGlassBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Opacity" Value="0.8" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            
            <Style x:Key="NeonSeekSlider" TargetType="Slider">
                <Setter Property="Height" Value="18"/>
                <Setter Property="IsMoveToPointEnabled" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Slider}">
                            <Grid Height="18" SnapsToDevicePixels="True">
                                <Track x:Name="PART_Track" IsDirectionReversed="False">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton IsHitTestVisible="False" Focusable="False">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                    <Border Height="6"
                                                            Background="{StaticResource AtlasCyanBrush}"
                                                            CornerRadius="3">
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="#8022D3EE" BlurRadius="14" ShadowDepth="0" Opacity="0"/>
                                                        </Border.Effect>
                                                    </Border>
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton IsHitTestVisible="False" Focusable="False">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                    <Border Height="6" Background="#30111A24" CornerRadius="3"/>
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Width="14" Height="14">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="{x:Type Thumb}">
                                                    <Grid Width="14" Height="14">
                                                        <Ellipse Fill="#0AFFFFFF" Stroke="{StaticResource AtlasCyanBrush}" StrokeThickness="2">
                                                                <Ellipse.Effect>
                                                                    <DropShadowEffect Color="#CC22D3EE" BlurRadius="18" ShadowDepth="0" Opacity="0"/>
                                                                </Ellipse.Effect>
                                                        </Ellipse>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            
            <!-- Volume Slider Style -->
            <Style x:Key="VolumeSlider" TargetType="Slider">
                <Setter Property="Height" Value="4" />
                <Setter Property="Width" Value="80" />
            </Style>

            <Style x:Key="PlayerButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="20">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource AtlasGlassBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource AtlasGlassMediumBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="PlayPauseButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Ellipse x:Name="glow" Stroke="{StaticResource AtlasCyanBrush}" StrokeThickness="2" Opacity="0"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="glow" Property="Opacity" Value="0.5"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="glow" Property="Opacity" Value="0.8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            
            <!-- Minimal Transport Button (no glow) -->
            <Style x:Key="MinimalTransportButton" TargetType="Button" BasedOn="{StaticResource PlayerButtonStyle}">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
            </Style>
            
            <!-- Minimal Seek Slider (reduced glow) -->
            <Style x:Key="MinimalSeekSlider" TargetType="Slider">
                <Setter Property="Height" Value="12"/>
                <Setter Property="IsMoveToPointEnabled" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Slider}">
                            <Grid Height="12" SnapsToDevicePixels="True">
                                <Track x:Name="PART_Track" IsDirectionReversed="False">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton IsHitTestVisible="False" Focusable="False">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                    <Border Height="4" Background="#30FFFFFF" CornerRadius="2"/>
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton IsHitTestVisible="False" Focusable="False">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                    <Border Height="4" Background="#202530" CornerRadius="2"/>
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Width="12" Height="12">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="{x:Type Thumb}">
                                                    <Grid Width="12" Height="12">
                                                        <Ellipse Fill="#55FFFFFF" Stroke="#00FFFFFF" StrokeThickness="0"/>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <Grid Name="PlayerGrid" Background="Black" MouseMove="Grid_MouseMove">
        <!-- Grid Partitioning to solve Airspace issues (Native Video vs WPF Controls) -->
        <!-- Figma integration test - MediaPlayer component mapping -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Top Bar -->
            <RowDefinition Height="*" />    <!-- Video -->
            <RowDefinition Height="Auto" /> <!-- Bottom Bar -->
        </Grid.RowDefinitions>

        <!-- Top Header (Row 0) -->
        <Border Name="TopControlBar"
                Grid.Row="0"
                Height="60"
                VerticalAlignment="Top"
                Margin="0"
                Background="#CC101015"
                BorderBrush="Transparent"
                BorderThickness="0"
                Padding="16,10"
                IsHitTestVisible="True"
                Panel.ZIndex="2100">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <!-- Title Info -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="NOW PLAYING"
                               Foreground="{StaticResource AtlasCyanBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,16,0"
                               VerticalAlignment="Center"
                               Opacity="0.8" />
                    <TextBlock Name="MediaTitleText"
                               Text="Select Media to Play"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Name="MinimizePlayerButton"
                            Content="—"
                            Click="MinimizePlayerButton_Click"
                            Background="Transparent"
                            Foreground="{StaticResource AtlasTextPrimaryBrush}"
                            BorderBrush="#5522d3ee"
                            BorderThickness="1"
                            Width="34"
                            Height="28"
                            FontSize="14"
                            Margin="0,0,10,0"
                            Padding="0"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center" />
                    <Button Name="ClosePlayerButton"
                            Content="✕"
                            Click="ClosePlayerButton_Click"
                            Background="Transparent"
                            Foreground="{StaticResource AtlasTextPrimaryBrush}"
                            BorderBrush="#5522d3ee"
                            BorderThickness="1"
                            Width="34"
                            Height="28"
                            FontSize="14"
                            Padding="0"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Video View (Row 1) -->
        <vlc:VideoView Name="VideoView"
                       Grid.Row="1"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"
                       MinHeight="300"
                       IsHitTestVisible="False"
                       ClipToBounds="True"
                       Background="Black" />

        <!-- Loading Overlay (Row 1) -->
        <Grid Name="LoadingOverlay"
              Grid.Row="1"
              Background="Black"
              Visibility="Collapsed"
              Panel.ZIndex="2000">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                             Width="200"
                             Height="4"
                             Foreground="{StaticResource AtlasCyanBrush}"
                             Background="#33FFFFFF"
                             BorderThickness="0" />
                <TextBlock Text="Loading Media..."
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0"
                           FontSize="14" />
            </StackPanel>
        </Grid>
        
        <!-- Status Overlay (Row 1) - For OSD messages like Volume, Subs, Aspect -->
        <Grid Name="StatusOverlay"
              Grid.Row="1"
              VerticalAlignment="Top"
              HorizontalAlignment="Right"
              Margin="0,32,32,0"
              Visibility="Collapsed"
              Panel.ZIndex="2100">
            <Border Background="#CC000000" 
                    CornerRadius="8" 
                    Padding="16,8">
                <TextBlock Name="StatusText"
                           Text="Aspect Ratio: 16:9"
                           Foreground="White"
                           FontSize="16"
                           FontWeight="SemiBold"/>
            </Border>
        </Grid>

        <!-- Lyrics Overlay (Row 1) -->
        <Grid Name="LyricsOverlay"
              Grid.Row="1"
              Background="#E6000000"
              Visibility="Collapsed"
              Panel.ZIndex="2200">
            <ScrollViewer Name="LyricsScrollViewer"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="True"
                          PanningMode="VerticalOnly">
                <ItemsControl Name="LyricsItemsControl"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Margin="0,100">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Margin="0,12"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       FontFamily="{StaticResource AtlasFontPrimary}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#80FFFFFF"/>
                                        <Setter Property="Opacity" Value="0.6"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AtlasCyanBrush}"/>
                                                <Setter Property="Opacity" Value="1.0"/>
                                                <Setter Property="FontSize" Value="32"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="{StaticResource AtlasCyan}" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
            <!-- Close Lyrics Button -->
            <Button HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="32"
                    Click="LyricsButton_Click"
                    Style="{StaticResource PlayerButtonStyle}"
                    ToolTip="Close Lyrics">
                <Viewbox Width="24" Height="24">
                    <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                          Fill="White" Stretch="Uniform"/>
                </Viewbox>
            </Button>
        </Grid>

        <!-- Error Overlay (Row 1) -->
        <Grid Name="ErrorOverlay"
              Grid.Row="1"
              Background="Black"
              Visibility="Collapsed"
              Panel.ZIndex="2500">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Path Data="M13,13H11V7H13M13,17H11V15H13M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2Z"
                      Fill="{StaticResource AtlasErrorBrush}"
                      Width="48"
                      Height="48"
                      Stretch="Uniform"
                      Margin="0,0,0,16" />
                <TextBlock Text="Playback Error"
                           Foreground="{StaticResource AtlasErrorBrush}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8" />
                <TextBlock Name="ErrorMessage"
                           Text="Unable to play this media file."
                           Foreground="{StaticResource AtlasTextMutedBrush}"
                           FontSize="14"
                           HorizontalAlignment="Center" />
                <TextBlock Name="ErrorDetails"
                           Text=""
                           Foreground="{StaticResource AtlasTextMutedBrush}"
                           FontSize="11"
                           Opacity="0.9"
                           TextWrapping="Wrap"
                           MaxWidth="720"
                           Margin="0,10,0,0"
                           HorizontalAlignment="Center" />
                           
                <Button Name="RetryButton"
                        Content="Retry"
                        Click="RetryButton_Click"
                        Style="{StaticResource PrimaryTransportButton}"
                        Padding="24,8"
                        Margin="0,16,0,0"
                        Width="120"
                        Height="40" />
                <Button Name="CopyErrorButton"
                        Content="Copy"
                        Click="CopyErrorButton_Click"
                        Style="{StaticResource PrimaryTransportButton}"
                        Padding="24,8"
                        Margin="0,10,0,0"
                        Width="120"
                        Height="40" />
                <Button Name="CloseErrorButton"
                        Content="Close"
                        Click="CloseErrorButton_Click"
                        Style="{StaticResource PrimaryTransportButton}"
                        Padding="24,8"
                        Margin="0,10,0,0"
                        Width="120"
                        Height="40" />
            </StackPanel>
        </Grid>

        <!-- Bottom Controls (Row 2) -->
        <Border Name="ControlBar"
                Grid.Row="2"
                Background="#000000"
                BorderBrush="Transparent"
                BorderThickness="0"
                Padding="16,12,16,12"
                IsHitTestVisible="True">
            <StackPanel Orientation="Vertical">
                <!-- Progress Bar -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Name="CurrentTimeText" 
                               Grid.Column="0"
                               Text="0:00"
                               Foreground="White"
                               FontSize="14"
                               FontFamily="Consolas"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0" />
                    <Slider Name="ProgressSlider"
                            Grid.Column="1"
                            Minimum="0"
                            Maximum="100"
                            Value="0"
                            VerticalAlignment="Center"
                            Style="{StaticResource MinimalSeekSlider}"
                            Margin="0,0,12,0"
                            PreviewMouseLeftButtonDown="ProgressSlider_PreviewMouseLeftButtonDown"
                            PreviewMouseLeftButtonUp="ProgressSlider_PreviewMouseLeftButtonUp"
                            ValueChanged="ProgressSlider_ValueChanged" />
                    <TextBlock Name="TotalTimeText"
                               Grid.Column="2"
                               Text="0:00"
                               Foreground="White"
                               FontSize="14"
                               FontFamily="Consolas"
                               VerticalAlignment="Center" />
                </Grid>
                
                <!-- Transport Controls -->
                <Grid Height="96">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <!-- Left: Shuffle/Repeat -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Name="ShuffleButton"
                                Width="56"
                                Height="56"
                                Margin="0,0,12,0"
                                Click="ShuffleButton_Click"
                                Style="{StaticResource MinimalTransportButton}"
                                Padding="0"
                                ToolTip="Toggle Shuffle">
                            <Viewbox Stretch="Uniform">
                                <Image x:Name="ShuffleIconImage"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Source="pack://siteoforigin:,,,/Assets/MediaPlayer/Buttons/shuffle.png"/>
                            </Viewbox>
                        </Button>
                        <Button Name="RepeatButton"
                                Width="56"
                                Height="56"
                                Margin="0,0,12,0"
                                Click="RepeatButton_Click"
                                Style="{StaticResource MinimalTransportButton}"
                                Padding="0"
                                ToolTip="Toggle Repeat">
                            <Viewbox Stretch="Uniform">
                                <Image x:Name="RepeatIconImage"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Source="pack://siteoforigin:,,,/Assets/MediaPlayer/Buttons/repeat.png"/>
                            </Viewbox>
                        </Button>
                    </StackPanel>

                    <!-- Center: Play/Prev/Next -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Name="PreviousButton"
                                Width="64"
                                Height="64"
                                Margin="0,0,12,0"
                                Click="PreviousButton_Click"
                                Style="{StaticResource MinimalTransportButton}"
                                Padding="0"
                                ToolTip="REW">
                            <Viewbox Stretch="Uniform">
                                <Image Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Source="pack://siteoforigin:,,,/Assets/MediaPlayer/Buttons/prev.png"/>
                            </Viewbox>
                        </Button>
                        <Button Name="PlayPauseButton"
                                Width="72"
                                Height="72"
                                Margin="0,0,12,0"
                                Click="PlayPauseButton_Click"
                                Style="{StaticResource MinimalTransportButton}"
                                Padding="0"
                                ToolTip="Play/Pause">
                            <Grid>
                                <Viewbox Stretch="Uniform">
                                    <Image x:Name="PlayIconImage"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           Source="pack://siteoforigin:,,,/Assets/MediaPlayer/Buttons/play.png"
                                           Visibility="Collapsed"/>
                                </Viewbox>
                                <Viewbox Stretch="Uniform">
                                    <Image x:Name="PauseIconImage"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           Source="pack://siteoforigin:,,,/Assets/MediaPlayer/Buttons/pause.png"
                                           Visibility="Visible"/>
                                </Viewbox>
                            </Grid>
                        </Button>
                        <Button Name="NextButton"
                                Width="64"
                                Height="64"
                                Click="NextButton_Click"
                                Style="{StaticResource MinimalTransportButton}"
                                Padding="0"
                                ToolTip="FFD">
                            <Viewbox Stretch="Uniform">
                                <Image Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Source="pack://siteoforigin:,,,/Assets/MediaPlayer/Buttons/next.png"/>
                            </Viewbox>
                        </Button>
                    </StackPanel>

                    <!-- Right: Options + Volume -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- Subtitle Button -->
                        <Button Name="SubtitleButton"
                                Width="36"
                                Height="36"
                                Margin="0,0,8,0"
                                Click="SubtitleButton_Click"
                                Style="{StaticResource MinimalTransportButton}"
                                ToolTip="Toggle Subtitles">
                            <Image Width="22"
                                   Height="22"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Source="pack://siteoforigin:,,,/Assets/MediaPlayer/Buttons/closed_captions.png"/>
                        </Button>

                        <!-- Audio Track Button -->
                        <Button Name="AudioTrackButton"
                                Width="36"
                                Height="36"
                                Margin="0,0,8,0"
                                Click="AudioTrackButton_Click"
                                Style="{StaticResource MinimalTransportButton}"
                                ToolTip="Change Audio Track">
                            <Image Width="22"
                                   Height="22"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Source="pack://siteoforigin:,,,/Assets/MediaPlayer/Buttons/language.png"/>
                        </Button>

                        <!-- Aspect Ratio Button -->
                        <Button Name="AspectRatioButton"
                                Width="36"
                                Height="36"
                                Margin="0,0,12,0"
                                Click="AspectRatioButton_Click"
                                Style="{StaticResource MinimalTransportButton}"
                                ToolTip="Change Aspect Ratio">
                            <Image Width="22"
                                   Height="22"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Source="pack://siteoforigin:,,,/Assets/MediaPlayer/Buttons/aspect_ratio.png"/>
                        </Button>

                         <Button Name="MuteButton"
                                Width="36"
                                Height="36"
                                Margin="0,0,8,0"
                                Click="MuteButton_Click"
                                Style="{StaticResource MinimalTransportButton}"
                                ToolTip="Mute">
                            <Grid>
                                <Image x:Name="VolumeIconImage"
                                       Width="22"
                                       Height="22"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Source="pack://siteoforigin:,,,/Assets/MediaPlayer/Buttons/volume.png"
                                       Visibility="Visible"/>
                                <Image x:Name="MuteIconImage"
                                       Width="22"
                                       Height="22"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Source="pack://siteoforigin:,,,/Assets/MediaPlayer/Buttons/mute.png"
                                       Visibility="Collapsed"/>
                            </Grid>
                        </Button>
                        <Slider Name="VolumeSlider"
                                Width="92"
                                Minimum="0"
                                Maximum="100"
                                Value="70"
                                VerticalAlignment="Center"
                                ValueChanged="VolumeSlider_ValueChanged" 
                                Margin="0,0,16,0">
                            <Slider.Template>
                                <ControlTemplate TargetType="{x:Type Slider}">
                                    <Grid Height="18" SnapsToDevicePixels="True">
                                        <Track x:Name="PART_Track" IsDirectionReversed="False">
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton IsHitTestVisible="False" Focusable="False">
                                                    <RepeatButton.Template>
                                                        <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                            <Border Height="6"
                                                                    Background="{StaticResource AtlasCyanBrush}"
                                                                    CornerRadius="3">
                                                                <Border.Effect>
                                                                    <DropShadowEffect Color="#8022D3EE" BlurRadius="14" ShadowDepth="0" Opacity="0"/>
                                                                </Border.Effect>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </RepeatButton.Template>
                                                </RepeatButton>
                                            </Track.DecreaseRepeatButton>
                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton IsHitTestVisible="False" Focusable="False">
                                                    <RepeatButton.Template>
                                                        <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                            <Border Height="6" Background="#30111A24" CornerRadius="3"/>
                                                        </ControlTemplate>
                                                    </RepeatButton.Template>
                                                </RepeatButton>
                                            </Track.IncreaseRepeatButton>
                                            <Track.Thumb>
                                                <Thumb Width="14" Height="14">
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="{x:Type Thumb}">
                                                            <Grid Width="14" Height="14">
                                                                <Ellipse Fill="#0AFFFFFF" Stroke="{StaticResource AtlasCyanBrush}" StrokeThickness="2">
                                                                <Ellipse.Effect>
                                                                    <DropShadowEffect Color="#CC22D3EE" BlurRadius="18" ShadowDepth="0" Opacity="0"/>
                                                                </Ellipse.Effect>
                                                                </Ellipse>
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Slider.Template>
                        </Slider>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
