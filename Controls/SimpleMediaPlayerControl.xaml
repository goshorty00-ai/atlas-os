<UserControl x:Class="AtlasAI.Controls.SimpleMediaPlayerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             Focusable="True"
             KeyDown="SimpleMediaPlayerControl_KeyDown"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Theme/Colors.xaml"/>
                <ResourceDictionary Source="../Theme/Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="PlayerButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="20">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource AtlasGlassBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource AtlasGlassMediumBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="PlayPauseButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Ellipse x:Name="glow" Stroke="{StaticResource AtlasCyanBrush}" StrokeThickness="2" Opacity="0.35"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="glow" Property="Opacity" Value="0.65"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="glow" Property="Opacity" Value="0.9"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                    <Setter TargetName="glow" Property="Opacity" Value="0"/>
                                    <Setter TargetName="glow" Property="StrokeThickness" Value="0"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="PlayerNeonSliderStyle" TargetType="Slider">
                <Setter Property="Height" Value="18"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Slider">
                            <Grid Height="{TemplateBinding Height}">
                                <Track x:Name="PART_Track"
                                       Minimum="{TemplateBinding Minimum}"
                                       Maximum="{TemplateBinding Maximum}"
                                       Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Value}"
                                       IsDirectionReversed="False">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="Slider.DecreaseLarge" IsHitTestVisible="False">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <Border Height="6" CornerRadius="3" Background="{StaticResource AtlasCyanBrush}" Margin="0,0,-4,0">
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="{StaticResource AtlasCyan}" BlurRadius="12" ShadowDepth="0" Opacity="0.85"/>
                                                        </Border.Effect>
                                                    </Border>
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="Slider.IncreaseLarge" IsHitTestVisible="False">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <Border Height="6" CornerRadius="3" Background="#334155" Margin="4,0,0,0"/>
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Width="16" Height="16" Background="Transparent" Margin="0,-1,0,0">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                                                        <Ellipse Fill="#E0FFFF" Stroke="{StaticResource AtlasCyanBrush}" StrokeThickness="2">
                                                            <Ellipse.Effect>
                                                                <DropShadowEffect Color="{StaticResource AtlasCyan}" BlurRadius="15" ShadowDepth="0" Opacity="1.0"/>
                                                            </Ellipse.Effect>
                                                        </Ellipse>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" MouseMove="Grid_MouseMove" MouseLeftButtonDown="Grid_MouseLeftButtonDown">
        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="Background" Value="Black"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                            <Setter Property="Background" Value="#0A0E14"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsMiniPlayer, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                            <Setter Property="Background" Value="#0A0E14"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <MediaElement x:Name="Player"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Manual"
                      Stretch="UniformToFill"
                      MediaOpened="Player_MediaOpened"
                      MediaEnded="Player_MediaEnded"
                      MediaFailed="Player_MediaFailed">
            <MediaElement.Style>
                <Style TargetType="MediaElement">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                            <Setter Property="Visibility" Value="Hidden"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsMiniPlayer, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                            <Setter Property="Visibility" Value="Hidden"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </MediaElement.Style>
        </MediaElement>

        <Border x:Name="SubtitleOverlay"
                Background="#B0000000"
                CornerRadius="10"
                Padding="12,8"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Margin="24,0,24,120"
                Visibility="Collapsed">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock x:Name="SubtitleText"
                       Foreground="White"
                       FontSize="20"
                       TextAlignment="Center"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Controls Overlay -->
        <Grid x:Name="ControlsGrid" VerticalAlignment="Bottom" Margin="24,0,24,24">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Margin" Value="24,0,24,24"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                            <Setter Property="Margin" Value="0"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsMiniPlayer, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                            <Setter Property="VerticalAlignment" Value="Top"/>
                            <Setter Property="Margin" Value="0"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border x:Name="ControlsBorder" Background="#CC000000" CornerRadius="16" Padding="16" BorderThickness="1" BorderBrush="#221E293B">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Padding" Value="16"/>
                        <Setter Property="CornerRadius" Value="16"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                <Setter Property="Padding" Value="8"/>
                                <Setter Property="CornerRadius" Value="12"/>
                                <Setter Property="Background" Value="#CC0A0E14"/>
                                <Setter Property="BorderBrush" Value="#331E293B"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsMiniPlayer, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                <Setter Property="Padding" Value="10"/>
                                <Setter Property="CornerRadius" Value="14"/>
                                <Setter Property="Background" Value="#CC0A0E14"/>
                                <Setter Property="BorderBrush" Value="#331E293B"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <!-- Progress -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="CurrentTimeText" Text="0:00" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsMiniPlayer, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Slider x:Name="ProgressSlider" Grid.Column="1"
                                VerticalAlignment="Center"
                                Thumb.DragStarted="ProgressSlider_DragStarted"
                                Thumb.DragCompleted="ProgressSlider_DragCompleted"
                                ValueChanged="ProgressSlider_ValueChanged">
                            <Slider.Style>
                                <Style TargetType="Slider" BasedOn="{StaticResource PlayerNeonSliderStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                            <Setter Property="Height" Value="12"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Slider.Style>
                        </Slider>
                        <TextBlock x:Name="TotalTimeText" Grid.Column="2" Text="0:00" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsMiniPlayer, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                        <Setter Property="Margin" Value="0,0,0,4"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                    </Grid>

                    <!-- Buttons -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Volume -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsMiniPlayer, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Button x:Name="MuteButton" Width="40" Height="40" Click="MuteButton_Click">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PlayerButtonStyle}">
                                        <Setter Property="Width" Value="40"/>
                                        <Setter Property="Height" Value="40"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                <Setter Property="Width" Value="32"/>
                                                <Setter Property="Height" Value="32"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Grid Width="20" Height="20">
                                    <Image x:Name="VolumeIconImage" Stretch="Uniform" Visibility="Collapsed" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <Image x:Name="MuteIconImage" Stretch="Uniform" Visibility="Collapsed" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <Viewbox Width="20" Height="20">
                                        <Path x:Name="VolumeIcon" Data="M14,3.23V5.29C16.89,6.15 19,8.83 19,12C19,15.17 16.89,17.84 14,18.7V20.77C18,19.86 21,16.28 21,12C21,7.72 18,4.14 14,3.23M16.5,12C16.5,10.23 15.5,8.71 14,7.97V16.02C15.5,15.29 16.5,13.76 16.5,12M3,9V15H7L12,20V4L7,9H3Z" Fill="White"/>
                                    </Viewbox>
                                </Grid>
                            </Button>
                            <Slider x:Name="VolumeSlider" Width="100" Minimum="0" Maximum="1" Value="0.8" 
                                    Style="{StaticResource PlayerNeonSliderStyle}"
                                    ValueChanged="VolumeSlider_ValueChanged" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>

                        <!-- Center: Transport -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="PrevButton" Width="48" Height="48" Click="PrevButton_Click" Margin="0,0,8,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PlayerButtonStyle}">
                                        <Setter Property="Width" Value="48"/>
                                        <Setter Property="Height" Value="48"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                <Setter Property="Width" Value="32"/>
                                                <Setter Property="Height" Value="32"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Grid Width="24" Height="24">
                                    <Image x:Name="PrevIconImage" Stretch="Uniform" Visibility="Collapsed" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <Viewbox Width="24" Height="24">
                                        <Path x:Name="PrevIconPath" Data="M6,18V6H8V18H6M9.5,12L18,6V18L9.5,12Z" Fill="White"/>
                                    </Viewbox>
                                </Grid>
                            </Button>
                            <Button x:Name="PlayPauseButton" Width="64" Height="64" Click="PlayPauseButton_Click">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PlayPauseButtonStyle}">
                                        <Setter Property="Width" Value="64"/>
                                        <Setter Property="Height" Value="64"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                <Setter Property="Width" Value="40"/>
                                                <Setter Property="Height" Value="40"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Grid>
                                    <Image x:Name="PlayIconImage" Width="28" Height="28" Stretch="Uniform" Visibility="Collapsed" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <Image x:Name="PauseIconImage" Width="28" Height="28" Stretch="Uniform" Visibility="Collapsed" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <Viewbox Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path x:Name="PlayIcon" Data="M8,5.14V19.14L19,12.14L8,5.14Z" Fill="White" Visibility="Visible">
                                            <Path.RenderTransform>
                                                <TranslateTransform X="1"/>
                                            </Path.RenderTransform>
                                        </Path>
                                    </Viewbox>
                                    <Viewbox Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path x:Name="PauseIcon" Data="M14,19H18V5H14M6,19H10V5H6V19Z" Fill="White" Visibility="Collapsed"/>
                                    </Viewbox>
                                </Grid>
                            </Button>
                            <Button x:Name="NextButton" Width="48" Height="48" Click="NextButton_Click" Margin="8,0,0,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PlayerButtonStyle}">
                                        <Setter Property="Width" Value="48"/>
                                        <Setter Property="Height" Value="48"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                <Setter Property="Width" Value="32"/>
                                                <Setter Property="Height" Value="32"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Grid Width="24" Height="24">
                                    <Image x:Name="NextIconImage" Stretch="Uniform" Visibility="Collapsed" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <Viewbox Width="24" Height="24">
                                        <Path x:Name="NextIconPath" Data="M16,18H18V6H16M6,18L14.5,12L6,6V18Z" Fill="White"/>
                                    </Viewbox>
                                </Grid>
                            </Button>
                            <Button x:Name="SubtitleButton" Width="40" Height="40" Click="SubtitleButton_Click" Margin="12,0,0,0"
                                    ToolTip="Subtitles">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PlayerButtonStyle}">
                                        <Setter Property="Width" Value="40"/>
                                        <Setter Property="Height" Value="40"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsMiniPlayer, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock x:Name="SubtitleIcon" Text="CC" Foreground="White" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Button>
                            <Button x:Name="FullscreenButton" Width="40" Height="40" Click="FullscreenButton_Click" Margin="12,0,0,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PlayerButtonStyle}">
                                        <Setter Property="Width" Value="40"/>
                                        <Setter Property="Height" Value="40"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsMiniPlayer, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Viewbox Width="20" Height="20">
                                    <Path Data="M5,5H10V7H7V10H5V5M14,5H19V10H17V7H14V5M17,14H19V19H14V17H17V14M10,17V19H5V14H7V17H10Z" Fill="White"/>
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Close Button -->
        <Button x:Name="SubtitleTopButton"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Width="40"
                Height="40"
                Margin="0,24,120,0"
                Click="SubtitleButton_Click"
                ToolTip="Subtitles">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource PlayerButtonStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsMiniPlayer, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <TextBlock Text="CC" Foreground="White" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Button>

        <Button x:Name="FullscreenTopButton"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Width="40"
                Height="40"
                Margin="0,24,72,0"
                Click="FullscreenButton_Click"
                ToolTip="Fullscreen">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource PlayerButtonStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsMiniPlayer, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <Viewbox Width="20" Height="20">
                <Path Data="M5,5H10V7H7V10H5V5M14,5H19V10H17V7H14V5M17,14H19V19H14V17H17V14M10,17V19H5V14H7V17H10Z"
                      Fill="White"/>
            </Viewbox>
        </Button>

        <Button x:Name="CloseButton"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Width="40"
                Height="40"
                Margin="0,24,24,0"
                Click="CloseButton_Click"
                ToolTip="Close">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource PlayerButtonStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMiniPlayer, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <Viewbox Width="20" Height="20">
                <Grid Width="20" Height="20">
                    <Image x:Name="CloseIconImage" Stretch="Uniform" Visibility="Collapsed" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <Path x:Name="CloseIconPath" Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                          Fill="#EF4444"/>
                </Grid>
            </Viewbox>
        </Button>

        <!-- Loading / Error Overlay -->
        <Border x:Name="MessageOverlay" Background="#CC000000" Visibility="Collapsed">
            <TextBlock x:Name="MessageText" Text="Loading..." Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
