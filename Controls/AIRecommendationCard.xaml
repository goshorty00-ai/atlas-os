<!-- Figma Component: AIRecommendationCard -->
<!-- Design URL: https://www.figma.com/make/d4uCeNSISrzcORhzKRF76b/Atlas.MediaCentre.Main (Copy) -->
<UserControl x:Class="AtlasAI.Controls.AIRecommendationCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Margin="0,0,0,16"
             Cursor="Hand">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Theme/Colors.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <Border Name="CardBorder"
            Background="{StaticResource AtlasGlassBrush}"
            BorderBrush="{StaticResource AtlasGlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            
            <!-- Thumbnail and Match -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                
                <!-- Thumbnail -->
                <Border Grid.Column="0"
                        Width="80"
                        Height="120"
                        CornerRadius="8"
                        ClipToBounds="True"
                        Margin="0,0,12,0">
                    <Image Name="ThumbnailImage"
                           Stretch="UniformToFill" />
                </Border>
                
                <!-- Info -->
                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                    <!-- Match Badge -->
                    <Border Background="{StaticResource AtlasCyanBrush}"
                            CornerRadius="6"
                            Padding="8,4"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Name="MatchText"
                                       Text="94%"
                                       Foreground="{StaticResource AtlasBgDeepBrush}"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Margin="0,0,4,0" />
                            <TextBlock Text="MATCH"
                                       Foreground="{StaticResource AtlasBgDeepBrush}"
                                       FontSize="10"
                                       FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                    
                    <!-- Title -->
                    <TextBlock Name="TitleText"
                               Text="Title"
                               Foreground="{StaticResource AtlasTextPrimaryBrush}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,0,0,4" />
                    
                    <!-- Type -->
                    <TextBlock Name="TypeText"
                               Text="Type"
                               Foreground="{StaticResource AtlasTextSecondaryBrush}"
                               FontSize="11" />
                </StackPanel>
            </Grid>
            
            <!-- Reason -->
            <TextBlock Name="ReasonText"
                       Grid.Row="1"
                       Text="Reason for recommendation"
                       Foreground="{StaticResource AtlasTextMutedBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       LineHeight="16" />
        </Grid>
    </Border>
    
    <!-- Hover Effect -->
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="MouseEnter">
            <BeginStoryboard>
                <Storyboard>
                    <ColorAnimation Storyboard.TargetName="CardBorder"
                                    Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                    To="#22d3ee"
                                    Duration="0:0:0.15" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
        <EventTrigger RoutedEvent="MouseLeave">
            <BeginStoryboard>
                <Storyboard>
                    <ColorAnimation Storyboard.TargetName="CardBorder"
                                    Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                    To="#ffffff10"
                                    Duration="0:0:0.15" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
</UserControl>
