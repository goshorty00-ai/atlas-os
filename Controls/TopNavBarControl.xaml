<UserControl x:Class="AtlasAI.Controls.TopNavBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lottie="clr-namespace:LottieSharp.WPF;assembly=LottieSharp"
             mc:Ignorable="d" 
             d:DesignHeight="56" d:DesignWidth="1920"
             Height="56"
             Background="{StaticResource DeepSeaGradient}">

             <Grid Margin="16,0"
                 Background="Transparent"
                 shell:WindowChrome.IsHitTestVisibleInChrome="True"
                 MouseLeftButtonDown="TopNavBar_MouseLeftButtonDown">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*" MinWidth="80"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Center brand: absolute center of the window header (logo only; no pill container) -->
        <Image Grid.Column="0"
               Grid.ColumnSpan="3"
               Height="46"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Stretch="Uniform"
               IsHitTestVisible="False"
               Source="pack://application:,,,/Assets/Header/AtlasLogo.png"/>
        
        <DockPanel x:Name="RightControlsHost" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" LastChildFill="False">
            <TextBlock x:Name="LottieStatusText"
                       DockPanel.Dock="Left"
                       Margin="0,0,12,0"
                       VerticalAlignment="Center"
                       FontFamily="{StaticResource AtlasFontMono}"
                       FontSize="11"
                       Foreground="{StaticResource Brush.AccentOrange}"
                       Opacity="1"
                       Visibility="Collapsed"
                       Text="LOTTIE INIT"/>

                    <Button x:Name="SectionSpeechBtn"
                        DockPanel.Dock="Right"
                        Content="SPEECH"
                        Click="SectionSpeech_Click"
                        Style="{StaticResource GhostBtn}"
                        FontSize="10"
                        Width="56"
                        Height="26"
                        Margin="0,0,6,0"
                        Padding="0"
                        Visibility="Collapsed"
                        IsHitTestVisible="False"
                        ToolTip="Toggle section speech"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>

                    <Button x:Name="SectionMicBtn"
                        DockPanel.Dock="Right"
                        Content="MIC"
                        Click="SectionMic_Click"
                        Style="{StaticResource GhostBtn}"
                        FontSize="10"
                        Width="44"
                        Height="26"
                        Margin="0,0,6,0"
                        Padding="0"
                        Visibility="Collapsed"
                        IsHitTestVisible="False"
                        ToolTip="Start section microphone"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>

            <!-- Window buttons (rightmost) -->
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Button x:Name="StopVoiceBtn"
                        Content="⏹"
                        Click="StopVoice_Click"
                        Style="{StaticResource GhostBtn}"
                        FontSize="11"
                        Width="26"
                        Height="26"
                        Margin="0,0,6,0"
                        Padding="0"
                        ToolTip="Stop voice"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>

                    <Button x:Name="OrbToggleBtn"
                        Content="◎"
                        Click="OrbToggle_Click"
                        Style="{StaticResource GhostBtn}"
                        FontSize="11"
                        Width="26"
                        Height="26"
                        Margin="0,0,6,0"
                        Padding="0"
                        ToolTip="Turn orb off"
                        shell:WindowChrome.IsHitTestVisibleInChrome="False"/>

                    <Button x:Name="WallpaperOnlyBtn"
                        Content="▣"
                        Click="WallpaperOnly_Click"
                        Style="{StaticResource GhostBtn}"
                        FontSize="11"
                        Width="26"
                        Height="26"
                        Margin="0,0,6,0"
                        Padding="0"
                        ToolTip="Wallpaper only"
                        shell:WindowChrome.IsHitTestVisibleInChrome="False"/>

                <Button Content="⟨"
                        Click="HeaderToggle_Click"
                        Style="{StaticResource GhostBtn}"
                        FontSize="11"
                        Width="26"
                        Height="26"
                        Margin="0,0,6,0"
                        Padding="0"
                    shell:WindowChrome.IsHitTestVisibleInChrome="False"
                        ToolTip="Hide header"/>

                <Button Content="─" 
                    Click="Minimize_Click" 
                    Style="{StaticResource GhostBtn}" 
                    FontSize="10" 
                    Width="32" 
                    Height="32"
                    Foreground="{StaticResource Brush.AccentCyan}"
                    shell:WindowChrome.IsHitTestVisibleInChrome="False"
                    ToolTip="Minimize"/>

                <Button x:Name="MaximizeBtn" 
                    Content="□" 
                    Click="Maximize_Click" 
                    Style="{StaticResource GhostBtn}" 
                    FontSize="10" 
                    Width="32" 
                    Height="32"
                    Foreground="{StaticResource Brush.AccentCyan}"
                    shell:WindowChrome.IsHitTestVisibleInChrome="False"
                    ToolTip="Maximize"/>
                    
                <Button Content="✕" 
                    Click="Close_Click" 
                    Style="{StaticResource GhostBtn}" 
                    FontSize="10" 
                    Width="32" 
                    Height="32"
                    Foreground="{StaticResource Brush.AccentCyan}"
                    shell:WindowChrome.IsHitTestVisibleInChrome="False"
                    ToolTip="Close"/>
            </StackPanel>

            <!-- Voice State Pill -->
            <Border x:Name="VoiceStatePill"
                    DockPanel.Dock="Right"
                    Margin="0,0,8,0"
                    Padding="8,3"
                    CornerRadius="8"
                    BorderThickness="1"
                    VerticalAlignment="Center"
                    Background="#07141A"
                    BorderBrush="#1FB6CE">
                <Border.Effect>
                    <DropShadowEffect Color="#1FB6CE" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                </Border.Effect>
                <TextBlock x:Name="VoiceStatePillText"
                           FontFamily="{StaticResource AtlasFontMono}"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="#7DD5F0"
                           Text="IDLE"/>
            </Border>

            <!-- Unload current tab button -->
            <Button x:Name="UnloadBtn"
                    DockPanel.Dock="Right"
                    Content="⏏"
                    Click="Unload_Click"
                    Style="{StaticResource GhostBtn}"
                    FontSize="11"
                    Width="26"
                    Height="26"
                    Margin="0,0,4,0"
                    Padding="0"
                    Visibility="Collapsed"
                    ToolTip="Unload current tab (free memory)"
                    shell:WindowChrome.IsHitTestVisibleInChrome="False"/>

            <!-- Day/Date/Time just left of the window buttons -->
            <TextBlock x:Name="ClockText"
                       DockPanel.Dock="Right"
                       Margin="0,0,12,0"
                       VerticalAlignment="Center"
                       FontFamily="{StaticResource AtlasFontMono}"
                       FontSize="12"
                       Foreground="{StaticResource AtlasTextMutedBrush}"
                       Opacity="0.9"
                       Text=""/>

            <!-- Lottie animation right next to clock (visually to its left) -->
            <lottie:LottieAnimationView x:Name="AnimatedLogoHost"
                                        DockPanel.Dock="Right"
                                        Width="60"
                                        Height="40"
                                        Margin="0,0,4,0"
                                        AutoPlay="True"
                                        RepeatCount="-1"
                                        VerticalAlignment="Center"
                                        IsHitTestVisible="False"
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        CacheMode="BitmapCache"
                                        Visibility="Visible"/>
        </DockPanel>
    </Grid>
</UserControl>
