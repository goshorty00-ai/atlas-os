<UserControl x:Class="AtlasAI.Controls.HoloCoreControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="320" d:DesignWidth="320"
             x:Name="HoloCoreRoot"
             RenderOptions.BitmapScalingMode="HighQuality"
             RenderOptions.EdgeMode="Aliased"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             CacheMode="BitmapCache">

    <!-- HOLO CORE - ANIMATED 320px (XAML ANIMATIONS - NO MEMORY LEAK) -->
    <Grid x:Name="CoreContainer" Width="320" Height="320" 
          ClipToBounds="True">
        
        <!-- Ambient field - Subtle glow background -->
        <Ellipse x:Name="AmbientField" Width="300" Height="300"
                 Fill="#0a22d3ee" Opacity="0.3"
                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
        
        <!-- Outer ring - Slow clockwise rotation -->
        <Ellipse x:Name="OuterRing" Width="320" Height="320"
                 StrokeThickness="2" Fill="Transparent"
                 Stroke="#22d3ee33"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <RotateTransform x:Name="OuterRingTransform" Angle="0"/>
            </Ellipse.RenderTransform>
        </Ellipse>
        
        <!-- Middle ring - Medium clockwise rotation -->
        <Ellipse x:Name="MiddleRing" Width="260" Height="260"
                 StrokeThickness="1.5" Fill="Transparent"
                 Stroke="#22d3ee1a"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <RotateTransform x:Name="MiddleRingTransform" Angle="0"/>
            </Ellipse.RenderTransform>
        </Ellipse>
        
        <!-- Inner ring - Fast counter-clockwise rotation -->
        <Ellipse x:Name="InnerRing" Width="200" Height="200"
                 StrokeThickness="2" Fill="Transparent"
                 StrokeDashArray="8 4"
                 Stroke="#4022d3ee"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <RotateTransform x:Name="InnerRingTransform" Angle="0"/>
            </Ellipse.RenderTransform>
        </Ellipse>
        
        <Canvas x:Name="ParticleLayer" Width="320" Height="320"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                IsHitTestVisible="False"/>
        
        <!-- Center core - Breathing animation -->
        <Ellipse x:Name="CenterCore" Width="140" Height="140"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 Fill="#FF22d3ee"
                 Opacity="0.8"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="CenterCoreScale" ScaleX="1" ScaleY="1"/>
            </Ellipse.RenderTransform>
        </Ellipse>
        
        <!-- Center dot - Static -->
        <Ellipse x:Name="CoreDot" Width="28" Height="28"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 Fill="#22d3ee"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="CoreDotScale" ScaleX="1" ScaleY="1"/>
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Action Buttons Layer - Orbiting Controls -->
        <Grid x:Name="ActionButtonsLayer" Width="320" Height="320" Visibility="Collapsed">
            <Grid.Resources>
                <Style TargetType="Button">
                    <Setter Property="Width" Value="36"/>
                    <Setter Property="Height" Value="36"/>
                    <Setter Property="Background" Value="#1122d3ee"/>
                    <Setter Property="BorderBrush" Value="#22d3ee"/>
                    <Setter Property="Foreground" Value="#22d3ee"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="FontSize" Value="10"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Grid>
                                    <Ellipse Fill="{TemplateBinding Background}" 
                                             Stroke="{TemplateBinding BorderBrush}" 
                                             StrokeThickness="{TemplateBinding BorderThickness}"/>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#3322d3ee"/>
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#22d3ee" BlurRadius="10" ShadowDepth="0"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#5522d3ee"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Grid.Resources>

            <!-- 1. Volume (Top) -->
            <Button x:Name="BtnVolume" Content="VOL" Click="OnVolumeActionClick"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button.RenderTransform>
                    <TranslateTransform Y="-130"/>
                </Button.RenderTransform>
            </Button>

            <!-- 2. Settings (Top Right) -->
            <Button x:Name="BtnSettings" Content="SET" Click="OnSettingsActionClick"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button.RenderTransform>
                    <TranslateTransform X="112" Y="-65"/>
                </Button.RenderTransform>
            </Button>

            <!-- 3. Security (Bottom Right) -->
            <Button x:Name="BtnSecurity" Content="SEC" Click="OnSecurityActionClick"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button.RenderTransform>
                    <TranslateTransform X="112" Y="65"/>
                </Button.RenderTransform>
            </Button>

            <!-- 4. Network (Bottom) -->
            <Button x:Name="BtnNetwork" Content="NET" Click="OnNetworkActionClick"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button.RenderTransform>
                    <TranslateTransform Y="130"/>
                </Button.RenderTransform>
            </Button>

            <!-- 5. Performance (Bottom Left) -->
            <Button x:Name="BtnPerformance" Content="PRF" Click="OnPerformanceActionClick"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button.RenderTransform>
                    <TranslateTransform X="-112" Y="65"/>
                </Button.RenderTransform>
            </Button>

            <!-- 6. Mic (Top Left) -->
            <Button x:Name="BtnMic" Content="MIC" Click="OnMicActionClick"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button.RenderTransform>
                    <TranslateTransform X="-112" Y="-65"/>
                </Button.RenderTransform>
            </Button>
        </Grid>


    </Grid>
</UserControl>
