<Window x:Class="AtlasAI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Atlas Settings" Height="750" Width="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False"
        ResizeMode="NoResize">

    <Window.Resources>
        <FontFamily x:Key="MainFont">Segoe UI Variable, Segoe UI, Arial</FontFamily>
        <FontFamily x:Key="MonoFont">Cascadia Code, Consolas</FontFamily>
        
        <!-- Atlas Colors -->
        <Color x:Key="BgDeep">#050508</Color>
        <Color x:Key="BgDark">#08080c</Color>
        <Color x:Key="BgMedium">#0c0c12</Color>
        <Color x:Key="Surface">#16161f</Color>
        <Color x:Key="SurfaceHover">#1a1a24</Color>
        <Color x:Key="Cyan">#22d3ee</Color>
        <Color x:Key="Violet">#8b5cf6</Color>
        <Color x:Key="Green">#22c55e</Color>
        <Color x:Key="TextPrimary">#f1f5f9</Color>
        <Color x:Key="TextSecondary">#94a3b8</Color>
        <Color x:Key="TextMuted">#64748b</Color>
        
        <SolidColorBrush x:Key="BgDeepBrush" Color="{StaticResource BgDeep}"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}"/>
        <SolidColorBrush x:Key="CyanBrush" Color="{StaticResource Cyan}"/>
        <SolidColorBrush x:Key="VioletBrush" Color="{StaticResource Violet}"/>
        <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource Green}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
        
        <!-- Modern TextBox Style -->
        <Style x:Key="AtlasTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#12121a"/>
            <Setter Property="Foreground" Value="#f1f5f9"/>
            <Setter Property="BorderBrush" Value="#22d3ee40"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#22d3ee"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#22d3ee"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Modern PasswordBox Style -->
        <Style x:Key="AtlasPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#12121a"/>
            <Setter Property="Foreground" Value="#f1f5f9"/>
            <Setter Property="BorderBrush" Value="#22d3ee40"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#22d3ee"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#22d3ee"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Modern ComboBox Style with Dark Theme -->
        <Style x:Key="AtlasComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#12121a"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#22d3ee40"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border" Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                <Border.Effect>
                                    <DropShadowEffect Color="#22d3ee" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                                </Border.Effect>
                            </Border>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" 
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  Margin="12,8,0,8" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <ContentPresenter.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                        </Style>
                                    </ContentPresenter.Resources>
                                </ContentPresenter>
                                <ToggleButton x:Name="ToggleButton" Grid.ColumnSpan="2" Focusable="False"
                                              IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              Background="Transparent" BorderThickness="0">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent">
                                                <TextBlock Text="˅" FontSize="14" Foreground="#22d3ee" 
                                                           HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <TextBox x:Name="PART_EditableTextBox" Grid.Column="0" Visibility="Hidden" IsReadOnly="True"
                                         Background="Transparent" Foreground="#FFFFFF" BorderThickness="0"/>
                            </Grid>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" 
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border x:Name="DropDown" Background="#0c0c12" BorderBrush="#22d3ee" BorderThickness="1" 
                                        CornerRadius="6" Margin="0,4,0,0" MinWidth="{TemplateBinding ActualWidth}" 
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#22d3ee" BlurRadius="15" ShadowDepth="0" Opacity="0.4"/>
                                    </Border.Effect>
                                    <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#22d3ee"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#22d3ee" BlurRadius="8" ShadowDepth="0" Opacity="0.3"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#22d3ee"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- ComboBoxItem Style for dropdown items -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}" CornerRadius="4">
                            <ContentPresenter>
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#FFFFFF"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22d3ee30"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22d3ee20"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Section Header Style -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#22d3ee"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        </Style>
        
        <!-- Label Style -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" Background="#050508" BorderThickness="1" BorderBrush="#22d3ee30">
        <Border.Effect>
            <DropShadowEffect Color="#22d3ee" BlurRadius="40" ShadowDepth="0" Opacity="0.2"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Border Grid.Row="0" Background="#08080c" CornerRadius="12,12,0,0" 
                    BorderBrush="#22d3ee20" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⚙" FontSize="18" Foreground="#22d3ee" Margin="0,0,12,0"/>
                        <TextBlock Text="SETTINGS" FontSize="14" FontWeight="SemiBold" Foreground="#f1f5f9"
                                   FontFamily="{StaticResource MainFont}"/>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right" Click="Close_Click"
                            Background="Transparent" Foreground="#64748b" BorderThickness="0"
                            Width="32" Height="32" FontSize="14" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#ef444430"/>
                                        <Setter Property="Foreground" Value="#ef4444"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
            
            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20">
                <StackPanel>
                    
                        <!-- AI PROVIDER SECTION (ADMIN ONLY) -->
                        <TextBlock Text="AI PROVIDER" Style="{StaticResource SectionHeader}" Visibility="Collapsed"/>
                        <Border Background="#0c0c12" CornerRadius="8" Padding="16" Margin="0,0,0,24"
                            BorderBrush="#22d3ee20" BorderThickness="1" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Provider" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="AIProviderComboBox" Style="{StaticResource AtlasComboBox}"
                                      SelectionChanged="AIProviderComboBox_SelectionChanged" Margin="0,0,0,16"/>
                            
                            <TextBlock Text="Model" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="AIModelComboBox" Style="{StaticResource AtlasComboBox}"
                                      SelectionChanged="AIModelComboBox_SelectionChanged"/>

                            <TextBlock x:Name="AIKeyLabel" Text="API Key" Style="{StaticResource FieldLabel}" Margin="0,16,0,0"/>
                            <PasswordBox x:Name="AIProviderKeyBox" Style="{StaticResource AtlasPasswordBox}"/>
                            <Button Content="Test Connection" Click="TestAIConnection_Click" Padding="20,10"
                                    Background="#16161f" Foreground="#94a3b8" Margin="0,12,0,0" HorizontalAlignment="Left">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#1a1a24"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="AI RUNTIME" Style="{StaticResource SectionHeader}"/>
                    <Border Background="#0c0c12" CornerRadius="8" Padding="16" Margin="0,0,0,24"
                            BorderBrush="#22d3ee20" BorderThickness="1">
                        <StackPanel>
                            <StackPanel x:Name="AiPublicSubscriptionPanel" Visibility="Collapsed">
                                <TextBlock Text="Your current Atlas subscription and quality settings for this device."
                                           Foreground="#94a3b8" FontSize="11" Margin="0,0,0,14" TextWrapping="Wrap"/>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Current Plan" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock x:Name="AiPublicCurrentPlanValue" Foreground="#22d3ee" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Credits Remaining" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock x:Name="AiPublicCreditsRemainingValue" Foreground="#f1f5f9" FontSize="13" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Renewal Date" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock x:Name="AiPublicRenewalDateValue" Foreground="#f1f5f9" FontSize="13" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Quality Mode" Style="{StaticResource FieldLabel}"/>
                                        <ComboBox x:Name="AiPublicQualityModeCombo" Style="{StaticResource AtlasComboBox}"
                                                  SelectionChanged="AiPublicQualityMode_Changed">
                                            <ComboBoxItem Content="Economy" Tag="economy"/>
                                            <ComboBoxItem Content="Balanced" Tag="balanced"/>
                                            <ComboBoxItem Content="Best Quality" Tag="best_quality"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Premium Access" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock x:Name="AiPublicPremiumAccessValue" Foreground="#f1f5f9" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#16161f" CornerRadius="6" Padding="12" BorderBrush="#22d3ee20" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Premium Features Enabled" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                            <TextBlock x:Name="AiPublicFeaturesEnabledValue" Foreground="#22c55e" FontSize="12" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Background="#16161f" CornerRadius="6" Padding="12" BorderBrush="#22d3ee20" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Premium Features Locked" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                            <TextBlock x:Name="AiPublicFeaturesLockedValue" Foreground="#f1f5f9" FontSize="12" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>

                            <StackPanel x:Name="AiInternalRuntimePanel" Visibility="Collapsed">
                                <TextBlock Text="Live provider, routing, budget, and usage state from the active AI runtime."
                                           Foreground="#94a3b8" FontSize="11" Margin="0,0,0,14" TextWrapping="Wrap"/>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Current Provider" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock x:Name="AiUsageCurrentProviderValue" Foreground="#f1f5f9" FontSize="13" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Current Effective Model" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock x:Name="AiUsageEffectiveModelValue" Foreground="#f1f5f9" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Routing Mode" Style="{StaticResource FieldLabel}"/>
                                        <ComboBox x:Name="AiRoutingModeCombo" Style="{StaticResource AtlasComboBox}"
                                                  SelectionChanged="AiRoutingMode_Changed">
                                            <ComboBoxItem Content="Thresholds" Tag="thresholds"/>
                                            <ComboBoxItem Content="Manual" Tag="manual"/>
                                            <ComboBoxItem Content="Cheap" Tag="cheap"/>
                                            <ComboBoxItem Content="Smart" Tag="smart"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Cost Mode" Style="{StaticResource FieldLabel}"/>
                                        <ComboBox x:Name="AiCostModeCombo" Style="{StaticResource AtlasComboBox}"
                                                  SelectionChanged="AiCostMode_Changed">
                                            <ComboBoxItem Content="Balanced" Tag="balanced"/>
                                            <ComboBoxItem Content="Budget" Tag="budget"/>
                                            <ComboBoxItem Content="Performance" Tag="performance"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Spend Used Today" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock x:Name="AiSpendUsedTodayValue" Foreground="#22d3ee" FontSize="13" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Daily Spend Cap" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock x:Name="AiSpendCapValue" Foreground="#f1f5f9" FontSize="13" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Remaining Daily Budget" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock x:Name="AiRemainingBudgetValue" Foreground="#22c55e" FontSize="13" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Chat Tokens Used Today" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock x:Name="AiChatTokensUsedValue" Foreground="#f1f5f9" FontSize="13" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Heavy Calls Used Today" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock x:Name="AiHeavyCallsUsedValue" Foreground="#f1f5f9" FontSize="13" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>

                                <Border Background="#16161f" CornerRadius="6" Padding="12" BorderBrush="#22d3ee20" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Last AI Request Result" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="AiLastRequestResultValue" Foreground="#f1f5f9" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="DistributionPolicySectionHeader" Text="DISTRIBUTION POLICY" Style="{StaticResource SectionHeader}" Visibility="Collapsed"/>
                    <Border x:Name="DistributionPolicySectionBorder" Background="#0c0c12" CornerRadius="8" Padding="16" Margin="0,0,0,24"
                            BorderBrush="#22d3ee20" BorderThickness="1" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Live build flavor and billing policy state for the current desktop app instance."
                                       Foreground="#94a3b8" FontSize="11" Margin="0,0,0,14" TextWrapping="Wrap"/>

                            <Border Background="#16161f" CornerRadius="6" Padding="12" BorderBrush="#22d3ee20" BorderThickness="1" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Effective Policy" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="DistributionPolicySummaryValue" Foreground="#f1f5f9" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Distribution Mode" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock x:Name="DistributionModeValue" Foreground="#f1f5f9" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Billing Mode" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock x:Name="DistributionEffectiveBillingModeValue" Foreground="#f1f5f9" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Effective Plan" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock x:Name="DistributionEffectivePlanValue" Foreground="#22d3ee" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Current Actor" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock x:Name="DistributionCurrentActorValue" Foreground="#f1f5f9" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Actor Internal" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock x:Name="DistributionActorInternalValue" Foreground="#f1f5f9" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Actor Admin" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock x:Name="DistributionActorAdminValue" Foreground="#f1f5f9" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel x:Name="DistributionPublicBillingModePanel" Margin="0,0,0,14">
                                <TextBlock Text="Public Billing Mode" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="DistributionBillingModeCombo" Style="{StaticResource AtlasComboBox}"
                                          SelectionChanged="DistributionBillingMode_Changed">
                                    <ComboBoxItem Content="Shadow" Tag="shadow"/>
                                    <ComboBoxItem Content="Enforced" Tag="enforced"/>
                                </ComboBox>
                                <TextBlock Text="Public builds can switch between shadow and enforced billing. Distribution mode remains fixed by the compiled build flavor."
                                           Foreground="#64748b" FontSize="10" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel x:Name="DistributionInternalControlsPanel">
                                <CheckBox x:Name="DistributionSimulationEnabledCheckBox"
                                          Content="Enable public-plan simulation for this internal build"
                                          Foreground="#f1f5f9"
                                          Margin="0,0,0,12"
                                          Checked="DistributionSimulationEnabled_Changed"
