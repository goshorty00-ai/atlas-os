                    </Border>
                    
                        <!-- CSV IMPORT SECTION -->
                        <TextBlock Text="CSV IMPORT" Style="{StaticResource SectionHeader}" Visibility="Collapsed"/>
                        <Border Background="#0c0c12" CornerRadius="8" Padding="16" Margin="0,0,0,24"
                            BorderBrush="#22c55e20" BorderThickness="1" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Import music lists from CSV and convert to MP3"
