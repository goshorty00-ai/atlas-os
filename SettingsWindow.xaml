                                      Foreground="#f1f5f9"
                                      Margin="0,0,0,0"
                                      Checked="CsvEmbedThumbnails_Changed"
                                      Unchecked="CsvEmbedThumbnails_Changed"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- AUDIO SECTION -->
                        <TextBlock Text="AUDIO INPUT" Style="{StaticResource SectionHeader}"/>
                        <Border Background="#0c0c12" CornerRadius="8" Padding="16" Margin="0,0,0,24"
                            BorderBrush="#22d3ee20" BorderThickness="1">
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Microphone" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox x:Name="MicrophoneCombo" Style="{StaticResource AtlasComboBox}"
                                              SelectionChanged="Microphone_Changed"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="8,0,0,0">
                                    <Button x:Name="TestMicBtn" Content="🎤" Width="36" Height="36" Click="TestMic_Click"
                                            Background="#22d3ee20" Foreground="#22d3ee" BorderThickness="0" ToolTip="Test Mic">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#22d3ee40"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button x:Name="RefreshMicBtn" Content="🔄" Width="36" Height="36" Margin="4,0,0,0"
                                            Click="RefreshMic_Click" Background="#16161f" Foreground="#64748b" 
                                            BorderThickness="0" ToolTip="Refresh">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#1a1a24"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Grid>
                            
                            <TextBlock Text="Sensitivity" Style="{StaticResource FieldLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="MicSensitivitySlider" Minimum="50" Maximum="500" Value="120"
                                        VerticalAlignment="Center" ValueChanged="MicSensitivity_Changed"/>
                                <Border Grid.Column="1" Background="#22d3ee20" CornerRadius="4" Padding="8,4" Margin="8,0,0,0">
                                    <TextBlock x:Name="MicSensitivityValue" Text="120" Foreground="#22d3ee" 
                                               HorizontalAlignment="Center" FontWeight="Bold" FontSize="12"/>
                                </Border>
                            </Grid>
                            
                            <!-- Audio Level Visualizer -->
                            <Border Background="#08080c" CornerRadius="6" Padding="12" Margin="0,16,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="🎤" Foreground="#64748b" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Border Grid.Column="1" Background="#12121a" CornerRadius="4" Height="8">
                                        <Grid>
                                            <Border x:Name="AudioLevelBar" Background="#22d3ee" CornerRadius="4" 
                                                    HorizontalAlignment="Left" Width="0"/>
                                            <Border x:Name="AudioPeakIndicator" Background="#f59e0b" Width="3" 
                                                    HorizontalAlignment="Left" CornerRadius="1" Visibility="Collapsed"/>
                                        </Grid>
                                    </Border>
                                    <TextBlock x:Name="AudioLevelText" Grid.Column="2" Text="0" Foreground="#64748b" 
                                               Width="35" TextAlignment="Right" Margin="10,0,0,0" FontSize="11"/>
                                </Grid>
                            </Border>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button x:Name="StartMonitorBtn" Content="▶ Monitor" Click="StartMonitor_Click"
                                        Background="#22d3ee20" Foreground="#22d3ee" Padding="12,6" FontSize="11">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#22d3ee40"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button x:Name="StopMonitorBtn" Content="⏹ Stop" Click="StopMonitor_Click" Margin="8,0,0,0"
                                        Background="#ef444420" Foreground="#ef4444" Padding="12,6" FontSize="11" IsEnabled="False">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#ef444440"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button x:Name="AutoScanBtn" Content="🔍 Auto-Scan" Click="AutoScan_Click" Margin="8,0,0,0"
                                        Background="#f59e0b20" Foreground="#f59e0b" Padding="12,6" FontSize="11"
                                        ToolTip="Scan all mics and auto-select the first working one">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#f59e0b40"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                            
                            <TextBlock x:Name="MicStatusText" Text="🎤 Microphone: Ready" 
                                       Foreground="#94a3b8" FontSize="11" Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- VOICE INPUT SECTION -->
                        <TextBlock Text="VOICE INPUT" Style="{StaticResource SectionHeader}" Visibility="Collapsed"/>
                        <Border Background="#0c0c12" CornerRadius="8" Padding="16" Margin="0,0,0,24"
                            BorderBrush="#22d3ee20" BorderThickness="1" Visibility="Collapsed">
                        <StackPanel>
                            <!-- Wake Word Enable -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Wake Word Detection" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock Text="Enable 'Atlas' wake word for hands-free activation" 
                                               Foreground="#94a3b8" FontSize="11" Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox x:Name="EnableWakeWordCheckBox" Grid.Column="1" VerticalAlignment="Center"
                                          Checked="EnableWakeWord_Changed" Unchecked="EnableWakeWord_Changed">
                                    <CheckBox.Template>
                                        <ControlTemplate TargetType="CheckBox">
                                            <Border x:Name="border" Background="#12121a" BorderBrush="#22d3ee40" 
                                                    BorderThickness="2" CornerRadius="4" Width="20" Height="20">
                                                <TextBlock x:Name="checkMark" Text="✓" Foreground="#22d3ee" 
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                           FontSize="12" FontWeight="Bold" Visibility="Collapsed"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                                    <Setter TargetName="border" Property="Background" Value="#22d3ee20"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#22d3ee"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </CheckBox.Template>
                                </CheckBox>
                            </Grid>
                            
                            <!-- Always Listening -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Always Listening Mode" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock Text="Continuously listen for wake word (requires wake word enabled)" 
                                               Foreground="#94a3b8" FontSize="11" Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox x:Name="EnableAlwaysListeningCheckBox" Grid.Column="1" VerticalAlignment="Center"
                                          Checked="EnableAlwaysListening_Changed" Unchecked="EnableAlwaysListening_Changed">
                                    <CheckBox.Template>
                                        <ControlTemplate TargetType="CheckBox">
                                            <Border x:Name="border" Background="#12121a" BorderBrush="#22d3ee40" 
                                                    BorderThickness="2" CornerRadius="4" Width="20" Height="20">
                                                <TextBlock x:Name="checkMark" Text="✓" Foreground="#22d3ee" 
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                           FontSize="12" FontWeight="Bold" Visibility="Collapsed"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                                    <Setter TargetName="border" Property="Background" Value="#22d3ee20"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#22d3ee"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </CheckBox.Template>
                                </CheckBox>
                            </Grid>
                            
                            <!-- Wake Word Sensitivity -->
                            <TextBlock Text="Wake Word Sensitivity" Style="{StaticResource FieldLabel}"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="WakeWordSensitivitySlider" Minimum="0" Maximum="1" Value="0.5"
                                        VerticalAlignment="Center" ValueChanged="WakeWordSensitivity_Changed"/>
                                <Border Grid.Column="1" Background="#22d3ee20" CornerRadius="4" Padding="8,4" Margin="8,0,0,0">
                                    <TextBlock x:Name="WakeWordSensitivityValue" Text="50%" Foreground="#22d3ee" 
                                               HorizontalAlignment="Center" FontWeight="Bold" FontSize="12"/>
                                </Border>
                            </Grid>
                            
                            <!-- Follow-Up Listening Duration -->
                            <TextBlock Text="Follow-Up Listening Duration" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="How long Atlas continues listening after speaking (without requiring wake word)" 
                                       Foreground="#94a3b8" FontSize="11" Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="FollowUpListeningDurationSlider" Minimum="1" Maximum="10" Value="4"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center" ValueChanged="FollowUpListeningDuration_Changed"/>
                                <Border Grid.Column="1" Background="#22d3ee20" CornerRadius="4" Padding="8,4" Margin="8,0,0,0">
                                    <TextBlock x:Name="FollowUpListeningDurationValue" Text="4s" Foreground="#22d3ee" 
                                               HorizontalAlignment="Center" FontWeight="Bold" FontSize="12"/>
                                </Border>
                            </Grid>
                            
                            <!-- Wake Word Audio Cue -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Wake Word Audio Cue" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock Text="Play soft audio cue when wake word is detected" 
                                               Foreground="#94a3b8" FontSize="11" Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox x:Name="EnableWakeWordAudioCueCheckBox" Grid.Column="1" VerticalAlignment="Center"
                                          Checked="EnableWakeWordAudioCue_Changed" Unchecked="EnableWakeWordAudioCue_Changed">
                                    <CheckBox.Template>
                                        <ControlTemplate TargetType="CheckBox">
                                            <Border x:Name="border" Background="#12121a" BorderBrush="#22d3ee40" 
                                                    BorderThickness="2" CornerRadius="4" Width="20" Height="20">
                                                <TextBlock x:Name="checkMark" Text="✓" Foreground="#22d3ee" 
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                           FontSize="12" FontWeight="Bold" Visibility="Collapsed"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                                    <Setter TargetName="border" Property="Background" Value="#22d3ee20"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#22d3ee"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </CheckBox.Template>
                                </CheckBox>
                            </Grid>
                            
                            <!-- Show Listening Indicator -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Show Listening Indicator" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock Text="Display visual indicator when Atlas is listening" 
                                               Foreground="#94a3b8" FontSize="11" Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox x:Name="ShowListeningIndicatorCheckBox" Grid.Column="1" VerticalAlignment="Center"
                                          Checked="ShowListeningIndicator_Changed" Unchecked="ShowListeningIndicator_Changed">
                                    <CheckBox.Template>
                                        <ControlTemplate TargetType="CheckBox">
                                            <Border x:Name="border" Background="#12121a" BorderBrush="#22d3ee40" 
                                                    BorderThickness="2" CornerRadius="4" Width="20" Height="20">
                                                <TextBlock x:Name="checkMark" Text="✓" Foreground="#22d3ee" 
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                           FontSize="12" FontWeight="Bold" Visibility="Collapsed"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                                    <Setter TargetName="border" Property="Background" Value="#22d3ee20"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#22d3ee"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </CheckBox.Template>
                                </CheckBox>
                            </Grid>
                            
                            <!-- Privacy Notice -->
                            <Border Background="#22d3ee10" CornerRadius="4" Padding="12" Margin="0,8,0,0">
                                <StackPanel>
                                    <TextBlock Text="🔒 Privacy Notice" Foreground="#22d3ee" FontSize="12" FontWeight="Bold"/>
                                    <TextBlock Text="Atlas does not save microphone audio to disk. Voice processing happens locally on your device." 
                                               Foreground="#94a3b8" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Voice Status -->
                            <TextBlock x:Name="VoiceStatusText" Text="🎙️ Voice System: Disabled" 
                                       Foreground="#64748b" FontSize="11" Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>
                    
                        <!-- ORB APPEARANCE -->
                        <TextBlock Text="ORB APPEARANCE" Style="{StaticResource SectionHeader}" Visibility="Collapsed"/>
                        <Border Background="#0c0c12" CornerRadius="8" Padding="16" Margin="0,0,0,24"
                            BorderBrush="#8b5cf620" BorderThickness="1" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Style" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="OrbStyleCombo" Style="{StaticResource AtlasComboBox}"
                                      SelectionChanged="OrbStyle_Changed" Margin="0,0,0,16">
                                <ComboBoxItem Content="🔮 Floating Particles" Tag="particles"/>
                                <ComboBoxItem Content="✨ Siri Animation" Tag="Siri Animation.json"/>
                                <ComboBoxItem Content="🤖 AI Assistant" Tag="AI Assistant.json"/>
                                <ComboBoxItem Content="⚡ Loading Animation" Tag="Loading animation.json"/>
                            </ComboBox>
                            
                            <TextBlock Text="Color Theme" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="OrbColorCombo" Style="{StaticResource AtlasComboBox}"
                                      SelectionChanged="OrbColor_Changed" Margin="0,0,0,16">
                                <ComboBoxItem Content="🔵 Cyan (Default)" Tag="cyan"/>
                                <ComboBoxItem Content="🟣 Purple" Tag="purple"/>
                                <ComboBoxItem Content="🟢 Green" Tag="green"/>
                                <ComboBoxItem Content="🔴 Red" Tag="red"/>
                                <ComboBoxItem Content="🟡 Gold" Tag="gold"/>
                                <ComboBoxItem Content="🩷 Pink" Tag="pink"/>
                            </ComboBox>
                            
                            <TextBlock Text="Animation Speed" Style="{StaticResource FieldLabel}"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="OrbSpeedSlider" Minimum="0.1" Maximum="3.0" Value="1.0"
                                        ValueChanged="OrbSpeed_Changed"/>
                                <Border Grid.Column="1" Background="#8b5cf620" CornerRadius="4" Padding="8,4" Margin="8,0,0,0">
                                    <TextBlock x:Name="OrbSpeedLabel" Text="1.0x" Foreground="#8b5cf6" 
                                               HorizontalAlignment="Center" FontWeight="Bold" FontSize="12"/>
                                </Border>
                            </Grid>
                            
                            <TextBlock Text="Particle Count" Style="{StaticResource FieldLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="OrbParticleSlider" Minimum="50" Maximum="300" Value="180"
                                        ValueChanged="OrbParticle_Changed"/>
                                <Border Grid.Column="1" Background="#8b5cf620" CornerRadius="4" Padding="8,4" Margin="8,0,0,0">
                                    <TextBlock x:Name="OrbParticleLabel" Text="180" Foreground="#8b5cf6" 
                                               HorizontalAlignment="Center" FontWeight="Bold" FontSize="12"/>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                        <!-- CORE ANIMATIONS -->
                        <TextBlock Text="CORE ANIMATIONS" Style="{StaticResource SectionHeader}" Visibility="Collapsed"/>
                        <Border Background="#0c0c12" CornerRadius="8" Padding="16" Margin="0,0,0,24"
                            BorderBrush="#8b5cf620" BorderThickness="1" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Customize the HoloCore appearance and animation behavior. All animations are GPU-accelerated." 
                                       Foreground="#64748b" FontSize="11" Margin="0,0,0,12" TextWrapping="Wrap"/>
                            
                            <!-- HoloCore Style Selection -->
                            <TextBlock Text="HoloCore Style" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CoreStyleCombo" Style="{StaticResource AtlasComboBox}"
                                      SelectionChanged="CoreStyle_Changed" Margin="0,0,0,16">
                                <ComboBoxItem Content="🌀 Classic Ultron (Particle Rings)" Tag="Classic"/>
                                <ComboBoxItem Content="⚡ Energy Sphere (Dense Particles)" Tag="EnergySphere"/>
                                <ComboBoxItem Content="🔮 Quantum Core (Glowing Center)" Tag="QuantumCore"/>
                                <ComboBoxItem Content="💫 Nebula (Flowing Particles)" Tag="Nebula"/>
                                <ComboBoxItem Content="⭐ Minimal (Simple Ring)" Tag="Minimal"/>
                            </ComboBox>
                            
                            <!-- Custom Colors - Mix and Match -->
                            <TextBlock Text="Custom Colors (Mix &amp; Match)" Style="{StaticResource FieldLabel}"/>
                            
                            <!-- Primary Color (Particles) -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Particles:" Foreground="#94a3b8" FontSize="12" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" x:Name="PrimaryColorButton" Click="PrimaryColorButton_Click"
                                        Height="32" HorizontalAlignment="Stretch" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="ColorBorder" Background="#22d3ee" CornerRadius="6" 
                                                    BorderBrush="#ffffff20" BorderThickness="1">
                                                <TextBlock x:Name="PrimaryColorText" Text="#22d3ee" 
                                                           Foreground="#000" FontFamily="Consolas" FontSize="12"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ColorBorder" Property="BorderBrush" Value="#22d3ee"/>
                                                    <Setter TargetName="ColorBorder" Property="BorderThickness" Value="2"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                            
                            <!-- Secondary Color (Light Particles) -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Light Particles:" Foreground="#94a3b8" FontSize="12" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" x:Name="SecondaryColorButton" Click="SecondaryColorButton_Click"
                                        Height="32" HorizontalAlignment="Stretch" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="ColorBorder" Background="#7dd3fc" CornerRadius="6" 
                                                    BorderBrush="#ffffff20" BorderThickness="1">
                                                <TextBlock x:Name="SecondaryColorText" Text="#7dd3fc" 
                                                           Foreground="#000" FontFamily="Consolas" FontSize="12"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ColorBorder" Property="BorderBrush" Value="#22d3ee"/>
                                                    <Setter TargetName="ColorBorder" Property="BorderThickness" Value="2"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                            
                            <!-- Center Core Color -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Center Core:" Foreground="#94a3b8" FontSize="12" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" x:Name="CenterColorButton" Click="CenterColorButton_Click"
                                        Height="32" HorizontalAlignment="Stretch" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="ColorBorder" Background="#22d3ee" CornerRadius="6" 
                                                    BorderBrush="#ffffff20" BorderThickness="1">
                                                <TextBlock x:Name="CenterColorText" Text="#22d3ee" 
                                                           Foreground="#000" FontFamily="Consolas" FontSize="12"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ColorBorder" Property="BorderBrush" Value="#22d3ee"/>
                                                    <Setter TargetName="ColorBorder" Property="BorderThickness" Value="2"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                            
                            <!-- Thinking Color (Orange accent when thinking) -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Thinking Accent:" Foreground="#94a3b8" FontSize="12" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" x:Name="ThinkingColorButton" Click="ThinkingColorButton_Click"
                                        Height="32" HorizontalAlignment="Stretch" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="ColorBorder" Background="#f97316" CornerRadius="6" 
                                                    BorderBrush="#ffffff20" BorderThickness="1">
                                                <TextBlock x:Name="ThinkingColorText" Text="#f97316" 
                                                           Foreground="#fff" FontFamily="Consolas" FontSize="12"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ColorBorder" Property="BorderBrush" Value="#f97316"/>
                                                    <Setter TargetName="ColorBorder" Property="BorderThickness" Value="2"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                            
                            <!-- Quick Presets -->
                            <TextBlock Text="Quick Presets:" Foreground="#64748b" FontSize="11" Margin="0,0,0,6"/>
                            <WrapPanel Margin="0,0,0,16">
                                <Button Content="Cyan" Tag="Cyan" Click="QuickPreset_Click" 
                                        Background="#22d3ee" Foreground="#000" Padding="8,4" Margin="0,0,6,6" FontSize="10"/>
                                <Button Content="Purple" Tag="Purple" Click="QuickPreset_Click"
                                        Background="#a855f7" Foreground="#fff" Padding="8,4" Margin="0,0,6,6" FontSize="10"/>
                                <Button Content="Green" Tag="Green" Click="QuickPreset_Click"
                                        Background="#22c55e" Foreground="#000" Padding="8,4" Margin="0,0,6,6" FontSize="10"/>
                                <Button Content="Red" Tag="Red" Click="QuickPreset_Click"
                                        Background="#ef4444" Foreground="#fff" Padding="8,4" Margin="0,0,6,6" FontSize="10"/>
                                <Button Content="Gold" Tag="Gold" Click="QuickPreset_Click"
                                        Background="#eab308" Foreground="#000" Padding="8,4" Margin="0,0,6,6" FontSize="10"/>
                                <Button Content="Orange" Tag="Orange" Click="QuickPreset_Click"
                                        Background="#f97316" Foreground="#fff" Padding="8,4" Margin="0,0,6,6" FontSize="10"/>
                                <Button Content="Ice Blue" Tag="IceBlue" Click="QuickPreset_Click"
                                        Background="#06b6d4" Foreground="#fff" Padding="8,4" Margin="0,0,6,6" FontSize="10"/>
                                <Button Content="Pink" Tag="Pink" Click="QuickPreset_Click"
                                        Background="#ec4899" Foreground="#fff" Padding="8,4" Margin="0,0,6,6" FontSize="10"/>
                            </WrapPanel>
                            
                            <!-- Animation Speed -->
                            <TextBlock Text="Animation Speed" Style="{StaticResource FieldLabel}"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="CoreAnimationSpeedSlider" Minimum="0.1" Maximum="3.0" Value="1.0"
                                        TickFrequency="0.1" IsSnapToTickEnabled="True"
                                        ValueChanged="CoreAnimationSpeed_Changed"
                                        VerticalAlignment="Center">
                                    <Slider.Style>
                                        <Style TargetType="Slider">
                                            <Setter Property="Foreground" Value="#8b5cf6"/>
                                            <Setter Property="Background" Value="#ffffff08"/>
                                        </Style>
                                    </Slider.Style>
                                </Slider>
                                <TextBlock Grid.Column="1" x:Name="CoreAnimationSpeedValue" Text="1.0x" 
                                           Foreground="#8b5cf6" FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </Grid>
                            
                            <!-- Particle Count -->
                            <TextBlock Text="Particle Count" Style="{StaticResource FieldLabel}"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="CoreParticleCountSlider" Minimum="50" Maximum="300" Value="120"
                                        TickFrequency="10" IsSnapToTickEnabled="True"
                                        ValueChanged="CoreParticleCount_Changed"
                                        VerticalAlignment="Center">
                                    <Slider.Style>
                                        <Style TargetType="Slider">
                                            <Setter Property="Foreground" Value="#22d3ee"/>
                                            <Setter Property="Background" Value="#ffffff08"/>
                                        </Style>
                                    </Slider.Style>
                                </Slider>
                                <TextBlock Grid.Column="1" x:Name="CoreParticleCountValue" Text="120" 
                                           Foreground="#22d3ee" FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </Grid>
                            
                            <!-- Ring Rotation Speed -->
                            <TextBlock Text="Ring Rotation Speed" Style="{StaticResource FieldLabel}"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="CoreRingSpeedSlider" Minimum="0.1" Maximum="5.0" Value="1.0"
                                        TickFrequency="0.1" IsSnapToTickEnabled="True"
                                        ValueChanged="CoreRingSpeed_Changed"
                                        VerticalAlignment="Center">
                                    <Slider.Style>
                                        <Style TargetType="Slider">
                                            <Setter Property="Foreground" Value="#a855f7"/>
                                            <Setter Property="Background" Value="#ffffff08"/>
                                        </Style>
                                    </Slider.Style>
                                </Slider>
                                <TextBlock Grid.Column="1" x:Name="CoreRingSpeedValue" Text="1.0x" 
                                           Foreground="#a855f7" FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </Grid>
                            
                            <!-- Reset Animations Button -->
                            <Button x:Name="ResetCoreAnimationsBtn" Content="🔄 Reset to Defaults" Click="ResetCoreAnimations_Click"
                                    Background="#64748b20" Foreground="#64748b" Padding="12,6" FontSize="11"
                                    HorizontalAlignment="Left">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#64748b40"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            
                            <Border Background="#8b5cf610" CornerRadius="4" Padding="10" Margin="0,12,0,0">
                                <TextBlock Text="⚡ All animations use GPU acceleration for smooth 60fps performance. Higher particle counts may impact older GPUs." 
                                           Foreground="#8b5cf6" FontSize="11" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    
                        <!-- PERFORMANCE -->
                        <TextBlock Text="PERFORMANCE" Style="{StaticResource SectionHeader}" Visibility="Collapsed"/>
                        <Border Background="#0c0c12" CornerRadius="8" Padding="16" Margin="0,0,0,24"
                            BorderBrush="#f59e0b20" BorderThickness="1" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Quality Mode" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="QualityModeCombo" Style="{StaticResource AtlasComboBox}"
                                      SelectionChanged="QualityMode_Changed" Margin="0,0,0,12">
                                <ComboBoxItem Content="🐢 Battery Saver (Low CPU)" Tag="low"/>
                                <ComboBoxItem Content="⚖️ Balanced (Recommended)" Tag="balanced"/>
                                <ComboBoxItem Content="🚀 Performance (Fast Response)" Tag="high"/>
                            </ComboBox>
                            <Border Background="#f59e0b10" CornerRadius="4" Padding="10">
                                <TextBlock x:Name="PerformanceInfoText" Text="⚖️ Balanced mode: Good for most systems" 
                                           Foreground="#94a3b8" FontSize="11" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    
                        <!-- PROFILE -->
                        <TextBlock Text="PROFILE" Style="{StaticResource SectionHeader}" Visibility="Collapsed"/>
                        <Border Background="#0c0c12" CornerRadius="8" Padding="16" Margin="0,0,0,24"
                            BorderBrush="#22d3ee20" BorderThickness="1" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="How should Atlas address you?" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="HonorificComboBox" Style="{StaticResource AtlasComboBox}"
                                      SelectionChanged="HonorificComboBox_SelectionChanged">
                                <ComboBoxItem Content="Sir (JARVIS style)" Tag="Sir"/>
                                <ComboBoxItem Content="Ma'am" Tag="Maam"/>
                                <ComboBoxItem Content="By my name" Tag="Name"/>
                                <ComboBoxItem Content="No honorific" Tag="None"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>
                    
                        <!-- STARTUP -->
                        <TextBlock Text="STARTUP" Style="{StaticResource SectionHeader}" Visibility="Collapsed"/>
                        <Border Background="#0c0c12" CornerRadius="8" Padding="16" Margin="0,0,0,24"
                            BorderBrush="#22d3ee20" BorderThickness="1" Visibility="Collapsed">
                        <CheckBox x:Name="AutoStartCheckbox" Content="Start Atlas with Windows" 
                                  Foreground="#f1f5f9" FontSize="13"/>
                    </Border>
                    
                        <!-- PREFERENCES SECTION -->
                        <TextBlock Text="PREFERENCES" Style="{StaticResource SectionHeader}" Visibility="Collapsed"/>
                        <Border Background="#0c0c12" CornerRadius="8" Padding="16" Margin="0,0,0,24"
                            BorderBrush="#8b5cf620" BorderThickness="1" Visibility="Collapsed">
                        <StackPanel>
                            <!-- Personality -->
                            <TextBlock Text="Personality" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="PersonalityCombo" Style="{StaticResource AtlasComboBox}"
                                      SelectionChanged="Personality_Changed" Margin="0,0,0,8"/>
                            <Border x:Name="PersonalityDescBorder" Background="#22d3ee08" CornerRadius="4" Padding="10" Margin="0,0,0,16">
                                <TextBlock x:Name="PersonalityDescText" Foreground="#94a3b8" FontSize="11" TextWrapping="Wrap"/>
                            </Border>

                            <!-- Unrestricted Slider (applies to all personalities) -->
                            <TextBlock Text="Unrestricted Level (Profanity/Edge Control)" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="Control how edgy/unfiltered Atlas can be. Applies to all personalities. SafetyKernel is always active." 
                                       Foreground="#94a3b8" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="UnrestrictedSlider" Minimum="1" Maximum="5" Value="3"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        ValueChanged="UnrestrictedLevel_Changed"
                                        VerticalAlignment="Center">
                                    <Slider.Style>
                                        <Style TargetType="Slider">
                                            <Setter Property="Foreground" Value="#ef4444"/>
                                            <Setter Property="Background" Value="#ffffff08"/>
                                        </Style>
                                    </Slider.Style>
                                </Slider>
                                <TextBlock Grid.Column="1" x:Name="UnrestrictedLevelLabel" Text="Moderate" 
                                           Foreground="#ef4444" FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </Grid>
                            <Border Background="#ef444410" CornerRadius="4" Padding="10" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="⚠️ Unrestricted Levels:" Foreground="#ef4444" FontSize="11" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock Text="1 - Mild: Minimal profanity, light sarcasm" Foreground="#94a3b8" FontSize="10" Margin="0,0,0,2"/>
                                    <TextBlock Text="2 - Light: Occasional mild profanity, more wit" Foreground="#94a3b8" FontSize="10" Margin="0,0,0,2"/>
                                    <TextBlock Text="3 - Moderate: Regular profanity, sarcastic and witty" Foreground="#94a3b8" FontSize="10" Margin="0,0,0,2"/>
                                    <TextBlock Text="4 - Strong: Frequent profanity, sharp sarcasm" Foreground="#94a3b8" FontSize="10" Margin="0,0,0,2"/>
                                    <TextBlock Text="5 - Savage: Full profanity, brutal honesty, dark humor" Foreground="#94a3b8" FontSize="10" Margin="0,0,0,4"/>
                                    <TextBlock Text="🔒 SafetyKernel is always active - no destructive operations without confirmation" 
                                               Foreground="#22c55e" FontSize="10" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Show Confidence Statement -->
                            <CheckBox x:Name="ShowConfidenceCheckbox" Content="Show confidence statements in chat" 
                                      Foreground="#f1f5f9" FontSize="13" Margin="0,0,0,12"
                                      Checked="ShowConfidence_Changed" Unchecked="ShowConfidence_Changed"/>
                            
                            <!-- Proactive Suggestions -->
                            <CheckBox x:Name="ProactiveSuggestionsCheckbox" Content="Enable proactive suggestions" 
                                      Foreground="#f1f5f9" FontSize="13" Margin="0,0,0,12"
                                      Checked="ProactiveSuggestions_Changed" Unchecked="ProactiveSuggestions_Changed"/>
                            
                            <!-- Agent Mode Default -->
                            <CheckBox x:Name="AgentModeDefaultCheckbox" Content="Enable Agent Mode by default on startup" 
                                      Foreground="#f1f5f9" FontSize="13" Margin="0,0,0,12"
                                      Checked="AgentModeDefault_Changed" Unchecked="AgentModeDefault_Changed"/>
                            
                            <!-- Alive Mode -->
                    <StackPanel Margin="0,0,0,16">
                                <CheckBox x:Name="AliveModeCheckbox" Content="🌟 Alive Mode" 
                                          Foreground="#f1f5f9" FontSize="13" Margin="0,0,0,4"
                                          Checked="AliveMode_Changed" Unchecked="AliveMode_Changed"/>
                                <TextBlock Text="Prefer natural, conversational responses over rigid templates." 
                                           Foreground="#94a3b8" FontSize="11" Margin="24,0,0,0" TextWrapping="Wrap"/>
                                <Border x:Name="AliveModeStatusBorder" CornerRadius="4" Padding="10" Margin="24,8,0,0">
                                    <TextBlock x:Name="AliveModeStatusText" FontSize="11" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,16">
                                <CheckBox x:Name="CheckInsEnabledCheckbox" Content="Enable Atlas check-ins (water / jokes / you okay?)"
                                          Foreground="#f1f5f9" FontSize="13" Margin="0,0,0,6"
                                          Checked="CheckInsEnabled_Changed" Unchecked="CheckInsEnabled_Changed"/>
                                <Grid Margin="24,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Min minutes" Style="{StaticResource FieldLabel}" Margin="0,0,0,6"/>
                                        <TextBox x:Name="CheckInMinMinutesTextBox" Style="{StaticResource AtlasTextBox}" LostFocus="CheckInMinutes_LostFocus"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                        <TextBlock Text="Max minutes" Style="{StaticResource FieldLabel}" Margin="0,0,0,6"/>
                                        <TextBox x:Name="CheckInMaxMinutesTextBox" Style="{StaticResource AtlasTextBox}" LostFocus="CheckInMinutes_LostFocus"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Idle minutes" Style="{StaticResource FieldLabel}" Margin="0,0,0,6"/>
                                        <TextBox x:Name="CheckInIdleMinutesTextBox" Style="{StaticResource AtlasTextBox}" LostFocus="CheckInMinutes_LostFocus"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Check-ins only happen when you’re idle and not in movie-night mode."
                                           Foreground="#94a3b8" FontSize="11" Margin="24,8,0,0" TextWrapping="Wrap"/>
                            </StackPanel>

                            <Border Background="#22d3ee10" CornerRadius="4" Padding="10" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Lean single-file releases ship with the static wallpaper set only to keep startup fast and packaging reliable."
                                               Foreground="#f1f5f9" FontSize="12" TextWrapping="Wrap"/>
                                    <TextBlock Text="Paste an optional asset-pack link below so users can download the full wallpaper pack from Settings."
                                               Foreground="#94a3b8" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Optional wallpaper asset pack URL" Style="{StaticResource FieldLabel}"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="OptionalAssetPackUrlTextBox"
                                         Grid.Column="0"
                                         Style="{StaticResource AtlasTextBox}"
                                         Margin="0,0,8,0"
                                         LostFocus="OptionalAssetPackUrl_LostFocus"/>
                                <Button Grid.Column="1"
                                        Content="Open Download"
                                        Click="OpenOptionalAssetPackUrl_Click"
                                        Background="#22d3ee20"
                                        Foreground="#22d3ee"
                                        Padding="12,6"
                                        FontSize="11">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#22d3ee40"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                            
                            <!-- Actions Row -->
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button x:Name="ResetPrefsBtn" Content="🔄 Reset to Defaults" Click="ResetPreferences_Click"
                                        Background="#64748b20" Foreground="#64748b" Padding="12,6" FontSize="11">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#64748b40"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button x:Name="ExportPrefsBtn" Content="📤 Export" Click="ExportPreferences_Click" Margin="8,0,0,0"
                                        Background="#8b5cf620" Foreground="#8b5cf6" Padding="12,6" FontSize="11">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#8b5cf640"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button x:Name="FactoryResetBtn" Content="🧨 Factory Reset" Click="FactoryReset_Click"
                                        Background="#ef444420" Foreground="#ef4444" Padding="12,6" FontSize="11">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#ef444440"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <TextBlock Text="Wipes addons, watch history, settings, and keys" Foreground="#94a3b8" FontSize="11" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <Border Background="#8b5cf610" CornerRadius="4" Padding="10" Margin="0,12,0,0">
                                <TextBlock Text="💾 Preferences are saved to %AppData%\AtlasAI\preferences.json" 
                                           Foreground="#94a3b8" FontSize="11" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    
                        <!-- FLOATING HUD SECTION -->
                        <TextBlock Text="FLOATING HUD" Style="{StaticResource SectionHeader}" Visibility="Collapsed"/>
                        <Border Background="#0c0c12" CornerRadius="8" Padding="16" Margin="0,0,0,24"
                            BorderBrush="#22d3ee20" BorderThickness="1" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Always-present Atlas companion that stays visible on your desktop." 
                                       Foreground="#64748b" FontSize="11" Margin="0,0,0,12" TextWrapping="Wrap"/>
                            
                            <!-- Enable HUD -->
                            <CheckBox x:Name="FloatingHudEnabledCheckbox" Content="Enable Floating HUD" 
                                      Foreground="#f1f5f9" FontSize="13" Margin="0,0,0,16"
                                      Checked="FloatingHudEnabled_Changed" Unchecked="FloatingHudEnabled_Changed"/>
                            
                            <!-- Position -->
                            <TextBlock Text="Position" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="HudPositionCombo" Style="{StaticResource AtlasComboBox}"
                                      SelectionChanged="HudPosition_Changed" Margin="0,0,0,16">
                                <ComboBoxItem Content="↖️ Top Left" Tag="TopLeft"/>
                                <ComboBoxItem Content="↗️ Top Right" Tag="TopRight"/>
                                <ComboBoxItem Content="↙️ Bottom Left" Tag="BottomLeft"/>
                                <ComboBoxItem Content="↘️ Bottom Right" Tag="BottomRight"/>
                            </ComboBox>
                            
                            <!-- Size -->
                            <TextBlock Text="Size" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="HudSizeCombo" Style="{StaticResource AtlasComboBox}"
                                      SelectionChanged="HudSize_Changed" Margin="0,0,0,16">
                                <ComboBoxItem Content="🔹 Small (80×100)" Tag="Small"/>
                                <ComboBoxItem Content="🔷 Medium (100×120)" Tag="Medium"/>
                            </ComboBox>
                            
                            <!-- Click-through -->
                            <CheckBox x:Name="HudClickThroughCheckbox" Content="Click-through mode (HUD ignores mouse)" 
                                      Foreground="#f1f5f9" FontSize="13" Margin="0,0,0,12"
                                      Checked="HudClickThrough_Changed" Unchecked="HudClickThrough_Changed"/>
                            
                            <Border Background="#22d3ee10" CornerRadius="4" Padding="10" Margin="0,8,0,0">
                                <TextBlock Text="👁️ The HUD shows Atlas presence without adding controls. Click to open the main window." 
                                           Foreground="#22d3ee" FontSize="11" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    
                        <!-- WORKSPACE MEMORY SECTION -->
                        <TextBlock Text="WORKSPACE MEMORY" Style="{StaticResource SectionHeader}" Visibility="Collapsed"/>
                        <Border Background="#0c0c12" CornerRadius="8" Padding="16" Margin="0,0,0,24"
                            BorderBrush="#8b5cf620" BorderThickness="1" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Atlas learns your project preferences over time." 
                                       Foreground="#f1f5f9" FontSize="13" Margin="0,0,0,4"/>
                            <TextBlock Text="Stores: preferred build/test commands, project type, common entry points. Does NOT store source code or secrets."
                                       Foreground="#64748b" FontSize="11" Margin="0,0,0,16" TextWrapping="Wrap"/>
                            
                            <!-- Current Workspace Info -->
                            <TextBlock Text="Current Workspace" Style="{StaticResource FieldLabel}"/>
                            <Border Background="#08080c" CornerRadius="6" Padding="12,8" Margin="0,0,0,12">
                                <TextBlock x:Name="CurrentWorkspaceText" Text="No workspace loaded" 
                                           Foreground="#94a3b8" FontSize="12"/>
                            </Border>
                            
                            <!-- Reset Button -->
                            <Button x:Name="ResetWorkspaceMemoryBtn" Content="🗑️ Reset Workspace Memory" 
                                    Click="ResetWorkspaceMemory_Click"
                                    Background="#ef444420" Foreground="#ef4444" Padding="12,8" FontSize="12"
                                    HorizontalAlignment="Left" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#ef444440"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            
                            <Border Background="#8b5cf610" CornerRadius="4" Padding="10" Margin="0,12,0,0">
                                <TextBlock Text="💾 Workspace memory is stored in %AppData%\AtlasAI\repository_memory\" 
                                           Foreground="#94a3b8" FontSize="11" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    
                    <!-- SAFETY SECTION -->
                    <TextBlock Text="SAFETY" Style="{StaticResource SectionHeader}" Visibility="Collapsed"/>
                    <Border Background="#0c0c12" CornerRadius="8" Padding="16" Margin="0,0,0,24"
                            BorderBrush="#f59e0b20" BorderThickness="1" Visibility="Collapsed">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Safety Mode" Foreground="#f1f5f9" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Blocks all destructive system operations" 
                                               Foreground="#64748b" FontSize="11" Margin="0,4,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="1" x:Name="SafetyStatusBadge" Background="#f59e0b" 
                                        CornerRadius="4" Padding="10,6" VerticalAlignment="Center">
                                    <TextBlock x:Name="SafetyStatusText" Text="🛡️ SAFE" Foreground="White" 
                                               FontSize="11" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                            
                            <Border Background="#f59e0b10" CornerRadius="4" Padding="10" Margin="0,0,0,12">
                                <TextBlock Text="⚠️ Safety Mode prevents command execution, registry changes, process termination, and file deletion. Only disable for testing." 
                                           Foreground="#f59e0b" FontSize="11" TextWrapping="Wrap"/>
                            </Border>
                            
                            <Button x:Name="RunSelfTestBtn" Content="🧪 Run Safety Self-Test" Click="RunSelfTest_Click"
                                    Background="#22d3ee20" Foreground="#22d3ee" Padding="12,8" FontSize="12"
                                    HorizontalAlignment="Left" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#22d3ee40"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>
                    
                </StackPanel>
            </ScrollViewer>
            
            <!-- Footer -->
            <Border Grid.Row="2" Background="#08080c" CornerRadius="0,0,12,12"
                    BorderBrush="#22d3ee20" BorderThickness="0,1,0,0">
                <Grid Margin="24,0">
                    <TextBlock x:Name="HardwareInfoText" Text="🖥️ System info loading..." 
                               Foreground="#64748b" FontSize="11" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="Cancel" Click="Cancel_Click" Padding="20,10"
                                Background="#16161f" Foreground="#94a3b8" Margin="0,0,8,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#1a1a24"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="Save" Click="Save_Click" Padding="24,10"
                                Background="#22d3ee20" Foreground="#22d3ee" FontWeight="SemiBold">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#22d3ee40"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>


                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

